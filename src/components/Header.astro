                  {eventiTradizioni.map(l => (
                    <a href={l.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-med-blue/20 flex-shrink-0"></span>
                      {l.name}
                    </a>
                  ))}
                </div>
              </div>

              <!-- Gastronomia -->
              <div>
                <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-semibold mb-3 flex items-center gap-1">
                  <span class="w-2 h-2 rounded-full bg-med-gold/60"></span> {evSec.gastro}
                </p>
                <div class="space-y-0.5">
                  {eventiGastronomia.map(l => (
                    <a href={l.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-gold/5 hover:text-med-gold transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-med-gold/30 flex-shrink-0"></span>
                      {l.name}
                    </a>
                  ))}
                </div>
                <a href={tuttiEvHref} class="mt-3 flex items-center gap-1 px-2 py-1.5 text-xs text-med-blue hover:text-med-blue/70 font-medium transition-colors">
                  {tuttiEvLabel}
                </a>
              </div>

            </div>
          </div>
        </div>

      </nav>

      <!-- Right: Language + CTA -->
      <div class="flex items-center gap-2">

        <!-- Language Switcher -->
        <div class="hidden lg:block relative group/lang">
          <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-med-blue transition-colors border border-slate-200 rounded-full hover:border-med-blue/30">
            <span class="text-base leading-none">{flagMap[lang]}</span>
            <span class="font-semibold">{lang.split('-')[1].toUpperCase()}</span>
            <svg class="w-3 h-3 opacity-40 group-hover/lang:opacity-70 group-hover/lang:rotate-180 transition-all duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute right-0 top-full mt-2 w-52 bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-200 z-50 py-1.5">
            {locales.map(l => {
              const pageExists = pageKey && existingPages[l].includes(pageKey);
              const href = pageExists ? getLocalePath(l, pageKey!) : `/${l}/`;
              return (
                <a href={href} class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${l === lang ? 'bg-med-blue/5 text-med-blue font-semibold' : 'text-slate-700 hover:bg-slate-50'}`}>
                  <span class="text-base">{flagMap[l]}</span>
                  <span>{t.languages[l]}</span>
                  {l === lang && <span class="ml-auto w-1.5 h-1.5 rounded-full bg-med-blue flex-shrink-0"></span>}
                </a>
              );
            })}
          </div>
        </div>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-xl text-slate-700 hover:bg-slate-100" aria-label="Menu">
          <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-100 bg-white max-h-[80vh] overflow-y-auto">
    <div class="px-3 py-3 divide-y divide-slate-100">

      <!-- Destinazioni -->
      <details class="group/mob-dest">
        <summary class="flex items-center justify-between px-3 py-3.5 rounded-xl text-sm font-semibold text-slate-800 hover:bg-slate-50 cursor-pointer select-none list-none">
          {nav.dest}
          <svg class="w-4 h-4 text-slate-400 group-open/mob-dest:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="pb-3 pt-1 space-y-3">
          <div>
            <a href={`${costieraBase}/`} class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold px-4 py-1 block">{dh.costiera}</a>
            {costieraBorghi.map(b => (
              <a href={b.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{b.name}</a>
            ))}
          </div>
          <div>
            <a href={sorrentineHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold px-4 py-1 block">{dh.sorrentina}</a>
            {sorrentinaBorghi.map(b => (
              <a href={b.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{b.name}</a>
            ))}
          </div>
          <div>
            <a href={isoleHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold px-4 py-1 block">{dh.isole}</a>
            {isoleLinks.map(b => (
              <a href={b.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{b.name}</a>
            ))}
          </div>
        </div>
      </details>

      <!-- Spiagge -->
      <details class="group/mob-spiagge">
        <summary class="flex items-center justify-between px-3 py-3.5 rounded-xl text-sm font-semibold text-slate-800 hover:bg-slate-50 cursor-pointer select-none list-none">
          {nav.spiagge}
          <svg class="w-4 h-4 text-slate-400 group-open/mob-spiagge:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="pb-3 pt-1">
          <a href={spiaggeHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold px-4 py-1 block">{tutteBeachLabel}</a>
          {spiaggeAree.map(area => (
            <div class="mt-2">
              <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-semibold px-4 pb-1">{area.area}</p>
              {area.beaches.map(b => (
                <a href={b.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{b.name}</a>
              ))}
            </div>
          ))}
        </div>
      </details>

      <!-- Guida Pratica -->
      <details class="group/mob-guida">
        <summary class="flex items-center justify-between px-3 py-3.5 rounded-xl text-sm font-semibold text-slate-800 hover:bg-slate-50 cursor-pointer select-none list-none">
          {nav.guida}
          <svg class="w-4 h-4 text-slate-400 group-open/mob-guida:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="pb-3 pt-1">
          {guidaLinks.map(l => (
            <a href={l.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
          ))}
        </div>
      </details>

      <!-- Esperienze + Itinerari -->
      <details class="group/mob-esp">
        <summary class="flex items-center justify-between px-3 py-3.5 rounded-xl text-sm font-semibold text-slate-800 hover:bg-slate-50 cursor-pointer select-none list-none">
          {nav.esp}
          <svg class="w-4 h-4 text-slate-400 group-open/mob-esp:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="pb-3 pt-1 space-y-3">
          <div>
            <a href={esperienzeHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold px-4 py-1 block">{nav.esp}</a>
            {esperienze.map(l => (
              <a href={l.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
            ))}
          </div>
          <div>
            <a href={itinerariHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold px-4 py-1 block">{itinerariLabel}</a>
            <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-4 pb-1 mt-1">{itPeriods.d1}</p>
            {itinerari1g.map(l => (
              <a href={l.href} class="block px-6 py-1.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
            ))}
            <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-4 pb-1 mt-2">{itPeriods.d3}</p>
            {itinerari3g.map(l => (
              <a href={l.href} class="block px-6 py-1.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
            ))}
            {itinerari7g.length > 0 && (
              <>
                <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-4 pb-1 mt-2">{itPeriods.d7}</p>
                {itinerari7g.map(l => (
                  <a href={l.href} class="block px-6 py-1.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
                ))}
              </>
            )}
          </div>
        </div>
      </details>

      <!-- Eventi -->
      <details class="group/mob-ev">
        <summary class="flex items-center justify-between px-3 py-3.5 rounded-xl text-sm font-semibold text-slate-800 hover:bg-slate-50 cursor-pointer select-none list-none">
          {nav.ev}
          <svg class="w-4 h-4 text-slate-400 group-open/mob-ev:rotate-180 transition-transform duration-200 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="pb-3 pt-1 space-y-3">
          <div>
            <p class="text-[10px] uppercase tracking-[0.3em] text-med-terracotta font-semibold px-4 py-1">{evSec.cultura}</p>
            {eventiCultura.map(l => (
              <a href={l.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-terracotta/5 hover:text-med-terracotta transition-colors">{l.name}</a>
            ))}
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold px-4 py-1">{evSec.tradizioni}</p>
            {eventiTradizioni.map(l => (
              <a href={l.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
            ))}
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-semibold px-4 py-1">{evSec.gastro}</p>
            {eventiGastronomia.map(l => (
              <a href={l.href} class="block px-6 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-gold/5 hover:text-med-gold transition-colors">{l.name}</a>
            ))}
            <a href={tuttiEvHref} class="block px-6 py-2 text-xs text-med-blue font-medium hover:text-med-blue/70 transition-colors">{tuttiEvLabel}</a>
          </div>
        </div>
      </details>

      <!-- Lingua -->
      <div class="pt-3 pb-1">
        <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pb-2 font-semibold">Lingua</p>
        {locales.map(l => {
          const href = `/${l}/`;
          return (
            <a href={href} class={`flex items-center gap-3 px-3 py-2 rounded-xl text-sm transition-colors ${l === lang ? 'text-med-blue font-medium bg-med-blue/5' : 'text-slate-700 hover:bg-slate-50'}`}>
              <span class="text-base">{flagMap[l]}</span>
              <span>{t.languages[l]}</span>
            </a>
          );
        })}
      </div>

    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
