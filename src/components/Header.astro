---
import { getTranslations, getLocalePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
  pageKey?: string;
}

const { lang, pageKey } = Astro.props;
const t = getTranslations(lang);
const locales: Locale[] = ['en-us', 'en-gb', 'de-de', 'fr-fr', 'es-es', 'it-it'];

const existingPages: Record<Locale, string[]> = {
  'en-us': [],
  'en-gb': [],
  'de-de': [],
  'fr-fr': [],
  'es-es': [],
  'it-it': ['destinations', 'beaches', 'itineraries', 'getting-here', 'when-to-visit', 'costiera-amalfitana', 'positano'],
};

const isIT = lang === 'it-it';

const flagMap: Record<Locale, string> = {
  'it-it': '🇮🇹',
  'en-us': '🇺🇸',
  'en-gb': '🇬🇧',
  'de-de': '🇩🇪',
  'fr-fr': '🇫🇷',
  'es-es': '🇪🇸',
};

const costieraBorghi = [
  { name: 'Positano',  href: '/it-it/costiera-amalfitana/positano/' },
  { name: 'Amalfi',    href: '/it-it/costiera-amalfitana/amalfi/' },
  { name: 'Ravello',   href: '/it-it/costiera-amalfitana/ravello/' },
  { name: 'Praiano',   href: '/it-it/costiera-amalfitana/praiano/' },
  { name: 'Maiori',    href: '/it-it/costiera-amalfitana/maiori/' },
  { name: 'Minori',    href: '/it-it/costiera-amalfitana/minori/' },
];
const sorrentinaBorghi = [
  { name: 'Sorrento',        href: '/it-it/penisola-sorrentina/sorrento/' },
  { name: 'Vico Equense',    href: '/it-it/penisola-sorrentina/vico-equense/' },
  { name: 'Massa Lubrense',  href: '/it-it/penisola-sorrentina/massa-lubrense/' },
  { name: 'Sant\'Agnello',   href: '/it-it/penisola-sorrentina/sant-agnello/' },
];
const isole = [
  { name: 'Capri',    href: '/it-it/isole/capri/' },
  { name: 'Ischia',   href: '/it-it/isole/ischia/' },
  { name: 'Procida',  href: '/it-it/isole/procida/' },
];
const guidaLinks = [
  { name: 'Traghetti & Aliscafi', href: '/it-it/guida/traghetti/' },
  { name: 'Bus SITA',             href: '/it-it/guida/bus-sita/' },
  { name: 'Parcheggi e ZTL',      href: '/it-it/guida/parcheggi-ztl/' },
  { name: 'Quando andare',        href: '/it-it/quando-visitare/' },
];
const esperienze = [
  { name: 'Spiagge',                    href: '/it-it/esperienze/spiagge/' },
  { name: 'Trekking & Sentiero degli Dei', href: '/it-it/esperienze/trekking/' },
  { name: 'Tour in Barca',              href: '/it-it/esperienze/tour-barca/' },
];
const eventiCultura = [
  { name: 'Ravello Festival',           href: '/it-it/eventi/costiera-amalfitana/ravello-festival/' },
  { name: 'Regata Repubbliche Marinare',href: '/it-it/eventi/costiera-amalfitana/regata-storica-amalfi/' },
  { name: 'Capodanno Bizantino',        href: '/it-it/eventi/costiera-amalfitana/capodanno-bizantino/' },
  { name: 'Positano Arte & Cultura',    href: '/it-it/eventi/costiera-amalfitana/positano-mare-sole-cultura/' },
  { name: 'Ischia Film Festival',       href: '/it-it/eventi/isole/ischia-global-film-festival/' },
];
const eventiTradizioni = [
  { name: 'Luminaria di San Domenico',  href: '/it-it/eventi/costiera-amalfitana/luminaria-san-domenico-praiano/' },
  { name: 'Fuochi di Ferragosto',       href: '/it-it/eventi/costiera-amalfitana/fuochi-ferragosto-positano-maiori/' },
  { name: 'Festa di Sant\'Andrea',      href: '/it-it/eventi/costiera-amalfitana/festa-sant-andrea-amalfi/' },
  { name: 'Festa di Sant\'Antonino',    href: '/it-it/eventi/penisola-sorrentina/festa-sant-antonino/' },
  { name: 'Sagra del Mare (Procida)',   href: '/it-it/eventi/isole/sagra-del-mare-graziella-procida/' },
];
const eventiGastronomia = [
  { name: 'Sagra del Limone (Massa)',   href: '/it-it/eventi/penisola-sorrentina/sagra-limone-massa-lubrense/' },
  { name: 'Sagra della Melanzana',      href: '/it-it/eventi/penisola-sorrentina/sagra-melanzana-preazzano/' },
  { name: 'Sagra del Pesce (Positano)', href: '/it-it/eventi/costiera-amalfitana/sagra-del-pesce-positano/' },
  { name: 'Festival del Limone (Minori)',href: '/it-it/eventi/costiera-amalfitana/festival-limone-minori/' },
  { name: 'Gustamincanto',              href: '/it-it/eventi/penisola-sorrentina/gustamincanto-vico-equense/' },
];
const itinerari1g = [
  { name: 'Costiera da Napoli',      href: '/it-it/itinerari/1-giorno/costiera-amalfitana-da-napoli/' },
  { name: 'Costiera da Salerno',     href: '/it-it/itinerari/1-giorno/costiera-amalfitana-da-salerno/' },
  { name: 'Penisola Sorrentina',     href: '/it-it/itinerari/1-giorno/penisola-sorrentina-da-napoli/' },
  { name: 'Sentiero degli Dei',      href: '/it-it/itinerari/1-giorno/trekking-sentiero-degli-dei/' },
  { name: 'Capri da Sorrento',       href: '/it-it/itinerari/1-giorno/capri-da-sorrento/' },
];
const itinerari3g = [
  { name: 'Classico Costiera',       href: '/it-it/itinerari/3-giorni/classico-costiera-amalfitana/' },
  { name: 'Sorrento, Pompei e Storia', href: '/it-it/itinerari/3-giorni/sorrento-pompei-storia/' },
  { name: 'Isole: Ischia e Procida', href: '/it-it/itinerari/3-giorni/isole-ischia-procida/' },
];
const itinerari7g = [
  { name: 'Grand Tour Costiera',     href: '/it-it/itinerari/7-giorni/grand-tour-costiera-penisola/' },
  { name: 'Slow Travel Borghi & Cibo', href: '/it-it/itinerari/7-giorni/slow-travel-borghi-cibo/' },
];
---

<header class="glass-nav sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={`/${lang}/`} class="flex-shrink-0">
        <img src="/logo.svg" alt="Amalfi Coast Travel Guide" class="h-10 w-auto" />
      </a>

      <!-- Desktop Nav -->
      {isIT ? (
        <nav class="hidden lg:flex items-center gap-1">

          <!-- Destinazioni mega-dropdown -->
          <div class="relative group/dest">
            <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/dest:text-med-blue">
              Destinazioni
              <svg class="w-3.5 h-3.5 opacity-50 group-hover/dest:opacity-100 transition-transform group-hover/dest:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/dest:opacity-100 group-hover/dest:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 grid grid-cols-3 gap-6 w-[580px]">

                <!-- Costiera -->
                <div>
                  <a href="/it-it/costiera-amalfitana/" class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                    Costiera Amalfitana
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                  </a>
                  <div class="space-y-0.5 mt-2">
                    {costieraBorghi.map(b => (
                      <a href={b.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                        {b.name}
                      </a>
                    ))}
                  </div>
                </div>

                <!-- Penisola -->
                <div>
                  <a href="/it-it/penisola-sorrentina/" class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                    Penisola Sorrentina
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                  </a>
                  <div class="space-y-0.5 mt-2">
                    {sorrentinaBorghi.map(b => (
                      <a href={b.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                        {b.name}
                      </a>
                    ))}
                  </div>
                </div>

                <!-- Isole -->
                <div>
                  <a href="/it-it/isole/" class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                    Isole del Golfo
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                  </a>
                  <div class="space-y-0.5 mt-2">
                    {isole.map(b => (
                      <a href={b.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                        {b.name}
                      </a>
                    ))}
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- Guida Pratica -->
          <div class="relative group/guida">
            <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/guida:text-med-blue">
              Guida Pratica
              <svg class="w-3.5 h-3.5 opacity-50 group-hover/guida:opacity-100 transition-transform group-hover/guida:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/guida:opacity-100 group-hover/guida:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-4 w-52">
                <div class="space-y-0.5">
                  {guidaLinks.map(l => (
                    <a href={l.href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                      {l.name}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Esperienze -->
          <div class="relative group/esp">
            <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/esp:text-med-blue">
              Esperienze
              <svg class="w-3.5 h-3.5 opacity-50 group-hover/esp:opacity-100 transition-transform group-hover/esp:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/esp:opacity-100 group-hover/esp:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-5 grid grid-cols-2 gap-5 w-[480px]">

                <!-- Esperienze -->
                <div>
                  <a href="/it-it/esperienze/" class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                    Esperienze
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                  </a>
                  <div class="space-y-0.5 mt-2">
                    {esperienze.map(l => (
                      <a href={l.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                        {l.name}
                      </a>
                    ))}
                  </div>
                </div>

                <!-- Itinerari -->
                <div>
                  <a href="/it-it/itinerari/" class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                    Itinerari
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                  </a>
                  <div class="mt-2">
                    <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-2 mb-1">1 giorno</p>
                    <div class="space-y-0.5 mb-2">
                      {itinerari1g.map(l => (
                        <a href={l.href} class="flex items-center gap-2 px-2 py-1 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                          <span class="w-1.5 h-1.5 rounded-full bg-med-blue/20 flex-shrink-0"></span>
                          {l.name}
                        </a>
                      ))}
                    </div>
                    <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-2 mb-1">3 giorni</p>
                    <div class="space-y-0.5 mb-2">
                      {itinerari3g.map(l => (
                        <a href={l.href} class="flex items-center gap-2 px-2 py-1 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                          <span class="w-1.5 h-1.5 rounded-full bg-med-blue/20 flex-shrink-0"></span>
                          {l.name}
                        </a>
                      ))}
                    </div>
                    <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-2 mb-1">7 giorni</p>
                    <div class="space-y-0.5">
                      {itinerari7g.map(l => (
                        <a href={l.href} class="flex items-center gap-2 px-2 py-1 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                          <span class="w-1.5 h-1.5 rounded-full bg-med-blue/20 flex-shrink-0"></span>
                          {l.name}
                        </a>
                      ))}
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>

          <!-- Eventi -->
          <div class="relative group/ev">
            <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/ev:text-med-blue">
              Eventi
              <svg class="w-3.5 h-3.5 opacity-50 group-hover/ev:opacity-100 transition-transform group-hover/ev:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute right-0 top-full pt-2 opacity-0 invisible group-hover/ev:opacity-100 group-hover/ev:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-5 grid grid-cols-3 gap-5 w-[580px]">

                <!-- Cultura -->
                <div>
                  <p class="text-[10px] uppercase tracking-[0.3em] text-med-terracotta font-semibold mb-3 flex items-center gap-1">
                    <span class="w-2 h-2 rounded-full bg-med-terracotta/60"></span> Cultura
                  </p>
                  <div class="space-y-0.5">
                    {eventiCultura.map(l => (
                      <a href={l.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-terracotta/5 hover:text-med-terracotta transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-terracotta/30 flex-shrink-0"></span>
                        {l.name}
                      </a>
                    ))}
                  </div>
                </div>

                <!-- Tradizioni -->
                <div>
                  <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold mb-3 flex items-center gap-1">
                    <span class="w-2 h-2 rounded-full bg-med-blue/40"></span> Tradizioni
                  </p>
                  <div class="space-y-0.5">
                    {eventiTradizioni.map(l => (
                      <a href={l.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-blue/20 flex-shrink-0"></span>
                        {l.name}
                      </a>
                    ))}
                  </div>
                </div>

                <!-- Gastronomia -->
                <div>
                  <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-semibold mb-3 flex items-center gap-1">
                    <span class="w-2 h-2 rounded-full bg-med-gold/60"></span> Gastronomia
                  </p>
                  <div class="space-y-0.5">
                    {eventiGastronomia.map(l => (
                      <a href={l.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-gold/5 hover:text-med-gold transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-gold/30 flex-shrink-0"></span>
                        {l.name}
                      </a>
                    ))}
                  </div>
                  <a href="/it-it/eventi/" class="mt-3 flex items-center gap-1 px-2 py-1.5 text-xs text-med-blue hover:text-med-blue/70 font-medium transition-colors">
                    Tutti gli eventi →
                  </a>
                </div>

              </div>
            </div>
          </div>

        </nav>
      ) : (
        <nav class="hidden lg:flex items-center gap-6">
          <span class="text-sm text-slate-400">Coming soon in {t.languages[lang]}</span>
        </nav>
      )}

      <!-- Right: Language + CTA -->
      <div class="flex items-center gap-2">

        <!-- Language Switcher -->
        <div class="hidden md:block relative group/lang">
          <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-slate-600 hover:text-med-blue transition-colors border border-slate-200 rounded-full hover:border-med-blue/30">
            <span class="text-base leading-none">{flagMap[lang]}</span>
            <span class="font-semibold">{lang.split('-')[1].toUpperCase()}</span>
            <svg class="w-3 h-3 opacity-40 group-hover/lang:opacity-70 group-hover/lang:rotate-180 transition-all duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute right-0 top-full mt-2 w-52 bg-white rounded-2xl shadow-xl border border-slate-100 overflow-hidden opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-200 z-50 py-1.5">
            {locales.map(l => {
              const pageExists = pageKey && existingPages[l].includes(pageKey);
              const href = pageExists ? getLocalePath(l, pageKey!) : `/${l}/`;
              return (
                <a href={href} class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${l === lang ? 'bg-med-blue/5 text-med-blue font-semibold' : 'text-slate-700 hover:bg-slate-50'}`}>
                  <span class="text-base">{flagMap[l]}</span>
                  <span>{t.languages[l]}</span>
                  {l === lang && <span class="ml-auto w-1.5 h-1.5 rounded-full bg-med-blue flex-shrink-0"></span>}
                </a>
              );
            })}
          </div>
        </div>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-xl text-slate-700 hover:bg-slate-100" aria-label="Menu">
          <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-slate-100 bg-white max-h-[80vh] overflow-y-auto">
    <div class="px-4 py-5 space-y-1">
      {isIT && (
        <>
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-2 pb-1 font-semibold">Costiera Amalfitana</p>
          {costieraBorghi.map(b => (
            <a href={b.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{b.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Penisola Sorrentina</p>
          {sorrentinaBorghi.map(b => (
            <a href={b.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{b.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Isole del Golfo</p>
          {isole.map(b => (
            <a href={b.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{b.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Guida Pratica</p>
          {guidaLinks.map(l => (
            <a href={l.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Esperienze</p>
          {esperienze.map(l => (
            <a href={l.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Itinerari — 1 giorno</p>
          {itinerari1g.map(l => (
            <a href={l.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Itinerari — 3 giorni</p>
          {itinerari3g.map(l => (
            <a href={l.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Itinerari — 7 giorni</p>
          {itinerari7g.map(l => (
            <a href={l.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Eventi — Cultura</p>
          {eventiCultura.map(l => (
            <a href={l.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-terracotta/5 hover:text-med-terracotta transition-colors">{l.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Eventi — Tradizioni</p>
          {eventiTradizioni.map(l => (
            <a href={l.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">{l.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pt-4 pb-1 font-semibold">Eventi — Gastronomia</p>
          {eventiGastronomia.map(l => (
            <a href={l.href} class="block px-3 py-2.5 rounded-xl text-sm text-slate-700 hover:bg-med-gold/5 hover:text-med-gold transition-colors">{l.name}</a>
          ))}
        </>
      )}
      <div class="border-t border-slate-100 mt-4 pt-4">
        <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 px-3 pb-2">Lingua</p>
        {locales.map(l => {
          const href = `/${l}/`;
          return (
            <a href={href} class={`flex items-center gap-3 px-3 py-2 rounded-xl text-sm transition-colors ${l === lang ? 'text-med-blue font-medium bg-med-blue/5' : 'text-slate-700 hover:bg-slate-50'}`}>
              <span class="text-base">{flagMap[l]}</span>
              <span>{t.languages[l]}</span>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
