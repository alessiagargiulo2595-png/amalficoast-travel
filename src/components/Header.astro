---
import { getTranslations, getLocalePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
  pageKey?: string;
}

const { lang, pageKey } = Astro.props;
const t = getTranslations(lang);

const navLinks = [
  { key: 'destinations', label: t.nav.destinations },
  { key: 'beaches', label: t.nav.beaches },
  { key: 'itineraries', label: t.nav.itineraries },
  { key: 'getting-here', label: t.nav.getting_here },
  { key: 'when-to-visit', label: t.nav.when_to_visit },
];

const locales: Locale[] = ['en-us', 'en-gb', 'de-de', 'fr-fr', 'es-es', 'it-it'];

// Pages that exist per locale (only link to pages that are built)
const existingPages: Record<Locale, string[]> = {
  'en-us': [],
  'en-gb': [],
  'de-de': [],
  'fr-fr': [],
  'es-es': [],
  'it-it': ['destinations', 'beaches', 'itineraries', 'getting-here', 'when-to-visit'],
};
---

<header class="bg-white shadow-sm sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">

      <!-- Logo -->
      <a href={getLocalePath(lang, 'home')} class="flex items-center gap-2 group">
        <div class="w-8 h-8 bg-gradient-to-br from-sea-500 to-sea-700 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" />
          </svg>
        </div>
        <div>
          <span class="font-bold text-sea-700 text-sm leading-tight block group-hover:text-sea-500 transition-colors">
            Amalfi Coast
          </span>
          <span class="text-xs text-gray-400 leading-tight block">Travel Guide</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-6">
        {navLinks.map(link => {
          const exists = existingPages[lang].includes(link.key);
          return exists ? (
            <a
              href={getLocalePath(lang, link.key)}
              class={`text-sm font-medium transition-colors hover:text-sea-600 ${
                pageKey === link.key ? 'text-sea-600 border-b-2 border-sea-500 pb-0.5' : 'text-gray-600'
              }`}
            >
              {link.label}
            </a>
          ) : (
            <span class="text-sm font-medium text-gray-300 cursor-not-allowed">{link.label}</span>
          );
        })}
      </nav>

      <!-- Language Switcher -->
      <div class="hidden md:block relative group">
        <button class="flex items-center gap-1 text-sm text-gray-600 hover:text-sea-600 transition-colors px-3 py-2 rounded-lg hover:bg-sea-50">
          <span>{t.languages[lang].split(' ')[0]}</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute right-0 mt-1 w-44 bg-white rounded-xl shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
          {locales.map(l => {
            const pageExists = pageKey && existingPages[l].includes(pageKey);
            const href = pageExists ? getLocalePath(l, pageKey!) : `/${l}/`;
            return (
              <a
                href={href}
                class={`flex items-center gap-2 px-4 py-2 text-sm hover:bg-sea-50 hover:text-sea-600 transition-colors first:rounded-t-xl last:rounded-b-xl ${
                  l === lang ? 'bg-sea-50 text-sea-600 font-medium' : 'text-gray-700'
                }`}
              >
                {t.languages[l]}
              </a>
            );
          })}
        </div>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100"
        aria-label="Menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-4 space-y-1">
      {navLinks.map(link => {
        const exists = existingPages[lang].includes(link.key);
        return exists ? (
          <a
            href={getLocalePath(lang, link.key)}
            class="block px-4 py-2 rounded-lg text-sm font-medium text-gray-700 hover:bg-sea-50 hover:text-sea-600 transition-colors"
          >
            {link.label}
          </a>
        ) : (
          <span class="block px-4 py-2 rounded-lg text-sm font-medium text-gray-300">{link.label}</span>
        );
      })}
      <div class="border-t border-gray-100 pt-3 mt-3">
        <p class="px-4 text-xs text-gray-400 mb-2">{t.lang_switcher}</p>
        {locales.map(l => {
          const pageExists = pageKey && existingPages[l].includes(pageKey);
          const href = pageExists ? getLocalePath(l, pageKey!) : `/${l}/`;
          return (
            <a
              href={href}
              class={`block px-4 py-2 rounded-lg text-sm transition-colors ${
                l === lang ? 'bg-sea-50 text-sea-600 font-medium' : 'text-gray-700 hover:bg-gray-50'
              }`}
            >
              {t.languages[l]}
            </a>
          );
        })}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
