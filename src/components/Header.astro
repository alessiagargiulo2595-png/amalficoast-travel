---
import { getTranslations, getLocalePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
  pageKey?: string;
}

const { lang, pageKey } = Astro.props;
const t = getTranslations(lang);
const locales: Locale[] = ['en-us', 'en-gb', 'de-de', 'fr-fr', 'es-es', 'it-it'];

const existingPages: Record<Locale, string[]> = {
  'en-us': [],
  'en-gb': [],
  'de-de': [],
  'fr-fr': [],
  'es-es': [],
  'it-it': ['destinations', 'beaches', 'itineraries', 'getting-here', 'when-to-visit', 'costiera-amalfitana', 'positano'],
};

const isIT = lang === 'it-it';

const costieraBorghi = [
  { name: 'Positano',  href: '/it-it/costiera-amalfitana/positano/' },
  { name: 'Amalfi',    href: '/it-it/costiera-amalfitana/amalfi/' },
  { name: 'Ravello',   href: '/it-it/costiera-amalfitana/ravello/' },
  { name: 'Praiano',   href: '/it-it/costiera-amalfitana/praiano/' },
  { name: 'Maiori',    href: '/it-it/costiera-amalfitana/maiori/' },
  { name: 'Minori',    href: '/it-it/costiera-amalfitana/minori/' },
];
const sorrentinaBorghi = [
  { name: 'Sorrento',        href: '/it-it/penisola-sorrentina/sorrento/' },
  { name: 'Vico Equense',    href: '/it-it/penisola-sorrentina/vico-equense/' },
  { name: 'Massa Lubrense',  href: '/it-it/penisola-sorrentina/massa-lubrense/' },
  { name: 'Sant\'Agnello',   href: '/it-it/penisola-sorrentina/sant-agnello/' },
];
const isole = [
  { name: 'Capri',    href: '/it-it/isole/capri/' },
  { name: 'Ischia',   href: '/it-it/isole/ischia/' },
  { name: 'Procida',  href: '/it-it/isole/procida/' },
];
---

<header class="bg-white border-b border-gray-100 sticky top-0 z-50">
  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={`/${lang}/`} class="flex items-center gap-3 group flex-shrink-0">
        <div class="w-8 h-8 rounded-full bg-capri-500 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
          </svg>
        </div>
        <div class="leading-tight">
          <span class="font-serif font-semibold text-charcoal text-base tracking-tight block group-hover:text-capri-500 transition-colors">Amalfi Coast</span>
          <span class="text-[10px] text-gray-400 uppercase tracking-widest">Travel Guide</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      {isIT ? (
        <nav class="hidden lg:flex items-center gap-1">

          <!-- Silo A: Costiera -->
          <div class="relative group/mega">
            <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-charcoal hover:text-capri-500 transition-colors rounded-lg hover:bg-gray-50">
              Costiera Amalfitana
              <svg class="w-3.5 h-3.5 opacity-50 group-hover/mega:opacity-100 transition-transform group-hover/mega:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/mega:opacity-100 group-hover/mega:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-5 w-64">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-3 font-medium">Borghi della Costiera</p>
                <div class="space-y-1">
                  {costieraBorghi.map(b => (
                    <a href={b.href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors group/item">
                      <span class="w-1.5 h-1.5 rounded-full bg-capri-400 group-hover/item:bg-capri-500 flex-shrink-0"></span>
                      {b.name}
                    </a>
                  ))}
                </div>
                <div class="border-t border-gray-100 mt-3 pt-3">
                  <a href="/it-it/costiera-amalfitana/" class="text-xs text-capri-500 hover:text-capri-700 font-medium">
                    Guida completa →
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Silo B: Penisola -->
          <div class="relative group/mega2">
            <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-charcoal hover:text-capri-500 transition-colors rounded-lg hover:bg-gray-50">
              Penisola Sorrentina
              <svg class="w-3.5 h-3.5 opacity-50 group-hover/mega2:opacity-100 transition-transform group-hover/mega2:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/mega2:opacity-100 group-hover/mega2:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-5 w-56">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-3 font-medium">Borghi Sorrentini</p>
                <div class="space-y-1">
                  {sorrentinaBorghi.map(b => (
                    <a href={b.href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors group/item">
                      <span class="w-1.5 h-1.5 rounded-full bg-capri-400 flex-shrink-0"></span>
                      {b.name}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <!-- Silo C: Isole -->
          <div class="relative group/mega3">
            <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-charcoal hover:text-capri-500 transition-colors rounded-lg hover:bg-gray-50">
              Isole
              <svg class="w-3.5 h-3.5 opacity-50 group-hover/mega3:opacity-100 transition-transform group-hover/mega3:rotate-180" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/mega3:opacity-100 group-hover/mega3:visible transition-all duration-200 z-50">
              <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-5 w-48">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-3 font-medium">Le Isole del Golfo</p>
                <div class="space-y-1">
                  {isole.map(b => (
                    <a href={b.href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors group/item">
                      <span class="w-1.5 h-1.5 rounded-full bg-capri-400 flex-shrink-0"></span>
                      {b.name}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <a href="/it-it/quando-visitare/" class="px-4 py-2 text-sm font-medium text-charcoal hover:text-capri-500 transition-colors rounded-lg hover:bg-gray-50">
            Quando andare
          </a>
        </nav>
      ) : (
        <nav class="hidden lg:flex items-center gap-6">
          <span class="text-sm text-gray-400">Coming soon in {t.languages[lang]}</span>
        </nav>
      )}

      <!-- Right: Language + CTA -->
      <div class="flex items-center gap-2">

        <!-- Language Switcher -->
        <div class="hidden md:block relative group/lang">
          <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-capri-500 transition-colors border border-gray-200 rounded-full hover:border-capri-300">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/>
            </svg>
            <span>{lang.toUpperCase()}</span>
          </button>
          <div class="absolute right-0 top-full mt-2 w-48 bg-white rounded-2xl shadow-xl border border-gray-100 overflow-hidden opacity-0 invisible group-hover/lang:opacity-100 group-hover/lang:visible transition-all duration-200 z-50">
            {locales.map(l => {
              const pageExists = pageKey && existingPages[l].includes(pageKey);
              const href = pageExists ? getLocalePath(l, pageKey!) : `/${l}/`;
              return (
                <a href={href} class={`flex items-center gap-3 px-4 py-2.5 text-sm transition-colors ${l === lang ? 'bg-capri-50 text-capri-600 font-medium' : 'text-charcoal hover:bg-gray-50'}`}>
                  {t.languages[l]}
                </a>
              );
            })}
          </div>
        </div>

        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-xl text-charcoal hover:bg-gray-100" aria-label="Menu">
          <svg id="icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white max-h-[80vh] overflow-y-auto">
    <div class="px-4 py-5 space-y-1">
      {isIT && (
        <>
          <p class="text-[10px] uppercase tracking-widest text-gray-400 px-3 pt-2 pb-1">Costiera Amalfitana</p>
          {costieraBorghi.map(b => (
            <a href={b.href} class="block px-3 py-2.5 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors">{b.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-widest text-gray-400 px-3 pt-4 pb-1">Penisola Sorrentina</p>
          {sorrentinaBorghi.map(b => (
            <a href={b.href} class="block px-3 py-2.5 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors">{b.name}</a>
          ))}
          <p class="text-[10px] uppercase tracking-widest text-gray-400 px-3 pt-4 pb-1">Isole</p>
          {isole.map(b => (
            <a href={b.href} class="block px-3 py-2.5 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors">{b.name}</a>
          ))}
          <a href="/it-it/quando-visitare/" class="block px-3 py-2.5 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors mt-2">Quando andare</a>
        </>
      )}
      <div class="border-t border-gray-100 mt-4 pt-4">
        <p class="text-[10px] uppercase tracking-widest text-gray-400 px-3 pb-2">Lingua</p>
        {locales.map(l => {
          const href = `/${l}/`;
          return (
            <a href={href} class={`block px-3 py-2 rounded-xl text-sm transition-colors ${l === lang ? 'text-capri-600 font-medium bg-capri-50' : 'text-charcoal hover:bg-gray-50'}`}>
              {t.languages[l]}
            </a>
          );
        })}
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
