---

<header class="glass-nav sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href={`/${lang}/`} class="flex-shrink-0">
        <img src="/logo.svg" alt="Amalfi Coast Travel Guide" class="h-10 w-auto" />
      </a>

      <!-- Desktop Nav (mega dropdown - all locales) -->
      <nav class="hidden lg:flex items-center gap-1">

        <!-- Destinazioni mega-dropdown -->
        <div class="relative group/dest">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/dest:text-med-blue">
            {nav.dest}
            <svg class="w-3.5 h-3.5 opacity-50 group-hover/dest:opacity-100 transition-transform group-hover/dest:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/dest:opacity-100 group-hover/dest:visible transition-all duration-200 z-50">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 grid grid-cols-3 gap-6 w-[580px]">

              <!-- Costiera -->
              <div>
                <a href={`${costieraBase}/`} class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                  {dh.costiera}
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                </a>
                <div class="space-y-0.5 mt-2">
                  {costieraBorghi.map(b => (
                    <a href={b.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                      {b.name}
                    </a>
                  ))}
                </div>
              </div>

              <!-- Penisola -->
              <div>
                <a href={sorrentineHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                  {dh.sorrentina}
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                </a>
                <div class="space-y-0.5 mt-2">
                  {sorrentinaBorghi.map(b => (
                    <a href={b.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                      {b.name}
                    </a>
                  ))}
                </div>
              </div>

              <!-- Isole -->
              <div>
                <a href={isoleHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                  {dh.isole}
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                </a>
                <div class="space-y-0.5 mt-2">
                  {isoleLinks.map(b => (
                    <a href={b.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                      {b.name}
                    </a>
                  ))}
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- Spiagge dropdown -->
        <div class="relative group/spiagge">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/spiagge:text-med-blue">
            {nav.spiagge}
            <svg class="w-3.5 h-3.5 opacity-50 group-hover/spiagge:opacity-100 transition-transform group-hover/spiagge:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/spiagge:opacity-100 group-hover/spiagge:visible transition-all duration-200 z-50">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-6 grid grid-cols-3 gap-6 w-[560px]">
              <div class="col-span-3 mb-1">
                <a href={spiaggeHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold flex items-center gap-1">
                  {tutteBeachLabel}
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                </a>
              </div>
              {spiaggeAree.map(area => (
                <div>
                  <a href={area.href} class="text-[10px] uppercase tracking-[0.3em] text-slate-400 hover:text-med-blue font-semibold mb-3 block">
                    {area.area}
                  </a>
                  <div class="space-y-0.5">
                    {area.beaches.map(b => (
                      <a href={b.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                        {b.name}
                      </a>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Guida Pratica -->
        <div class="relative group/guida">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/guida:text-med-blue">
            {nav.guida}
            <svg class="w-3.5 h-3.5 opacity-50 group-hover/guida:opacity-100 transition-transform group-hover/guida:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/guida:opacity-100 group-hover/guida:visible transition-all duration-200 z-50">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-4 w-52">
              <div class="space-y-0.5">
                {guidaLinks.map(l => (
                  <a href={l.href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                    <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                    {l.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Esperienze -->
        <div class="relative group/esp">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/esp:text-med-blue">
            {nav.esp}
            <svg class="w-3.5 h-3.5 opacity-50 group-hover/esp:opacity-100 transition-transform group-hover/esp:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div class="absolute left-0 top-full pt-2 opacity-0 invisible group-hover/esp:opacity-100 group-hover/esp:visible transition-all duration-200 z-50">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-100 p-5 grid grid-cols-2 gap-5 w-[480px]">

              <!-- Esperienze -->
              <div>
                <a href={esperienzeHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                  {nav.esp}
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                </a>
                <div class="space-y-0.5 mt-2">
                  {esperienze.map(l => (
                    <a href={l.href} class="flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                      <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30 flex-shrink-0"></span>
                      {l.name}
                    </a>
                  ))}
                </div>
              </div>

              <!-- Itinerari -->
              <div>
                <a href={itinerariHref} class="text-[10px] uppercase tracking-[0.3em] text-med-blue hover:text-med-blue/70 font-semibold mb-3 flex items-center gap-1">
                  {itinerariLabel}
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
                </a>
                <div class="mt-2">
                  <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-2 mb-1">{itPeriods.d1}</p>
                  <div class="space-y-0.5 mb-2">
                    {itinerari1g.map(l => (
                      <a href={l.href} class="flex items-center gap-2 px-2 py-1 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-blue/20 flex-shrink-0"></span>
                        {l.name}
                      </a>
                    ))}
                  </div>
                  <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-2 mb-1">{itPeriods.d3}</p>
                  <div class="space-y-0.5 mb-2">
                    {itinerari3g.map(l => (
                      <a href={l.href} class="flex items-center gap-2 px-2 py-1 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                        <span class="w-1.5 h-1.5 rounded-full bg-med-blue/20 flex-shrink-0"></span>
                        {l.name}
                      </a>
                    ))}
                  </div>
                  {itinerari7g.length > 0 && (
                    <>
                      <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] px-2 mb-1">{itPeriods.d7}</p>
                      <div class="space-y-0.5">
                        {itinerari7g.map(l => (
                          <a href={l.href} class="flex items-center gap-2 px-2 py-1 rounded-lg text-sm text-slate-700 hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                            <span class="w-1.5 h-1.5 rounded-full bg-med-blue/20 flex-shrink-0"></span>
                            {l.name}
                          </a>
                        ))}
                      </div>
                    </>
                  )}
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- Eventi -->
        <div class="relative group/ev">
          <button class="flex items-center gap-1 px-4 py-2 text-sm font-medium text-slate-700 hover:text-med-blue transition-colors rounded-lg hover:bg-med-blue/5 group-hover/ev:text-med-blue">
            {nav.ev}
            <svg class="w-3.5 h-3.5 opacity-50 group-hover/ev:opacity-100 transition-transform group-hover/ev:rotate-180 duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
