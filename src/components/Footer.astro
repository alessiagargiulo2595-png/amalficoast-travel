---
import { getTranslations } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

/* ── Town base paths per locale ── */
const townBase: Record<Locale, string> = {
  'it-it': '/it-it/costiera-amalfitana',
  'en-us': '/en-us/amalfi-coast',
  'en-gb': '/en-gb/amalfi-coast',
  'de-de': '/de-de/amalfikueste',
  'fr-fr': '/fr-fr/cote-amalfitaine',
  'es-es': '/es-es/costa-amalfitana',
};

const towns = ['positano', 'amalfi', 'ravello', 'praiano', 'maiori', 'minori'];
const townLabels = ['Positano', 'Amalfi', 'Ravello', 'Praiano', 'Maiori', 'Minori'];

/* ── Section headings per locale ── */
type SectionKeys = 'territori' | 'guida' | 'esperienze' | 'eventi';
const sectionHeadings: Record<Locale, Record<SectionKeys, string>> = {
  'it-it': { territori: 'Territori', guida: 'Guida Pratica', esperienze: 'Esperienze', eventi: 'Eventi 2026' },
  'en-us': { territori: 'Destinations', guida: 'Practical Guide', esperienze: 'Experiences', eventi: 'Events 2026' },
  'en-gb': { territori: 'Destinations', guida: 'Practical Guide', esperienze: 'Experiences', eventi: 'Events 2026' },
  'de-de': { territori: 'Orte', guida: 'Praktischer Ratgeber', esperienze: 'Erlebnisse', eventi: 'Veranstaltungen 2026' },
  'fr-fr': { territori: 'Destinations', guida: 'Guide Pratique', esperienze: 'Expériences', eventi: 'Événements 2026' },
  'es-es': { territori: 'Destinos', guida: 'Guía Práctica', esperienze: 'Experiencias', eventi: 'Eventos 2026' },
};

/* ── Guida Pratica links per locale ── */
type GuidaKeys = 'ferries' | 'bus' | 'parking' | 'beaches' | 'trekking';
const guidaLinks: Record<Locale, Record<GuidaKeys, { label: string; href: string }>> = {
  'it-it': {
    ferries:  { label: 'Traghetti 2025',    href: '/it-it/guida/traghetti/' },
    bus:      { label: 'Bus SITA',          href: '/it-it/guida/bus-sita/' },
    parking:  { label: 'Parcheggi',         href: '/it-it/guida/parcheggi-ztl/' },
    beaches:  { label: 'Spiagge Libere',    href: '/it-it/spiagge/' },
    trekking: { label: 'Sentieri Trekking', href: '/it-it/esperienze/trekking/' },
  },
  'en-us': {
    ferries:  { label: 'Ferries 2025',   href: '/en-us/guide/ferries/' },
    bus:      { label: 'SITA Bus',       href: '/en-us/guide/sita-bus/' },
    parking:  { label: 'Parking & ZTL',  href: '/en-us/guide/parking-ztl/' },
    beaches:  { label: 'Free Beaches',   href: '/en-us/beaches' },
    trekking: { label: 'Hiking Trails',  href: '/en-us/experiences/trekking/' },
  },
  'en-gb': {
    ferries:  { label: 'Ferries 2025',   href: '/en-gb/guide/ferries/' },
    bus:      { label: 'SITA Bus',       href: '/en-gb/guide/sita-bus/' },
    parking:  { label: 'Parking & ZTL',  href: '/en-gb/guide/parking-ztl/' },
    beaches:  { label: 'Free Beaches',   href: '/en-gb/beaches' },
    trekking: { label: 'Hiking Trails',  href: '/en-gb/experiences/trekking/' },
  },
  'de-de': {
    ferries:  { label: 'Fähren 2025',    href: '/de-de/ratgeber/faehren/' },
    bus:      { label: 'SITA Bus',       href: '/de-de/ratgeber/sita-bus/' },
    parking:  { label: 'Parken & ZTL',   href: '/de-de/ratgeber/parken-ztl/' },
    beaches:  { label: 'Freie Strände',  href: '/de-de/strande' },
    trekking: { label: 'Wanderwege',     href: '#' },
  },
  'fr-fr': {
    ferries:  { label: 'Ferries 2025',    href: '/fr-fr/guide/ferries/' },
    bus:      { label: 'Bus SITA',        href: '/fr-fr/guide/bus-sita/' },
    parking:  { label: 'Parking & ZTL',   href: '/fr-fr/guide/parking-ztl/' },
    beaches:  { label: 'Plages Libres',   href: '/fr-fr/plages' },
    trekking: { label: 'Randonnées',      href: '#' },
  },
  'es-es': {
    ferries:  { label: 'Ferries 2025',        href: '/es-es/guia/ferries/' },
    bus:      { label: 'Bus SITA',            href: '/es-es/guia/bus-sita/' },
    parking:  { label: 'Aparcamiento & ZTL',  href: '/es-es/guia/aparcamiento-ztl/' },
    beaches:  { label: 'Playas Libres',       href: '/es-es/playas' },
    trekking: { label: 'Rutas de Senderismo', href: '#' },
  },
};

/* ── Esperienze links per locale ── */
type EsperienzeKeys = 'cooking' | 'weddings' | 'restaurants' | 'limoncello' | 'mozzarella';
const esperienzeLinks: Record<Locale, Record<EsperienzeKeys, { label: string; href: string }>> = {
  'it-it': { cooking: { label: 'Cooking Class', href: '/it-it/esperienze/cooking-class/' }, weddings: { label: 'Matrimoni', href: '/it-it/esperienze/matrimoni/' }, restaurants: { label: 'Ristoranti Stellati', href: '/it-it/esperienze/ristoranti-stellati/' }, limoncello: { label: 'Limoncello Tour', href: '/it-it/esperienze/limoncello-tour/' }, mozzarella: { label: 'Mozzarella Experience', href: '/it-it/esperienze/mozzarella-experience/' } },
  'en-us': { cooking: { label: 'Cooking Class', href: '/en-us/experiences/cooking-class/' }, weddings: { label: 'Weddings', href: '/en-us/experiences/weddings/' }, restaurants: { label: 'Michelin Restaurants', href: '/en-us/experiences/starred-restaurants/' }, limoncello: { label: 'Limoncello Tour', href: '/en-us/experiences/limoncello-tour/' }, mozzarella: { label: 'Mozzarella Experience', href: '/en-us/experiences/mozzarella-experience/' } },
  'en-gb': { cooking: { label: 'Cooking Class', href: '#' }, weddings: { label: 'Weddings', href: '#' }, restaurants: { label: 'Michelin Restaurants', href: '#' }, limoncello: { label: 'Limoncello Tour', href: '#' }, mozzarella: { label: 'Mozzarella Experience', href: '#' } },
  'de-de': { cooking: { label: 'Kochkurs', href: '/de-de/erlebnisse/kochkurs/' }, weddings: { label: 'Hochzeiten', href: '/de-de/erlebnisse/hochzeiten/' }, restaurants: { label: 'Sterne-Restaurants', href: '/de-de/erlebnisse/sterne-restaurants/' }, limoncello: { label: 'Limoncello Tour', href: '/de-de/erlebnisse/limoncello-tour/' }, mozzarella: { label: 'Mozzarella Erlebnis', href: '/de-de/erlebnisse/mozzarella-erlebnis/' } },
  'fr-fr': { cooking: { label: 'Cours de Cuisine', href: '#' }, weddings: { label: 'Mariages', href: '#' }, restaurants: { label: 'Restaurants Étoilés', href: '#' }, limoncello: { label: 'Tour Limoncello', href: '#' }, mozzarella: { label: 'Atelier Mozzarella', href: '#' } },
  'es-es': { cooking: { label: 'Clase de Cocina', href: '/es-es/experiencias/clase-cocina/' }, weddings: { label: 'Bodas', href: '/es-es/experiencias/bodas/' }, restaurants: { label: 'Restaurantes Estrella', href: '/es-es/experiencias/restaurantes-estrella/' }, limoncello: { label: 'Tour del Limoncello', href: '/es-es/experiencias/tour-limoncello/' }, mozzarella: { label: 'Experiencia Mozzarella', href: '/es-es/experiencias/experiencia-mozzarella/' } },
};

/* ── Eventi 2026 links per locale ── */
type EventiKeys = 'ravello' | 'regata' | 'capodanno' | 'sagra';
const eventiLinks: Record<Locale, Record<EventiKeys, { label: string; href: string }>> = {
  'it-it': {
    ravello:   { label: 'Ravello Festival',    href: '/it-it/eventi/costiera-amalfitana/ravello-festival/' },
    regata:    { label: 'Regata Storica',      href: '#' },
    capodanno: { label: 'Capodanno Bizantino', href: '#' },
    sagra:     { label: 'Sagra del Pesce',     href: '/it-it/eventi/costiera-amalfitana/sagra-del-pesce-positano/' },
  },
  'en-us': {
    ravello:   { label: 'Ravello Festival',   href: '/en-us/events/amalfi-coast/ravello-festival/' },
    regata:    { label: 'Historic Regatta',   href: '#' },
    capodanno: { label: 'Byzantine New Year', href: '#' },
    sagra:     { label: 'Fish Festival',      href: '/en-us/events/amalfi-coast/sagra-del-pesce-positano/' },
  },
  'en-gb': {
    ravello:   { label: 'Ravello Festival',   href: '/en-gb/events/amalfi-coast/ravello-festival/' },
    regata:    { label: 'Historic Regatta',   href: '#' },
    capodanno: { label: 'Byzantine New Year', href: '#' },
    sagra:     { label: 'Fish Festival',      href: '#' },
  },
  'de-de': {
    ravello:   { label: 'Ravello Festival',        href: '#' },
    regata:    { label: 'Historische Regatta',     href: '#' },
    capodanno: { label: 'Byzantinisches Neujahr',  href: '#' },
    sagra:     { label: 'Fischfest',               href: '#' },
  },
  'fr-fr': {
    ravello:   { label: 'Festival de Ravello',  href: '#' },
    regata:    { label: 'Régate Historique',    href: '#' },
    capodanno: { label: 'Nouvel An Byzantin',   href: '#' },
    sagra:     { label: 'Fête du Poisson',      href: '#' },
  },
  'es-es': {
    ravello:   { label: 'Festival de Ravello',  href: '#' },
    regata:    { label: 'Regata Histórica',     href: '#' },
    capodanno: { label: 'Año Nuevo Bizantino',  href: '#' },
    sagra:     { label: 'Fiesta del Pescado',   href: '#' },
  },
};

const h = sectionHeadings[lang];
const guida = Object.values(guidaLinks[lang]);
const esperienze = Object.values(esperienzeLinks[lang]);
const eventi = Object.values(eventiLinks[lang]);
const base = townBase[lang];
---

<footer class="bg-slate-900 border-t border-white/5 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Top grid: brand + 4 link columns -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-10 lg:gap-8">

      <!-- Brand -->
      <div class="col-span-2 md:col-span-3 lg:col-span-1">
        <div class="mb-5">
          <img src="/logo-footer.svg" alt="Amalfi Coast Travel Guide" class="h-9 w-auto" />
        </div>
        <p class="text-white/40 text-sm leading-relaxed">{t.footer.about_text}</p>
        <p class="mt-4 text-white/20 text-xs italic">{t.footer.tagline}</p>
      </div>

      <!-- Territori -->
      <div>
        <h3 class="font-serif font-bold text-med-gold text-sm uppercase tracking-[0.15em] mb-5">{h.territori}</h3>
        <ul class="space-y-2.5">
          {towns.map((slug, i) => (
            <li>
              <a href={`${base}/${slug}/`} class="text-white/45 hover:text-med-gold text-sm transition-colors">
                {townLabels[i]}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Guida Pratica -->
      <div>
        <h3 class="font-serif font-bold text-med-gold text-sm uppercase tracking-[0.15em] mb-5">{h.guida}</h3>
        <ul class="space-y-2.5">
          {guida.map(link => (
            <li>
              <a href={link.href} class="text-white/45 hover:text-med-gold text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
          {lang === 'it-it' && (
            <li>
              <a href="/it-it/blog/" class="text-white/45 hover:text-med-gold text-sm transition-colors">
                Blog
              </a>
            </li>
          )}
          {lang === 'fr-fr' && (
            <li>
              <a href="/fr-fr/blog/" class="text-white/45 hover:text-med-gold text-sm transition-colors">
                Blog
              </a>
            </li>
          )}
          {lang === 'en-us' && (
            <li>
              <a href="/en-us/blog/" class="text-white/45 hover:text-med-gold text-sm transition-colors">
                Blog
              </a>
            </li>
          )}
          {lang === 'de-de' && (
            <li>
              <a href="/de-de/blog/" class="text-white/45 hover:text-med-gold text-sm transition-colors">
                Blog
              </a>
            </li>
          )}
          {lang === 'es-es' && (
            <li>
              <a href="/es-es/blog/" class="text-white/45 hover:text-med-gold text-sm transition-colors">
                Blog
              </a>
            </li>
          )}
        </ul>
      </div>

      <!-- Esperienze -->
      <div>
        <h3 class="font-serif font-bold text-med-gold text-sm uppercase tracking-[0.15em] mb-5">{h.esperienze}</h3>
        <ul class="space-y-2.5">
          {esperienze.map(link => (
            <li>
              <a href={link.href} class="text-white/45 hover:text-med-gold text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Eventi 2026 -->
      <div>
        <h3 class="font-serif font-bold text-med-gold text-sm uppercase tracking-[0.15em] mb-5">{h.eventi}</h3>
        <ul class="space-y-2.5">
          {eventi.map(link => (
            <li>
              <a href={link.href} class="text-white/45 hover:text-med-gold text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 mt-14 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/20 text-[10px] uppercase tracking-[0.3em]">{t.footer.copyright}</p>
      <div class="flex items-center gap-6">
        <p class="text-white/20 text-[10px] uppercase tracking-[0.3em]">UNESCO World Heritage Site</p>
        <p class="text-white/20 text-[10px] uppercase tracking-[0.3em]">Campania, Southern Italy</p>
      </div>
    </div>

  </div>
</footer>
