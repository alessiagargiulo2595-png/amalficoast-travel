---
import { getTranslations, getLocalePath } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const navLinks = [
  { key: 'destinations', label: t.nav.destinations },
  { key: 'beaches', label: t.nav.beaches },
  { key: 'itineraries', label: t.nav.itineraries },
  { key: 'getting-here', label: t.nav.getting_here },
  { key: 'when-to-visit', label: t.nav.when_to_visit },
];
---

<footer class="bg-slate-900 border-t border-white/5 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- About -->
      <div>
        <div class="mb-6">
          <img src="/logo.svg" alt="Amalfi Coast Travel Guide" class="h-10 w-auto brightness-0 invert" />
        </div>
        <p class="text-white/40 text-sm leading-relaxed">{t.footer.about_text}</p>
        <p class="mt-4 text-white/20 text-xs italic">{t.footer.tagline}</p>
        <!-- Social icons -->
        <div class="flex items-center gap-4 mt-6">
          <a href="#" aria-label="Instagram" class="text-white/40 hover:text-med-gold transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="#" aria-label="Pinterest" class="text-white/40 hover:text-med-gold transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-serif font-bold text-white mb-6">{t.footer.quick_links}</h3>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a
                href={getLocalePath(lang, link.key)}
                class="text-white/40 hover:text-med-gold text-sm transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-serif font-bold text-white mb-6">{t.footer.contact_title}</h3>
        <a
          href={`mailto:${t.footer.contact_email}`}
          class="text-white/40 hover:text-med-gold text-sm transition-colors flex items-center gap-2"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {t.footer.contact_email}
        </a>
        <div class="mt-8 space-y-2">
          <p class="text-white/20 text-xs uppercase tracking-[0.2em]">UNESCO World Heritage Site</p>
          <p class="text-white/20 text-xs uppercase tracking-[0.2em]">Campania, Southern Italy</p>
        </div>
      </div>

    </div>

    <div class="border-t border-white/5 mt-16 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/20 text-[10px] uppercase tracking-[0.3em]">{t.footer.copyright}</p>
      <p class="text-white/20 text-[10px] uppercase tracking-[0.3em]">Mediterranean Luxury Travel Guide</p>
    </div>
  </div>
</footer>
