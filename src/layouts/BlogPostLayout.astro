---
import BaseLayout from './BaseLayout.astro';
import type { Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
  post: {
    title: string;
    subtitle: string;
    category: string;
    date: string;
    readTime: string;
    image: string;
    imageAlt: string;
    path: string;
  };
  metaTitle: string;
  metaDescription: string;
  breadcrumbs: { name: string; url: string }[];
  quickInfo: { label: string; value: string }[];
  faq: { q: string; a: string }[];
  sidebarLinks: { label: string; href: string }[];
  author?: string;
  authorRole?: string;
  extraSchema?: object[];
  relatedArticles?: { title: string; category: string; date: string; image: string; imageAlt: string; path: string }[];
}

const {
  lang, post, metaTitle, metaDescription,
  breadcrumbs, quickInfo, faq, sidebarLinks,
  author = 'Amalfi Coast Travel',
  authorRole,
  extraSchema = [],
  relatedArticles = [],
} = Astro.props;

const site = 'https://amalficoast-travel.com';

const localeLabel: Record<Locale, string> = {
  'en-us': 'en-US', 'en-gb': 'en-GB', 'de-de': 'de-DE',
  'fr-fr': 'fr-FR', 'es-es': 'es-ES', 'it-it': 'it-IT',
};

const blogBase: Record<Locale, string> = {
  'it-it': '/it-it/blog/', 'fr-fr': '/fr-fr/blog/',
  'en-us': '/en-us/blog/', 'en-gb': '/en-gb/blog/',
  'de-de': '/de-de/blog/', 'es-es': '/es-es/blog/',
};

const ui: Record<Locale, { faqTitle: string; quickInfoTitle: string; writtenBy: string; backBlog: string; readTime: string; relatedArticles: string; readAlso: string }> = {
  'it-it': { faqTitle: 'Domande Frequenti',          quickInfoTitle: 'Info Rapide',    writtenBy: 'Scritto da',       backBlog: 'Torna al Blog',    readTime: 'di lettura', relatedArticles: 'Articoli Correlati', readAlso: 'Leggi anche' },
  'fr-fr': { faqTitle: 'Questions Fréquentes',        quickInfoTitle: 'Infos Pratiques', writtenBy: 'Écrit par',       backBlog: 'Retour au Blog',   readTime: 'de lecture', relatedArticles: 'Articles Connexes', readAlso: 'Lire aussi' },
  'en-us': { faqTitle: 'Frequently Asked Questions',  quickInfoTitle: 'Quick Info',      writtenBy: 'Written by',      backBlog: 'Back to Blog',     readTime: 'read', relatedArticles: 'Related Articles', readAlso: 'Read also' },
  'en-gb': { faqTitle: 'Frequently Asked Questions',  quickInfoTitle: 'Quick Info',      writtenBy: 'Written by',      backBlog: 'Back to Blog',     readTime: 'read', relatedArticles: 'Related Articles', readAlso: 'Read also' },
  'de-de': { faqTitle: 'Häufige Fragen',              quickInfoTitle: 'Kurzinfos',       writtenBy: 'Geschrieben von', backBlog: 'Zurück zum Blog',  readTime: 'Lesezeit', relatedArticles: 'Verwandte Artikel', readAlso: 'Lesen Sie auch' },
  'es-es': { faqTitle: 'Preguntas Frecuentes',        quickInfoTitle: 'Info Rápida',     writtenBy: 'Escrito por',     backBlog: 'Volver al Blog',   readTime: 'de lectura', relatedArticles: 'Artículos Relacionados', readAlso: 'Lee también' },
};
const t = ui[lang];

const defaultAuthorRole: Record<Locale, string> = {
  'it-it': 'Guide locali · Costiera Amalfitana',
  'fr-fr': 'Spécialiste Côte Amalfitaine',
  'en-us': 'Local Expert · Amalfi Coast',
  'en-gb': 'Local Expert · Amalfi Coast',
  'de-de': 'Lokaler Experte · Amalfiküste',
  'es-es': 'Experto Local · Costa Amalfitana',
};
const resolvedAuthorRole = authorRole ?? defaultAuthorRole[lang];

const schemaArticle = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": metaDescription,
  "image": `${site}${post.image}`,
  "datePublished": "2026-04-22",
  "dateModified": "2026-04-22",
  "author": { "@type": "Organization", "name": "Amalfi Coast Travel" },
  "publisher": { "@type": "Organization", "name": "Amalfi Coast Travel", "url": site },
  "url": `${site}${post.path}`,
  "inLanguage": localeLabel[lang],
};

const schemaFaq = faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a },
  })),
} : null;

const allSchema = [schemaArticle, ...(schemaFaq ? [schemaFaq] : []), ...extraSchema];
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={allSchema}
>

  <!-- Hero -->
  <section class="relative h-[75vh] overflow-hidden flex items-center justify-center">
    <img
      src={post.image}
      alt={post.imageAlt}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="sync"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/30 to-black/80"></div>

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="absolute bottom-8 left-0 right-0 z-10 max-w-7xl mx-auto px-6">
      <ol class="flex items-center flex-wrap gap-1.5 text-white/60 text-xs" itemscope itemtype="https://schema.org/BreadcrumbList">
        {breadcrumbs.map((crumb, i) => (
          <Fragment>
            {i > 0 && <li aria-hidden="true" class="mx-0.5">/</li>}
            <li
              itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem"
              class:list={[{ 'text-white': i === breadcrumbs.length - 1 }]}
            >
              {i < breadcrumbs.length - 1
                ? <a href={crumb.url} class="hover:text-white transition-colors" itemprop="item"><span itemprop="name">{crumb.name}</span></a>
                : <span itemprop="name">{crumb.name}</span>
              }
              <meta itemprop="position" content={String(i + 1)} />
            </li>
          </Fragment>
        ))}
      </ol>
    </nav>

    <!-- Titolo centrato -->
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-4">
        {post.category} · {post.date}
      </p>
      <h1 class="font-serif text-display text-white mb-6 leading-tight">{post.title}</h1>
      <p class="text-xl md:text-2xl font-light text-white/80">{post.subtitle}</p>
      <div class="mt-6 flex items-center justify-center gap-4 text-white/60 text-sm">
        <span>{post.date}</span>
        <span>·</span>
        <span>{post.readTime} {t.readTime}</span>
      </div>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-16 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-16">

      <!-- Articolo -->
      <article class="lg:col-span-8 space-y-8">

        <!-- Corpo (slot) -->
        <slot />

        <!-- FAQ -->
        {faq.length > 0 && (
          <div>
            <h2 class="font-serif text-3xl font-bold text-slate-900 mb-8">{t.faqTitle}</h2>
            <div class="space-y-4">
              {faq.map((item) => (
                <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm overflow-hidden">
                  <details class="group">
                    <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer list-none">
                      <span class="font-bold text-slate-900">{item.q}</span>
                      <svg class="w-5 h-5 text-med-gold flex-shrink-0 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                    </summary>
                    <div class="px-6 pb-6 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                      {item.a}
                    </div>
                  </details>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Author -->
        <div class="flex items-center gap-5 pt-8 border-t border-slate-100">
          <div class="w-14 h-14 rounded-full bg-med-gold/15 flex items-center justify-center flex-shrink-0">
            <span class="text-med-gold font-serif font-bold text-xl">AC</span>
          </div>
          <div>
            <p class="text-xs text-slate-400 uppercase tracking-wider mb-1">{t.writtenBy}</p>
            <p class="font-bold text-slate-900">{author}</p>
            <p class="text-slate-500 text-sm">{resolvedAuthorRole}</p>
          </div>
        </div>

        <!-- Related Articles -->
        {relatedArticles && relatedArticles.length > 0 && (
          <div class="pt-12 border-t border-slate-100">
            <h2 class="font-serif text-3xl font-bold text-slate-900 mb-8">{t.relatedArticles}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {relatedArticles.slice(0, 2).map((article) => (
                <a href={article.path} class="group bg-white rounded-[2rem] border border-slate-100 shadow-sm overflow-hidden hover:shadow-lg transition-shadow">
                  <div class="overflow-hidden h-48 bg-slate-200">
                    <img
                      src={article.image}
                      alt={article.imageAlt}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                  <div class="p-6">
                    <p class="text-med-gold text-sm font-medium uppercase tracking-wide mb-3">{article.category} · {article.date}</p>
                    <h3 class="font-serif text-xl font-bold text-slate-900 group-hover:text-med-gold transition-colors">{article.title}</h3>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Back link -->
        <div class="pt-8">
          <a href={blogBase[lang]} class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-slate-900 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            {t.backBlog}
          </a>
        </div>

      </article>

      <!-- Sidebar -->
      <aside class="lg:col-span-4">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 text-med-gold">{t.quickInfoTitle}</h3>
          <div class="space-y-5">
            {quickInfo.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          {sidebarLinks.length > 0 && (
            <div class="mt-10 pt-8 border-t border-white/10">
              <h4 class="text-med-gold font-serif font-bold text-lg mb-4">{t.readAlso}</h4>
              <div class="space-y-3">
                {sidebarLinks.map(link => (
                  <a href={link.href} class="flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
