---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyBar from '../components/StickyBar.astro';
import { getTranslations, getLocalePath, slugMap } from '../i18n/translations';
import type { Locale } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  lang: Locale;
  pageKey?: string;
  breadcrumbs?: { name: string; url: string }[];
  schema?: object[];
}

const { title, description, lang, pageKey, breadcrumbs, schema } = Astro.props;
const t = getTranslations(lang);
const site = 'https://amalficoast-travel.com';

const locales: Locale[] = ['en-us', 'en-gb', 'de-de', 'fr-fr', 'es-es', 'it-it'];
const hreflangs = locales.map((l) => {
  const path = pageKey ? getLocalePath(l, pageKey) : `/${l}/`;
  return { locale: l, url: `${site}${path}` };
});

const schemaLocaleMap: Record<Locale, string> = {
  'en-us': 'en-US', 'en-gb': 'en-GB', 'de-de': 'de-DE',
  'fr-fr': 'fr-FR', 'es-es': 'es-ES', 'it-it': 'it-IT',
};
const htmlLang = schemaLocaleMap[lang];
const canonicalUrl = `${site}${Astro.url.pathname}`;

// Base website schema
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Amalfi Coast Travel Guide",
  "url": site,
  "description": "Guida turistica alla Costiera Amalfitana, Penisola Sorrentina e Isole del Golfo di Napoli.",
  "inLanguage": htmlLang,
};

// Breadcrumb schema
const breadcrumbSchema = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": b.name,
    "item": `${site}${b.url}`
  }))
} : null;

const allSchemas = [websiteSchema, ...(schema || []), ...(breadcrumbSchema ? [breadcrumbSchema] : [])];
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    {hreflangs.map(({ locale, url }) => (
      <link rel="alternate" hreflang={schemaLocaleMap[locale as Locale]} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${site}/en-us/`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Amalfi Coast Travel Guide" />
    <meta property="og:locale" content={htmlLang} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Schema.org JSON-LD -->
    {allSchemas.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C9MBPN3GKX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-C9MBPN3GKX');
    </script>

    <!-- Iubenda Cookie Consent -->
    <script type="text/javascript" define:vars={{ iubLang: lang.split('-')[0] }}>
      var _iub = _iub || [];
      _iub.csConfiguration = {"siteId":4492263,"cookiePolicyId":63076172,"lang": iubLang,"storage":{"useSiteId":true}};
    </script>
    <script type="text/javascript" src="https://cs.iubenda.com/autoblocking/4492263.js"></script>
    <script type="text/javascript" src="//cdn.iubenda.com/cs/gpp/stub.js"></script>
    <script type="text/javascript" src="//cdn.iubenda.com/cs/iubenda_cs.js" charset="UTF-8" async></script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-med-cream text-charcoal font-sans antialiased">
    <Header lang={lang} pageKey={pageKey} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    {lang === 'it-it' && <StickyBar />}
  </body>
</html>
