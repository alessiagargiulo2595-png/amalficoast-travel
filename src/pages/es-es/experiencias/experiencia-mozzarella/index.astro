---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiencias } from '../../../../data/experiences-es';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Experiencias', url: '/es-es/experiencias/' },
  { name: 'Experiencia Mozzarella', url: '/es-es/experiencias/experiencia-mozzarella/' },
];

const facts = [
  { label: 'Duración', value: '3–4 horas' },
  { label: 'Zona', value: 'Península Sorrentina' },
  { label: 'Idioma', value: 'Italiano, Inglés' },
  { label: 'Incluido', value: 'Degustación, delantal, recetas' },
  { label: 'Precio orientativo', value: 'desde €65 por persona' },
  { label: 'Ideal para', value: 'Parejas, familias, amantes de la cocina' },
];

const otherExperiences = experiencias.filter(e => e.id !== 'experiencia-mozzarella');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Experiencia Mozzarella: El Arte del Quesero",
  "description": "Una experiencia quesera auténtica en la Península Sorrentina. Aprende a hacer mozzarella y descubre el legendario Provolone del Monaco DOP.",
  "location": {
    "@type": "Place",
    "name": "Península Sorrentina",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Experiencia Mozzarella Península Sorrentina 2026 | Arte del Quesero"
  description="Aprende a hacer mozzarella y descubre el Provolone del Monaco DOP con un maestro quesero en la Península Sorrentina."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/mozzarella-provolone-hero.jpg"
      alt="Provolone del Monaco DOP, Península Sorrentina"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Gastronomía · Península Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Experiencia Mozzarella</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Desde la cuajada elástica al tesoro curado de los Montes Lattari.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">El Arte del Quesero</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            En la Península Sorrentina, el arte quesero es una vocación transmitida durante siglos. Participar en esta experiencia no significa solo degustar, sino tocar con las manos la materia prima que nace de los pastos inmaculados de los Montes Lattari. Desde la frescura inmediata de la mozzarella hasta la complejidad del Provolone del Monaco, revelaremos los secretos de la excelencia láctea campana.
          </p>
        </div>

        <!-- Imagen editorial -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/mozzarella-cagliata.jpg"
            alt="Cuajada fresca trabajada por el maestro quesero"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Provolone del Monaco DOP: La Historia de un Nombre Legendario</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Si la mozzarella es la "reina", el Provolone del Monaco es sin duda el "rey" indiscutible de nuestras montañas. ¿Pero por qué este nombre tan peculiar?
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La historia se remonta al siglo XVIII, cuando los pastores que vivían en los Montes Lattari bajaban al amanecer hacia el puerto de Nápoles para vender sus productos. Para protegerse de la humedad y el frío de la noche durante el largo trayecto marítimo, los queseros se envolvían en pesados mantos de tela de saco oscura, similares al hábito de un monje. Al llegar al mercado de Nápoles, la gente comenzó a llamarlos familiarmente "los monjes" y, en consecuencia, el exquisito queso que llevaban consigo pasó a ser conocido por todos como Provolone del Monaco.
          </p>

          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-4">Un Pliego de Condiciones Riguroso</h3>
          <p class="text-slate-600 text-lg leading-relaxed">
            Hoy este queso está protegido por la denominación DOP. Se elabora exclusivamente con leche de vaca, de la cual al menos el 20% debe provenir de la raza Agerolese, una raza valiosa y rara que confiere al queso un sabor único: dulce y mantecoso al principio, pero con un retrogusto picante y aromático que se intensifica con la maduración (que debe durar al menos 6 meses).
          </p>
        </div>

        <!-- Programa -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Qué se hace durante una experiencia mozzarella</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Hilado en Directo</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Observaréis al maestro quesero transformar la leche en trenzas y bocados ante vuestros ojos.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Manos a la Obra</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Tendréis la oportunidad de "mozzare" (cortar y dar forma) mozzarella fresca con vuestras propias manos, sintiendo el calor y la textura de la cuajada elástica.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Cata Vertical de Maduraciones</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Una cata guiada que parte del fior di latte más fresco y llega al Provolone del Monaco DOP, acompañado de miel local y nueces de Sorrento.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Consejo local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Consejo Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Al degustar el Provolone del Monaco, buscad los pequeños agujeros (occhiature): deben ser del tamaño de un grano de pimienta. Pero el verdadero secreto está en el maridaje: probadlo con una copa de <strong>Gragnano espumoso bien frío</strong>. Las burbujas limpian el paladar de la untuosidad del queso, realzando la nota picante de la Agerolese.
          </p>
        </div>

      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Datos Rápidos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/experiencias/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las experiencias
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Otras Experiencias -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Otras Experiencias</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
