---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiencias } from '../../../../data/experiences-es';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Experiencias', url: '/es-es/experiencias/' },
  { name: 'Clase de Cocina', url: '/es-es/experiencias/clase-cocina/' },
];

const facts = [
  { label: 'Duración', value: '4–5 horas' },
  { label: 'Zona', value: 'Península Sorrentina · Costa Amalfitana' },
  { label: 'Idioma', value: 'Italiano, Inglés' },
  { label: 'Incluido', value: 'Visita al mercado, clase, comida, recetas' },
  { label: 'Precio orientativo', value: 'desde €75 por persona' },
  { label: 'Ideal para', value: 'Parejas, grupos, amantes de la gastronomía' },
];

const otherExperiences = experiencias.filter(e => e.id !== 'clase-cocina');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Clase de Cocina: Los Secretos de la Cocina Costera",
  "description": "Masterclass de cocina campana en la Península Sorrentina y Costa Amalfitana. Ravioli alla Caprese, Gnocchi alla Sorrentina, Delizia al Limone y mucho más.",
  "location": {
    "@type": "Place",
    "name": "Península Sorrentina y Costa Amalfitana",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Clase de Cocina Costa Amalfitana 2026 | Cocina Campana Auténtica"
  description="Clases de cocina en la Península Sorrentina y Costa Amalfitana: Ravioli alla Caprese, Totani e Patate, Delizia al Limone. Del mercado a los fogones."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cooking-class-hero.jpg"
      alt="Clase de cocina, salsa de tomate campana - Península Sorrentina"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Gastronomía · Península Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Clase de Cocina</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Los Secretos de la Cocina Costera.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Una inmersión en la cultura mediterránea</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Las clases de cocina en la Península Sorrentina y la Costa Amalfitana no son simples cursos, sino verdaderas inmersiones en la cultura mediterránea. Muchas de estas experiencias comienzan mucho antes de encender los fogones: el ritual empieza entre los puestos de los mercados locales o en los huertos en terrazas que se asoman al mar, donde se aprende a elegir el tomate perfecto y a reconocer el aroma de la albahaca "napolitana" de hoja ancha.
          </p>
        </div>

        <!-- El Menú de la Tradición -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">El Menú de la Tradición: Los Pilares del Sabor</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Durante estas masterclasses, los participantes tienen la oportunidad de preparar recetas que representan el alma de Campania.
          </p>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Entrante — Impepata di Cozze</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un clásico intemporal que celebra la frescura del mar. Pocos ingredientes — mejillones, pimienta negra, perejil y limón de Sorrento — para un resultado que encierra todo el sabor del Golfo.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Primer Plato — Ravioli alla Caprese</h4>
                <p class="text-slate-600 text-sm leading-relaxed">El símbolo del domingo. Una pasta fresca preparada con una masa sencilla (agua y harina), rellena con la típica caciotta sorrentina y una pizca de mejorana fresca, servida con una salsa de tomate ligera.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Segundo Plato — Totani e Patate alla Praianese</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un plato típico de los pescadores de la Costiera. La dulzura del calamar se fusiona con la cremosidad de las patatas locales, todo desglasado con vino blanco y perfumado con ajo y guindilla.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">4</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Postre — Delizia al Limone</h4>
                <p class="text-slate-600 text-sm leading-relaxed">La reina de la pastelería local. Un suave bizcocho en cúpula, relleno y cubierto de una crema sedosa perfumada con el sfusato amalfitano o el limón de Sorrento IGP.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Imagen editorial -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/cooking-class-pasta.jpg"
            alt="Preparación de pasta fresca durante una clase de cocina en la Costa Amalfitana"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <!-- El Arte de Hacer -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">El Arte de Hacer</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            El objetivo de estas masterclasses es desvelar los secretos de la dieta mediterránea. A menudo se comienza con la preparación de pasta fresca: aprender a dosificar agua y harina para crear los icónicos Ravioli alla Caprese o los Gnocchi alla Sorrentina, que requieren una técnica especial — ¡y dedos rápidos! — para conseguir la consistencia porosa adecuada que absorba el tomate y el fior di latte hilante de la zona. Nunca faltan los secretos de la pastelería local, donde la precisión se une a la fragancia de los cítricos recogidos al amanecer.
          </p>
        </div>

        <!-- Consejo local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Consejo Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Para una experiencia auténtica, elegid las clases que se celebran en antiguas masías o directamente en los huertos cítricos, a la sombra de las "pagliarelle".
          </p>
          <p class="text-slate-600 leading-relaxed">
            ¿Un secreto de los locales para los ñoquis perfectos? Usad siempre patatas viejas: contienen menos agua y por tanto necesitan menos harina al amasar. ¿El resultado? Un ñoqui increíblemente ligero que literalmente se deshace en la boca.
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Datos Rápidos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/es-es/experiencias/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Todas las experiencias
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Otras Experiencias -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Otras Experiencias</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
