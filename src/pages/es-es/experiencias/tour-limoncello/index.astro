---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiencias } from '../../../../data/experiences-es';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Experiencias', url: '/es-es/experiencias/' },
  { name: 'Tour del Limoncello', url: '/es-es/experiencias/tour-limoncello/' },
];

const facts = [
  { label: 'Duración', value: '2–3 horas' },
  { label: 'Zona', value: 'Península Sorrentina' },
  { label: 'Idioma', value: 'Italiano, Inglés' },
  { label: 'Incluido', value: 'Visita al huerto, taller, degustación' },
  { label: 'Precio orientativo', value: 'desde €55 por persona' },
  { label: 'Ideal para', value: 'Parejas, familias, amantes de la gastronomía' },
];

const otherExperiences = experiencias.filter(e => e.id !== 'tour-limoncello');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Tour del Limoncello: El Licor Dorado y la Leyenda del Femminiello",
  "description": "Un viaje sensorial a través de los aromas del Limón de Sorrento IGP. Visita a un huerto cítrico histórico, taller de infusión y degustación de Limoncello artesano.",
  "location": {
    "@type": "Place",
    "name": "Península Sorrentina",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Tour del Limoncello Sorrento 2026 | Femminiello IGP y Huerto Histórico"
  description="Visita un huerto cítrico histórico en la Península Sorrentina, descubre el secreto del Limón Femminiello IGP y aprende a hacer Limoncello artesano. Degustación incluida."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/limoncello-mercato-hero.jpg"
      alt="Limones Femminiello IGP en el mercado, Península Sorrentina"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Gastronomía · Península Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Tour del Limoncello</h1>
      <p class="text-lg md:text-xl font-light text-white/80">El Licor Dorado y la Leyenda del Femminiello de Sorrento IGP.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Un viaje a través de los aromas del Limón IGP</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Caminar por un huerto cítrico sorrentino no es solo una excursión agrícola — es una inmersión en un ecosistema protegido donde el tiempo parece haberse detenido. Aquí reina el Femminiello, la variedad de limón que ha hecho famosa a Sorrento en todo el mundo y que hoy ostenta la prestigiosa marca IGP (Indicación Geográfica Protegida).
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">La Historia y el Nombre: Un Legado Milenario</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            El nombre "Femminiello" proviene de la extraordinaria fertilidad de esta planta, que florece varias veces al año produciendo frutos con una constancia casi "maternal". Sus raíces se remontan a la época romana — incluso se han encontrado frescos que la representan en las excavaciones de Pompeya — pero fue gracias a los monjes jesuitas en el siglo XVII cuando su cultivo se extendió ampliamente.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Este limón es único por dos razones fundamentales:
          </p>

          <div class="space-y-6">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">Los Emparrados</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Las plantas crecen bajo las típicas "pagliarelle" (celosías de paja) que protegen los frutos del frío y el viento, retrasando la maduración y permitiendo tener limones frescos durante todo el año.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">El Suelo Volcánico</h4>
              <p class="text-slate-600 text-sm leading-relaxed">El fértil suelo de la península, rico en minerales procedentes de las antiguas erupciones del Vesubio, confiere al Femminiello un sabor ácido pero equilibrado y una piel extraordinariamente rica en aceites esenciales.</p>
            </div>
          </div>
        </div>

        <!-- Imagen editorial -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/limoncello-femminiello.jpg"
            alt="Limones Femminiello IGP recolectados a mano en la Península Sorrentina"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">¿Qué hace especial al Femminiello?</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            A diferencia del Sfusato Amalfitano — su "primo" de la Costa Amalfitana, más alargado y grande — el Femminiello de Sorrento tiene forma elíptica y tamaño mediano. Su verdadera magia reside en la piel: gruesa, intensamente perfumada y rica en terpenos. Es precisamente esta capa amarilla, la "ralladura", la que — infundida en alcohol puro — libera el inconfundible aroma del verdadero Limoncello.
          </p>
        </div>

        <!-- Programa -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Qué se hace durante un Tour del Limoncello</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Paseo guiado bajo los emparrados</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un recorrido bajo las históricas celosías de paja con el guía contando la historia de las antiguas familias de cultivadores de limón y los secretos del cultivo IGP.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Visita al taller de infusión</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Descubriréis cada fase de la producción artesanal: desde la selección y el rallado de las pieles hasta la infusión en alcohol puro, pasando por la mezcla con el almíbar de azúcar.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Degustación</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un sorbo de Limoncello helado, mermelada de limón sobre pan tostado y la famosa cáscara confitada recubierta de chocolate negro.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Consejo local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Consejo Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Prestad atención al color de la piel durante el tour. El Femminiello perfecto debe tener un brillante amarillo citrino. Si frotáis ligeramente la piel con el pulgar y el aroma permanece en vuestros dedos durante horas, habéis encontrado el oro de Sorrento. ¿Otro secreto? ¡Los auténticos sorrentinos también comen la parte blanca (el albedo): es dulce, esponjosa y muy rica en vitaminas!
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Datos Rápidos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/es-es/experiencias/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Todas las experiencias
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Otras Experiencias -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Otras Experiencias</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
