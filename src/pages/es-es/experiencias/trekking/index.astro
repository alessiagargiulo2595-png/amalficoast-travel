---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Experiencias', url: '/es-es/experiencias/' },
  { name: 'Trekking & Sendero de los Dioses', url: '/es-es/experiencias/trekking/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué dificultad tiene el Sendero de los Dioses?",
      "acceptedAnswer": { "@type": "Answer", "text": "El Sendero de los Dioses (de Agerola a Nocelle) está clasificado EE (excursionistas expertos): 8 km, ~500 m de desnivel, 3-4 horas. Requiere botas de senderismo, buena forma física y no tener vértigo. No apto para niños pequeños ni personas con problemas de movilidad." }
    },
    {
      "@type": "Question",
      "name": "¿Cómo llegar al Sendero de los Dioses?",
      "acceptedAnswer": { "@type": "Answer", "text": "Punto de partida: Agerola (fracción San Lazzaro, 618 m s.n.m.). Desde Amalfi: autobús SITA a Agerola (~45 min, conexiones limitadas). Desde Nápoles o Salerno: tren/autobús hasta Amalfi, luego autobús a Agerola. Se recomienda salida matutina (9:00-10:00)." }
    },
    {
      "@type": "Question",
      "name": "¿Se puede hacer el Sendero de los Dioses en sentido inverso?",
      "acceptedAnswer": { "@type": "Answer", "text": "Técnicamente sí, pero no recomendado: el sentido Agerola→Nocelle es casi todo bajada y más seguro. El inverso (Nocelle→Agerola) supone 500 m de subida empinada por terreno inestable. La señalización CAI está diseñada para el sentido tradicional." }
    }
  ]
};

const trails = [
  { name: 'Sendero de los Dioses', difficulty: 'EE', km: '8 km', time: '3-4h', start: 'Agerola (S. Lazzaro)', end: 'Nocelle (Positano)', highlights: 'Vistas costeras espectaculares, flora mediterránea, sin asfalto' },
  { name: 'Valle delle Ferriere', difficulty: 'E', km: '7 km ida/vuelta', time: '2,5-3h', start: 'Centro de Amalfi', end: 'Amalfi (regreso)', highlights: 'Cascadas, helechos tropicales, papiros silvestres, sombra natural' },
  { name: "Via dell'Infinito (Ravello)", difficulty: 'E', km: '5 km ida/vuelta', time: '2h', start: 'Ravello', end: 'Ravello', highlights: 'Vista panorámica de la costa, olivares, silencio total' },
  { name: 'Punta Campanella', difficulty: 'E', km: '6 km ida/vuelta', time: '2,5h', start: 'Termini (Massa Lubrense)', end: 'Termini', highlights: 'Punta más meridional, ruinas romanas, vistas de Capri, reserva marina' },
  { name: 'Monte Solaro (Capri)', difficulty: 'E', km: '4 km', time: '2h (subida)', start: 'Anacapri', end: 'Anacapri (teleférico vuelta)', highlights: '589 m, panorama 360°, santuario, silencio' },
];
---

<BaseLayout
  title="Trekking Costa Amalfitana 2026 | Sendero de los Dioses y Rutas"
  description="Las mejores rutas de senderismo en la Costa Amalfitana: Sendero de los Dioses (Agerola-Nocelle), Valle delle Ferriere, Punta Campanella. Dificultad, tiempos y cómo llegar."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/trekking-hero.jpg" alt="Sendero de los Dioses, Costa Amalfitana" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/80"></div>
    <div class="relative z-10 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white/60">Experiencias</span>
        <span>/</span>
        <span class="text-white">Trekking</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Experiencias</p>
        <h1 class="font-serif text-display text-white mb-4">Trekking & Sendero de los Dioses</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La Costa Amalfitana no es solo playas y ferries: es también uno de los paisajes más espectaculares de Europa para recorrer a pie. Del legendario Sendero de los Dioses a las cascadas del Valle delle Ferriere.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Las 5 rutas imprescindibles</h2>
      <div class="space-y-4">
        {trails.map(t => (
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6 hover:border-med-blue/30 transition-colors">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-semibold text-charcoal text-lg">{t.name}</h3>
              <span class={`text-[10px] uppercase tracking-wide px-2 py-1 rounded-full font-medium flex-shrink-0 ${t.difficulty === 'EE' ? 'bg-red-50 text-red-600' : 'bg-med-blue/5 text-med-blue'}`}>
                {t.difficulty === 'EE' ? 'EE - Exigente' : 'E - Fácil'}
              </span>
            </div>
            <div class="grid sm:grid-cols-4 gap-3 text-sm mb-3">
              <div><span class="text-slate-400">Distancia</span><br /><span class="font-medium">{t.km}</span></div>
              <div><span class="text-slate-400">Tiempo</span><br /><span class="font-medium">{t.time}</span></div>
              <div><span class="text-slate-400">Inicio</span><br /><span class="font-medium">{t.start}</span></div>
              <div><span class="text-slate-400">Final</span><br /><span class="font-medium">{t.end}</span></div>
            </div>
            <p class="text-sm text-med-blue font-medium">{t.highlights}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Sendero de los Dioses - Guía Rápida</p>
      <div class="grid sm:grid-cols-2 gap-6">
        <div><p class="text-white/60 text-sm mb-1">Cómo llegar al inicio</p><p class="text-sm leading-relaxed">Desde Amalfi: autobús SITA a Agerola (conexiones limitadas, ~45 min). Recomendado: salir de Amalfi a las 8:30 para coger el autobús de las 9:15 a Agerola.</p></div>
        <div><p class="text-white/60 text-sm mb-1">Regreso desde el final</p><p class="text-sm leading-relaxed">Desde Nocelle: autobús local al centro de Positano (~15 min) o bajada a pie (~1.000 escalones, 45 min). Desde Positano: autobús SITA o ferry a Amalfi/Sorrento/Nápoles.</p></div>
        <div><p class="text-white/60 text-sm mb-1">Qué llevar</p><p class="text-sm leading-relaxed">Botas de senderismo (no sandalias), 1,5L de agua, sombrero, crema solar, snacks, chaqueta ligera. El sendero no tiene puntos de agua ni tiendas.</p></div>
        <div><p class="text-white/60 text-sm mb-1">Mejor temporada</p><p class="text-sm leading-relaxed">Abril-junio y septiembre-octubre. En julio y agosto el calor lo hace agotador y masificado. En invierno posible pero con barro y terreno resbaladizo.</p></div>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>
  </div>

  <CorrelationSlider
    heading="Explorar destinos de senderismo"
    items={[
      { name: 'Positano',       href: '/es-es/costa-amalfitana/positano/',             tag: 'Final del sendero', desc: 'El colorido pueblo donde termina el Sendero de los Dioses.' },
      { name: 'Amalfi',         href: '/es-es/costa-amalfitana/amalfi/',               tag: 'Inicio Valle',      desc: 'Punto de partida del Valle delle Ferriere.' },
      { name: 'Massa Lubrense', href: '/es-es/peninsula-sorrentina/massa-lubrense/',   tag: 'Punta Campanella',  desc: 'Reserva marina con la ruta a Punta Campanella.' },
      { name: 'Capri',          href: '/es-es/islas/capri/',                            tag: 'Monte Solaro',      desc: 'Teleférico o trekking hasta los 589 m de la cima.' },
    ]}
  />

</BaseLayout>
