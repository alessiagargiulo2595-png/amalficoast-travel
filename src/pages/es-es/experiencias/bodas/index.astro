---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiencias } from '../../../../data/experiences-es';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Experiencias', url: '/es-es/experiencias/' },
  { name: 'Bodas', url: '/es-es/experiencias/bodas/' },
];

const facts = [
  { label: 'Tipo', value: 'Rito civil o religioso' },
  { label: 'Zona', value: 'Península Sorrentina · Costa Amalfitana' },
  { label: 'Idioma', value: 'Italiano, Inglés, otros bajo petición' },
  { label: 'Mejor temporada', value: 'Abril – Octubre' },
  { label: 'Ideal para', value: 'Destination Wedding, parejas internacionales' },
  { label: 'Organización', value: 'Wedding planner local recomendado' },
];

const otherExperiences = experiencias.filter(e => e.id !== 'bodas');

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Bodas en la Costa Amalfitana y Península Sorrentina",
  "description": "Guía de los lugares más bellos para casarse en la Costa Amalfitana y Península Sorrentina: claustros medievales, iglesias a pico sobre el mar y villas históricas para una Destination Wedding inolvidable.",
  "areaServed": {
    "@type": "Place",
    "name": "Costa Amalfitana y Península Sorrentina",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "provider": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Bodas Costa Amalfitana 2026 | Lugares, Iglesias y Destination Wedding"
  description="Casarse en la Costa Amalfitana y Península Sorrentina: los lugares más bellos para ritos civiles y religiosos, desde el Claustro de San Francisco hasta iglesias a pico sobre el mar."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaService]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/matrimoni-chiostro-hero.jpg"
      alt="Claustro de San Francisco, Sorrento - lugar para bodas civiles"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Wedding · Costa Amalfitana</p>
      <h1 class="font-serif text-display text-white mb-6">Bodas</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Promesas Suspendidas entre Roca y Sal.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">La capital mundial del Destination Wedding</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            No es casualidad que Sorrento y la Costa Amalfitana sean uno de los destinos más codiciados del mundo para las bodas de destino. Aquí la belleza no es solo un detalle, sino una cómplice silenciosa: se encuentra en la luz dorada que acaricia los pueblos al atardecer, en la arquitectura de iglesias milenarias y en el embriagador perfume de las flores de azahar que invade el aire en primavera. Casarse en estos lugares significa inscribir la propia historia de amor en un marco legendario, donde cada rincón parece pintado expresamente para un álbum fotográfico inolvidable.
          </p>
        </div>

        <!-- Rito civil -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">El Encanto del Rito Civil: Historia y Naturaleza</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Más allá de las celebraciones religiosas, el territorio ofrece sedes municipales de una belleza sobrecogedora para los ritos civiles, permitiendo pronunciar el "Sí" oficial en contextos que fusionan historia y naturaleza. Muchas administraciones locales han abierto las puertas de villas históricas y jardines botánicos, transformando la burocracia en un momento de pura poesía.
          </p>

          <div class="space-y-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">El Claustro de San Francisco — Sorrento</h3>
              <p class="text-slate-600 leading-relaxed mb-4">
                Sin duda el lugar más icónico para un rito civil en la Península Sorrentina. Este claustro del siglo XIV es una joya arquitectónica donde diferentes estilos — del gótico tardío al renacentista — se fusionan en un abrazo de arcos entrelazados y columnas de toba. La atmósfera es recogida, casi mística, animada por plantas trepadoras y flores que decoran las paredes medievales.
              </p>
              <p class="text-slate-600 leading-relaxed">
                A pocos pasos del claustro, la Villa Comunale ofrece una terraza natural con una vista impresionante sobre Capri, perfecta para las primeras fotos como recién casados justo después de la ceremonia.
              </p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">Terrazas y Museos</h3>
              <p class="text-slate-600 leading-relaxed">
                Además del Claustro, Sorrento ofrece lugares como el Museo Correale di Terranova o la Villa Fondi en Piano di Sorrento, donde los jardines a pico sobre el mar y los hallazgos arqueológicos son testigos de una promesa eterna.
              </p>
            </div>
          </div>
        </div>

        <!-- Iglesias monumentales -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Iglesias Monumentales: Altares entre Cielo y Mar</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Para quienes sueñan con una ceremonia religiosa, la Costiera alberga algunos de los lugares de culto más sugestivos del mundo, donde la fe se encuentra con el vértigo de la costa.
          </p>

          <div class="rounded-[2rem] overflow-hidden shadow-xl mb-6">
            <img
              src="/images/chiesa-annunziata-vico.webp"
              alt="Iglesia de la Santísima Anunciación en Vico Equense, a pico sobre el Golfo de Nápoles con el Vesubio al fondo"
              class="w-full h-72 object-cover"
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          </div>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Iglesia de la Santísima Anunciación — Vico Equense</h4>
                <p class="text-slate-600 text-sm leading-relaxed">A menudo llamada "la iglesia más bella de Italia", es una joya gótica de fachada rosa encaramada en un promontorio a pico sobre el mar. Celebrar aquí significa intercambiar promesas con la vista abarcando todo el Golfo de Nápoles y el Vesubio en el horizonte. Es la única iglesia del mundo que parece literalmente suspendida sobre las olas.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">La Catedral de Amalfi — Sant'Andrea</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Para quienes desean una entrada triunfal. Su imponente escalinata y el estilo árabe-normando ofrecen una majestuosidad atemporal en el corazón de la Costiera.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Santa Maria Assunta — Positano</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Célebre por su cúpula de mayólica amarilla y verde que brilla bajo el sol, a pocos pasos de la playa grande. Perfecta para una boda glamurosa e icónica que huele a Dolce Vita.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Experiencias y recepciones -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Experiencias y Recepciones</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Desde las históricas mansiones de Ravello — como la Villa Cimbrone con su Terrazza dell'Infinito — hasta calas ocultas accesibles solo en barco para una fiesta exclusiva a orillas del mar, las posibilidades son infinitas. Muchas parejas eligen recibir a sus invitados con un típico aperitivo sorrentino entre los limoneros, convirtiendo la boda en un fin de semana de descubrimiento gastronómico y descanso.
          </p>
        </div>

        <!-- Consejo local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Consejo Local para los Novios</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Si elegís la Santísima Anunciación en Vico Equense, programad la salida de la iglesia al atardecer: la luz que golpea la fachada rosa crea un reflejo mágico, perfecto para fotos sin filtros. Para el Claustro de San Francisco, tened en cuenta que la acústica es extraordinaria: un arpa o un cuarteto de cuerdas convertirán la ceremonia civil en una experiencia de película.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Un consejo práctico para las novias: las callejuelas de la Costiera son bellísimas pero peligrosas para los tacones de aguja. Llevad unos "luxury flat" o cuñas joya para desplazaros entre los callejones, y reservad los tacones altos para el momento del banquete.
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Datos Rápidos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/es-es/experiencias/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Todas las experiencias
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Otras Experiencias -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Otras Experiencias</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
