---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiencias } from '../../../../data/experiences-es';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Experiencias', url: '/es-es/experiencias/' },
  { name: 'Restaurantes con Estrella', url: '/es-es/experiencias/restaurantes-estrella/' },
];

const facts = [
  { label: 'Guía', value: 'Michelin 2026' },
  { label: 'Zona', value: 'Península Sorrentina · Costa Amalfitana' },
  { label: 'Dirección estrella', value: 'Quattro Passi - 3 Estrellas Michelin' },
  { label: 'Reserva', value: '3–4 meses de antelación (fines de semana)' },
  { label: 'Ideal para', value: 'Foodies, ocasiones especiales, aniversarios' },
  { label: 'Imprescindible', value: 'Visita a la bodega excavada en la roca' },
];

const otherExperiences = experiencias.filter(e => e.id !== 'restaurantes-estrella');

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Restaurantes Michelin 2026 - Sorrento y Costa Amalfitana",
  "description": "El ranking 2026 de los mejores restaurantes con estrella Michelin entre la Península Sorrentina y la Costa Amalfitana: Quattro Passi, Il Buco, Don Alfonso 1890 y más.",
  "url": "https://amalficoast-travel.com/es-es/experiencias/restaurantes-estrella/",
  "numberOfItems": 8,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Quattro Passi - Nerano (3 Estrellas Michelin)" },
    { "@type": "ListItem", "position": 2, "name": "Il Buco - Sorrento" },
    { "@type": "ListItem", "position": 3, "name": "Lorelei - Sorrento" },
    { "@type": "ListItem", "position": 4, "name": "Terrazza Bosquet - Sorrento" },
    { "@type": "ListItem", "position": 5, "name": "Don Alfonso 1890 - Sant'Agata sui Due Golfi" },
    { "@type": "ListItem", "position": 6, "name": "La Caravella - Amalfi" },
    { "@type": "ListItem", "position": 7, "name": "Glicine - Positano" },
    { "@type": "ListItem", "position": 8, "name": "Zass e Li Galli - Positano" },
  ],
};
---

<BaseLayout
  title="Restaurantes con Estrella Costa Amalfitana 2026 | Guía Michelin"
  description="Guía de los mejores restaurantes con estrella Michelin 2026 entre Sorrento y la Costa Amalfitana: Quattro Passi (3 estrellas), Il Buco, Don Alfonso 1890 y las joyas de Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/stellati-hero.jpg"
      alt="Plato de alta cocina en un restaurante con estrella Michelin, Costa Amalfitana"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Alta Cocina · Costa Amalfitana</p>
      <h1 class="font-serif text-display text-white mb-6">Restaurantes con Estrella</h1>
      <p class="text-lg md:text-xl font-light text-white/80">El Firmamento del Sabor 2026.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Una peregrinación al corazón de la excelencia gastronómica</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Si existe una tierra donde la alta cocina está en casa, esa es la región que abraza Sorrento y la Costa Amalfitana. En 2026, la Guía Michelin confirma este territorio como el más luminoso de Italia: Campania no solo está en la cima por el número total de estrellas, sino que ostenta un récord único por densidad gastronómica.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Basta pensar que, a pesar de ser una de las regiones más pequeñas por extensión, Campania alberga aproximadamente el <strong>12% de los restaurantes con estrella de toda la Península Italiana</strong>, superando en concentración por kilómetro cuadrado a gigantes del sabor como el Piamonte y la Lombardía. En este pequeño trozo de tierra suspendido sobre el mar, la excelencia culinaria no es una excepción sino una verdadera vocación territorial.
          </p>
        </div>

        <!-- El Ranking 2026 -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">El Ranking 2026: Los Protagonistas</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            El panorama gastronómico de 2026 ve reconfirmados los grandes nombres que han convertido esta zona en un destino de peregrinación para los foodies de todo el mundo.
          </p>

          <div class="space-y-6">

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Quattro Passi — Nerano, Massa Lubrense</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">El Vértice Absoluto</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                El legendario Quattro Passi en Nerano mantiene las prestigiosas 3 Estrellas Michelin, único restaurante de la región en alcanzar la cima mundial. Su cocina es un himno a la pureza de los sabores marinos reinterpretados con una técnica impecable.
              </p>
            </div>

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Las Estrellas de Sorrento</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Una ciudad, tres direcciones imprescindibles</span>
                </div>
              </div>
              <div class="space-y-4 mt-4">
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Il Buco</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Situado en una evocadora antigua rampa de monasterio, donde la historia del edificio dialoga con la cocina del territorio.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Lorelei</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Cocina de vanguardia en una terraza de ensueño: dos experiencias sensoriales en una.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Terrazza Bosquet</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Icónico templo del sabor dentro del Excelsior Vittoria: lujo, historia y alta cocina bajo el mismo techo.</p>
                </div>
              </div>
            </div>

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Iconos y Nuevos Descubrimientos</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">De Sant'Agata a Positano</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                No se puede decir que se ha vivido la Costa sin mencionar el <strong>Don Alfonso 1890</strong> en Sant'Agata sui Due Golfi, pionero de la sostenibilidad, o las joyas de Amalfi y Positano: <strong>La Caravella</strong>, <strong>Glicine</strong>, <strong>Zass</strong> y <strong>Li Galli</strong>.
              </p>
            </div>

          </div>
        </div>

        <!-- Más allá del plato -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Una Experiencia Más Allá del Plato</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Cenar en un restaurante con estrella entre Sorrento y Amalfi no es solo una cena, sino un viaje sensorial. Va desde la arquitectura de los platos hasta el cuidado obsesivo por los ingredientes de "kilómetro cero" procedentes de los huertos verticales que dominan la costa. Aquí el lujo se encuentra con la tierra: no es raro ver ingredientes humildes como las anchoas o el limón transformados en obras maestras de alta ingeniería gastronómica.
          </p>
        </div>

        <!-- Consejo local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Consejo Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Muchos de estos restaurantes de excelencia tienen bodegas históricas excavadas directamente en la roca caliza o en el tufo. Aunque no seáis sumilleres, pedid siempre visitarlas: son auténticos museos subterráneos que custodian añadas raras de "vinos heroicos" producidos en los viñedos en bancales de Furore y Tramonti.
          </p>
          <p class="text-slate-600 leading-relaxed">
            ¿Un secreto de los locales? Para los restaurantes más famosos de la Costa, las reservas de fin de semana deben hacerse con al menos <strong>3–4 meses de antelación</strong>: ¡el panorama está incluido, pero la mesa hay que ganársela!
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Datos Rápidos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/es-es/experiencias/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Todas las experiencias
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Otras Experiencias -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Otras Experiencias</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
