---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Península Sorrentina', url: '/es-es/peninsula-sorrentina/' },
  { name: 'Massa Lubrense', url: '/es-es/peninsula-sorrentina/massa-lubrense/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuál es la mejor playa de Massa Lubrense?",
      "acceptedAnswer": { "@type": "Answer", "text": "Marina del Cantone, en el pueblo de Nerano, es la más bella: guijarros claros, agua cristalina y una zona marina protegida. Perfecta para hacer snorkel." }
    },
    {
      "@type": "Question",
      "name": "¿Cómo llegar a Massa Lubrense desde Sorrento?",
      "acceptedAnswer": { "@type": "Answer", "text": "Autobús EAV desde Sorrento (~20-30 min, ~€1,50). En coche: SS145 desde Sorrento hacia Massa Lubrense." }
    },
    {
      "@type": "Question",
      "name": "¿Qué son los Espaguetis alla Nerano?",
      "acceptedAnswer": { "@type": "Answer", "text": "Espaguetis con calabacín frito, queso Provolone del Monaco, albahaca y pecorino. Inventados en los años 50 en Nerano, en la Trattoria da Maria Grazia." }
    }
  ]
};

const fastFacts = [
  { dt: 'Ubicación', dd: 'Punta de la Península Sorrentina' },
  { dt: 'Fracciones', dd: "Nerano, Termini, Sant'Agata" },
  { dt: 'Desde Sorrento', dd: '~20 min (autobús EAV)' },
  { dt: 'Especialidad', dd: 'Espaguetis alla Nerano' },
  { dt: 'Playa', dd: 'Marina del Cantone (guijarros)' },
  { dt: 'Reserva marina', dd: 'Punta Campanella' },
  { dt: 'Mejor época', dd: 'May-Oct' },
];
---

<BaseLayout
  title="Massa Lubrense 2026: Punta Campanella, Marina del Cantone y Nerano"
  description="Guía de Massa Lubrense: playa de Marina del Cantone, Espaguetis alla Nerano y la reserva marina de Punta Campanella. Qué ver y cómo llegar desde Sorrento."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/massa-lubrense-hero.jpg" alt="Massa Lubrense, Italia" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Península Sorrentina · Naturaleza & Gastronomía</p>
        <h1 class="font-serif text-display text-white mb-4">Massa Lubrense</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          El extremo más meridional de la península, frente a Capri. Reservas marinas, senderismo, la playa de Marina del Cantone y los Espaguetis alla Nerano: un paraíso para el turismo lento.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Massa Lubrense es un municipio de 15 fracciones dispersas entre olivares y limoneros en la ladera frente a Capri. Cada fracción tiene su carácter: Nerano para los gastrónomos, Sant'Agata sui Due Golfi para las mejores vistas de los dos golfos y Marina del Cantone para la mejor playa de la península.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabías que?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">15</p><p class="text-white/60 text-xs italic mt-1">fracciones en el municipio</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">4,9 km</p><p class="text-white/60 text-xs italic mt-1">de Punta Campanella a Capri</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">1997</p><p class="text-white/60 text-xs italic mt-1">fundación de la reserva marina</p></div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            La reserva marina de Punta Campanella fue una de las primeras establecidas en Italia. Hoy protege 1.172 hectáreas de fondo marino con praderas de posidonia, hábitat coralígeno y especies protegidas como la tortuga boba.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Qué ver en Massa Lubrense</h2>
          <div class="space-y-6">
            {[
              { title: 'Marina del Cantone', text: "La bahía de guijarros claros y el agua más cristalina de la península, protegida por la Reserva Marina de Punta Campanella. Perfecta para snorkel. Accesible en autobús desde Sorrento o en barco desde Capri." },
              { title: 'Espaguetis alla Nerano', text: "El plato más famoso de la zona: espaguetis con calabacín frito generosamente, Provolone del Monaco derretido, albahaca fresca y un toque de pecorino. Inventados en la Trattoria da Maria Grazia de Nerano en los años 50. Pruébalos en Conca del Sogno o en la propia Maria Grazia." },
              { title: 'Punta Campanella', text: "La punta rocosa con ruinas de un templo de Atenea y una torre angevina del siglo XIV. Se llega a pie desde Termini en 45 min. Vistas de Capri a 4,9 km. Una de las primeras áreas marinas protegidas de Italia." },
              { title: "Sant'Agata sui Due Golfi", text: 'El mirador más espectacular de la península: desde esta fracción se ven simultáneamente el Golfo de Nápoles al norte (con el Vesubio y Capri) y el Golfo de Salerno al sur (con la Costa Amalfitana). Acceso libre, hay aparcamiento.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos Rápidos - Massa Lubrense</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Península Sorrentina</p>
          <nav class="space-y-1">
            {[
              { href: '/es-es/peninsula-sorrentina/sorrento/', label: 'Sorrento' },
              { href: '/es-es/peninsula-sorrentina/vico-equense/', label: 'Vico Equense' },
              { href: '/es-es/peninsula-sorrentina/sant-agnello/', label: "Sant'Agnello" },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Explora también"
    items={[
      { name: 'Sorrento',     href: '/es-es/peninsula-sorrentina/sorrento/',  tag: 'Base ideal',    desc: 'Hub para Capri, Nápoles y la Costa. Limoncello y Piazza Tasso.' },
      { name: 'Capri',        href: '/es-es/islas/capri/',                     tag: 'Más icónica',   desc: '5 km desde Punta Campanella: Gruta Azul y Farallones.' },
      { name: 'Positano',     href: '/es-es/costa-amalfitana/positano/',       tag: 'Moda & Vistas', desc: 'Las coloridas casas sobre el acantilado de la Costa Amalfitana.' },
      { name: 'Praiano',      href: '/es-es/costa-amalfitana/praiano/',        tag: 'Puesta de sol', desc: 'El atardecer desde la iglesia de San Gennaro y Marina di Praia.' },
    ]}
  />

</BaseLayout>
