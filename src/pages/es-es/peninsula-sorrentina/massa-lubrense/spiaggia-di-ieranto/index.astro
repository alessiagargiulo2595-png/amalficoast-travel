---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Península de Sorrento', url: '/es-es/peninsula-sorrentina/' },
  { name: 'Spiaggia di Ieranto', url: '/es-es/peninsula-sorrentina/massa-lubrense/spiaggia-di-ieranto/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Spiaggia di Ieranto",
  "description": "La Bahía de Ieranto es una cala salvaje en la Península de Sorrento en Massa Lubrense, rodeada de acantilados y reserva marina. Uno de los lugares más vírgenes de la península, accesible solo a pie o en barco.",
  "url": "https://amalficoast-travel.com/es-es/peninsula-sorrentina/massa-lubrense/spiaggia-di-ieranto/",
  "image": "https://amalficoast-travel.com/images/ieranto-hero.jpg",
  "touristType": ["Naturaleza", "Senderismo", "Snorkel", "Fotografía"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Massa Lubrense",
    "addressRegion": "Nápoles",
    "addressCountry": "IT",
    "postalCode": "80061"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.5805,
    "longitude": 14.3795
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Spiaggia di Ieranto, Península de Sorrento",
  "description": "Cala salvaje de la Península de Sorrento en Massa Lubrense, parte del área marina protegida de Punta Campanella. Accesible solo por senderismo o barco.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.5805,
    "longitude": 14.3795
  },
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Península de Sorrento"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Dónde está Spiaggia di Ieranto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La Bahía de Ieranto se encuentra en Nerano, municipio de Massa Lubrense, en la Península de Sorrento. Se encuentra dentro del área marina protegida de Punta Campanella, entre Punta Campanella y Marina del Cantone."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo se accede a Ieranto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A pie: desde Nerano, aproximadamente 45–60 minutos de caminata en un sendero bien señalizado pero empinado. En barco: excursiones desde Nerano, Sorrento o Capri (~20 min de Capri). El sendero desciende abruptamente hacia la playa y requiere botas de senderismo robustas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Es una playa equipada?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No, Ieranto es una playa completamente salvaje y protegida. No hay tumbonas, bares o servicios. Los fuegos están prohibidos y está estrictamente prohibido dejar basura. Lleve agua, snacks y respete el ecosistema marino."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la mejor época para visitar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mayo–septiembre para nadar. Los meses intermedios (abril, octubre) son ideales para senderismo con temperaturas más suaves y menos multitudes. La visibilidad submarina es mejor de junio a septiembre (snorkel excelente). Evite noviembre–marzo cuando los acantilados y senderos están húmedos y resbaladizos."
      }
    },
    {
      "@type": "Question",
      "name": "¿Es un buen lugar para snorkel?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, la Bahía de Ieranto es excelente para snorkel como parte del área marina protegida con extraordinaria biodiversidad. Verá barracudas, meros, erizos de mar, estrellas de mar y esponjas coloridas. La profundidad comienza a 2–3 metros de la orilla. Lleve una cámara subacuática."
      }
    }
  ]
};
---

<BaseLayout
  title="Spiaggia di Ieranto 2026: Cala Salvaje de la Península de Sorrento"
  description="Guía de Ieranto (Bahía de Ieranto): la playa salvaje de Massa Lubrense, área marina protegida, senderismo desde Nerano, snorkel y acceso en barco."
  lang={lang}
  pageKey="ieranto"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, placeSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/ieranto-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager"  referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Península de Sorrento · Naturaleza Protegida</p>
        <h1 class="font-serif text-display text-white mb-4">Spiaggia di Ieranto</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La Bahía de Ieranto es el secreto mejor guardado de la Península de Sorrento. Una cala salvaje rodeada de acantilados, envuelta en área marina protegida, accesible solo a pie o en barco. Aquí, el tiempo fluye de manera diferente.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Datos rápidos
          </a>
          <a href="#cosa-fare" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Qué hacer
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <!-- Main Content -->
      <div class="space-y-16">

        <!-- Intro -->
        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            La Bahía de Ieranto ha permanecido salvaje porque es difícil de alcanzar. No hay carretera asfaltada, sin aparcamiento, sin bares de playa con sombrillas. Para llegar debe caminar 45 minutos por un sendero tallado en la roca, o venir en barco. Y precisamente por esta razón sigue siendo uno de los lugares más puros e intactos de la Península de Sorrento.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            La bahía está protegida por el área marina protegida de Punta Campanella, establecida en 1997. Esto significa que nadará sobre praderas de hierba marina, verá peces que han desaparecido en otros lugares, hará snorkel sin ver plástico. Es el paraíso para quienes aman la naturaleza auténtica.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabía que?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">45 min</p>
              <p class="text-white/60 text-xs italic mt-1">senderismo desde Nerano</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1.172 ha</p>
              <p class="text-white/60 text-xs italic mt-1">área marina protegida</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1997</p>
              <p class="text-white/60 text-xs italic mt-1">año de creación</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            La Bahía de Ieranto es una de las pocas playas en Italia donde los fuegos están prohibidos y la limpieza es realizada por voluntarios. Es un símbolo del turismo consciente.
          </p>
        </div>

        <!-- Qué hacer -->
        <div id="cosa-fare">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Qué hacer en Ieranto</h2>
          <div class="space-y-8">

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Snorkel en área marina protegida</h3>
                <p class="text-slate-600 leading-relaxed">El agua es cristalina y la biodiversidad es excepcional. Puede nadar sobre praderas de hierba marina (posidonia), ver barracudas, meros y erizos, observar esponjas coloridas. La profundidad comienza a 2–3 metros de la orilla y aumenta gradualmente. La visibilidad es mejor de junio a septiembre.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Senderismo desde Nerano</h3>
                <p class="text-slate-600 leading-relaxed">El sendero que desciende a Ieranto está bien señalizado pero empinado: 45–60 minutos de descenso, lo mismo para subir. Salga temprano por la mañana para evitar el calor y tener más tiempo en la playa. Lleve botas de senderismo robustas - no será cómodo subir con los pies mojados.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Visita en barco</h3>
                <p class="text-slate-600 leading-relaxed">Excursiones en barco desde Nerano (Massa Lubrense), Sorrento e incluso desde Capri (~20 min). Es la forma más cómoda si no le gusta el senderismo. Reserve con anticipación durante el verano - los lugares son limitados para preservar el ecosistema.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Fotografía y contemplación</h3>
                <p class="text-slate-600 leading-relaxed">Los acantilados reflejados en el agua cristalina, las rocas y la luz al atardecer crean composiciones fotográficas extraordinarias. Siéntese en una roca y observe el silencio. Este es el tipo de lugar donde el tiempo se vuelve irrelevante.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Cómo llegar -->
        <div class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white tracking-tight mb-6">Cómo llegar a Ieranto</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Ieranto es accesible solo a pie mediante senderismo o en barco. No hay carretera que llegue directamente a la playa. Por eso permanece salvaje e intacta.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0"><svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg></div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Senderismo desde Nerano</h3><p class="text-white/50 text-sm leading-relaxed">Vía SS145 a Massa Lubrense, localidad Nerano. Aparcamiento en el centro, luego 45 min de descenso en el sendero hacia la bahía. Botas de senderismo robustas esenciales.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0"><svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 20c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm14 0c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM3.5 6.5C3.5 5.12 4.62 4 6 4h12c1.38 0 2.5 1.12 2.5 2.5v2M3.5 8.5h17"/></svg></div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Barco desde Nerano/Sorrento/Capri</h3><p class="text-white/50 text-sm leading-relaxed">Excursiones regulares desde Nerano y Sorrento. Desde Capri ~20 min. Reserve con anticipación, especialmente en verano para proteger el ecosistema.</p></div>
              </div>
            </div>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Preguntas frecuentes</h2>
          <div class="space-y-4">

            <details class="group border border-slate-200 rounded-2xl overflow-hidden">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                ¿Dónde está Spiaggia di Ieranto?
                <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                La Bahía de Ieranto se encuentra en Nerano, municipio de Massa Lubrense, en la Península de Sorrento. Se encuentra dentro del área marina protegida de Punta Campanella, entre Punta Campanella y Marina del Cantone, a unos 4,9 km de Capri.
              </div>
            </details>

            <details class="group border border-slate-200 rounded-2xl overflow-hidden">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                ¿Cómo se accede a Ieranto?
                <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                A pie: desde Nerano, aproximadamente 45–60 minutos de caminata en un sendero bien señalizado pero empinado. En barco: excursiones diarias desde Nerano, Sorrento o Capri (aproximadamente 20 minutos desde Capri). El sendero desciende abruptamente hacia la playa y requiere botas de senderismo robustas.
              </div>
            </details>

            <details class="group border border-slate-200 rounded-2xl overflow-hidden">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                ¿Es una playa equipada?
                <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                No, Ieranto es una playa completamente salvaje y protegida. No hay tumbonas, sombrillas, bares o servicios. Los fuegos están prohibidos y está estrictamente prohibido dejar basura. Lleve agua, snacks, una cámara y una toalla de playa. Respete el ecosistema marino.
              </div>
            </details>

            <details class="group border border-slate-200 rounded-2xl overflow-hidden">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                ¿Cuál es la mejor época para visitar?
                <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                Mayo–septiembre para nadar. Los meses intermedios (abril, octubre) son ideales para senderismo con temperaturas más suaves y menos multitudes. La visibilidad submarina es mejor de junio a septiembre (snorkel excelente). Evite noviembre–marzo cuando los acantilados y senderos están húmedos y resbaladizos.
              </div>
            </details>

            <details class="group border border-slate-200 rounded-2xl overflow-hidden">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                ¿Es bueno para hacer snorkel?
                <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                Sí, la Bahía de Ieranto es excelente para snorkel como parte del área marina protegida con biodiversidad extraordinaria. Verá barracudas, meros, erizos de mar, estrellas de mar y esponjas coloridas. La profundidad comienza a 2–3 metros de la orilla y aumenta gradualmente. Lleve una cámara subacuática.
              </div>
            </details>

          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <!-- Datos rápidos -->
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos rápidos - Ieranto</p>
          <dl class="space-y-3">
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Municipio</dt>
              <dd class="text-white font-medium text-sm text-right">Massa Lubrense, NA</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Localidad</dt>
              <dd class="text-white font-medium text-sm text-right">Nerano</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Acceso</dt>
              <dd class="text-white font-medium text-sm text-right">Senderismo o barco</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Distancia a pie</dt>
              <dd class="text-white font-medium text-sm text-right">45–60 min</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Tipo de playa</dt>
              <dd class="text-white font-medium text-sm text-right">Arena y rocas</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Protección</dt>
              <dd class="text-white font-medium text-sm text-right">AMP Campanella</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Servicios</dt>
              <dd class="text-white font-medium text-sm text-right">Ninguno</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Mejor época</dt>
              <dd class="text-white font-medium text-sm text-right">May–Sep</dd>
            </div>
          </dl>
        </div>

        <!-- Quick Links -->
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Península de Sorrento</p>
          <nav class="space-y-1">
            <a href="/es-es/peninsula-sorrentina/sorrento/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
              <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> Sorrento
            </a>
            <a href="/es-es/peninsula-sorrentina/massa-lubrense/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
              <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> Massa Lubrense
