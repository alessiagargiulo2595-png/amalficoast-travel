---
import BlogPostLayout from '../../../../layouts/BlogPostLayout.astro';

const lang = 'es-es';
const post = {
  title: 'Atrani',
  subtitle: "El Pueblo Más Pequeño de Italia Donde el Tiempo se Detuvo",
  category: 'DESCUBRIMIENTOS',
  date: '22 de abril de 2026',
  readTime: '6 min',
  image: '/images/atrani-hero.jpg',
  imageAlt: "Atrani - el pueblo más pequeño de Italia en la Costa Amalfitana",
  path: '/es-es/blog/atrani/',
};

const metaTitle = "Atrani: El Pueblo Más Pequeño de Italia en la Costa Amalfitana | Guía 2026";
const metaDescription = "Guía de Atrani, el municipio más pequeño de Italia: historia de los Dogos de la República de Amalfi, la leyenda de Masaniello, escenario de Ripley en Netflix y consejos prácticos para visitarlo.";

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Blog', url: '/es-es/blog/' },
  { name: 'Atrani', url: '/es-es/blog/atrani/' },
];

const quickInfo = [
  { label: 'Récord', value: "Municipio más pequeño de Italia (0,12 km²)" },
  { label: 'Distancia de Amalfi', value: '700 m · 10-15 min a pie' },
  { label: 'Acceso', value: 'A pie desde Amalfi · Autobús SITA' },
  { label: 'Aparcamiento', value: 'Casi inexistente — usar Amalfi' },
  { label: 'Evento de culto', value: 'Fiesta de Sta. María Magdalena (22 julio)' },
  { label: 'Plato típico', value: 'Sarchiapone' },
  { label: 'Plató de rodaje', value: 'Ripley (Netflix, 2024)' },
  { label: 'Atmósfera', value: 'Auténtica, medieval, tranquila' },
];

const faq = [
  {
    q: '¿A qué distancia está Atrani de Amalfi?',
    a: 'Están separadas por solo 700 metros. Se pueden recorrer a pie en unos 10-15 minutos por el túnel peatonal o siguiendo la carretera costera.',
  },
  {
    q: '¿Es difícil aparcar en Atrani?',
    a: 'Sí, el aparcamiento es extremadamente limitado y reservado casi exclusivamente para los residentes. Se recomienda encarecidamente aparcar en Amalfi y llegar a Atrani a pie.',
  },
  {
    q: '¿Es Atrani adecuada para unas vacaciones tranquilas?',
    a: 'Absolutamente. Comparada con Amalfi o Positano, Atrani ofrece un ritmo mucho más lento y silencioso, aunque está a un paso de las principales conexiones de transporte de la Costa.',
  },
  {
    q: '¿Por qué Atrani fue elegida como plató de Ripley?',
    a: "La serie de Netflix Ripley (2024) eligió Atrani por su capacidad de evocar una Italia suspendida en el tiempo, con sus arcos sobre la carretera principal, callejuelas medievales y una plaza a pocos metros del mar. El pueblo ha permanecido casi idéntico desde hace décadas — algo rarísimo en la Costa.",
  },
  {
    q: '¿Qué es el Sarchiapone de Atrani?',
    a: 'Es la especialidad gastronómica local, preparada tradicionalmente para la fiesta de Santa María Magdalena el 22 de julio: un calabacín largo relleno de carne, quesos y huevos, luego frito y gratinado al horno.',
  },
  {
    q: "¿Qué es el 'birecto' y por qué está ligado a Atrani?",
    a: "El birecto era el tocado ducal de los Dogos de la República Marítima de Amalfi. En Atrani, en la iglesia de San Salvatore de' Birecto, se celebraba la solemne investidura de los Dogos: el pueblo era el centro del poder aristocrático de la República, no la más turística Amalfi.",
  },
];

const sidebarLinks = [
  { label: 'Descubre Amalfi', href: '/es-es/costa-amalfitana/amalfi/' },
  { label: 'Autobús SITA', href: '/es-es/guia/bus-sita/' },
  { label: 'Las playas', href: '/es-es/playas/' },
  { label: 'Cuándo visitar', href: '/es-es/cuando-visitar/' },
  { label: 'Cómo llegar', href: '/es-es/costa-amalfitana/come-arrivare/' },
];

const relatedArticles = [
  {
    title: 'Gruta Esmeralda',
    category: 'DESCUBRIMIENTOS',
    date: '22 de abril de 2026',
    image: '/images/grotta-smeraldo-hero.webp',
    imageAlt: 'Gruta Esmeralda - Conca dei Marini, Costa Amalfitana',
    path: '/es-es/blog/gruta-esmeralda/'
  },
  {
    title: 'Valle de las Ferriere',
    category: 'DESCUBRIMIENTOS',
    date: '22 de abril de 2026',
    image: '/images/valle-ferriere-hero.jpg',
    imageAlt: 'Cascada en el Valle de las Ferriere, Amalfi - Costa Amalfitana',
    path: '/es-es/blog/valle-ferriere/'
  }
];

const authorRole = 'Especialista en Costa Amalfitana';
---

<BlogPostLayout
  lang={lang}
  post={post}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  breadcrumbs={breadcrumbs}
  quickInfo={quickInfo}
  faq={faq}
  sidebarLinks={sidebarLinks}
  authorRole={authorRole}
  relatedArticles={relatedArticles}
>

  <!-- Intro -->
  <div>
    <p class="text-slate-600 text-xl leading-relaxed mb-6 font-light">
      A pocos pasos de la famosa y concurrida Amalfi, separada solo por un breve espolón rocoso, se alza Atrani. Con sus 0,12 km², es el municipio más pequeño de Italia, pero lo que le falta en tamaño lo compensa ampliamente con encanto, historia y autenticidad. Atrani no es solo un pueblo: es un anfiteatro natural frente al mar, un laberinto de "scalinatielle" y un refugio para quienes buscan la Costa Amalfitana más genuina.
    </p>
  </div>

  <!-- Arquitectura -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Una Arquitectura de Película</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Nada más llegar a Atrani, la mirada queda atrapada por los famosos arcos que sostienen la SS163, convirtiendo el paso de los coches en un elemento escenográfico que enmarca la playa y el pueblo. Atrani ha mantenido intacta su estructura medieval: un laberinto de callejuelas estrechas, casas blancas superpuestas y pequeños patios que se abren de improviso, convirtiéndola en uno de los <strong>Pueblos más Bellos de Italia</strong>.
    </p>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
      <h3 class="font-serif text-xl font-bold text-slate-900 mb-4">El Plató de Ripley</h3>
      <p class="text-slate-600 leading-relaxed">
        No es casualidad que Atrani fuera elegida como plató para la serie <strong>Netflix Ripley (2024)</strong>, gracias a su capacidad de evocar una atmósfera suspendida en el tiempo, lejos del turismo de masas. Las callejuelas, la plaza y los arcos sobre la carretera han permanecido casi idénticos desde hace décadas — una rareza absoluta en la Costa.
      </p>
    </div>
  </div>

  <!-- Historia -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Historia y Leyendas: El Corazón de la República</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      A pesar de su cercanía a Amalfi, Atrani siempre tuvo una identidad fuerte y aristocrática. En la época ducal, aquí residían las familias más nobles y en la <strong>iglesia de San Salvatore de' Birecto</strong> se celebraba la solemne investidura de los Dogos de la República Marítima de Amalfi con la imposición del "birecto" (el tocado ducal).
    </p>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Una de las leyendas más fascinantes tiene que ver con la <strong>Cueva de Masaniello</strong>: se dice que el famoso revolucionario napolitano, cuya madre era originaria de Atrani, se refugió aquí entre las callejuelas del pueblo para escapar de los guardias del virrey.
    </p>

    <blockquote class="border-l-4 border-med-gold pl-6 my-8">
      <p class="text-slate-700 text-xl font-serif italic leading-relaxed">
        "Atrani es un secreto susurrado entre las rocas, un lugar donde el aliento del mar llega hasta el interior de las casas."
      </p>
    </blockquote>
  </div>

  <!-- Qué ver -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Qué Ver en Atrani</h2>
    <div class="space-y-4">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Plaza Umberto I</h4>
          <p class="text-slate-600 text-sm leading-relaxed">El corazón palpitante del pueblo. Una pequeña plaza íntima a pocos metros de la arena, perfecta para un café o un aperitivo rodeado de la vida cotidiana de los residentes. Sin tiendas de souvenirs, sin colas: solo el Atrani auténtico.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Colegiata de Santa María Magdalena</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Con su cúpula de mayólica que domina el perfil del pueblo, es uno de los puntos más fotografiados de la Costa. La fachada barroca y la posición sobre el mar la hacen única.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Las "Scalinatielle"</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Piérdete por las escalinatas que suben hacia la parte alta del pueblo. Cada peldaño ofrece un nuevo rincón, entre ropa tendida al sol y el aroma de la cocina local. El verdadero Atrani vive aquí, no en la carretera principal.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Consejos -->
  <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
    <div class="flex items-center gap-4 mb-6">
      <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      <h3 class="text-xl font-bold text-slate-900">Consejos de Experto</h3>
    </div>
    <div class="space-y-6">
      <div>
        <p class="font-bold text-slate-900 mb-1">Llegar a pie desde Amalfi</p>
        <p class="text-slate-600 text-sm leading-relaxed">En lugar de usar el autobús o el coche, recorre el sendero peatonal que parte de la parte alta de Amalfi. En menos de 15 minutos de paseo panorámico estarás en el corazón de Atrani, evitando el tráfico de la carretera costera.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">La Playa</p>
        <p class="text-slate-600 text-sm leading-relaxed">La playa de Atrani es pequeña y resguardada, ideal para familias con niños o para quien quiera disfrutar del sol en un entorno más íntimo que el de la vecina Amalfi. Menos concurrida, más tranquila.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">El Plato Típico: el Sarchiapone</p>
        <p class="text-slate-600 text-sm leading-relaxed">No te vayas sin probar el Sarchiapone, especialidad local preparada tradicionalmente para Santa María Magdalena (22 de julio): un calabacín largo relleno de carne, quesos y huevos, frito y gratinado al horno.</p>
      </div>
    </div>
  </div>

</BlogPostLayout>
