---
import BlogPostLayout from '../../../../layouts/BlogPostLayout.astro';

const lang = 'es-es';
const post = {
  title: 'Valle delle Ferriere',
  subtitle: 'Senderismo en el Corazón Verde y Salvaje de Amalfi',
  category: 'DESCUBRIMIENTOS',
  date: '22 de abril de 2026',
  readTime: '8 min',
  image: '/images/valle-ferriere-hero.jpg',
  imageAlt: 'Cascada en el Valle delle Ferriere, Amalfi - Costa Amalfitana',
  path: '/es-es/blog/valle-ferriere/',
};

const metaTitle = 'Valle delle Ferriere Amalfi: Senderismo, Cascadas y Helechos Prehistóricos 2026';
const metaDescription = 'Guía completa del senderismo en el Valle delle Ferriere de Amalfi: ruta, helechos gigantes prehistóricos, antiguas fábricas de papel medievales, cascadas y consejos para visitar la reserva natural.';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Blog', url: '/es-es/blog/' },
  { name: 'Valle delle Ferriere', url: '/es-es/blog/valle-ferriere/' },
];

const quickInfo = [
  { label: 'Punto de partida', value: 'Pontone o Amalfi (centro)' },
  { label: 'Dificultad', value: 'E – Senderismo (Fácil/Medio)' },
  { label: 'Duración', value: 'Unas 3-4 horas (con paradas)' },
  { label: 'Distancia', value: 'Unos 6 km' },
  { label: 'Tarifa reserva', value: 'aprox. 5 € por persona' },
  { label: 'Equipo', value: 'Botas de senderismo obligatorias' },
  { label: 'Qué ver', value: 'Cascadas, helechos prehistóricos, molinos de papel' },
  { label: 'Mejor época', value: 'Abril – Junio / Otoño' },
];

const faq = [
  {
    q: '¿El sendero es apto para niños?',
    a: "Sí, el sendero principal está bien señalizado y no presenta peligros extremos. Sin embargo, no es practicable con cochecitos debido a los escalones y raíces. Con niños pequeños es aconsejable empezar en Pontone (bajada) en lugar de Amalfi (subida).",
  },
  {
    q: '¿Se puede nadar en el arroyo?',
    a: "Aunque el agua es cristalina e invitante, es extremadamente fría (unos 12-14°C) y, al tratarse de una zona protegida, es mejor evitarlo para no disturbar el ecosistema local.",
  },
  {
    q: '¿Cuál es la mejor época para visitar?',
    a: "La primavera (abril-junio) es el momento mágico: las cascadas están al máximo caudal y la vegetación es de un verde explosivo. El otoño también ofrece maravillosos colores cálidos. En verano el valle se mantiene fresco gracias al microclima, pero el caudal de las cascadas se reduce.",
  },
  {
    q: '¿Hay cobertura móvil en el valle?',
    a: "En muchos puntos del valle la señal es inexistente o muy débil. Es la ocasión perfecta para un detox digital, pero recuerda descargar el mapa sin conexión e informar a alguien de tu ruta antes de salir.",
  },
  {
    q: '¿Qué es la Woodwardia radicans?',
    a: "Es un rarísimo helecho gigante que data de la época prehistórica (Terciario), que sobrevivió en los valles húmedos del Mediterráneo gracias a microclimas particulares. Sus frondes pueden alcanzar los 2 metros. En el Valle delle Ferriere constituye uno de los hábitats más importantes de Europa para esta especie.",
  },
];

const sidebarLinks = [
  { label: 'Senderismo y Sendero de los Dioses', href: '/es-es/experiencias/trekking/' },
  { label: 'Descubre Amalfi', href: '/es-es/costa-amalfitana/amalfi/' },
  { label: 'Autobús SITA hacia Amalfi', href: '/es-es/guia/bus-sita/' },
];

const authorRole = 'Guía de Naturaleza y Senderismo · Costa Amalfitana';

const keyTakeaways = [
  'El Valle delle Ferriere alberga la Woodwardia radicans, un helecho gigante prehistórico del Terciario que sobrevivió gracias a un microclima único en el Mediterráneo.',
  'El nombre viene de antiguas ferreras medievales que aprovechaban el arroyo Canneto; a lo largo del sendero se encuentran ruinas de históricos molinos de papel que producían la famosa Carta di Amalfi.',
  'El sendero está clasificado E (Senderismo): unos 6 km, 3-4 horas con paradas. Se recomienda empezar en Pontone para bajar hacia Amalfi.',
  'La zona de cascadas y helechos raros es una reserva natural protegida: reserva y contribución (~5 €) obligatorias — mejor organizarse con antelación.',
  'Mejor época: primavera (abril-junio) para cascadas al máximo y verde explosivo; otoño para los cálidos colores del bosque.',
];
---

<BlogPostLayout
  lang={lang}
  post={post}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  breadcrumbs={breadcrumbs}
  quickInfo={quickInfo}
  faq={faq}
  sidebarLinks={sidebarLinks}
  authorRole={authorRole}
>

  <!-- Key Takeaways -->
  <div class="bg-slate-900 text-white p-8 rounded-[2rem]">
    <div class="flex items-center gap-3 mb-6">
      <svg class="w-5 h-5 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <h2 class="font-serif text-lg font-bold text-med-gold uppercase tracking-[0.15em]">Key Takeaways</h2>
    </div>
    <ul class="space-y-4">
      {keyTakeaways.map((point) => (
        <li class="flex items-start gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-med-gold flex-shrink-0 mt-2"></span>
          <span class="text-white/80 text-sm leading-relaxed">{point}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Intro -->
  <div>
    <p class="text-slate-600 text-xl leading-relaxed mb-6 font-light">
      Mientras las multitudes se aglomeran en las callejuelas de Amalfi o en las playas de Positano, existe un sendero que lleva a un mundo paralelo, hecho de cascadas, helechos prehistóricos y un silencio interrumpido solo por el susurro del agua. El Valle delle Ferriere es el secreto mejor guardado de la Costa Amalfitana: un pulmón verde que parece pertenecer a una selva tropical más que al Mediterráneo.
    </p>
  </div>

  <!-- Microclima único -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Un Microclima Único</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Lo que hace mágico el Valle delle Ferriere es su particular conformación geológica. Las altas paredes rocosas protegen el fondo del valle de los vientos cálidos, manteniendo una humedad constante y temperaturas frescas incluso en pleno verano.
    </p>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm my-6">
      <h3 class="font-serif text-xl font-bold text-slate-900 mb-4">Woodwardia radicans: Un Fósil Viviente</h3>
      <p class="text-slate-600 leading-relaxed mb-4">
        Este microclima permitió la supervivencia de la <strong>Woodwardia radicans</strong>, un rarísimo helecho gigante que data de la época prehistórica (Terciario). Sus frondes pueden alcanzar los 2 metros de longitud y constituyen uno de los hábitats más importantes de Europa para esta especie.
      </p>
      <p class="text-slate-600 leading-relaxed">
        Caminar entre estas enormes frondes, rodeado de musgos y manantiales, da la sensación de haber dado un salto atrás en el tiempo de millones de años. Una experiencia que ninguna fotografía puede transmitir plenamente.
      </p>
    </div>
  </div>

  <!-- Arqueología industrial -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Arqueología Industrial entre los Limoneros</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      El nombre del valle proviene de las antiguas ferreras que antaño aprovechaban la fuerza del arroyo Canneto para la producción de hierro. Pero hay más: a lo largo del sendero se encuentran los restos de los históricos <strong>molinos de papel de Amalfi</strong>.
    </p>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Aquí se producía la célebre <strong>Carta di Amalfi</strong> (o Charta Bambagina), exportada a todo el mundo medieval. Ver las ruinas de estos imponentes edificios envueltos por la vegetación le da al valle una atmósfera decadente y fascinante, similar a una ciudad perdida.
    </p>

    <blockquote class="border-l-4 border-med-gold pl-6 my-8">
      <p class="text-slate-700 text-xl font-serif italic leading-relaxed">
        "El Valle delle Ferriere es el lugar donde la fuerza del agua construyó la historia de Amalfi."
      </p>
    </blockquote>
  </div>

  <!-- Guía práctica -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Guía Práctica del Sendero</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      El senderismo en el Valle delle Ferriere es apto para casi todos, pero requiere una mínima preparación. Hay dos accesos principales.
    </p>

    <div class="space-y-4 mb-8">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Desde Pontone (Recomendado)</h4>
          <p class="text-slate-600 text-sm leading-relaxed">El acceso más panorámico. Partiendo de la pequeña plaza de Pontone (aldea de Scala), el sendero es mayormente en bajada hacia Amalfi. Ideal para quienes no les gustan las subidas y quieren disfrutar del recorrido sin demasiado esfuerzo.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Desde Amalfi</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Se parte desde la parte alta del pueblo, pasando el Museo del Papel. Es un recorrido en subida, más exigente pero muy pintoresco ya que remonta el curso del arroyo. Los antiguos molinos de papel se ven justo al inicio del camino.</p>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-[2rem] border border-slate-100 shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-slate-900 text-white">
          <tr>
            <th class="text-left p-5 font-serif font-bold text-med-gold">Parámetro</th>
            <th class="text-left p-5 font-serif font-bold text-med-gold">Detalle</th>
          </tr>
        </thead>
        <tbody class="bg-white">
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Dificultad</td>
            <td class="p-5 text-slate-600">E – Senderismo (Fácil / Medio)</td>
          </tr>
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Duración</td>
            <td class="p-5 text-slate-600">Unas 3-4 horas (con paradas)</td>
          </tr>
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Distancia</td>
            <td class="p-5 text-slate-600">Unos 6 km</td>
          </tr>
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Desnivel</td>
            <td class="p-5 text-slate-600">~400 m (Pontone → Amalfi)</td>
          </tr>
          <tr>
            <td class="p-5 font-bold text-slate-900">Tarifa reserva</td>
            <td class="p-5 text-slate-600">aprox. 5 € por persona (reserva recomendada)</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Consejos -->
  <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
    <div class="flex items-center gap-4 mb-6">
      <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      <h3 class="text-xl font-bold text-slate-900">Consejos de Experto</h3>
    </div>
    <div class="space-y-6">
      <div>
        <p class="font-bold text-slate-900 mb-1">La Reserva Integral: reserva con antelación</p>
        <p class="text-slate-600 text-sm leading-relaxed">El corazón del valle es una reserva protegida. Para acceder a la zona de cascadas y helechos raros hay que reservar la entrada (a menudo gestionada por asociaciones locales) y pagar una pequeña contribución. Hazlo con antelación, especialmente los fines de semana de primavera.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Ropa: no subestimes el frío</p>
        <p class="text-slate-600 text-sm leading-relaxed">Aunque en Amalfi haga 30°C, en el valle la temperatura baja drásticamente. Lleva una chaqueta ligera y usa obligatoriamente botas de senderismo: las piedras cerca del arroyo pueden ser muy resbaladizas.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">El Tentempié del Caminante</p>
        <p class="text-slate-600 text-sm leading-relaxed">Para en una de las tiendas de Pontone antes de bajar y hazte preparar un bocadillo con fiordilatte de los Montes Lattari y tomates locales. Comerlo junto a una cascada no tiene precio.</p>
      </div>
    </div>
  </div>

</BlogPostLayout>
