---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Itinerarios', url: '/es-es/itinerarios/' },
  { name: 'Islas: Ischia y Procida — 3 días', url: '/es-es/itinerarios/3-dias/islas-ischia-procida/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuál es mejor para un fin de semana, Ischia o Procida?",
      "acceptedAnswer": { "@type": "Answer", "text": "Depende de lo que busques: Ischia es grande (46 km²), con termas, playas variadas, castillos y vida nocturna — necesita al menos 2 días. Procida es pequeña (4 km²), auténtica, con colores pastel icónicos, pescadores y poca masificación. Con 3 días puedes pasar 2 noches en Ischia y hacer una excursión a Procida." }
    },
    {
      "@type": "Question",
      "name": "¿Cómo llegar a Ischia y Procida desde Nápoles?",
      "acceptedAnswer": { "@type": "Answer", "text": "Desde Nápoles Beverello: hidrofoil a Ischia Porto (~50 min, €20–24) o ferry (~75 min, €12–14). Para Procida: hidrofoil desde Nápoles (~35 min, €15–18). Desde Pozzuoli: ferry Medmar/Caremar a Ischia y Procida, más económico (~€10–13). Reservar online en verano." }
    }
  ]
};

const days = [
  {
    day: 'Día 1',
    title: 'Llegada a Ischia',
    items: [
      'Ferry o hidrofoil desde Nápoles Beverello a Ischia Porto (50–75 min).',
      'Check-in. Tarde: Ischia Ponte y el Castillo Aragonés (entrada ~€24, 2h).',
      'Playa de Maronti (la más larga de la isla, arena volcánica negra) o aperitivo en Forio.',
      'Cena en Lacco Ameno o Ischia Porto: cocina isquiana, conejo a la ischiana.',
    ],
  },
  {
    day: 'Día 2',
    title: 'Termas y Playas',
    items: [
      'Mañana: jardines termales (Poseidón o Negombo, ~€35–40 entrada). Piscinas termales, saunas.',
      'Tarde: Playa de Citara (Forio), una de las mejores de la isla.',
      'Atardecer desde el mirador de Sant\'Angelo, el pueblo más pintoresco de Ischia.',
      'Cena en Sant\'Angelo o regreso a Ischia Porto.',
    ],
  },
  {
    day: 'Día 3',
    title: 'Excursión a Procida',
    items: [
      'Hidrofoil de Ischia a Procida (20 min, ~€9). Primer servicio 08:00.',
      'Marina Corricella: el puerto de los pescadores, casas de colores pastel, bar en el embarcadero.',
      'Terra Murata: el pueblo medieval más alto de la isla, vistas sobre el Golfo.',
      'Playa del Pozzo Vecchio (la playa de El cartero) para un baño al mediodía.',
      'Regreso a Nápoles en hidrofoil desde Procida (35 min).',
    ],
  },
];
---

<BaseLayout
  title="Ischia y Procida en 3 Días 2026 | Itinerario Islas del Golfo de Nápoles"
  description="Itinerario de 3 días por Ischia y Procida: termas, playas volcánicas, Marina Corricella y Castillo Aragonés. Cómo llegar, dónde dormir y qué ver."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/isole-hero.jpg" alt="Ischia y Procida, Golfo de Nápoles" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/es-es/itinerarios/" class="hover:text-white transition-colors">Itinerarios</a>
        <span>/</span>
        <span class="text-white">Islas: Ischia y Procida</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 3 días</p>
        <h1 class="font-serif text-display text-white mb-4">Islas: Ischia y Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Dos islas, dos caracteres opuestos: Ischia grande y termal, Procida pequeña y auténtica. Un fin de semana perfecto en el Golfo de Nápoles, lejos de las masas de la Costa Amalfitana.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duración</p>
          <p class="font-semibold text-charcoal">3 días / 2 noches</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base</p>
          <p class="font-semibold text-charcoal">Ischia Porto o Forio</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transporte</p>
          <p class="font-semibold text-charcoal">Hidrofoils + autobús isla</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programa día a día</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consejos prácticos</p>
      <ul class="space-y-2">
        {[
          'En Ischia el autobús circular (CS/CD) funciona todo el día: billete único ~€1.50, bono día ~€6.',
          'Reservar los jardines termales online: Poseidón y Negombo se agotan en verano.',
          'Procida como excursión: tomar el primer hidrofoil (08:00) para tener tiempo antes de que lleguen las masas.',
          'Ischia fuera de temporada (octubre–noviembre): termas abiertas, pocos turistas, precios bajos.',
          'El hidrofoil no sale con mar gruesa: comprobar el tiempo antes de reservar.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
