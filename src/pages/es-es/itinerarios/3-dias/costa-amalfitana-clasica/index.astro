---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Itinerarios', url: '/es-es/itinerarios/' },
  { name: 'Costa Amalfitana clásica — 3 días', url: '/es-es/itinerarios/3-dias/costa-amalfitana-clasica/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Dónde dormir para visitar la Costa Amalfitana en 3 días?",
      "acceptedAnswer": { "@type": "Answer", "text": "Las mejores bases son Amalfi (posición central, buena oferta de hoteles y B&B, bien comunicada por autobús y ferry) o Positano (más romántica pero más cara). Sorrento es ideal para quienes buscan una ciudad más práctica con más servicios y precios más bajos, haciendo excursiones a la Costa." }
    },
    {
      "@type": "Question",
      "name": "¿3 días en la Costa: mejor en temporada alta o baja?",
      "acceptedAnswer": { "@type": "Answer", "text": "Mayo–junio y septiembre–octubre son los mejores meses: clima perfecto, menos turistas que en julio–agosto, precios más bajos. En julio–agosto los autobuses van llenos, los aparcamientos saturados y las playas masificadas. En invierno muchos establecimientos cierran pero los pueblos son tranquilos y auténticos." }
    }
  ]
};

const days = [
  {
    day: 'Día 1',
    title: 'Llegada y Positano',
    items: [
      'Llegada a Sorrento o Amalfi. Check-in.',
      'Tarde en Positano: Spiaggia Grande, via Cristoforo Colombo, iglesia Santa Maria Assunta.',
      'Aperitivo con vistas desde el mirador sobre el pueblo.',
      'Cena en Positano o regreso en autobús a Amalfi.',
    ],
  },
  {
    day: 'Día 2',
    title: 'Amalfi y Ravello',
    items: [
      'Mañana: Catedral de Amalfi, Claustro del Paraíso, Museo del Papel (papel amalfitano, s. XIII).',
      'Autobús SITA a Ravello (25 min). Villa Rufolo, Villa Cimbrone, panoramas sobre la Costa.',
      'Almuerzo en Ravello, regreso a Amalfi por la tarde.',
      'Cena en el puerto de Amalfi: pescado del día, mozzarella de búfala.',
    ],
  },
  {
    day: 'Día 3',
    title: 'Praiano y Gruta Esmeralda',
    items: [
      'Mañana: autobús SITA hacia Positano, parada en Praiano (paseo tranquilo, playa Gavitella).',
      'Gruta Esmeralda cerca de Conca dei Marini: entrada ~€5, espectacular luz verde.',
      'Tarde libre en Amalfi o excursión en barco (vuelta a la costa desde Amalfi, ~€40–70 p.p.).',
      'Salida a última hora de la tarde hacia Nápoles/Salerno.',
    ],
  },
];
---

<BaseLayout
  title="Costa Amalfitana en 3 Días 2026 | Itinerario Clásico Completo"
  description="Itinerario clásico de 3 días por la Costa Amalfitana: Positano, Amalfi, Ravello y Gruta Esmeralda. Dónde dormir, qué ver y cómo moverse."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Costa Amalfitana clásica" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/es-es/itinerarios/" class="hover:text-white transition-colors">Itinerarios</a>
        <span>/</span>
        <span class="text-white">Costa Amalfitana clásica — 3 días</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 3 días</p>
        <h1 class="font-serif text-display text-white mb-4">Costa Amalfitana Clásica</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Tres días para ver lo mejor de la Costa: Positano, Amalfi, Ravello y la Gruta Esmeralda. El recorrido clásico, optimizado para el transporte público.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duración</p>
          <p class="font-semibold text-charcoal">3 días / 2 noches</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base recomendada</p>
          <p class="font-semibold text-charcoal">Amalfi o Positano</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transporte</p>
          <p class="font-semibold text-charcoal">Autobús SITA + ferries</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programa día a día</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consejos para 3 días en la Costa</p>
      <ul class="space-y-2">
        {[
          'Base en Amalfi: posición central, más barata que Positano, excelentes conexiones en autobús y ferry.',
          'Comprar los billetes SITA en lote (estanco) a la llegada: ahorra tiempo cada mañana.',
          'Ravello no tiene playas pero ofrece el mejor mirador de la Costa: prever al menos medio día.',
          'El tour en barco del día 3 es opcional pero transforma la jornada: reservar la víspera.',
          'En verano: desplazarse antes de las 9h para evitar los autobuses llenos y las colas.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
