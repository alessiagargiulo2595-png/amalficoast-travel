---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Itinerarios', url: '/es-es/itinerarios/' },
  { name: 'Sorrento, Pompeya e Historia — 3 días', url: '/es-es/itinerarios/3-dias/sorrento-pompeya-historia/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo se necesita para visitar Pompeya?",
      "acceptedAnswer": { "@type": "Answer", "text": "Para una visita completa se necesitan al menos 3–4 horas. Una visita esencial (Foro, Via dell'Abbondanza, Casa del Fauno, anfiteatro) puede hacerse en 2–2,5 horas. Llegar a la apertura (09:00) para evitar el calor de la tarde y las colas. Entrada ~€18–20, gratuita para menores de 18 años." }
    },
    {
      "@type": "Question",
      "name": "¿Vale la pena visitar Herculano además de Pompeya?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí, Herculano es preferido por los visitantes más experimentados: más pequeño que Pompeya (2h es suficiente) pero con restos mejor conservados porque quedó sepultado en barro en lugar de ceniza. Existe una entrada combinada Pompeya + Herculano. Con 3 días, visita Herculano por la tarde del día 2 y Pompeya por la mañana del día 3." }
    }
  ]
};

const days = [
  {
    day: 'Día 1',
    title: 'Sorrento',
    items: [
      'Llegada a Sorrento en Circumvesuviana desde Nápoles (70 min, ~€3.90).',
      'Casco antiguo: Piazza Tasso, Catedral, Vallone dei Mulini (valle volcánica en el centro urbano).',
      'Museo Correale: objetos romanos y vistas del siglo XVIII de Sorrento.',
      'Marina Grande: el puerto de los pescadores, cena con vistas.',
    ],
  },
  {
    day: 'Día 2',
    title: 'Herculano y Vesubio',
    items: [
      'Circumvesuviana hasta Herculano Scavi (20 min desde Nápoles, 50 min desde Sorrento).',
      'Yacimiento arqueológico de Herculano: conservación extraordinaria, 2–3 horas.',
      'Tarde: autobús/lanzadera al Vesubio (cráter a 1.281 m, ~€12 entrada + guía obligatorio). Vistas sobre el Golfo de Nápoles.',
      'Regreso a Sorrento en Circumvesuviana.',
    ],
  },
  {
    day: 'Día 3',
    title: 'Pompeya',
    items: [
      'Circumvesuviana hasta Pompei Scavi – Villa dei Misteri (35 min desde Nápoles, 45 min desde Sorrento).',
      'Excavaciones de Pompeya: Foro, Termas, anfiteatro, casas patricias. Al menos 3h.',
      'Almuerzo en Pompeya moderna, luego visita al Museo del Tesoro de San Gennaro (opcional).',
      'Regreso hacia Nápoles o Sorrento por la tarde.',
    ],
  },
];
---

<BaseLayout
  title="Sorrento, Pompeya y Herculano en 3 Días 2026 | Itinerario Histórico"
  description="Itinerario de 3 días combinando historia y mar: Sorrento, Herculano, Vesubio y Pompeya. Horarios de la Circumvesuviana, precios de entradas y consejos prácticos."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/sorrento-hero.jpg" alt="Sorrento y Pompeya" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/es-es/itinerarios/" class="hover:text-white transition-colors">Itinerarios</a>
        <span>/</span>
        <span class="text-white">Sorrento, Pompeya e Historia</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 3 días</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrento, Pompeya e Historia</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Tres días de arqueología y el Golfo de Nápoles: Sorrento como base, Herculano y el Vesubio el segundo día, Pompeya el tercero. Todo en tren, sin coche.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duración</p>
          <p class="font-semibold text-charcoal">3 días / 2 noches</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base recomendada</p>
          <p class="font-semibold text-charcoal">Sorrento</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transporte clave</p>
          <p class="font-semibold text-charcoal">Circumvesuviana</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programa día a día</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consejos prácticos</p>
      <ul class="space-y-2">
        {[
          'Pompeya y Herculano: llegar a la apertura (09:00). El calor de la tarde y las colas dificultan la visita.',
          'Entrada combinada Pompeya + Herculano: rentable si se visitan ambos en el mismo día o en días consecutivos.',
          'La Circumvesuviana es frecuente pero lenta: de Sorrento a Pompei Scavi ~45 min, desde Nápoles ~35 min.',
          'Vesubio: el autobús lanzadera sale desde Herculano y Pompeya (consultar horarios de temporada). Guía obligatorio por ley.',
          'Sorrento al atardecer es espléndido: aperitivo en Marina Grande, cena en el corso principal.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
