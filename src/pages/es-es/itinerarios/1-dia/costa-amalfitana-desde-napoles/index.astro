---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Home', url: '/es-es/' },
  { name: 'Itinerarios', url: '/es-es/itinerarios/' },
  { name: '1 Día desde Nápoles', url: '/es-es/itinerarios/1-dia/costa-amalfitana-desde-napoles/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo llegar a la Costa Amalfitana desde Nápoles en un día?",
      "acceptedAnswer": { "@type": "Answer", "text": "El recorrido más práctico es: tren Nápoles→Salerno (40 min, Trenitalia/Italo), luego ferry Travelmar Salerno→Amalfi (45 min, temporada abr-oct) o bus SITA desde Salerno. Alternativamente, tren Nápoles→Sorrento (Circumvesuviana, 70 min) y bus SITA Sorrento→Amalfi (90 min)." }
    },
    {
      "@type": "Question",
      "name": "¿Qué ver en un día en la Costa Amalfitana saliendo desde Nápoles?",
      "acceptedAnswer": { "@type": "Answer", "text": "Con una jornada: llega a Amalfi (Duomo, centro histórico, 2h), luego Ravello en bus (25 min, Villa Rufolo y panoramas, 1.5h), luego vuelve a Amalfi y toma el bus para Positano (45 min, paseo y playa, 1.5h). El regreso desde Positano en bus o ferry." }
    },
    {
      "@type": "Question",
      "name": "¿A qué hora salir de Nápoles hacia la Costa Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sal de Nápoles antes de las 7:30-8:00. El tren de las 7:45 llega a Salerno a las 8:25; el ferry Travelmar sale alrededor de las 9:00 y llega a Amalfi antes de las 10:00. Esto te da 8-9 horas de visita antes del regreso." }
    }
  ]
};

const schedule = [
  { time: '07:45', place: 'Nápoles Central', action: 'Tren a Salerno (Trenitalia/Italo, 40 min, ~€5-12)', transport: 'train' },
  { time: '09:00', place: 'Salerno', action: 'Ferry Travelmar a Amalfi (45 min, ~€8, temporada abr-oct)', transport: 'ferry' },
  { time: '09:45', place: 'Amalfi', action: 'Duomo de Sant\'Andrea, Claustro del Paraíso, corso y centro histórico (2h)', transport: 'visit' },
  { time: '12:00', place: 'Amalfi → Ravello', action: 'Bus SITA local a Ravello (25 min, ~€1.50). Almuerzo en la plaza.', transport: 'bus' },
  { time: '13:30', place: 'Ravello', action: 'Villa Rufolo, mirador, Villa Cimbrone (1.5h)', transport: 'visit' },
  { time: '15:15', place: 'Ravello → Amalfi → Positano', action: 'Bus a Amalfi (25 min), luego bus SITA a Positano (45 min)', transport: 'bus' },
  { time: '16:30', place: 'Positano', action: 'Paseo por Via Cristoforo Colombo, Spiaggia Grande, aperitivo (1.5h)', transport: 'visit' },
  { time: '18:30', place: 'Positano → Nápoles', action: 'Bus SITA a Sorrento (50 min), luego Circumvesuviana a Nápoles (70 min)', transport: 'bus' },
];

const tips = [
  'El ferry Travelmar desde Salerno es estacional (abr-oct): en invierno usa el bus SITA desde Salerno.',
  'Compra el billete de bus SITA en un estanco antes de subir - no se vende a bordo.',
  'En julio-agosto el bus Amalfi→Positano puede tardar 1.5h en lugar de 45 min: calcula margen.',
  'Ravello merece el desvío: Villa Rufolo (€7) es uno de los miradores más bellos de la Costa.',
  'El regreso desde Positano en bus SITA es más lento (curvas + tráfico) - calcula al menos 1h hasta Sorrento.',
];

const transportBadge: Record<string, { label: string; cls: string }> = {
  train: { label: 'TREN', cls: 'bg-orange-100 text-orange-700' },
  ferry: { label: 'FERRY', cls: 'bg-blue-100 text-blue-700' },
  bus:   { label: 'BUS', cls: 'bg-green-100 text-green-700' },
  walk:  { label: 'A PIE', cls: 'bg-gray-100 text-slate-500' },
  visit: { label: '', cls: '' },
};
---

<BaseLayout
  title="Costa Amalfitana en 1 Día desde Nápoles 2026 | Itinerario Completo"
  description="Itinerario de 1 día por la Costa Amalfitana saliendo desde Nápoles: Amalfi, Ravello y Positano en tren, ferry y bus SITA. Horarios, precios y consejos prácticos."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <!-- Hero -->
  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Costa Amalfitana desde Nápoles" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/es-es/itinerarios/" class="hover:text-white transition-colors">Itinerarios</a>
        <span>/</span>
        <span class="text-white">Costa desde Nápoles - 1 día</span>
      </nav>
      <div class="max-w-2xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 1 día</p>
        <h1 class="font-serif text-display text-white mb-4">Costa Amalfitana desde Nápoles</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Amalfi, Ravello y Positano en una jornada sin coche. Tren hasta Salerno, ferry hasta Amalfi, luego bus SITA por la Costa. Factible, espectacular, económico.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <!-- Fast Facts Bar -->
    <section class="max-w-4xl mx-auto">
      <div class="grid grid-cols-3 gap-6">
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <div>
            <p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Duración</p>
            <p class="font-bold text-charcoal text-lg">1 día</p>
          </div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
          </svg>
          <div>
            <p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Coste transporte</p>
            <p class="font-bold text-charcoal text-lg">~€25–40</p>
          </div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
          <div>
            <p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Dificultad</p>
            <p class="font-bold text-charcoal text-lg">Fácil</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Two-column layout -->
    <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">

      <!-- Timeline (col-span-8) -->
      <section class="lg:col-span-8">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programa Hora a Hora</h2>
        <div class="relative">
          <div class="space-y-12 border-l-2 border-slate-200 pl-8 ml-3">
            {schedule.map((s, i) => {
              const badge = transportBadge[s.transport] ?? transportBadge.visit;
              return (
                <div class="relative">
                  <div class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-med-blue ring-4 ring-white shadow-sm"></div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-med-blue font-bold text-sm">{s.time}</span>
                    {badge.label && (
                      <span class={`text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded ${badge.cls}`}>{badge.label}</span>
                    )}
                  </div>
                  <p class="font-semibold text-charcoal text-base leading-snug">{s.place}</p>
                  <p class="text-slate-600 text-sm mt-1 leading-relaxed">{s.action}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Sidebar (col-span-4) -->
      <aside class="lg:col-span-4 mt-12 lg:mt-0">
        <div class="lg:sticky lg:top-24 space-y-6">

          <!-- Consejos Prácticos -->
          <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 2a7 7 0 0 1 7 7c0 3-1.7 5.2-4 6.4V17a1 1 0 0 1-1 1H10a1 1 0 0 1-1-1v-1.6C6.7 14.2 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M10 21h4M12 17v4"/>
              </svg>
              Consejos Prácticos
            </p>
            <ul class="space-y-3">
              {tips.map(tip => (
                <li class="flex gap-2.5 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Mapa Rápido -->
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>
              </svg>
              Mapa Rápido
            </p>
            <a href="https://maps.google.com/maps?q=Amalfi,Italy" target="_blank" rel="noopener" class="flex items-center justify-between bg-slate-50 hover:bg-med-blue/5 rounded-xl px-4 py-3 text-sm text-med-blue font-medium transition-colors group">
              Abrir ruta en Google Maps
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

        </div>
      </aside>
    </div>

    <!-- FAQ -->
    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas Frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
