---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Home', url: '/es-es/' },
  { name: 'Itinerarios', url: '/es-es/itinerarios/' },
  { name: 'Capri desde Sorrento', url: '/es-es/itinerarios/1-dia/capri-desde-sorrento/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo se tarda de Sorrento a Capri en hidrofoil?",
      "acceptedAnswer": { "@type": "Answer", "text": "El hidrofoil desde Sorrento (Marina Piccola) a Capri (Marina Grande) tarda aproximadamente 20-25 minutos. Las principales compañías son NLG y Alilauro. En verano los viajes salen cada 30-60 min desde las 7:00 hasta las 20:00. El billete de ida y vuelta cuesta ~€18-22." }
    },
    {
      "@type": "Question",
      "name": "¿Es posible ver la Gruta Azul en un día desde Sorrento?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí, pero requiere una organización precisa. Toma el primer hidrofoil desde Sorrento (7:30-8:00), llega a Capri y ve enseguida a la Gruta Azul antes de la multitud (mejor antes de las 10:00). Luego exploras Capri y Anacapri por la tarde. Regreso a Sorrento con el último hidrofoil (hacia las 18:30-19:00)." }
    },
    {
      "@type": "Question",
      "name": "Capri vs Anacapri: ¿cuál visitar en un día?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ambas merecen la visita, pero con un solo día elige según tus intereses: Capri ciudad es más chic, llena de tiendas y con los Farallones. Anacapri es más tranquila, con Villa San Michele y el telesilla para el Monte Solaro (589 m). Una buena jornada incluye mañana en la Gruta Azul, almuerzo en Anacapri, tarde en Capri y los Farallones." }
    }
  ]
};

const schedule = [
  { time: '07:30', place: 'Sorrento, Marina Piccola', action: 'Hidrofoil NLG/Alilauro a Capri (20-25 min, ~€9-11)', transport: 'ferry' },
  { time: '08:00', place: 'Capri, Marina Grande', action: 'Bus a la Gruta Azul (20 min, ~€2). Llega antes de las 10 para evitar colas.', transport: 'bus' },
  { time: '08:30', place: 'Gruta Azul', action: 'Barca de remos en la gruta (€15 + entrada €14). Espera variable.', transport: 'ferry' },
  { time: '10:00', place: 'Anacapri', action: 'Bus desde Capri a Anacapri (15 min). Villa San Michele (~€7). Telesilla Monte Solaro (589 m, ~€13 A/R).', transport: 'bus' },
  { time: '12:30', place: 'Anacapri', action: 'Almuerzo en trattoria local (más barata que el centro de Capri)', transport: 'visit' },
  { time: '14:00', place: 'Capri centro', action: 'Bus a Capri. La Piazzetta, Via Camerelle, Jardines de Augusto, vista de los Farallones.', transport: 'bus' },
  { time: '16:00', place: 'Marina Grande', action: 'Paseo en barca alrededor de los Farallones (~€18-25 p.p., 1-2h)', transport: 'ferry' },
  { time: '18:00', place: 'Capri → Sorrento', action: 'Hidrofoil de regreso a Sorrento (20-25 min)', transport: 'ferry' },
];

const tips = [
  'Gruta Azul: antes de las 10:00 casi sin cola. Después de las 11 la espera puede ser 1-2 horas.',
  'En julio-agosto reserva el hidrofoil online el día anterior: los primeros viajes se agotan.',
  'Capri es cara: almorzar en Anacapri cuesta un 30-40% menos que en la Piazzetta.',
  'El telesilla para el Monte Solaro desde Anacapri es imprescindible: 589 m, vista 360° sobre la Costa y Nápoles.',
  'El hidrofoil no sale con mar agitado: comprueba el pronóstico marino y ten un plan alternativo.',
];

const transportBadge: Record<string, { label: string; cls: string }> = {
  train: { label: 'TREN', cls: 'bg-orange-100 text-orange-700' },
  ferry: { label: 'FERRY', cls: 'bg-blue-100 text-blue-700' },
  bus:   { label: 'BUS', cls: 'bg-green-100 text-green-700' },
  walk:  { label: 'A PIE', cls: 'bg-gray-100 text-slate-500' },
  visit: { label: '', cls: '' },
};
---

<BaseLayout
  title="Capri desde Sorrento en 1 Día 2026 | Gruta Azul, Farallones, Anacapri"
  description="Itinerario de 1 día en Capri saliendo desde Sorrento: Gruta Azul, Anacapri, Monte Solaro y Farallones. Hidrofoiles, horarios y consejos para evitar las colas."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/capri-hero.jpg" alt="Capri desde Sorrento" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/es-es/itinerarios/" class="hover:text-white transition-colors">Itinerarios</a>
        <span>/</span>
        <span class="text-white">Capri desde Sorrento — 1 día</span>
      </nav>
      <div class="max-w-2xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 1 día</p>
        <h1 class="font-serif text-display text-white mb-4">Capri desde Sorrento</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          25 minutos en hidrofoil y estás en la isla más famosa de Italia. Gruta Azul a primera hora, Monte Solaro en Anacapri, Farallones por la tarde: la jornada perfecta en Capri.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-4xl mx-auto">
      <div class="grid grid-cols-3 gap-6">
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Duración</p><p class="font-bold text-charcoal text-lg">1 día</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Coste transporte</p><p class="font-bold text-charcoal text-lg">~€40–60</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Dificultad</p><p class="font-bold text-charcoal text-lg">Fácil</p></div>
        </div>
      </div>
    </section>

    <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">
      <section class="lg:col-span-8">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programa Hora a Hora</h2>
        <div class="relative">
          <div class="space-y-12 border-l-2 border-slate-200 pl-8 ml-3">
            {schedule.map((s) => {
              const badge = transportBadge[s.transport] ?? transportBadge.visit;
              return (
                <div class="relative">
                  <div class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-med-blue ring-4 ring-white shadow-sm"></div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-med-blue font-bold text-sm">{s.time}</span>
                    {badge.label && <span class={`text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded ${badge.cls}`}>{badge.label}</span>}
                  </div>
                  <p class="font-semibold text-charcoal text-base leading-snug">{s.place}</p>
                  <p class="text-slate-600 text-sm mt-1 leading-relaxed">{s.action}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <aside class="lg:col-span-4 mt-12 lg:mt-0">
        <div class="lg:sticky lg:top-24 space-y-6">
          <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2a7 7 0 0 1 7 7c0 3-1.7 5.2-4 6.4V17a1 1 0 0 1-1 1H10a1 1 0 0 1-1-1v-1.6C6.7 14.2 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M10 21h4M12 17v4"/></svg>
              Consejos Prácticos
            </p>
            <ul class="space-y-3">
              {tips.map(tip => (
                <li class="flex gap-2.5 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
              Mapa Rápido
            </p>
            <a href="https://maps.google.com/maps?q=Capri,Italy" target="_blank" rel="noopener" class="flex items-center justify-between bg-slate-50 hover:bg-med-blue/5 rounded-xl px-4 py-3 text-sm text-med-blue font-medium transition-colors group">
              Abrir ruta en Google Maps
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </aside>
    </div>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas Frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
