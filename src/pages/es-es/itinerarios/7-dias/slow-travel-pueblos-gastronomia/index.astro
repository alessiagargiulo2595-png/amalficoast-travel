---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Itinerarios', url: '/es-es/itinerarios/' },
  { name: 'Slow Travel - 7 días', url: '/es-es/itinerarios/7-dias/slow-travel-pueblos-gastronomia/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué es el slow travel en la Costa Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "El slow travel en la Costa significa quedarse más días en el mismo pueblo en lugar de moverse cada día, comer en restaurantes locales (no turísticos), caminar por senderos poco conocidos, ir al mercado, comprar productos locales (limones, anchoas, vino tinto de Ravello). Es lo contrario del itinerario todo incluido." }
    },
    {
      "@type": "Question",
      "name": "¿Cuáles son los pueblos menos turísticos de la Costa Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "Los pueblos menos visitados son: Praiano (entre Positano y Amalfi, sin ZTL, playa tranquila), Cetara (famoso por la colatura de anchoas, auténtico), Furore (el pueblo que no existe, construido en el desfiladero), Conca dei Marini (300 habitantes, cerca de la Gruta Esmeralda). Todos accesibles en autobús SITA por la SS163." }
    }
  ]
};

const days = [
  { day: 'Día 1', title: 'Llegada a Praiano', items: ['Praiano: el pueblo central sin ZTL. Menos turistas que Positano, precios más bajos.', 'Playa Gavitella: pequeña, bonita, accesible a pie.', 'Cena en una trattoria del puerto: pescado del día.'] },
  { day: 'Día 2', title: 'Sendero de los Dioses', items: ['Autobús SITA a Amalfi, luego a Agerola (inicio del sendero).', 'Sendero de los Dioses (Agerola→Nocelle, 8 km, 3–4h, exigente).', 'Regreso a Praiano vía Positano en autobús SITA.'] },
  { day: 'Día 3', title: 'Amalfi y Furore', items: ['Autobús SITA a Amalfi. Mañana: mercado del jueves (productos locales, mozzarella, limones).', 'Furore: el Fiordo di Furore, parada a demanda en el autobús SITA. El pueblo en el desfiladero.', 'Museo del Papel de Amalfi: papel artesanal fabricado desde el siglo XIII.'] },
  { day: 'Día 4', title: 'Ravello y Scala', items: ['Autobús a Ravello (25 min). Mañana tranquila sin masas a las 9:00.', 'Sendero Ravello→Scala: 4 km entre olivares y viñedos, vistas sobre el golfo. Almuerzo en Scala.', 'Tarde: aperitivo con vistas, cata de vino tinto de Ravello.'] },
  { day: 'Día 5', title: 'Cetara y Vietri', items: ['Autobús SITA hacia el este hasta Cetara (famoso por su colatura de anchoas DOP). Mercado de pescado.', 'Visita al Museo de la Colatura y compra directa a los productores.', 'Vietri sul Mare: cerámica, Museo de la Cerámica. Paseo por el frente marítimo.'] },
  { day: 'Día 6', title: 'Valle delle Ferriere', items: ['Mañana: senderismo Valle delle Ferriere desde Amalfi (7 km ida y vuelta, 3h, fácil–moderado). Cascadas y helechos tropicales.', 'Tarde: baño en las calas aisladas cerca de Amalfi o tour en kayak.', 'Cena de pescado fresco en Amalfi.'] },
  { day: 'Día 7', title: 'Mercado y partida', items: ['Mañana libre en el mercado local. Comprar productos típicos: limoncello artesanal, anchoas, cerámica.', 'Larga comida en una trattoria. Despedidas.', 'Autobús SITA a Salerno (60 min) o Sorrento (90 min) para trenes o aeropuerto.'] },
];
---

<BaseLayout
  title="Slow Travel Costa Amalfitana 7 Días 2026 | Pueblos, Gastronomía y Senderos"
  description="Itinerario slow travel de 7 días por la Costa Amalfitana: Praiano, Furore, Cetara, Valle delle Ferriere y Sendero de los Dioses. Pueblos auténticos, mercados locales y gastronomía."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Slow travel Costa Amalfitana" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/es-es/itinerarios/" class="hover:text-white transition-colors">Itinerarios</a>
        <span>/</span>
        <span class="text-white">Slow Travel - 7 días</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 7 días</p>
        <h1 class="font-serif text-display text-white mb-4">Slow Travel: Pueblos y Gastronomía</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Una semana lenta entre pueblos auténticos, mercados locales y senderos poco conocidos. Praiano como base, Furore, Cetara, Valle delle Ferriere. La Costa Amalfitana sin prisa, sin visitas guiadas.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duración</p>
          <p class="font-semibold text-charcoal">7 días / 6 noches</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base</p>
          <p class="font-semibold text-charcoal">Praiano o Amalfi</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Mejor temporada</p>
          <p class="font-semibold text-charcoal">May–Jun / Sep–Oct</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Ritmo</p>
          <p class="font-semibold text-charcoal">Lento</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programa día a día</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Productos que no hay que perderse</p>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <p class="font-semibold mb-1">Limón sfusato amalfitano IGP</p>
          <p class="text-white/70">Los enormes limones de la Costa: aroma único, piel gruesa. Comprarlos directamente a los productores de Amalfi o Minori.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Colatura de anchoas de Cetara DOP</p>
          <p class="text-white/70">Garum moderno: un líquido ámbar de anchoas fermentadas. Cetara produce la mejor versión DOP de Italia.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Vino de Ravello</p>
          <p class="text-white/70">Los viñedos en altitud producen un tinto ligero y aromático. Cata en las bodegas de Ravello.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Cerámica de Vietri sul Mare</p>
          <p class="text-white/70">La capital italiana de la cerámica: azulejos, platos y obras pintadas a mano. Elegir los talleres artesanales locales.</p>
        </div>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
