---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Itinerarios', url: '/es-es/itinerarios/' },
  { name: 'Gran Tour — 7 días', url: '/es-es/itinerarios/7-dias/gran-tour-costa-peninsula/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo organizar 7 días entre la Costa Amalfitana y la Península Sorrentina?",
      "acceptedAnswer": { "@type": "Answer", "text": "El recorrido clásico: 2 noches en Nápoles (días 1–2), luego Sorrento o Amalfi como base para la Costa (días 3–5), con excursión a Capri (día 4 o 5), y las islas al final (días 6–7). Con autobús SITA, Circumvesuviana e hidrofoils es posible hacerlo todo sin coche." }
    },
    {
      "@type": "Question",
      "name": "¿Cuántas noches en Nápoles antes de la Costa?",
      "acceptedAnswer": { "@type": "Answer", "text": "1–2 noches son suficientes para Nápoles: Spaccanapoli, Museo Arqueológico Nacional, pizza auténtica, Certosa di San Martino. Con 2 noches se puede incluir Herculano o Pompeya como excursión de día. Nápoles es el punto de llegada y salida natural para toda la región." }
    }
  ]
};

const days = [
  { day: 'Día 1', title: 'Nápoles', items: ['Llegada a Nápoles. Spaccanapoli, centro histórico UNESCO.', 'Museo Arqueológico Nacional: hallazgos de Pompeya, mosaicos, bronces.', 'Pizza auténtica en el barrio histórico: Da Michele, Sorbillo o Brandi.'] },
  { day: 'Día 2', title: 'Pompeya o Herculano', items: ['Excursión en Circumvesuviana: excavaciones de Herculano (mañana, 2–3h) + Vesubio (tarde).', 'Alternativa: Pompeya todo el día (3–4h en el yacimiento).', 'Regreso a Nápoles para cenar.'] },
  { day: 'Día 3', title: 'Sorrento y llegada a la Costa', items: ['Circumvesuviana Nápoles→Sorrento (70 min). Check-in Sorrento o Amalfi.', 'Tarde: centro de Sorrento, Vallone dei Mulini, Marina Grande.', 'Autobús SITA a Positano (opcional, 50 min): primer contacto con la Costa.'] },
  { day: 'Día 4', title: 'Capri', items: ['Hidrofoil de Sorrento a Capri (20–25 min). Primer servicio 07:30.', 'Gruta Azul a primera hora. Anacapri y Monte Solaro en telesilla.', 'Faraglioni por la tarde. Aperitivo en la Piazzetta. Regreso al atardecer.'] },
  { day: 'Día 5', title: 'Amalfi y Ravello', items: ['Autobús SITA Sorrento→Amalfi (90 min) o ferry Sorrento→Amalfi.', 'Catedral, Claustro del Paraíso, Museo del Papel.', 'Autobús a Ravello (25 min): Villa Rufolo, Villa Cimbrone. Cena en Amalfi.'] },
  { day: 'Día 6', title: 'Positano y tour en barco', items: ['Autobús SITA a Positano (45 min desde Amalfi). Mañana libre en la playa.', 'Tour en barco desde Positano (Gruta Esmeralda, calas, ~€50–80, 4h).', 'Regreso a Amalfi o Positano. Cena en el puerto.'] },
  { day: 'Día 7', title: 'Ischia o Procida y salida', items: ['Ferry Amalfi/Nápoles→Ischia o Procida (excursión media jornada).', 'Procida: Marina Corricella, Terra Murata, playa del Pozzo Vecchio.', 'Regreso a Nápoles para la salida.'] },
];
---

<BaseLayout
  title="Gran Tour Costa Amalfitana 7 Días 2026 | Nápoles, Capri, Positano, Amalfi"
  description="Itinerario completo de 7 días: Nápoles, Costa Amalfitana, Capri e islas del Golfo. Pompeya, Sorrento, Positano, Amalfi, Ravello — el Gran Tour del sur de Italia."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Gran Tour Costa Amalfitana" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <a href="/es-es/itinerarios/" class="hover:text-white transition-colors">Itinerarios</a>
        <span>/</span>
        <span class="text-white">Gran Tour — 7 días</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 7 días</p>
        <h1 class="font-serif text-display text-white mb-4">Gran Tour: Costa y Península</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Una semana para verlo todo: Nápoles, Pompeya, Sorrento, Capri, Positano, Amalfi, Ravello y una isla. El Gran Tour del Golfo de Nápoles — sin coche, solo transporte público.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duración</p>
          <p class="font-semibold text-charcoal">7 días / 6 noches</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Bases</p>
          <p class="font-semibold text-charcoal">Nápoles + Amalfi/Sorrento</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transporte</p>
          <p class="font-semibold text-charcoal">Tren + autobús + ferries</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Presupuesto transporte</p>
          <p class="font-semibold text-charcoal">~€80–120</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programa día a día</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consejos para el Gran Tour</p>
      <ul class="space-y-2">
        {[
          'Campania Express: billete de día en la Circumvesuviana (válido Nápoles–Sorrento–Pompeya–Herculano) ~€10.',
          'Reservar Capri y la Gruta Azul con 1–2 días de antelación en julio–agosto.',
          'Cambiar de base a mitad del viaje: 2 noches Nápoles + 3 noches Amalfi/Sorrento + 1 noche isla (opcional).',
          'El día del tour en barco es flexible: reprogramarlo según el estado del mar.',
          'Llevar zapatos cómodos para los adoquines de Nápoles y las escaleras de Positano.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
