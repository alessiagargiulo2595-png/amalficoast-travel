---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Eventos', url: '/es-es/eventos/' },
  { name: 'Gustamincanto – Vico Equense', url: '/es-es/eventos/peninsula-sorrentina/gustamincanto-vico-equense/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Gustamincanto Vico Equense 2026",
  "startDate": "2026-09-01",
  "endDate": "2026-09-30",
  "location": {
    "@type": "Place",
    "name": "Centro histórico, Vico Equense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vico Equense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/es-es/eventos/peninsula-sorrentina/gustamincanto-vico-equense/"
};

const facts = [
  { dt: 'Período', dd: 'Septiembre 2026' },
  { dt: 'Lugar', dd: 'Centro histórico, Vico Equense' },
  { dt: 'Tipo', dd: 'Festival gastronómico' },
  { dt: 'Especialidad', dd: 'Provolone del Monaco DOP' },
  { dt: 'Desde Nápoles', dd: 'Circumvesuviana, 45 min' },
];
---

<BaseLayout
  title="Gustamincanto Vico Equense 2026 – Excelencia Gastronómica de la Península"
  description="El Gustamincanto en Vico Equense en septiembre de 2026. Festival gastronómico con Provolone del Monaco DOP y chefs con estrella en los callejones medievales de Vico Equense."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/vico-equense-hero.jpg"
      alt="Gustamincanto, Vico Equense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">Septiembre 2026</span>
        <span class="text-white/70 text-sm">Vico Equense, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Gustamincanto</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Excelencia gastronómica de la Península Sorrentina en los callejones medievales de Vico Equense.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Sobre el Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>El Gustamincanto es el evento gastronómico de referencia de la Península Sorrentina. En los callejones medievales de Vico Equense, productores locales y chefs con estrella presentan los mejores productos de la región – sobre todo el Provolone del Monaco DOP, el queso emblemático de la península.</p>
            <p>El festival combina degustaciones, demostraciones de cocina y encuentros con productores en una experiencia que celebra tanto la tradición culinaria como la innovación gastronómica de la Campania. Vico Equense en sí es una joya escondida con vistas panorámicas al golfo de Nápoles.</p>
          </div>
        </div>

        <!-- Los Productos -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Los Productos</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Provolone del Monaco DOP</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">El queso de la península</h4>
              <p class="text-slate-600 text-sm leading-relaxed">El Provolone del Monaco DOP se produce únicamente en la Península Sorrentina, con la leche de las vacas locales agerolesas. Su sabor inconfundible lo convierte en uno de los mejores quesos del sur de Italia.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Alta cocina</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Excelencia en el plato</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Reconocidos chefs de la Campania y más allá presentan creaciones que interpretan los productos locales en un contexto culinario moderno – tradición encuentra innovación.</p>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Cómo llegar</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transporte</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servicio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Desde Nápoles Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Aprox. 45 min, parada Vico Equense</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Coche</td>
                  <td class="px-6 py-4 text-slate-600">Autopista A3 Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Salida Castellammare di Stabia</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Detalles del Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Recomendamos llegar con antelación. Consulta el programa actualizado en los canales oficiales.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
