---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Eventos', url: '/es-es/eventos/' },
  { name: 'Sorrento Meeting', url: '/es-es/eventos/peninsula-sorrentina/sorrento-meeting-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Sorrento Meeting 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Claustro de San Francesco, Sorrento",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sorrento",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/es-es/eventos/peninsula-sorrentina/sorrento-meeting-cultura/"
};

const facts = [
  { dt: 'Período', dd: 'Jun–Jul 2026' },
  { dt: 'Lugar', dd: 'Claustro de San Francesco' },
  { dt: 'Tipo', dd: 'Ciclo literario' },
  { dt: 'Acceso', dd: 'Reserva recomendada' },
  { dt: 'Desde Nápoles', dd: 'Circumvesuviana 70 min' },
];
---

<BaseLayout
  title="Sorrento Meeting 2026 – Literatura y Periodismo en el Claustro Gótico-Árabe"
  description="El Sorrento Meeting de junio a julio de 2026. Encuentros vespertinos con autores de renombre internacional en el claustro gótico-árabe del siglo XIV de San Francesco."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Sorrento Meeting, Claustro de San Francesco"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">Jun–Jul 2026</span>
        <span class="text-white/70 text-sm">Sorrento, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Sorrento Meeting</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Literatura y periodismo internacional en el claustro del siglo XIV.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Sobre el Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Una serie de encuentros literarios y periodísticos en el Claustro de San Francesco. Reuniones vespertinas con autores de renombre internacional. El claustro gótico-árabe del siglo XIV ofrece un escenario único para los encuentros culturales de este ciclo de verano.</p>
            <p>Los encuentros suelen tener lugar al atardecer, aprovechando la mágica luz vespertina del claustro. Los participantes pueden continuar la velada en los restaurantes y terrazas panorámicas del centro de Sorrento.</p>
          </div>
        </div>

        <!-- El Ciclo Cultural -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">El Ciclo Cultural</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Encuentros con autores</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Literatura internacional</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Escritores, periodistas e intelectuales de renombre internacional se turnan en el claustro para presentar sus obras y dialogar con el público en un formato abierto e informal.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">El Claustro</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Un escenario único</h4>
              <p class="text-slate-600 text-sm leading-relaxed">El Claustro de San Francesco, con sus arcos gótico-árabes del siglo XIV, es uno de los lugares más evocadores de Sorrento y un activo centro cultural durante todo el verano.</p>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Cómo llegar</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transporte</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servicio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Desde Nápoles Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">70 minutos, parada Sorrento</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Desde la costa o Nápoles</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Puerto de Sorrento, conexiones con las islas</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">A pie</td>
                  <td class="px-6 py-4 text-slate-600">Desde el centro de Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minutos desde la Piazza Tasso</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Detalles del Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Recomendamos llegar con antelación. Consulta el programa actualizado en los canales oficiales.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
