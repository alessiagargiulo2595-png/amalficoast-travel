---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Eventos', url: '/es-es/eventos/' },
  { name: "Madonna della Libera – Sant'Agnello", url: '/es-es/eventos/peninsula-sorrentina/madonna-della-libera/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Madonna della Libera Sant'Agnello 2026",
  "startDate": "2026-09-13",
  "endDate": "2026-09-13",
  "location": {
    "@type": "Place",
    "name": "Sant'Agnello",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sant'Agnello",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/es-es/eventos/peninsula-sorrentina/madonna-della-libera/"
};

const facts = [
  { dt: 'Fecha', dd: '13 septiembre 2026' },
  { dt: 'Lugar', dd: "Sant'Agnello" },
  { dt: 'Tipo', dd: 'Fiesta de barrio' },
  { dt: 'Ambiente', dd: 'Tradicional y auténtico' },
  { dt: 'Desde Sorrento', dd: '5 min en autobús' },
];
---

<BaseLayout
  title="Madonna della Libera Sant'Agnello 2026 – Fiesta de Barrio de la Península"
  description="La fiesta de la Madonna della Libera en Sant'Agnello el 13 de septiembre de 2026. Fiesta de barrio local que preserva el espíritu auténtico de las tradiciones de la Península Sorrentina."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Madonna della Libera, Sant'Agnello"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">13 sep 2026</span>
        <span class="text-white/70 text-sm">Sant'Agnello, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Madonna della Libera</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        La fiesta de barrio con el sabor de las celebraciones de antaño.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Sobre el Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Una fiesta de barrio que preserva el sabor de las celebraciones de antaño, con iluminaciones tradicionales y productos locales. Una oportunidad para vivir la Península Sorrentina lejos de los flujos turísticos del verano.</p>
            <p>Sant'Agnello, a pocos minutos de Sorrento, mantiene su propia identidad comunitaria. La fiesta de la Madonna della Libera es uno de esos eventos que los residentes defienden con orgullo como patrimonio de su barrio.</p>
          </div>
        </div>

        <!-- La Celebración -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">La Celebración</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Iluminaciones tradicionales</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Las luces del barrio</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Las calles de Sant'Agnello se adornan con iluminaciones tradicionales que evocan el ambiente festivo de la antigua fiesta de barrio del sur de Italia – íntima, cálida y profundamente local.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Productos locales</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">El sabor del territorio</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Puestos de productos locales, street food con especialidades sorrentinas y la convivialidad de la comunidad hacen de esta fiesta una auténtica muestra de la vida en la Península.</p>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Cómo llegar</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transporte</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servicio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Autobús local</td>
                  <td class="px-6 py-4 text-slate-600">Desde Sorrento Piazza Tasso</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minutos, muy frecuente</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">A pie</td>
                  <td class="px-6 py-4 text-slate-600">Desde el centro de Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Paseo agradable de 20 min por la carretera costera</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Detalles del Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Recomendamos llegar con antelación. Consulta el programa actualizado en los canales oficiales.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
