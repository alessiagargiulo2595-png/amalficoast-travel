---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Eventos', url: '/es-es/eventos/' },
  { name: 'Ischia Global Film & Music Fest', url: '/es-es/eventos/islas/ischia-global-film-festival/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Ischia Global Film & Music Festival 2026",
  "startDate": "2026-07-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Lacco Ameno & Ischia Porto",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ischia",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/es-es/eventos/islas/ischia-global-film-festival/"
};

const facts = [
  { dt: 'Período', dd: 'Julio 2026' },
  { dt: 'Lugares', dd: 'Lacco Ameno & Ischia Porto' },
  { dt: 'Tipo', dd: 'Festival de cine y música' },
  { dt: 'Ambiente', dd: 'Glamour y sol mediterráneo' },
  { dt: 'Desde Nápoles', dd: 'Ferry, aprox. 80 min' },
];
---

<BaseLayout
  title="Ischia Global Film & Music Festival 2026 – Glamour de Hollywood en la Isla"
  description="El Ischia Global Film & Music Festival en julio de 2026. Estrenos mundiales, ceremonias de premios y estrellas internacionales en las plazas y hoteles de lujo de Ischia."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ischia-hero.jpg"
      alt="Ischia Global Film & Music Festival"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">Julio 2026</span>
        <span class="text-white/70 text-sm">Ischia, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Ischia Global Film & Music Fest</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        El glamour de Hollywood bajo el sol mediterráneo de la isla de Ischia.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Sobre el Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>El Ischia Global Film & Music Festival es uno de los eventos culturales más glamurosos del verano mediterráneo. Estrellas internacionales del cine y la música se reúnen en la isla para estrenos mundiales, ceremonias de premios y memorables eventos nocturnos al aire libre.</p>
            <p>El escenario es único: las plazas de Lacco Ameno, las terrazas de los hoteles de lujo y los espacios históricos de Ischia Porto se transforman en escenarios festivaleros donde la cultura cinematográfica y la magia de la isla se encuentran.</p>
          </div>
        </div>

        <!-- El Festival -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">El Festival</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Proyecciones</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Estrenos mundiales y premios</h4>
              <p class="text-slate-600 text-sm leading-relaxed">El festival proyecta producciones internacionales, otorga galardones a los cineastas y ofrece al público la oportunidad de conocer a estrellas y directores – un encuentro único entre el cine y la cultura insular.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Programa musical</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Conciertos y eventos</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Junto al programa cinematográfico, el festival ofrece un rico programa musical con conciertos de artistas internacionales en los más bellos escenarios de la isla – desde escenarios al aire libre hasta villas históricas.</p>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Cómo llegar</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transporte</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servicio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Desde Nápoles Molo Beverello</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Aprox. 80 min a Ischia Porto</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Aliscafo</td>
                  <td class="px-6 py-4 text-slate-600">Desde Nápoles o Pozzuoli</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Aprox. 45 min, conexiones frecuentes</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Autobús (en la isla)</td>
                  <td class="px-6 py-4 text-slate-600">Ischia Porto → Lacco Ameno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Línea CD/CS, aprox. 20 min</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Detalles del Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Recomendamos llegar con antelación. Consulta el programa actualizado en los canales oficiales.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
