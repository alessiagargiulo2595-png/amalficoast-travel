---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Eventos', url: '/es-es/eventos/' },
  { name: 'Anacapri Settembre Borgo', url: '/es-es/eventos/islas/anacapri-settembre-borgo/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Anacapri Settembre Borgo 2026",
  "startDate": "2026-09-01",
  "endDate": "2026-09-10",
  "location": {
    "@type": "Place",
    "name": "Centro histórico, Anacapri",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Anacapri",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/es-es/eventos/islas/anacapri-settembre-borgo/"
};

const facts = [
  { dt: 'Fecha', dd: '1–10 septiembre 2026' },
  { dt: 'Lugar', dd: 'Centro histórico, Anacapri' },
  { dt: 'Tipo', dd: 'Festival folclórico y competición de barrios' },
  { dt: 'Especial', dd: 'Patios privados abiertos' },
  { dt: 'Desde Capri', dd: 'Autobús o telesilla' },
];
---

<BaseLayout
  title="Anacapri Settembre Borgo 2026 – El Capri Auténtico en Septiembre"
  description="Anacapri Settembre Borgo, 1–10 septiembre 2026. Festival folclórico con la competencia entre los cuatro barrios de Anacapri y patios privados abiertos a los visitantes."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/capri-hero.jpg"
      alt="Anacapri Settembre Borgo, Capri"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">1–10 sep 2026</span>
        <span class="text-white/70 text-sm">Anacapri, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Anacapri Settembre Borgo</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        La competencia entre barrios, patios abiertos y el Capri auténtico de septiembre.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Sobre el Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>El Settembre Borgo es el evento más auténtico de Capri – un festival folclórico que pone en el centro la competencia entre los cuatro barrios históricos de Anacapri. Cada barrio decora sus calles, organiza eventos y abre patios privados a los visitantes.</p>
            <p>En septiembre Anacapri se libera del turismo de temporada alta – las temperaturas son agradables, los precios más bajos y el ambiente es el de una pequeña comunidad que celebra su patrimonio. El momento ideal para conocer el "otro Capri".</p>
          </div>
        </div>

        <!-- El Festival -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">El Festival</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Competición de barrios</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Los cuatro barrios</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Los cuatro barrios históricos de Anacapri – Capodimonte, Caprile, La Ninfa y Pagliaro – compiten amistosamente entre sí. Decoraciones, música, comida y juegos determinan al ganador.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Patios abiertos</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Una mirada tras las fachadas</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Durante diez días los particulares abren sus patios y jardines a los visitantes – una rara oportunidad de ver la vida auténtica tras los blancos muros de Anacapri, lejos de los circuitos turísticos.</p>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Cómo llegar</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transporte</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servicio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry + autobús</td>
                  <td class="px-6 py-4 text-slate-600">Desde Nápoles, Sorrento o Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ferry a Capri Porto, autobús a Anacapri</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Telesilla</td>
                  <td class="px-6 py-4 text-slate-600">Desde Capri ciudad</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Telesilla Monte Solaro hasta Anacapri</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Detalles del Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Recomendamos llegar con antelación. Consulta el programa actualizado en los canales oficiales.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
