---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Eventos', url: '/es-es/eventos/' },
  { name: 'Fiesta del Pescado – Positano', url: '/es-es/eventos/costa-amalfi/sagra-del-pesce-positano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Fiesta del Pescado Positano 2026",
  "startDate": "2026-09-26",
  "endDate": "2026-09-26",
  "location": {
    "@type": "Place",
    "name": "Playa Fornillo, Positano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/es-es/eventos/costa-amalfi/sagra-del-pesce-positano/"
};

const facts = [
  { dt: 'Fecha', dd: '26 de septiembre 2026' },
  { dt: 'Lugar', dd: 'Playa Fornillo, Positano' },
  { dt: 'Especialidad', dd: 'Frittura di paranza' },
  { dt: 'Lanzadera', dd: 'Embarcación gratuita' },
  { dt: 'Entrada', dd: 'Gratuita' },
];
---

<BaseLayout
  title="Fiesta del Pescado Positano 2026 – Frittura di Paranza en la Playa Fornillo"
  description="La Fiesta del Pescado en Positano el 26 de septiembre de 2026. Plato de pescado local en la playa Fornillo con lanzadera marítima gratuita desde el embarcadero principal."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Fiesta del Pescado, Playa Fornillo, Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">26 sep 2026</span>
        <span class="text-white/70 text-sm">Positano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Fiesta del Pescado</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        La Frittura di paranza anuncia el fin del verano en la playa Fornillo.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Sobre el Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Una fiesta de pescado local en la tranquila playa Fornillo, alejada de las concurridas playas principales de Positano. El punto culminante: la Frittura di paranza, un plato mixto de pescado fresco del mar Tirreno, preparado al momento y ofrecido gratuitamente.</p>
            <p>Una embarcación lanzadera gratuita conecta el embarcadero principal de Positano con la playa Fornillo durante toda la fiesta – ideal para llegar sin estrés y disfrutar de la silueta costera desde el agua.</p>
          </div>
        </div>

        <!-- La Fiesta -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">La Fiesta</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Frittura di paranza</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">El plato tradicional</h4>
              <p class="text-slate-600 text-sm leading-relaxed">La Frittura di paranza es un plato típico de la Costa Amalfi: pequeños peces de la pesca local, rebozados en harina y fritos en aceite de oliva hasta quedar dorados – simple e incomparable.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Playa Fornillo</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">La playa tranquila</h4>
              <p class="text-slate-600 text-sm leading-relaxed">A diferencia de la animada Spiaggia Grande, la playa Fornillo es un lugar más tranquilo, preferido por los pescadores – más auténtico y menos turístico.</p>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Cómo llegar</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transporte</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servicio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Lanzadera marítima</td>
                  <td class="px-6 py-4 text-slate-600">Desde el embarcadero principal</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Gratuita durante la fiesta</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">A pie</td>
                  <td class="px-6 py-4 text-slate-600">Desde el centro de Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">15 min por el sendero costero</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Desde Amalfi o Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Muelle de Positano, luego lanzadera</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Detalles del Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Recomendamos llegar con antelación. Consulta el programa actualizado en los canales oficiales.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
