---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Eventos', url: '/es-es/eventos/' },
  { name: 'Festival de Ravello', url: '/es-es/eventos/costa-amalfi/ravello-festival/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Festival de Ravello 2026",
  "startDate": "2026-07-04",
  "endDate": "2026-09-05",
  "location": {
    "@type": "Place",
    "name": "Villa Rufolo, Ravello",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ravello",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/es-es/eventos/costa-amalfi/ravello-festival/"
};

const facts = [
  { dt: 'Período', dd: '4 jul – 5 sep 2026' },
  { dt: 'Lugar', dd: 'Villa Rufolo, Ravello' },
  { dt: 'Tipo', dd: 'Música clásica y contemporánea' },
  { dt: 'Entradas', dd: 'Reserva recomendada' },
  { dt: 'Desde Amalfi', dd: 'Autobús + 5 min a pie' },
];
---

<BaseLayout
  title="Festival de Ravello 2026 – Música entre el Cielo y el Mar"
  description="El Festival de Ravello 2026, del 4 de julio al 5 de septiembre. La 74.ª edición del festival cultural más prestigioso de la Costa Amalfi en el legendario escenario de la Villa Rufolo."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ravello-hero.jpg"
      alt="Festival de Ravello, Villa Rufolo"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">4 jul – 5 sep 2026</span>
        <span class="text-white/70 text-sm">Ravello, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Festival de Ravello</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Música entre el cielo y el mar en el legendario escenario de la Villa Rufolo.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Sobre el Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>La 74.ª edición del festival cultural más prestigioso de la Costa Amalfi. Conciertos en el legendario escenario de la Villa Rufolo con vistas al mar: una experiencia única donde la música y el paisaje se fusionan en una obra de arte total.</p>
            <p>El Festival de Ravello es uno de los festivales de música más importantes de Italia. Cada año atrae a orquestas de clase mundial, directores y solistas al teatro de la Villa Rufolo, cuyo escenario se alza directamente sobre el mar Tirreno.</p>
          </div>
        </div>

        <!-- El Programa -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">El Programa</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Conciertos orquestales</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Orquestas de clase mundial</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Orquestas de renombre internacional actúan en la terraza de la Villa Rufolo. El mar forma el telón de fondo natural para conciertos nocturnos inolvidables.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">El escenario</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Villa Rufolo</h4>
              <p class="text-slate-600 text-sm leading-relaxed">La villa medieval del siglo XIII con sus jardines moriscos y su terraza sobre el mar es considerada uno de los escenarios de concierto más hermosos del mundo.</p>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Cómo llegar</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transporte</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servicio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Autobús SITA</td>
                  <td class="px-6 py-4 text-slate-600">Desde Amalfi o Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Parada Ravello, 5 min a pie hasta la Villa</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry + autobús</td>
                  <td class="px-6 py-4 text-slate-600">Desde Nápoles o Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ferry a Amalfi, luego autobús a Ravello</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Taxi/Transfer</td>
                  <td class="px-6 py-4 text-slate-600">Desde cualquier pueblo costero</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Recomendado para eventos nocturnos</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Detalles del Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Recomendamos reservar las entradas con antelación. Consulta el programa actualizado en los canales oficiales.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
