---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Guía práctica', url: '/es-es/guia/' },
  { name: 'Aparcamiento & ZTL', url: '/es-es/guia/aparcamiento-ztl/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Se puede ir en coche a Positano?",
      "acceptedAnswer": { "@type": "Answer", "text": "En verano Positano está cerrado al tráfico de 9:00 a 18:00 (ZTL). Solo los residentes y los huéspedes de hoteles pueden entrar en coche. Mejor consejo: aparca en Sorrento o Praiano y llega en bus SITA o ferry." }
    },
    {
      "@type": "Question",
      "name": "¿Dónde aparcar para visitar la Costa Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "Mejores opciones: 1) Dejar el coche en Salerno o Vietri sul Mare y tomar el bus/ferry. 2) Aparcar en Sorrento (Garaje Achille Lauro, ~€2/h) y tomar el bus SITA o el hidrofoil. 3) Usar los aparcamientos de pago de Amalfi (Luna Rossa, Flavio Gioia, ~€4–5/h)." }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta aparcar en Amalfi?",
      "acceptedAnswer": { "@type": "Answer", "text": "Los principales aparcamientos de Amalfi (Luna Rossa y Flavio Gioia) cuestan ~€4–5/hora o ~€25–30/día. Casi siempre llenos en julio y agosto. Se recomienda llegar antes de las 9:00 o usar el transporte público." }
    }
  ]
};

const ztlData = [
  { location: 'Positano', ztl: 'Sí', period: 'Jun–Sep (9:00–18:00)', note: 'Acceso reservado a residentes y huéspedes de hoteles. Bus SITA o ferry recomendados.' },
  { location: 'Amalfi', ztl: 'Sí', period: 'Todo el año (centro)', note: 'ZTL permanente en el núcleo histórico. Aparcamientos de pago en el paseo marítimo (~€4/h).' },
  { location: 'Ravello', ztl: 'Sí', period: 'Verano (10:00–19:00)', note: 'Solo bus SITA desde Amalfi (25 min, ~€1,50) o coche con autorización del hotel.' },
  { location: 'Sorrento', ztl: 'Sí', period: 'Verano (centro)', note: 'Garajes cubiertos disponibles. Piazza Lauro ~€2/h.' },
  { location: 'Praiano', ztl: 'No', period: '—', note: 'Aparcamientos gratuitos y de pago en la SS163. Excelente punto de parada.' },
  { location: 'Maiori', ztl: 'No', period: '—', note: 'Aparcamientos disponibles en el paseo marítimo. Más fácil que los pueblos del oeste.' },
  { location: 'Minori', ztl: 'No', period: '—', note: 'Aparcamientos en el paseo marítimo, gratuitos o de bajo coste.' },
];
---

<BaseLayout
  title="Aparcamiento & ZTL Costa Amalfitana 2026 | Dónde Dejar el Coche"
  description="Guía completa de aparcamientos y zonas ZTL en la Costa Amalfitana: Positano, Amalfi, Ravello, Sorrento. Dónde aparcar y cómo llegar a los pueblos sin estrés."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/parcheggi-hero.jpg" alt="Sorrento, Península Sorrentina" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white/60">Guía práctica</span>
        <span>/</span>
        <span class="text-white">Aparcamiento & ZTL</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Guía práctica</p>
        <h1 class="font-serif text-display text-white mb-4">Aparcamiento & Zonas ZTL</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          La Costa Amalfitana en verano es una pesadilla para los conductores: ZTL en todas partes, carreteras estrechas y aparcamientos caros. Consejo principal: deja el coche y usa el transporte público.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="bg-red-50 border border-red-200 rounded-[2rem] p-6 mb-8">
        <p class="font-semibold text-red-800 mb-2">⚠️ Atención a las ZTL</p>
        <p class="text-sm text-red-700">Las ZTL (Zonas de Tráfico Limitado) de la Costa Amalfitana están vigiladas con cámaras. Entrar sin autorización conlleva una multa de €80–160 que llega directamente a la empresa de alquiler o a tu domicilio.</p>
      </div>
      <p class="text-xl leading-relaxed text-charcoal">
        La mejor estrategia es el "aparcamiento estratégico": dejar el coche en un punto accesible (Salerno, Vietri, Sorrento o Praiano) y usar desde allí buses, ferrys o hidrofoils.
      </p>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">ZTL y aparcamiento en cada pueblo</h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-med-blue/5 text-charcoal">
              <th class="text-left px-4 py-3 font-semibold">Pueblo</th>
              <th class="text-left px-4 py-3 font-semibold">ZTL</th>
              <th class="text-left px-4 py-3 font-semibold">Período</th>
              <th class="text-left px-4 py-3 font-semibold">Consejo</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {ztlData.map(r => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-semibold text-charcoal">{r.location}</td>
                <td class="px-4 py-3">
                  {r.ztl === 'Sí'
                    ? <span class="text-[10px] bg-red-50 text-red-600 px-2 py-0.5 rounded-full font-medium">Sí</span>
                    : <span class="text-[10px] bg-med-blue/5 text-med-blue px-2 py-0.5 rounded-full font-medium">No</span>
                  }
                </td>
                <td class="px-4 py-3 text-slate-500">{r.period}</td>
                <td class="px-4 py-3 text-slate-600 text-xs">{r.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
