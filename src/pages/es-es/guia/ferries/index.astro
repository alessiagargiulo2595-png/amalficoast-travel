---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Guía práctica', url: '/es-es/guia/' },
  { name: 'Ferrys e Hidrofoils', url: '/es-es/guia/ferries/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuál es la diferencia entre ferry e hidrofoil en la Costa Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "El ferry (traghetto) es más lento (50–90 min Nápoles–Capri) pero más económico y estable. El hidrofoil (aliscafo) es más rápido (40–50 min) pero más caro y no circula con mar agitado. En verano, prefiere el hidrofoil para ahorrar tiempo; en invierno o mal tiempo, el ferry es más fiable." }
    },
    {
      "@type": "Question",
      "name": "¿Se pueden reservar los ferrys online?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí, casi todas las compañías permiten la reserva online: nlg.it, alilauro.it, snav.it, travelmar.it, caremar.it. En verano (julio–agosto) se recomienda reservar con al menos 1–2 días de antelación." }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta el ferry de Nápoles a Capri?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ferry Nápoles–Capri (Caremar/SNAV): ~€13–15 ida. Hidrofoil (NLG/Alilauro): ~€20–23 ida. Desde Sorrento: ~€18–22 ida y vuelta en hidrofoil." }
    },
    {
      "@type": "Question",
      "name": "¿Circulan los ferrys en invierno?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí, pero con menor frecuencia. Nápoles–Capri: al menos 4–5 travesías al día durante todo el año. Las rutas estacionales (Positano, Amalfi, Salerno) operan de abril a octubre." }
    }
  ]
};

const routes = [
  { from: 'Nápoles Beverello', to: 'Capri', time: '40–50 min (hidrofoil) / 75 min (ferry)', price: '€20–23 / €13–15', companies: 'NLG, Alilauro, SNAV, Caremar', seasonal: false },
  { from: 'Nápoles Beverello', to: 'Ischia (Casamicciola/Porto)', time: '50 min (hidrofoil) / 75 min (ferry)', price: '€20–24 / €12–14', companies: 'Alilauro, SNAV, Caremar, Medmar', seasonal: false },
  { from: 'Nápoles Beverello', to: 'Procida', time: '35 min (hidrofoil)', price: '€15–18', companies: 'Alilauro, SNAV', seasonal: false },
  { from: 'Sorrento', to: 'Capri', time: '20–25 min (hidrofoil)', price: '€18–22', companies: 'NLG, Alilauro', seasonal: false },
  { from: 'Pozzuoli', to: 'Ischia / Procida', time: '35 min / 15 min (ferry)', price: '€10–13 / €7–9', companies: 'Medmar, Caremar', seasonal: false },
  { from: 'Salerno', to: 'Amalfi / Positano / Capri', time: '45 min / 65 min / 100 min', price: '€8–12 / €12–16 / €18–22', companies: 'Travelmar, NLG', seasonal: true },
  { from: 'Nápoles Beverello', to: 'Positano / Amalfi', time: '75 min / 90 min', price: '€15–20 / €18–22', companies: 'NLG, Alilauro', seasonal: true },
];
---

<BaseLayout
  title="Ferrys e Hidrofoils Costa Amalfitana 2026 | Horarios y Precios"
  description="Guía completa de ferrys e hidrofoils en la Costa Amalfitana: Nápoles–Capri, Nápoles–Ischia, Sorrento–Capri, Salerno–Amalfi–Positano. Compañías, horarios y precios actualizados."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/traghetti-hero.jpg" alt="Ferry en la Costa Amalfitana" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white/60">Guía práctica</span>
        <span>/</span>
        <span class="text-white">Ferrys & Hidrofoils</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Guía práctica</p>
        <h1 class="font-serif text-display text-white mb-4">Ferrys & Hidrofoils</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Todas las rutas marítimas de Campania: Nápoles, Sorrento, Salerno, Positano, Amalfi, Capri, Ischia y Procida. Compañías, horarios indicativos y precios actualizados para la temporada 2026.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Todas las rutas principales</h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-med-blue/5 text-charcoal">
              <th class="text-left px-4 py-3 font-semibold">Desde</th>
              <th class="text-left px-4 py-3 font-semibold">Hasta</th>
              <th class="text-left px-4 py-3 font-semibold">Duración</th>
              <th class="text-left px-4 py-3 font-semibold">Precio (ida)</th>
              <th class="text-left px-4 py-3 font-semibold">Compañías</th>
              <th class="text-left px-4 py-3 font-semibold">Estacional</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {routes.map(r => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-medium text-charcoal">{r.from}</td>
                <td class="px-4 py-3">{r.to}</td>
                <td class="px-4 py-3 text-slate-600">{r.time}</td>
                <td class="px-4 py-3 font-mono text-sm">{r.price}</td>
                <td class="px-4 py-3 text-slate-500 text-xs">{r.companies}</td>
                <td class="px-4 py-3">
                  {r.seasonal
                    ? <span class="text-[10px] bg-med-cream text-med-gold px-2 py-0.5 rounded-full font-medium">Abr–Oct</span>
                    : <span class="text-[10px] bg-med-blue/5 text-med-blue px-2 py-0.5 rounded-full font-medium">Todo el año</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-slate-400 mt-2">* Precios y duraciones orientativos. Verifica siempre con las compañías: nlg.it, alilauro.it, snav.it, caremar.it, medmar.it, travelmar.it</p>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consejos prácticos</p>
      <ul class="space-y-2">
        {[
          'En julio y agosto, reserva los billetes el día anterior: las primeras salidas de la mañana (7:00–8:30) se agotan.',
          'Los hidrofoils no salen con mar agitado (Beaufort 4–5): consulta siempre el pronóstico del tiempo marino.',
          'El puerto de embarque en Nápoles para casi todas las rutas es el Molo Beverello (Piazza Municipio). Medmar sale de Pozzuoli.',
          'Con niños pequeños, el ferry es más estable que el hidrofoil.',
          'Los billetes de vuelta se pueden comprar en la isla - no es necesario comprarlos en el trayecto de ida.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
