---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Islas', url: '/es-es/islas/' },
  { name: 'Procida', url: '/es-es/islas/procida/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo ir de Nápoles a Procida?",
      "acceptedAnswer": { "@type": "Answer", "text": "Desde Nápoles Molo Beverello hay hidroplanos (~35 min, Alilauro/SNAV) y ferries (~1 hora, Caremar). La opción más práctica y económica es el ferry desde Pozzuoli (~15 min, Caremar): frecuente, barato (~3 €) y fácil de combinar con el metro de Nápoles (línea 2, estación Pozzuoli). En temporada alta hay también conexiones directas desde Ischia." }
    },
    {
      "@type": "Question",
      "name": "¿Por qué Procida fue Capital de la Cultura 2022?",
      "acceptedAnswer": { "@type": "Answer", "text": "Procida fue elegida Capital Italiana de la Cultura 2022 bajo el lema 'La cultura no excluye'. La distinción reconoció su apuesta por la cultura como herramienta de desarrollo comunitario e inclusión social - no como espectáculo turístico. El programa incluyó residencias de artistas, teatro comunitario y proyectos educativos que continúan hasta hoy." }
    },
    {
      "@type": "Question",
      "name": "¿Qué ver en Marina Corricella?",
      "acceptedAnswer": { "@type": "Answer", "text": "Marina Corricella es el puerto de pescadores más fotografiado del golfo de Nápoles: casas de colores pastel (amarillo, naranja, azul, rosa) apiladas sobre el acantilado sin ninguna carretera que llegue hasta el agua. Solo accesible a pie o en barca. Aquí se rodaron escenas de 'El Cartero y Pablo Neruda' (1994). Por la mañana temprano o al atardecer es cuando la luz y la tranquilidad son perfectas." }
    },
    {
      "@type": "Question",
      "name": "¿Se puede visitar Procida en un solo día?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí. Procida es pequeña (4,1 km²) y se puede recorrer a pie o en bicicleta en un día cómodo. Ruta típica: Marina Grande → Terra Murata (el barrio alto histórico) → Abbazia di San Michele → Marina Corricella → Spiaggia della Chiaiolella. Si solo tienes medio día, céntrate en Marina Corricella y Terra Murata." }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la mejor época para visitar Procida?",
      "acceptedAnswer": { "@type": "Answer", "text": "Abril y mayo son ideales: muy pocos turistas, las calles pertenecen a los isleños, la Semana Santa de Procida es de las más espectaculares del sur de Italia. Junio y septiembre son perfectos para combinar playa y autenticidad. Julio y agosto son los más concurridos pero Procida sigue siendo mucho menos masificada que Capri." }
    }
  ]
};

const fastFacts = [
  { dt: 'Ubicación',       dd: 'Golfo de Nápoles, NA' },
  { dt: 'Superficie',      dd: '4,1 km²' },
  { dt: 'Población',       dd: '~10.000 hab.' },
  { dt: 'Capital Cultura', dd: 'Italia 2022' },
  { dt: 'Desde Nápoles',   dd: '~35 min (hidroplano)' },
  { dt: 'Desde Pozzuoli',  dd: '~15 min (ferry)' },
  { dt: 'Playas',          dd: 'Arena oscura y clara' },
  { dt: 'Mejor época',     dd: 'Abr–Jun / Sep' },
  { dt: 'Moneda',          dd: 'Euro (€)' },
];

const tips = [
  'Llegar el primer ferry de la mañana desde Pozzuoli: 15 minutos, ~3 €, y Marina Corricella completamente vacía.',
  'Alquilar una bicicleta en el puerto: Procida tiene solo 4 km², perfecta para pedalear de playa en playa.',
  'La Semana Santa de Procida (Procesión de los Misterios) es una de las más antiguas y espectaculares de Italia - reservar alojamiento con meses de antelación.',
  'Probar el limoncello de Procida (limones IGP) y la pizza fritta en cualquier bar del puerto.',
];
---

<BaseLayout
  title="Procida 2026: Guía Completa | Marina Corricella y Capital de la Cultura"
  description="Guía completa de Procida: Marina Corricella, Terra Murata, Abbazia di San Michele, playas. Capital Italiana de la Cultura 2022. Cómo llegar, qué ver, cuándo ir."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/procida-hero.jpg" alt="Procida, Marina Corricella" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Isla · Capital de la Cultura 2022 · Sin masas</p>
        <h1 class="font-serif text-display text-white mb-4">Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La más pequeña y auténtica de las islas del golfo. Casas de colores apiladas sobre el acantilado, redes de pesca extendidas en el puerto, callejones que llevan al mar sin avisar. Procida es la Italia que muchos buscan y pocos encuentran: elegida Capital Italiana de la Cultura 2022, sigue siendo sorprendentemente ella misma.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#datos-rapidos" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Datos rápidos
          </a>
          <a href="#como-llegar" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Cómo llegar
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Preguntas frecuentes
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <!-- Intro -->
        <div>
          <p class="text-xl leading-relaxed text-charcoal">
            Procida es la isla más pequeña del golfo de Nápoles (4,1 km²) y la más auténtica. Mientras Capri se llenó de turistas y Ischia de parques termales, Procida mantuvo su identidad de isla de pescadores, con una comunidad real que vive del mar y del turismo con una ecuanimidad admirable.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            El reconocimiento como Capital Italiana de la Cultura 2022 trajo atención internacional pero no masificación. Los isleños preservaron lo más importante: la autenticidad. Marina Corricella, con sus casas de colores sin carreteras, es una de las imágenes más reproducidas de Italia - y en persona supera cualquier fotografía.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabías que...?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1994</p>
              <p class="text-white/60 text-xs italic mt-1">rodaje de "Il Postino" en Procida</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">4,1 km²</p>
              <p class="text-white/60 text-xs italic mt-1">la isla más pequeña del golfo</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">15 min</p>
              <p class="text-white/60 text-xs italic mt-1">desde Pozzuoli en ferry</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            La película "Il Postino" (El Cartero y Pablo Neruda, 1994), ganadora del Oscar a la Mejor Música, fue rodada casi íntegramente en Procida. El director Massimo Troisi murió 12 horas después de terminar el rodaje. La película convirtió la isla en un símbolo cinematográfico de Italia.
          </p>
        </div>

        <!-- What to See -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Qué ver en Procida</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Marina Corricella',
                text: 'El puerto de pescadores más fotogénico del Mediterráneo: casas de colores pastel apiladas en el acantilado sin ninguna carretera que llegue hasta el agua. Solo accesible a pie bajando desde Terra Murata o en barca desde Marina Grande. Aquí se rodó "Il Postino". La luz de primera mañana y del atardecer es especialmente mágica.',
              },
              {
                n: 2,
                title: 'Terra Murata',
                text: 'El barrio histórico amurallado en lo alto de la isla (90 m sobre el mar): callejones medievales, la Abbazia di San Michele Arcangelo (patrón de la isla, con un Cristo Morto procesionado en Semana Santa), palacios barrocos y vistas panorámicas sobre Marina Corricella y todo el golfo. El corazón histórico de Procida.',
              },
              {
                n: 3,
                title: 'Spiaggia della Chiaiolella',
                text: 'La playa más popular de Procida: 300 m de arena oscura en una bahía protegida en el extremo sur-oeste de la isla, frente al islote de Vivara. Ambiente local y relajado, chiringuitos y restaurantes de marisco. Se llega en autobús desde Marina Grande o a pie en 20 minutos desde el centro.',
              },
              {
                n: 4,
                title: 'Riserva Naturale di Vivara',
                text: 'Un islote volcánico de 37 hectáreas unido a Procida por un puente, habitado desde la Edad del Bronce y hoy reserva natural protegida. Las visitas guiadas (previa reserva en el comune) permiten explorar la macchia mediterranea, la flora endemica y los restos arqueológicos. Una rareza ecológica en el golfo.',
              },
              {
                n: 5,
                title: 'Abbazia di San Michele Arcangelo',
                text: 'El monasterio benedictino del siglo XI en Terra Murata alberga obras de arte barrocas, una cripta con cientos de nichos funerarios y el Cristo Morto, una estatua procesionada la noche del Viernes Santo en la celebración de los Misterios - una de las processioni más antiguas y emotivas de Italia.',
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to Get Here -->
        <div id="como-llegar" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Cómo llegar a Procida</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Procida no tiene aeropuerto ni puente. La conexión más rápida y económica es el ferry desde Pozzuoli (15 min). Desde Nápoles hay ferries e hidroplanos todo el año. En temporada hay conexiones desde Ischia.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Desde Pozzuoli</h3><p class="text-white/50 text-sm leading-relaxed">Ferry ~15 min (Caremar). La opción más rápida, económica (~3 €) y frecuente. Pozzuoli es accesible desde Nápoles en metro (línea 2, 20 min).</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Desde Nápoles</h3><p class="text-white/50 text-sm leading-relaxed">Hidroplano ~35 min (SNAV) o ferry ~1 hora (Caremar) desde Molo Beverello. Salidas regulares todo el año, más frecuentes en verano.</p></div>
              </div>
            </div>
            <a href="/es-es/como-llegar/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Guía completa de ferries
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Ferry Schedules -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4">Horarios de ferries - Verano 2026</h3>
          <p class="text-sm text-slate-500 mb-4">Servicios todo el año desde Pozzuoli y Nápoles. Confirmar en los sitios oficiales de las compañías.</p>

          <div class="overflow-x-auto rounded-2xl border border-slate-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Ferries - Pozzuoli → Marina Grande, Procida
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Sale Pozzuoli</th>
                  <th class="text-left px-4 py-3 font-semibold">Llega Procida</th>
                  <th class="text-left px-4 py-3 font-semibold">Compañía</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['06:00', '06:15', 'Caremar'],
                  ['07:30', '07:45', 'Caremar'],
                  ['09:00', '09:15', 'Caremar'],
                  ['11:00', '11:15', 'Caremar'],
                  ['13:30', '13:45', 'Caremar'],
                  ['15:30', '15:45', 'Caremar'],
                  ['17:30', '17:45', 'Caremar'],
                  ['20:00', '20:15', 'Caremar'],
                ].map(([dep, arr, co]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{co}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Hidroplanos - Nápoles Beverello → Marina Grande, Procida
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Sale Nápoles</th>
                  <th class="text-left px-4 py-3 font-semibold">Llega Procida</th>
                  <th class="text-left px-4 py-3 font-semibold">Duración</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['07:30', '08:05', '~35 min'],
                  ['09:00', '09:35', '~35 min'],
                  ['11:30', '12:05', '~35 min'],
                  ['14:00', '14:35', '~35 min'],
                  ['16:30', '17:05', '~35 min'],
                  ['18:30', '19:05', '~35 min'],
                ].map(([dep, arr, dur]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{dur}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Horarios orientativos para el verano de 2026. Confirmar en caremar.it, snav.it.</p>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Los rincones escondidos de Procida</h2>
          <p class="text-slate-500 mb-8">Una isla pequeña con muchos secretos: cuatro lugares que los visitantes de un día no suelen ver.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Spiaggia del Pozzo Vecchio', text: 'La playa donde se rodaron las escenas de "Il Postino": arena oscura rodeada de tufo, completamente apartada del circuito turístico. Accesible solo a pie por un sendero desde Terra Murata. Sin chiringuitos, sin servicios - solo la misma belleza de la película.' },
              { title: 'Belvedere di Punta Pizzaco', text: 'Un mirador casi secreto en la punta norte de la isla: vista panorámica sobre Ischia, el Castello Aragonese y el Vesuvio. Accesible en bicicleta desde Marina Grande en 15 minutos. Al amanecer, la luz dorada sobre el golfo es absolutamente cinematográfica.' },
              { title: 'Rione Terra di Sopra', text: 'Las calles altas de Terra Murata más allá de la Abbazia: pocas casas, poca gente, balcones floridos sobre el mare. El Procida de los isleños, donde los gatos duermen en la calzada y los viejos juegan a las cartas bajo los arcos. Ninguna atracción, perfección total.' },
              { title: 'Spiaggia di Ciraccio', text: 'La playa más larga de Procida (entre Chiaiolella y Vivara): aguas poco profundas, perfectas para niños, con vistas directas al islote de Vivara. Menos popular que Chiaiolella, con algún bar y mucho espacio incluso en agosto.' },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Consejo local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">El mejor momento para Marina Corricella</h3>
              <p class="text-white/70 leading-relaxed">Llega a Marina Corricella antes de las 9 de la mañana o después de las 18:00. Los grupos de excursionistas llegan entre las 10 y las 16 h. A primera hora, los pescadores extienden las redes, los gatos duermen en los botes y la luz es de película - literalmente. Es el Procida que no sale en las fotos de Instagram.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Preguntas frecuentes sobre Procida</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <div id="datos-rapidos" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos rápidos - Procida</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

