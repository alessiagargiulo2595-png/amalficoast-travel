---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Islas', url: '/es-es/islas/' },
];

const islands = [
  {
    name: 'Capri',
    href: '/es-es/islas/capri/',
    desc: 'La Gruta Azul, los Faraglioni y la glamurosa Piazzetta: la isla más icónica del golfo de Nápoles.',
    tag: 'La más icónica',
    facts: ['40 min desde Nápoles', 'Sin coches privados', 'Gruta Azul'],
  },
  {
    name: 'Ischia',
    href: '/es-es/islas/ischia/',
    desc: 'La isla verde del golfo: parques termales naturales, el Castillo Aragonés, playas volcánicas y el Monte Epomeo a 789 m.',
    tag: 'Termas & Naturaleza',
    facts: ['50 min desde Nápoles', '100+ fuentes termales', 'Castillo Aragonés'],
  },
  {
    name: 'Procida',
    href: '/es-es/islas/procida/',
    desc: 'La más pequeña y auténtica: casas de colores en Marina Corricella, Capital italiana de la Cultura 2022.',
    tag: 'La más auténtica',
    facts: ['15 min desde Pozzuoli', 'Capital de la Cultura 2022', 'La isla del Cartero'],
  },
];

const destinationSchema = {
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": "Islas del golfo de Nápoles",
  "description": "Capri, Ischia y Procida: las tres islas del golfo de Nápoles, accesibles en ferry desde Nápoles, Pozzuoli y Sorrento.",
  "url": "https://amalficoast-travel.com/es-es/islas/",
  "touristType": ["Mar", "Cultura", "Termas", "Naturaleza"],
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.5500,
    "longitude": 14.1000
  }
};
---

<BaseLayout
  title="Islas del golfo de Nápoles 2026: Capri, Ischia y Procida"
  description="Guía de las islas del golfo de Nápoles: Capri, Ischia y Procida. Cómo llegar, qué ver, cuándo ir. Todo para planificar tu excursión o estancia insular."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[destinationSchema]}
>

  <!-- Hero -->
  <section class="relative bg-charcoal py-24 md:py-32 overflow-hidden">
    <img src="/images/isole-hero.jpg" alt="Islas del golfo de Nápoles" class="absolute inset-0 w-full h-full object-cover opacity-40" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-charcoal/90 via-charcoal/75 to-charcoal/60"></div>
    <div class="relative z-10 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/50 text-xs mb-8">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white/80">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-4">Golfo de Nápoles</p>
      <h1 class="font-serif text-display text-white mb-6 max-w-3xl">Las Islas del golfo de Nápoles</h1>
      <p class="text-xl text-white/70 leading-relaxed max-w-2xl">
        Tres islas, tres caracteres completamente distintos. Capri para el glamour y las vistas icónicas. Ischia para los baños termales volcánicos y la naturaleza salvaje. Procida para la autenticidad y la Italia que los turistas raramente encuentran. Todas accesibles en ferry o hidroplano en menos de una hora.
      </p>
    </div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-med-gold/5 rounded-full blur-3xl pointer-events-none"></div>
  </section>

  <!-- Island Cards -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid md:grid-cols-3 gap-8">
      {islands.map(({ name, href, desc, tag, facts }) => (
        <a href={href} class="group block bg-white rounded-[3rem] border border-slate-100 p-8 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">{tag}</p>
          <h2 class="font-serif text-3xl font-bold text-charcoal mb-3 group-hover:text-med-blue transition-colors">{name}</h2>
          <p class="text-slate-600 leading-relaxed text-sm mb-6">{desc}</p>
          <ul class="space-y-2 mb-6">
            {facts.map(fact => (
              <li class="flex items-center gap-2 text-xs text-slate-500">
                <span class="w-1.5 h-1.5 rounded-full bg-med-gold flex-shrink-0"></span>
                {fact}
              </li>
            ))}
          </ul>
          <span class="inline-flex items-center gap-1.5 text-med-blue text-xs font-bold uppercase tracking-[0.2em] group-hover:gap-2.5 transition-all">
            Descubrir {name}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Comparison -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">¿Qué isla te conviene?</h2>
      <p class="text-slate-500 mb-10 max-w-2xl leading-relaxed">Cada isla tiene una personalidad distinta. Una comparativa rápida para ayudarte a elegir.</p>

      <div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="text-left px-6 py-4 font-semibold text-charcoal">Característica</th>
              <th class="text-left px-6 py-4 font-semibold text-charcoal">Capri</th>
              <th class="text-left px-6 py-4 font-semibold text-charcoal">Ischia</th>
              <th class="text-left px-6 py-4 font-semibold text-charcoal">Procida</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {[
              ['Superficie', '10,4 km²', '46,3 km²', '4,1 km²'],
              ['Aglomeración', 'Muy alta en verano', 'Moderada', 'Baja a moderada'],
              ['Nivel de precios', '€€€€', '€€–€€€', '€–€€'],
              ['Ideal para', 'Glamour, vistas, excursión', 'Estancia 2–3 días, termas', 'Autenticidad, excursión'],
              ['Playas', 'Rocas y guijarros', 'Arena volcánica oscura', 'Arena oscura y clara'],
              ['¿Coche?', 'No (solo residentes)', 'Sí', 'Motos y coches pequeños'],
              ['Desde Nápoles', '~40 min hidroplano', '~50 min hidroplano', '~35 min hidroplano'],
              ['Puerto más cercano', 'Sorrento (25 min)', 'Pozzuoli (35 min)', 'Pozzuoli (15 min)'],
            ].map(([feature, capri, ischia, procida]) => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-6 py-3 font-medium text-charcoal">{feature}</td>
                <td class="px-6 py-3 text-slate-600">{capri}</td>
                <td class="px-6 py-3 text-slate-600">{ischia}</td>
                <td class="px-6 py-3 text-slate-600">{procida}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Getting There -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
      <div class="relative z-10">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-4">Cómo llegar a las islas</p>
        <h2 class="font-serif text-3xl font-bold text-white mb-6 tracking-tight">Todas las islas en ferry o hidroplano</h2>
        <p class="text-white/60 mb-10 leading-relaxed max-w-2xl">Sin puentes ni aeropuertos. La única manera de llegar a las islas del golfo es por mar - lo que ya es parte de la experiencia. Los principales puntos de salida son Nápoles Molo Beverello y Pozzuoli. Sorrento solo conecta con Capri.</p>
        <div class="grid sm:grid-cols-3 gap-6 mb-10">
          {[
            { from: 'Nápoles → Capri', time: '~40 min', note: 'Hidroplano, todo el año' },
            { from: 'Nápoles → Ischia', time: '~50 min', note: 'Hidroplano, todo el año' },
            { from: 'Pozzuoli → Procida', time: '~15 min', note: 'Ferry, todo el año' },
          ].map(({ from, time, note }) => (
            <div class="bg-white/5 rounded-2xl p-5 border border-white/10">
              <p class="text-white/50 text-xs mb-1">{from}</p>
              <p class="font-serif text-2xl font-bold text-med-gold">{time}</p>
              <p class="text-white/40 text-xs mt-1">{note}</p>
            </div>
          ))}
        </div>
        <a href="/es-es/como-llegar/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
          Guía completa de ferries con horarios
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
    </div>
  </section>

</BaseLayout>
