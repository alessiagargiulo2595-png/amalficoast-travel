---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocalePath } from '../../i18n/translations';

const lang = 'es-es';
const t = getTranslations(lang);

const months = [
  { name: 'Enero', weather: '8–14°C', sea: 'Fría', crowds: 'Desierta', notes: 'La costa está casi desierta. Muchos hoteles y restaurantes cerrados. Para quienes aman el silencio absoluto y la fotografía sin gente en escena.' },
  { name: 'Febrero', weather: '9–15°C', sea: 'Fría', crowds: 'Desierta', notes: 'Similar a enero. Algunas aperturas por el Carnaval. Mimosas en flor en las colinas.' },
  { name: 'Marzo', weather: '11–17°C', sea: 'Fresca', crowds: 'Baja', notes: 'La costa despierta. Limones y cítricos madurando. Algún turista pero todavía tranquilo. Excelente para senderismo.' },
  { name: 'Abril', weather: '13–20°C', sea: 'Fresca', crowds: 'Media', notes: 'Periodo ideal: temperatura agradable, paisajes muy verdes, relativamente pocos turistas. Los ferris reanudan servicio. Semana Santa trae algo de afluencia.' },
  { name: 'Mayo', weather: '16–24°C', sea: 'Templada', crowds: 'Media-alta', notes: 'Uno de los mejores meses del año. Todo abierto, mar ya bañable para los más atrevidos, flores por todas partes. Reservar alojamiento con antelación.' },
  { name: 'Junio', weather: '20–28°C', sea: 'Cálida', crowds: 'Alta', notes: 'Primera semana todavía manejable, luego comienza la temporada alta. Mar espléndido, tardes largas y luminosas. Precios altos.' },
  { name: 'Julio', weather: '23–32°C', sea: 'Cálida', crowds: 'Muy alta', notes: 'Mes más concurrido. Tráfico intenso en la SS163, playas llenas, precios máximos. A evitar si no te gustan las multitudes, de lo contrario el mar es magnífico.' },
  { name: 'Agosto', weather: '23–32°C', sea: 'Cálida', crowds: 'Muy alta', notes: 'Como julio, incluso peor. Ferragosto trae el éxodo estival italiano. Si vienes, reserva todo con meses de antelación. La magia nocturna es sin embargo inigualable.' },
  { name: 'Septiembre', weather: '20–27°C', sea: 'Cálida', crowds: 'Media-alta', notes: 'Septiembre es el mes secreto de los entendidos: mar todavía cálido, multitudes menguando desde la segunda quincena, precios bajando. Probablemente el mejor mes.' },
  { name: 'Octubre', weather: '16–22°C', sea: 'Templada', crowds: 'Baja', notes: 'La costa vuelve a sí misma. Colores otoñales en las colinas, limones maduros. Excelente para senderismo y fotografía.' },
  { name: 'Noviembre', weather: '12–17°C', sea: 'Fresca', crowds: 'Desierta', notes: 'Muchos establecimientos cierran. Posibles lluvias. Para quienes quieren silencio absoluto, precios mínimos y una Italia auténtica.' },
  { name: 'Diciembre', weather: '9–14°C', sea: 'Fría', crowds: 'Muy baja', notes: 'Algunas aperturas para las fiestas navideñas. Nacimientos vivientes en Praiano y en las grutas. Atmósfera única pero servicios limitados.' },
];

const crowdColor: Record<string, string> = {
  'Desierta':   'bg-med-gold/10 text-med-gold',
  'Baja':       'bg-med-gold/10 text-med-gold',
  'Muy baja':   'bg-med-gold/10 text-med-gold',
  'Media':      'bg-med-blue/10 text-med-blue',
  'Media-alta': 'bg-med-blue/15 text-med-blue',
  'Alta':       'bg-slate-200 text-slate-700',
  'Muy alta':   'bg-slate-800 text-white',
};
---

<BaseLayout
  title={t.meta.when_to_visit_title}
  description={t.meta.when_to_visit_description}
  lang={lang}
  pageKey="when-to-visit"
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/quando-visitare-hero.jpg" alt="Villa Cimbrone, Ravello" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <p class="text-med-gold text-sm uppercase tracking-[0.3em] mb-3 font-medium">Guía estacional</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Cuándo visitar la Costa Amalfitana</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto font-light">Cada mes tiene sus pros y contras. Guía completa mes a mes sobre el clima, la afluencia y los precios.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-lg text-slate-600 leading-relaxed">
      La pregunta más habitual de quienes planifican un viaje a la Costa Amalfitana es: ¿cuándo ir? La respuesta honesta es que no existe el momento perfecto en sentido absoluto — depende de lo que estés buscando. En julio y agosto el mar es magnífico pero la costa está masificada; en primavera y otoño el paisaje es impresionante y la afluencia mínima, pero algún servicio está reducido. Esta guía mes a mes te ayudará a elegir el periodo adecuado para ti.
    </p>
  </section>

  <!-- Top recommendation -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8 text-center">
        <div class="w-12 h-12 rounded-2xl bg-med-gold/15 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-2">Mejor periodo</p>
        <p class="font-serif text-2xl font-bold text-white mb-2">Mayo · Septiembre</p>
        <p class="text-white/50 text-sm">Temperatura ideal, mar bañable, afluencia manejable</p>
      </div>

      <div class="bg-white border border-slate-100 rounded-[3rem] p-8 text-center shadow-sm">
        <div class="w-12 h-12 rounded-2xl bg-med-blue/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-medium mb-2">Buena alternativa</p>
        <p class="font-serif text-2xl font-bold text-slate-900 mb-2">Abril · Octubre</p>
        <p class="text-slate-500 text-sm">Menos calor, precios más bajos, paisajes hermosos</p>
      </div>

      <div class="bg-white border border-slate-100 rounded-[3rem] p-8 text-center shadow-sm">
        <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-medium mb-2">Evitar (si es posible)</p>
        <p class="font-serif text-2xl font-bold text-slate-900 mb-2">Julio · Agosto</p>
        <p class="text-slate-500 text-sm">Masificado, caro, tráfico intenso</p>
      </div>

    </div>
  </section>

  <!-- Month-by-month table -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-serif text-slate-900 mb-8">Guía mes a mes</h2>
      <div class="space-y-4">
        {months.map(month => (
          <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 p-6 sm:p-8">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h3 class="font-bold text-slate-900 text-lg w-24">{month.name}</h3>
              <span class="text-sm text-slate-500 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/></svg>
                {month.weather}
              </span>
              <span class="text-sm text-slate-500 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-med-blue flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3.744 12 2.25l5.25 1.494m-10.5 0 5.25 1.494M6.75 3.744 2.25 9l4.5 5.256 5.25-1.494M17.25 3.744 21.75 9l-4.5 5.256-5.25-1.494M12 15.75 6.75 14.25m5.25 1.5 5.25-1.5"/></svg>
                Mar: {month.sea}
              </span>
              <span class={`text-xs font-semibold px-3 py-1 rounded-full ${crowdColor[month.crowds]}`}>
                Afluencia: {month.crowds}
              </span>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">{month.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Events -->
  <section class="bg-slate-900 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Calendario</p>
      <h2 class="text-2xl font-bold font-serif text-white mb-10">Eventos que no te puedes perder</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Festival de Ravello</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Julio – Septiembre</p>
          <p class="text-white/60 text-sm leading-relaxed">Conciertos de música clásica en la terraza con vistas al mar de la Villa Rufolo. Uno de los eventos culturales más emocionantes de Italia. Reserva las entradas con antelación.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Regata de las Antiguas Repúblicas Marineras</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Junio (cada 4 años en Amalfi)</p>
          <p class="text-white/60 text-sm leading-relaxed">La regata que enfrenta a Amalfi, Venecia, Génova y Pisa. Cuando le toca ser sede a Amalfi, la ciudad se viste con trajes medievales.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Luminara di Sant'Andrea</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">27 de junio y 30 de noviembre</p>
          <p class="text-white/60 text-sm leading-relaxed">La fiesta del patrón de Amalfi ilumina la Catedral y la plaza con miles de velas. Un espectáculo nocturno extraordinario muy sentido por la comunidad local.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Fiesta del Limón (Sagra del Limone)</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Agosto (varios pueblos)</p>
          <p class="text-white/60 text-sm leading-relaxed">Degustaciones de limoncello, dulces de limón, mercados artesanales. El limón sfusato amalfitano es un producto IGP: aprovecha para llevarte algunos a casa.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">¿Has decidido cuándo venir?</h2>
      <p class="text-slate-600 mb-6">Descubre cómo organizar mejor tus días en la costa.</p>
      <a href={getLocalePath(lang, 'itineraries')}
        class="inline-block bg-med-blue text-white font-semibold px-8 py-3 rounded-full hover:shadow-lg transition-shadow">
        Ver los itinerarios
      </a>
    </div>
  </section>

</BaseLayout>
