---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Costa Amalfitana', url: '/es-es/costa-amalfitana/' },
];

const borghi = [
  {
    name: 'Positano',
    href: '/es-es/costa-amalfitana/positano/',
    desc: 'El pueblo más fotografiado de la costa, con casas de colores a pico sobre el mar y la famosa Spiaggia Grande.',
    tag: 'El más icónico',
  },
  {
    name: 'Amalfi',
    href: '/es-es/costa-amalfitana/amalfi/',
    desc: 'Capital histórica de la costa, con la Catedral de Sant\'Andrea y el museo del papel.',
    tag: 'Capital histórica',
  },
  {
    name: 'Ravello',
    href: '/es-es/costa-amalfitana/ravello/',
    desc: 'A 350 m sobre el mar, la "ciudad de la música" con la Villa Rufolo y la Villa Cimbrone.',
    tag: 'Vista panorámica',
  },
  {
    name: 'Praiano',
    href: '/es-es/costa-amalfitana/praiano/',
    desc: 'El secreto mejor guardado: menos turistas, espectaculares atardeceres desde la Bahía de Praia.',
    tag: 'La más auténtica',
  },
  {
    name: 'Maiori',
    href: '/es-es/costa-amalfitana/maiori/',
    desc: 'La playa de arena más larga de la costa: ideal para quienes buscan el mar sin renunciar al confort.',
    tag: 'Playa de arena',
  },
  {
    name: 'Minori',
    href: '/es-es/costa-amalfitana/minori/',
    desc: 'Pueblo de limoneros, con los restos de una villa romana del siglo I d.C. y excelentes pastelerías.',
    tag: 'Sabores auténticos',
  },
];

const destinationSchema = {
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": "Costa Amalfitana",
  "description": "La Costa Amalfitana es un tramo costero de Campania de 50 km, Patrimonio de la Humanidad de la UNESCO desde 1997, con pueblos de colores, acantilados y el azul del Mar Tirreno.",
  "url": "https://amalficoast-travel.com/es-es/costa-amalfitana/",
  "touristType": ["Cultura", "Mar", "Naturaleza", "Gastronomía", "Senderismo"],
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6333,
    "longitude": 14.6027
  }
};
---

<BaseLayout
  title="Costa Amalfitana 2026: Guía Completa de los Pueblos"
  description="Guía de la Costa Amalfitana: pueblos que visitar, playas, cómo llegar, cuándo ir. De Positano a Amalfi, todo lo que necesitas saber."
  lang={lang}
  pageKey="costiera-amalfitana"
  breadcrumbs={breadcrumbs}
  schema={[destinationSchema]}
>

  <!-- Hero -->
  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager"  referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/es-es/" class="hover:text-white transition-colors">Inicio</a>
        <span>/</span>
        <span class="text-white">Costa Amalfitana</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Patrimonio Mundial UNESCO</p>
        <h1 class="font-serif text-display text-white mb-4">Costa Amalfitana</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Cincuenta kilómetros de acantilados, pueblos de colores y aguas turquesas. La costa más famosa de Italia en una guía completa y actualizada para 2026.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-20">

    <!-- Intro -->
    <section class="max-w-text">
      <p class="text-xl leading-relaxed text-charcoal">
        La Costa Amalfitana es uno de esos lugares que supera cualquier expectativa. No importa cuántas fotografías hayas visto: la realidad — el olor a limones, el reflejo del sol en el mar, las casas aferradas a la roca — es siempre más intensa.
      </p>
      <p class="mt-4 text-slate-600 leading-relaxed">
        Reconocida Patrimonio de la Humanidad de la UNESCO en 1997, se extiende durante 50 km desde la península sorrentina hasta Vietri sul Mare, en la provincia de Salerno. El corazón es la SS163, una carretera sinuosa excavada en la roca que conecta 13 municipios, cada uno con su propia historia, paisaje y sabor.
      </p>
    </section>

    <!-- Borghi Grid -->
    <section>
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-serif text-3xl font-semibold text-slate-900">Los pueblos de la costa</h2>
        <p class="text-sm text-slate-400 hidden sm:block">De oeste a este por la SS163</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {borghi.map(b => (
          <a href={b.href} class="group bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm hover:border-med-blue/30 hover:shadow-xl transition-all duration-300">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-serif text-xl font-semibold text-slate-900 group-hover:text-med-blue transition-colors">{b.name}</h3>
              <span class="text-[10px] uppercase tracking-wide bg-med-blue/5 text-med-blue px-2 py-1 rounded-full font-medium flex-shrink-0 ml-2">{b.tag}</span>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">{b.desc}</p>
            <p class="text-med-blue text-sm font-medium mt-4 group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
              Explorar {b.name}
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
            </p>
          </a>
        ))}
      </div>
    </section>

    <!-- Did You Know -->
    <section class="bg-charcoal text-white rounded-[2rem] p-10">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-8">La costa en cifras</p>
      <div class="grid sm:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">50 km</p>
          <p class="text-white/60 text-sm mt-2">de litoral UNESCO</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">13</p>
          <p class="text-white/60 text-sm mt-2">municipios costeros</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">1997</p>
          <p class="text-white/60 text-sm mt-2">año UNESCO</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">2 M+</p>
          <p class="text-white/60 text-sm mt-2">turistas/año</p>
        </div>
      </div>
    </section>

    <!-- Quick Links -->
    <section>
      <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Guías prácticas</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/es-es/costa-amalfitana/come-arrivare/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Cómo llegar</p>
            <p class="text-xs text-slate-500">Ferrys, autobús, coche</p>
          </div>
        </a>
        <a href="/es-es/quando-visitare/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Cuándo ir</p>
            <p class="text-xs text-slate-500">Mes a mes</p>
          </div>
        </a>
        <a href="/es-es/spiagge/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17c3-3 6-3 9 0s6 3 9 0M3 12c3-3 6-3 9 0s6 3 9 0"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Las playas</p>
            <p class="text-xs text-slate-500">8 playas seleccionadas</p>
          </div>
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
