---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Costa Amalfitana', url: '/es-es/costa-amalfitana/' },
  { name: 'Ravello', url: '/es-es/costa-amalfitana/ravello/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Ravello",
  "description": "Ravello es un pueblo medieval en lo alto de una colina a 350 m sobre el mar, famoso por la Villa Rufolo, la Villa Cimbrone y el Festival de Ravello. La 'ciudad de la música' ofrece las vistas más espectaculares de toda la Costa Amalfitana.",
  "url": "https://amalficoast-travel.com/es-es/costa-amalfitana/ravello/",
  "image": "https://amalficoast-travel.com/images/ravello-hero.jpg",
  "touristType": ["Cultura", "Música", "Vistas", "Jardines"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ravello",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6492,
    "longitude": 14.6122
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo se llega a Ravello desde Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Desde Amalfi se toma el autobús SITA hasta Ravello (unos 25 min, ~€1,30). Los autobuses salen desde la plaza del puerto en Amalfi. En coche la carretera es estrecha y sinuosa — el autobús es mejor opción. No hay acceso directo en ferry."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuándo se celebra el Festival de Ravello?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El Festival de Ravello se celebra cada año de junio a septiembre, con conciertos en el espectacular escenario de la Villa Rufolo. Es uno de los festivales de música clásica más prestigiosos de Italia. Las entradas se deben comprar con antelación en ravellofestival.com."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta la entrada a la Villa Cimbrone?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La entrada a los jardines de la Villa Cimbrone cuesta unos €7 por adulto. Los jardines están abiertos todo el año desde las 9:00 hasta el atardecer. El Belvedere dell'Infinito (Terraza del Infinito) es el mirador más fotografiado de la costa."
      }
    },
    {
      "@type": "Question",
      "name": "¿Vale la pena visitar Ravello sin asistir al Festival?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutamente. La Villa Rufolo y la Villa Cimbrone con sus jardines y vistas merecen el viaje independientemente del Festival. El centro medieval, la Piazza Vescovado y la Catedral también merecen una visita detallada."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hay aparcamiento en Ravello?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hay aparcamientos de pago a la entrada del pueblo. La carretera SP13 desde Amalfi es estrecha y difícil. Se recomienda llegar en autobús SITA desde Amalfi para evitar problemas de tráfico y aparcamiento."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Ubicación', dd: 'Costa Amalfitana, SA' },
  { dt: 'Altitud', dd: '350 m s.n.m.' },
  { dt: 'Población', dd: '~2.500 habitantes' },
  { dt: 'Desde Amalfi', dd: '~25 min (autobús SITA)' },
  { dt: 'Transporte', dd: 'Solo autobús SITA' },
  { dt: 'Imprescindible', dd: 'Villa Rufolo, Villa Cimbrone' },
  { dt: 'Festival', dd: 'Jun–Sep 2026' },
  { dt: 'Mejor época', dd: 'May–Oct' },
];
---

<BaseLayout
  title="Ravello 2026: Guía Completa | Costa Amalfitana"
  description="Todo sobre Ravello: Villa Rufolo, Villa Cimbrone, el Festival de Ravello 2026, cómo llegar en autobús desde Amalfi. La guía completa de la ciudad de la música sobre la Costa Amalfitana."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/ravello-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costa Amalfitana · Música y Jardines</p>
        <h1 class="font-serif text-display text-white mb-4">Ravello</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          A 350 metros sobre el mar Tirreno, Ravello contempla la costa como un telón de fondo escénico. Wagner compuso aquí. Greta Garbo se escondió aquí. Y cada verano, el Festival de Ravello convierte la Villa Rufolo en una sala de conciertos suspendida entre el cielo y el mar.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Datos Rápidos</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Cómo Llegar</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Ravello es el único pueblo de la Costa Amalfitana que no tiene acceso directo al mar — y precisamente ese es su atractivo. Las vistas desde el Belvedere dell'Infinito de la Villa Cimbrone figuran entre las más celebradas del mundo, descritas por Gore Vidal como "las más bellas de la tierra".
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            A 350 metros sobre el nivel del mar, Ravello ofrece un contrapunto perfecto al caos estival de la costa. El aire es más fresco, la luz más nítida y el silencio — excepto durante el Festival — es un bien escaso en esta parte de Italia.
          </p>
        </div>

        <!-- ¿Sabías que? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabías que?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">350 m</p>
              <p class="text-white/60 text-xs italic mt-1">altitud sobre el nivel del mar</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1953</p>
              <p class="text-white/60 text-xs italic mt-1">año de fundación del Festival de Ravello</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1880</p>
              <p class="text-white/60 text-xs italic mt-1">año en que Wagner visitó la Villa Rufolo</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Richard Wagner quedó tan emocionado por los jardines de la Villa Rufolo que declaró haber encontrado la inspiración para el jardín de Klingsor en Parsifal. Cada año se celebra aquí un concierto en su memoria.
          </p>
        </div>

        <!-- Qué ver -->
        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Qué ver en Ravello</h2>
          <div class="space-y-6">
            {[
              { title: 'Villa Rufolo', text: 'La villa del siglo XIII con sus jardines en terrazas y el famoso belvedere desde el que se ve el mar muy abajo. El escenario de la Villa Rufolo es el venue para los conciertos del Festival de Ravello. Abierta todos los días; entrada ~€7.' },
              { title: 'Villa Cimbrone', text: 'La villa más romántica de la costa, con la Terraza del Infinito (Belvedere dell\'Infinito) bordeada de bustos de mármol que miran hacia una extensión infinita de mar azul. Abierta todo el año de 9:00 al atardecer; entrada ~€7.' },
              { title: 'Catedral de Ravello', text: 'La catedral del siglo XI en la Piazza Vescovado con una notable puerta de bronce del siglo XII. En el interior, dos púlpitos de ambo con mosaicos (siglos XII–XIII) son algunos de los mejores ejemplos de trabajo de piedra medieval incrustada del sur de Italia.' },
              { title: 'Autobús SITA desde Amalfi', text: 'La manera más fácil y pintoresca de llegar a Ravello. Los autobuses salen de la plaza del puerto en Amalfi aproximadamente cada 40 minutos. Tiempo de viaje: ~25 minutos. Billete: ~€1,30.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Cómo llegar -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 text-white">
          <h2 class="font-serif text-2xl font-bold text-white mb-6">Cómo llegar a Ravello</h2>
          <div class="overflow-x-auto rounded-2xl border border-white/10">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-white/5 text-white/70">
                  <th class="text-left px-4 py-3 font-semibold">Transporte</th>
                  <th class="text-left px-4 py-3 font-semibold">Ruta</th>
                  <th class="text-left px-4 py-3 font-semibold">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <tr><td class="px-4 py-3 text-white font-medium">Autobús SITA</td><td class="px-4 py-3 text-white/60">Desde el puerto de Amalfi</td><td class="px-4 py-3 text-white/40 text-xs">~25 min, ~€1,30, cada ~40 min</td></tr>
                <tr><td class="px-4 py-3 text-white font-medium">En coche</td><td class="px-4 py-3 text-white/60">SP13 desde Amalfi</td><td class="px-4 py-3 text-white/40 text-xs">Carretera estrecha y sinuosa; aparcamientos de pago a la entrada</td></tr>
                <tr><td class="px-4 py-3 text-white font-medium">Taxi</td><td class="px-4 py-3 text-white/60">Desde Amalfi o Maiori</td><td class="px-4 py-3 text-white/40 text-xs">~€20–25, negociar precio antes</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Rincones escondidos -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Rincones escondidos de Ravello</h2>
          <p class="text-slate-500 mb-8">Más allá de las villas famosas: cuatro rincones que los turistas de paso no descubren.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Belvedere Principessa di Piemonte</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Un pequeño mirador público cerca del centro con vistas espectaculares sobre el mar y la costa, sin la entrada de pago de las villas. Perfecto para fotografías al atardecer.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Iglesia de San Giovanni del Toro</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Una joya románica del siglo XI raramente visitada, con mosaicos medievales y una cubierta de madera excepcional. Se encuentra a pocos minutos a pie de la Piazza Vescovado.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Sendero de Ravello a Minori</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Un sendero de descenso de unos 4 km que baja desde Ravello hasta la costa en Minori, pasando por limoneros y huertos. Vistas impresionantes y sin turistas. Duración: ~1,5 horas.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Bar Calce — aperitivo con vistas</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Un bar local al borde del acantilado donde los ravellesi toman el aperitivo al atardecer. Precios mucho más razonables que los establecimientos turísticos de la Piazza Vescovado.</p>
            </div>
          </div>
        </div>

        <!-- Consejo Local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Consejo Local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Combina Ravello con Amalfi en un día</h3>
              <p class="text-white/70 leading-relaxed">Sube a Ravello por la mañana temprano (primer autobús SITA a las 7:30 desde Amalfi) y visita las villas antes de que lleguen los grupos. Baja a Amalfi para comer y por la tarde toma el ferry de vuelta a Salerno o Nápoles — un día perfecto.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes sobre Ravello</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos Rápidos — Ravello</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Consejos de expertos -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Consejos de expertos</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Compra las entradas al Festival online con meses de antelación: se agotan rápidamente.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Visita la Villa Cimbrone al abrirse (9:00): el Belvedere estará casi vacío durante la primera hora.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Lleva una chaqueta: a 350 m de altitud hace más fresco que en la costa, incluso en agosto.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Baja a Minori a pie por el sendero panorámico y toma el autobús de regreso a Amalfi desde allí.</span>
            </li>
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Costa Amalfitana</p>
          <nav class="space-y-1">
            {[
              { href: '/es-es/costa-amalfitana/positano/', label: 'Positano' },
              { href: '/es-es/costa-amalfitana/amalfi/', label: 'Amalfi' },
              { href: '/es-es/costa-amalfitana/praiano/', label: 'Praiano' },
              { href: '/es-es/costa-amalfitana/maiori/', label: 'Maiori' },
              { href: '/es-es/costa-amalfitana/minori/', label: 'Minori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Explorar también la Costa"
    items={[
      { name: 'Amalfi',   href: '/es-es/costa-amalfitana/amalfi/',   tag: 'Arte e Historia',    desc: 'La Catedral de San Andrés, el Claustro del Paraíso y los callejones de la república marítima.' },
      { name: 'Positano', href: '/es-es/costa-amalfitana/positano/', tag: 'Icónico',             desc: 'Casas de colores sobre el mar y la playa más famosa de la costa.' },
      { name: 'Praiano',  href: '/es-es/costa-amalfitana/praiano/', tag: 'Atardecer y Calma',     desc: 'El atardecer desde San Gennaro y la playa Marina di Praia.' },
      { name: 'Capri',    href: '/es-es/isole/capri/',                  tag: 'La más icónica',    desc: 'Gruta Azul, Faraglioni y la glamurosa Piazzetta.' },
    ]}
  />

</BaseLayout>
