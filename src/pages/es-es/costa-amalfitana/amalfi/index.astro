---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Costa Amalfitana', url: '/es-es/costa-amalfitana/' },
  { name: 'Amalfi', url: '/es-es/costa-amalfitana/amalfi/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Amalfi",
  "description": "Amalfi es la capital histórica de la Costa Amalfitana, antigua y poderosa República Marítima medieval. Famosa por la Catedral de San Andrés, el Claustro del Paraíso y su tradición del papel artesanal.",
  "url": "https://amalficoast-travel.com/es-es/costa-amalfitana/amalfi/",
  "image": "https://amalficoast-travel.com/images/amalfi-hero.jpg",
  "touristType": ["Cultura", "Historia", "Mar", "Gastronomía"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84011"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6339,
    "longitude": 14.6027
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo se llega a Amalfi desde Nápoles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Desde Nápoles puedes llegar a Amalfi en ferry desde el Molo Beverello (unos 90–105 min, servicio estacional) o en autobús SITA desde Sorrento por la SS163 (unos 90 min). En coche la SS163 es espectacular pero sinuosa: en verano es mejor evitarla."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la mejor época para visitar Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Abril–junio y septiembre–octubre son ideales: clima agradable, aglomeraciones moderadas y precios razonables. Julio y agosto son la temporada turística alta. Noviembre–marzo es tranquilo pero con riesgo de lluvia y servicios reducidos."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta el ferry de Salerno a Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El ferry Travelmar de Salerno a Amalfi cuesta unos €8–10 por trayecto. Los billetes se pueden comprar en línea o en la taquilla del puerto. El servicio opera aproximadamente de abril a octubre."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué ver en Amalfi en un día?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "En un día puedes visitar la Catedral de San Andrés y el Claustro del Paraíso, el Museo del Papel, el centro histórico con la Piazza del Duomo y dar un paseo por el Valle delle Ferriere. Por la noche, cenar en uno de los restaurantes del paseo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hay aparcamiento en Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El aparcamiento es escaso y caro (aparcamientos Luna Rossa y Flavio Gioia: unos €4–5/hora). En verano se aplica una ZTL en el centro histórico. Se recomienda llegar en ferry o autobús SITA para evitar el tráfico en la SS163."
      }
    }
  ]
};
---

<BaseLayout
  title="Amalfi 2026: Guía Completa | Costa Amalfitana"
  description="Todo sobre Amalfi: cómo llegar, la Catedral de San Andrés, el Museo del Papel, horarios de ferry y autobús, qué ver, cuándo ir. La guía completa de la capital histórica de la Costa Amalfitana."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/amalfi-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costa Amalfitana</p>
        <h1 class="font-serif text-display text-white mb-4">Amalfi</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La capital histórica de la costa: una República Marítima medieval cuya tradición papelera sigue viva en sus talleres, y cuya Catedral sigue siendo la iglesia más impresionante de la orilla del Tirreno.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Datos Rápidos</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Cómo Llegar</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Amalfi es mucho más que una postal. Entre los siglos IX y XIII fue una de las repúblicas marítimas más poderosas del Mediterráneo — a la par con Venecia, Génova y Pisa. Hoy, 5.000 habitantes viven en las laderas de una espectacular garganta tallada por el torrente Canneto, entre torres, conventos y una catedral que sola justifica el viaje.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            La ciudad también dio al mundo las Tablas de Amalfi — el código marítimo más antiguo del mundo occidental, que data de alrededor del siglo XI — y una tradición papelera que produjo el primer papel con filigrana de Europa.
          </p>
        </div>

        <!-- ¿Sabías que? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabías que?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">IX</p>
              <p class="text-white/60 text-xs italic mt-1">siglo: fundación de la República Marítima</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">62</p>
              <p class="text-white/60 text-xs italic mt-1">escalones de la escalinata de la Catedral</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">5.000</p>
              <p class="text-white/60 text-xs italic mt-1">habitantes actuales</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Las Tablas de Amalfi (Tabula Amalfitana), el código marítimo más antiguo del mundo occidental, rigieron el comercio en el Mediterráneo desde el siglo XI hasta el XVI.
          </p>
        </div>

        <!-- Qué ver -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Qué ver en Amalfi</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Catedral de San Andrés</h3>
                <p class="text-slate-600 leading-relaxed">La fachada árabe-normanda con su llamativo mosaico en blanco y negro y los 62 escalones que suben desde la Piazza del Duomo son la imagen icónica de Amalfi. El Claustro del Paraíso (Chiostro del Paradiso), un claustro árabe-normando del siglo XIII, está incluido en la entrada a la catedral. Abierta todos los días.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Museo del Papel (Museo della Carta)</h3>
                <p class="text-slate-600 leading-relaxed">Ubicado en un molino papelero del siglo XIII en el Valle dei Mulini, este museo traza la historia de la fabricación del papel en Amalfi. Las demostraciones en vivo muestran cómo se fabrican las hojas a mano con técnicas tradicionales. Entrada ~€4.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Arsenal de la República Marítima</h3>
                <p class="text-slate-600 leading-relaxed">El único astillero medieval superviviente de la República, con salas abovedadas donde se construían galeras. Hoy alberga exposiciones temporales y el Museo de la Brújula.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Valle delle Ferriere</h3>
                <p class="text-slate-600 leading-relaxed">Una reserva natural protegida sobre la ciudad con una cascada pintoresca y vegetación exuberante. El sendero parte del Museo del Papel y dura unas 2 horas de ida y vuelta. Acceso gratuito.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Cómo llegar -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Cómo llegar a Amalfi</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Amalfi está bien comunicada por ferry y autobús. En coche la SS163 es espectacular pero congestionada en verano — se recomienda encarecidamente el transporte público.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">En ferry</h3><p class="text-white/50 text-sm leading-relaxed">Travelmar desde Salerno (abril–octubre). NLG / Alilauro desde Nápoles Molo Beverello (estacional). La opción más pintoresca.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Autobús SITA</h3><p class="text-white/50 text-sm leading-relaxed">Desde Sorrento por la SS163 (~90 min, ~€2,50). Desde Salerno directo (~75 min). Servicio todo el año.</p></div>
              </div>
            </div>
            <a href="/es-es/guia/ferrys/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Guía completa de transporte
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Horarios ferry -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Horarios de Ferry — Verano 2026
          </h3>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Travelmar — Salerno ↔ Amalfi</caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Sale de Salerno</th>
                  <th class="text-left px-4 py-3 font-semibold">Llega a Amalfi</th>
                  <th class="text-left px-4 py-3 font-semibold">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">07:15</td><td class="px-4 py-3 font-mono">08:30</td><td class="px-4 py-3 text-slate-500">Vía Cetara, Maiori</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">09:00</td><td class="px-4 py-3 font-mono">10:15</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">11:00</td><td class="px-4 py-3 font-mono">12:15</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">14:15</td><td class="px-4 py-3 font-mono">15:30</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">16:30</td><td class="px-4 py-3 font-mono">17:45</td><td class="px-4 py-3 text-slate-500">—</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Horarios indicativos para 2026. Consulta travelmar.it para confirmar.</p>
        </div>

        <!-- Rincones escondidos -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Rincones escondidos de Amalfi</h2>
          <p class="text-slate-500 mb-8">Más allá de la Piazza del Duomo: cuatro rincones que los turistas de paso no descubren.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Playa de Santa Croce</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Una pequeña cala escondida al oeste de Amalfi, accesible en barco o a pie por un sendero desde el Valle delle Ferriere. Muy tranquila y rodeada de acantilados.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Valle dei Mulini</h3>
              <p class="text-sm text-slate-600 leading-relaxed">El valle detrás del Museo del Papel, con antiguos molinos de agua abandonados entre la vegetación. Un paseo fresco y silencioso a solo 10 minutos del centro.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Convento de Santa María del Carmelo</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Un convento medieval en las alturas sobre el centro histórico, con vistas privilegiadas sobre el puerto y la catedral. Rara vez visitado por los turistas.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Tiendas de papel artesanal</h3>
              <p class="text-sm text-slate-600 leading-relaxed">En el centro histórico encontrarás pequeñas tiendas con papel hecho a mano con la técnica tradicional. Un recuerdo auténtico y único que no encontrarás en ningún otro lugar del mundo.</p>
            </div>
          </div>
        </div>

        <!-- Consejo Local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Consejo Local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Visita la Catedral al amanecer</h3>
              <p class="text-white/70 leading-relaxed">La Piazza del Duomo está vacía antes de las 8:30 de la mañana. Es el único momento del día en que puedes fotografiar la fachada sin cientos de turistas. Sube los 62 escalones con la luz dorada de la mañana — una experiencia que no olvidarás.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Preguntas frecuentes sobre Amalfi</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos Rápidos — Amalfi</p>
          <dl class="space-y-3">
            {[
              { dt: 'Ubicación', dd: 'Costa Amalfitana, SA' },
              { dt: 'Población', dd: '~5.000 habitantes' },
              { dt: 'Desde Nápoles', dd: '~90 min (ferry)' },
              { dt: 'Desde Sorrento', dd: '~90 min (autobús SITA)' },
              { dt: 'ZTL', dd: 'Sí, en verano' },
              { dt: 'Playa', dd: 'Guijarros (centro)' },
              { dt: 'Mejor época', dd: 'Abr–Jun / Sep–Oct' },
              { dt: 'Moneda', dd: 'Euro (€)' },
            ].map(({ dt, dd }, i, arr) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < arr.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Consejos de expertos -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Consejos de expertos</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Visita la Catedral por la mañana temprano: la Piazza del Duomo estará casi vacía.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Compra papel artesanal de Amalfi: es un recuerdo único con siglos de historia.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
