---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Costa Amalfitana', url: '/es-es/costa-amalfitana/' },
  { name: 'Praiano', url: '/es-es/costa-amalfitana/praiano/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Praiano",
  "description": "Praiano es el secreto mejor guardado de la Costa Amalfitana: menos turístico que Positano, con espectaculares atardeceres desde San Gennaro, la playa Gavitella y la pintoresca Marina di Praia.",
  "url": "https://amalficoast-travel.com/es-es/costa-amalfitana/praiano/",
  "image": "https://amalficoast-travel.com/images/praiano-hero.jpg",
  "touristType": ["Naturaleza", "Mar", "Atardecer", "Calma"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6117,
    "longitude": 14.5353
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo se llega a Praiano desde Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Desde Positano, el autobús SITA tarda unos 15 minutos hasta Praiano (billete ~€2,50). También hay servicio de ferry estacional de mayo a octubre. En coche son unos 10 km por la SS163, pero la carretera es muy estrecha."
      }
    },
    {
      "@type": "Question",
      "name": "¿Por qué Praiano es menos turístico que Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Praiano no tiene una gran playa de arena ni las boutiques de lujo de Positano. El pueblo se extiende a lo largo de la SS163 sin un núcleo urbano compacto, lo que lo hace menos pintoresco a primera vista pero mucho más auténtico y tranquilo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la mejor playa de Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La playa Gavitella es la más accesible (escaleras desde la carretera) y ofrece vistas espectaculares. La Marina di Praia es una pequeña cala con barcos de pescadores y un par de restaurantes de mariscos - muy auténtica y menos concurrida."
      }
    },
    {
      "@type": "Question",
      "name": "¿Dónde ver el mejor atardecer en Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El mirador junto a la Iglesia de San Gennaro, en lo alto del pueblo, ofrece el atardecer más espectacular de la Costa Amalfitana. El sol se hunde exactamente entre las islas de Li Galli, frente a Positano - una vista única que justifica sola el viaje."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hay qué ver en Praiano además de las playas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La Iglesia de San Gennaro con su cúpula de mayólica y la Torre de Asciola (torre sarracena medieval) son los principales monumentos. El pueblo también es el punto de partida del sendero hacia el Fiordo di Furore, una de las calas más fotogénicas de la costa."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Ubicación', dd: 'Costa Amalfitana, SA' },
  { dt: 'Altitud', dd: '0–300 m s.n.m.' },
  { dt: 'Población', dd: '~1.800 habitantes' },
  { dt: 'Desde Positano', dd: '~15 min (autobús SITA)' },
  { dt: 'Desde Amalfi', dd: '~20 min (autobús SITA)' },
  { dt: 'Playa', dd: 'Gavitella, Marina di Praia' },
  { dt: 'Mejor para', dd: 'Atardeceres, autenticidad' },
  { dt: 'Mejor época', dd: 'May–Oct' },
];
---

<BaseLayout
  title="Praiano 2026: Guía Completa | Costa Amalfitana"
  description="Todo sobre Praiano: el secreto mejor guardado de la costa. Atardecer desde San Gennaro, playa Gavitella, Marina di Praia. Cómo llegar desde Positano y Amalfi."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/praiano-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costa Amalfitana · Atardecer y Calma</p>
        <h1 class="font-serif text-display text-white mb-4">Praiano</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Entre Positano y Amalfi, Praiano es el secreto mejor guardado de la costa. Sin las masas de turistas, sin los precios de lujo, pero con el mismo mar turquesa y los atardeceres más espectaculares de toda la Costa Amalfitana.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Datos Rápidos</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Cómo Llegar</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Praiano es el antídoto perfecto para el turismo de masas de la Costa Amalfitana. A solo 10 km de Positano, sus habitantes (menos de 2.000) todavía viven del mar y de los limoneros. No hay boutiques de diseñador, no hay colas en el embarcadero, no hay precios que quiten el aliento.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Lo que sí hay es el atardecer más bello de la costa. Desde la pequeña iglesia de San Gennaro, en lo alto del pueblo, el sol se pone exactamente entre las islas de Li Galli - el mismo archipiélago donde, según la leyenda, vivían las sirenas homéricas.
          </p>
        </div>

        <!-- ¿Sabías que? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabías que?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1.800</p>
              <p class="text-white/60 text-xs italic mt-1">habitantes durante todo el año</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">Li Galli</p>
              <p class="text-white/60 text-xs italic mt-1">islas frente a la costa, hogar de las sirenas</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">2</p>
              <p class="text-white/60 text-xs italic mt-1">playas principales accesibles al público</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            El coreógrafo Rudolf Nureyev compró las islas de Li Galli en los años 80 y las usó como retiro privado. Hoy se pueden alquilar como villa de lujo.
          </p>
        </div>

        <!-- Qué ver -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Qué ver en Praiano</h2>
          <div class="space-y-8">

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Iglesia de San Gennaro y el mirador</h3>
                <p class="text-slate-600 leading-relaxed">La pequeña iglesia con cúpula de mayólica está en lo alto del pueblo y tiene el mirador más espectacular de la costa. El atardecer aquí, con el sol hundiéndose entre las islas de Li Galli, es una experiencia única.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Playa Gavitella</h3>
                <p class="text-slate-600 leading-relaxed">La playa principal de Praiano, accesible por una escalinata de unos 100 escalones desde la SS163. Guijarros y aguas cristalinas. Hay un chiringuito con alquiler de tumbonas y una pequeña cafetería.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Marina di Praia</h3>
                <p class="text-slate-600 leading-relaxed">Una pequeña cala con barcos de pescadores, un restaurante de mariscos y una cueva marina natural. Se accede bajando por la carretera que parte de la SS163. Muy auténtica y poco concurrida.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Torre de Asciola</h3>
                <p class="text-slate-600 leading-relaxed">Una de las torres de vigilancia sarracenas medievales mejor conservadas de la costa, ubicada en la parte alta del pueblo. Vista panorámica sobre el mar y los acantilados. Acceso libre desde el exterior.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Cómo llegar -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Cómo llegar a Praiano</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Praiano está bien comunicada por autobús SITA con Positano y Amalfi. El ferry estacional es la opción más pintoresca llegando desde el mar.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">En ferry</h3><p class="text-white/50 text-sm leading-relaxed">Servicio estacional (mayo–octubre) desde Positano y Amalfi. El ferry llega a la Marina di Praia.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Autobús SITA</h3><p class="text-white/50 text-sm leading-relaxed">Desde Positano (~15 min) o Amalfi (~20 min) por la SS163. ~€2,50. Todo el año.</p></div>
              </div>
            </div>

            <div class="overflow-x-auto rounded-2xl border border-white/10">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-white/5 text-white/70">
                    <th class="text-left px-4 py-3 font-semibold">Origen</th>
                    <th class="text-left px-4 py-3 font-semibold">Duración</th>
                    <th class="text-left px-4 py-3 font-semibold">Medio</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                  <tr><td class="px-4 py-3 text-white font-medium">Positano</td><td class="px-4 py-3 text-white/60">~15 min</td><td class="px-4 py-3 text-white/40 text-xs">Autobús SITA, ~€2,50</td></tr>
                  <tr><td class="px-4 py-3 text-white font-medium">Amalfi</td><td class="px-4 py-3 text-white/60">~20 min</td><td class="px-4 py-3 text-white/40 text-xs">Autobús SITA, ~€2,50</td></tr>
                  <tr><td class="px-4 py-3 text-white font-medium">Sorrento</td><td class="px-4 py-3 text-white/60">~60 min</td><td class="px-4 py-3 text-white/40 text-xs">Autobús SITA (con transbordo)</td></tr>
                  <tr><td class="px-4 py-3 text-white font-medium">Nápoles</td><td class="px-4 py-3 text-white/60">~2,5 h</td><td class="px-4 py-3 text-white/40 text-xs">Tren + autobús SITA</td></tr>
                </tbody>
              </table>
            </div>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Rincones escondidos -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Rincones escondidos de Praiano</h2>
          <p class="text-slate-500 mb-8">El verdadero Praiano que los turistas raramente descubren.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Fiordo di Furore</h3>
              <p class="text-sm text-slate-600 leading-relaxed">A pocos kilómetros hacia Amalfi, el Fiordo di Furore es una grieta en el acantilado con una cala de aguas esmeralda. El famoso puente donde se celebran las competiciones de salto de altura. Acceso por escaleras muy empinadas.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Sendero de Praiano a Positano</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Un sendero de costa de unos 5 km con vistas impresionantes, pasando por viñedos y terrazas de limoneros. Dificultad moderada. Salida desde la Marina di Praia. Duración: ~2 horas.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Las islas de Li Galli al atardecer</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Desde la Marina di Praia se alquilan pequeñas embarcaciones para acercarse a las islas de Li Galli, el archipiélago privado frente a Positano. La mejor experiencia al atardecer desde el mar.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Restaurantes de pescadores en Marina di Praia</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Los dos o tres restaurantes de la Marina di Praia sirven pescado fresco del día a precios locales - la mitad de lo que pagarías en Positano o Amalfi, con la misma calidad y sin las colas.</p>
            </div>
          </div>
        </div>

        <!-- Consejo Local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Consejo Local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">El atardecer desde San Gennaro</h3>
              <p class="text-white/70 leading-relaxed">Sube a la Iglesia de San Gennaro al menos 30 minutos antes de la puesta de sol. Lleva algo de beber y siéntate en los escalones de la iglesia. El sol se hunde exactamente entre las islas de Li Galli - uno de los espectáculos naturales más bellos de toda la costa.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Preguntas frecuentes sobre Praiano</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos Rápidos - Praiano</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Consejos de expertos -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Consejos de expertos</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Alójate en Praiano y visita Positano en día: precios la mitad y sin multitudes por la noche.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Lleva calzado de trekking si quieres bajar a las playas: los escalones son muchos y empinados.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Pide la especialidad local: spaghetti alle vongole con mejillones del golfo de Salerno.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Reserva una excursión en barco desde Marina di Praia para ver las grutas y las islas de Li Galli.</span>
            </li>
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Costa Amalfitana</p>
          <nav class="space-y-1">
            {[
              { href: '/es-es/costa-amalfitana/positano/', label: 'Positano' },
              { href: '/es-es/costa-amalfitana/amalfi/', label: 'Amalfi' },
              { href: '/es-es/costa-amalfitana/ravello/', label: 'Ravello' },
              { href: '/es-es/costa-amalfitana/maiori/', label: 'Maiori' },
              { href: '/es-es/costa-amalfitana/minori/', label: 'Minori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
