---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Costa Amalfitana', url: '/es-es/costa-amalfitana/' },
  { name: 'Positano', url: '/es-es/costa-amalfitana/positano/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Positano",
  "description": "Positano es el pueblo más icónico de la Costa Amalfitana, conocido por sus casas de colores a pico sobre el mar, sus playas de guijarros y su atmósfera de dolce vita.",
  "url": "https://amalficoast-travel.com/es-es/costa-amalfitana/positano/",
  "image": "https://amalficoast-travel.com/images/positano-hero.jpg",
  "touristType": ["Cultura", "Naturaleza", "Mar", "Gastronomía"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Positano",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84017"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6281,
    "longitude": 14.4849
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Positano, Costa Amalfitana",
  "description": "Pueblo marinero de la Costa Amalfitana en la provincia de Salerno, Campania.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6281,
    "longitude": 14.4849
  },
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Costa Amalfitana"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo se llega a Positano desde Nápoles?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Desde Nápoles Centrale se toma la Circumvesuviana hasta Sorrento (unos 65 min) y luego el autobús SITA por la SS163 hasta Positano (unos 50 min). Alternativamente, hay ferry desde Nápoles Molo Beverello (unos 90 min en verano, servicio estacional)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la mejor época para visitar Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mayo–junio y septiembre–octubre ofrecen el mejor equilibrio entre clima agradable, aglomeraciones moderadas y precios razonables. Julio y agosto son muy calurosos y masificados. El invierno es tranquilo pero muchos negocios cierran."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hay aparcamiento en Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El aparcamiento de pago es limitado y caro (hasta €5/hora). En verano está en vigor la ZTL (zona de tráfico restringido): solo los residentes y los huéspedes de hoteles con permiso pueden entrar en coche en horas punta. Se recomienda encarecidamente el transporte público."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué playas hay en Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La playa principal es la Spiaggia Grande (guijarros, con chiringuitos y zona pública gratuita). La playa de Fornillo es más tranquila, accesible a pie en 10 minutos. La playa de Arienzo, más remota, solo se puede alcanzar en barco."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta alojarse en Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Positano es uno de los destinos más exclusivos de Italia. En temporada alta los B&B empiezan desde €120–150/noche, los hoteles boutique de 4 estrellas desde €250 y los de 5 estrellas desde €400+. Reservar con 3–6 meses de antelación es imprescindible."
      }
    }
  ]
};
---

<BaseLayout
  title="Positano 2026: Guía Completa | Costa Amalfitana"
  description="Todo sobre Positano: cómo llegar, playas, horarios de ferry y autobús, qué ver, cuándo ir. La guía definitiva del pueblo más bello de la Costa Amalfitana."
  lang={lang}
  pageKey="positano"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, placeSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/positano-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costa Amalfitana</p>
        <h1 class="font-serif text-display text-white mb-4">Positano</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Casas de colores pastel a pico sobre el mar Tirreno, escaleras de mayólica, aroma de limones y la playa más famosa de la costa. Bienvenido al pueblo que inspiró a artistas y viajeros de Steinbeck a Picasso.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Datos Rápidos
          </a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Cómo Llegar
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <!-- Main Content -->
      <div class="space-y-16">

        <!-- Intro -->
        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Positano es el símbolo de la Costa Amalfitana: un anfiteatro de casas de colores — blancas, ocre, rosas — que descienden en picado hacia el mar. Con menos de 4.000 habitantes, el pueblo concentra una densidad de belleza que pocos lugares en el mundo pueden igualar.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            El escritor John Steinbeck la describió en 1953 como "un lugar difícil de alcanzar e imposible de olvidar". Setenta años después, esa descripción sigue siendo perfecta. Positano no es un destino turístico: es una experiencia sensorial, donde cada curva revela una nueva vista y cada trattoria un sabor genuino.
          </p>
        </div>

        <!-- ¿Sabías que? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabías que?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1.000+</p>
              <p class="text-white/60 text-xs italic mt-1">escalones en el centro histórico</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">14°C</p>
              <p class="text-white/60 text-xs italic mt-1">temperatura media en enero</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">4 M</p>
              <p class="text-white/60 text-xs italic mt-1">visitantes estimados cada año</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            El nombre "Positano" probablemente deriva del latín <em>Positanum</em>, de una familia romana llamada Posidio que poseía una villa aquí en el siglo I d.C.
          </p>
        </div>

        <!-- Qué ver -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Qué ver en Positano</h2>
          <div class="space-y-8">

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Iglesia de Santa María Assunta</h3>
                <p class="text-slate-600 leading-relaxed">La cúpula de mayólica verde y amarilla es el símbolo del pueblo. En su interior alberga la <em>Madonna Nera de Positano</em>, un icono bizantino del siglo XII. Entrada gratuita, abierta todos los días.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Spiaggia Grande</h3>
                <p class="text-slate-600 leading-relaxed">La playa principal — un arco de guijarros oscuros con vistas a los coloridos barcos. La zona pública es gratuita; los chiringuitos ofrecen tumbonas y sombrillas. En verano se llena pronto: llegar antes de las 9:00.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Playa de Fornillo</h3>
                <p class="text-slate-600 leading-relaxed">Accesible a pie desde la Spiaggia Grande por un camino panorámico de 10 minutos. Menos concurrida, con dos impresionantes islotes rocosos (Las Islas Galli) en el horizonte.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Via dei Mulini y el centro</h3>
                <p class="text-slate-600 leading-relaxed">La calle principal del pueblo, flanqueada de boutiques de moda (Positano es la capital de la moda de playa italiana), tiendas de cerámica y restaurantes. Mejor explorarla al atardecer para evitar las aglomeraciones.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">5</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Sendero de los Dioses</h3>
                <p class="text-slate-600 leading-relaxed">La ruta de senderismo más espectacular de la costa parte desde Nocelle, por encima de Positano, y llega a Agerola. Unos 7,5 km con vistas impresionantes sobre el Golfo de Salerno. Dificultad: moderada.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Cómo llegar — Dark Box -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Cómo llegar a Positano</h2>
            <p class="text-white/60 mb-10 leading-relaxed">No hay estación de tren en Positano. Las principales opciones son el ferry (estacional) y el autobús. En verano se recomienda encarecidamente evitar el coche.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">En barco</h3><p class="text-white/50 text-sm leading-relaxed">De abril a octubre: desde Salerno, Amalfi, Sorrento y Nápoles. Llegar por mar ofrece la vista más icónica del pueblo.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Autobús SITA</h3><p class="text-white/50 text-sm leading-relaxed">Conecta Positano con Sorrento y Amalfi por la SS163. Económico (~€2,50), disponible todo el año.</p></div>
              </div>
            </div>
            <a href="/es-es/guia/ferrys/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Guía completa de transporte
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Horarios ferry y autobús -->
        <div>
          <div class="mb-10">
            <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
              Horarios de Ferry — Verano 2026
            </h3>
            <p class="text-sm text-slate-500 mb-4">Los servicios operan aproximadamente de abril a octubre. Verifica siempre los horarios actuales en los sitios web oficiales de las compañías.</p>

            <div class="overflow-x-auto rounded-2xl border border-slate-200">
              <table class="w-full text-sm">
                <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                  Travelmar — Salerno ↔ Positano (vía Amalfi)
                </caption>
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Sale de Salerno</th>
                    <th class="text-left px-4 py-3 font-semibold">Llega a Positano</th>
                    <th class="text-left px-4 py-3 font-semibold">Notas</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">07:15</td>
                    <td class="px-4 py-3 font-mono">08:55</td>
                    <td class="px-4 py-3 text-slate-500">Vía Cetara, Maiori, Amalfi</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">09:00</td>
                    <td class="px-4 py-3 font-mono">10:40</td>
                    <td class="px-4 py-3 text-slate-500">—</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">11:00</td>
                    <td class="px-4 py-3 font-mono">12:40</td>
                    <td class="px-4 py-3 text-slate-500">—</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">14:15</td>
                    <td class="px-4 py-3 font-mono">15:55</td>
                    <td class="px-4 py-3 text-slate-500">—</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">16:30</td>
                    <td class="px-4 py-3 font-mono">18:10</td>
                    <td class="px-4 py-3 text-slate-500">—</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="overflow-x-auto rounded-2xl border border-slate-200 mt-6">
              <table class="w-full text-sm">
                <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                  Alilauro — Nápoles (Beverello) ↔ Positano
                </caption>
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Sale de Nápoles</th>
                    <th class="text-left px-4 py-3 font-semibold">Llega a Positano</th>
                    <th class="text-left px-4 py-3 font-semibold">Duración</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">09:00</td>
                    <td class="px-4 py-3 font-mono">10:30</td>
                    <td class="px-4 py-3 text-slate-500">~90 min</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">11:00</td>
                    <td class="px-4 py-3 font-mono">12:30</td>
                    <td class="px-4 py-3 text-slate-500">~90 min</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">14:00</td>
                    <td class="px-4 py-3 font-mono">15:30</td>
                    <td class="px-4 py-3 text-slate-500">~90 min</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-400 mt-2">* Horarios indicativos para la temporada 2026. Consulta travelmar.it y alilauro.it para confirmar.</p>
          </div>

          <div>
            <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
              Autobús SITA — Sorrento ↔ Positano (SS163)
            </h3>
            <p class="text-sm text-slate-500 mb-4">El autobús SITA es la opción más económica (~€2,50). Sale desde Sorrento Piazza Tasso. Servicio frecuente durante todo el año.</p>

            <div class="overflow-x-auto rounded-2xl border border-slate-200">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Sale de Sorrento</th>
                    <th class="text-left px-4 py-3 font-semibold">Llega a Positano</th>
                    <th class="text-left px-4 py-3 font-semibold">Frecuencia</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">06:30</td>
                    <td class="px-4 py-3 font-mono">07:20</td>
                    <td class="px-4 py-3 text-slate-500">Solo días laborables</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">08:00</td>
                    <td class="px-4 py-3 font-mono">08:50</td>
                    <td class="px-4 py-3 text-slate-500">Diario</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">09:30</td>
                    <td class="px-4 py-3 font-mono">10:20</td>
                    <td class="px-4 py-3 text-slate-500">Diario</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">11:00</td>
                    <td class="px-4 py-3 font-mono">11:50</td>
                    <td class="px-4 py-3 text-slate-500">Diario</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">13:00</td>
                    <td class="px-4 py-3 font-mono">13:50</td>
                    <td class="px-4 py-3 text-slate-500">Diario</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">15:30</td>
                    <td class="px-4 py-3 font-mono">16:20</td>
                    <td class="px-4 py-3 text-slate-500">Diario</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">17:30</td>
                    <td class="px-4 py-3 font-mono">18:20</td>
                    <td class="px-4 py-3 text-slate-500">Diario</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-400 mt-2">* Horarios indicativos. En verano se añaden servicios extra. Consulta sitasudtrasporti.it para horarios actualizados.</p>
          </div>
        </div>

        <!-- Rincones escondidos -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Rincones escondidos de Positano</h2>
          <p class="text-slate-500 mb-8">Más allá de las postales: cuatro rincones que los turistas de paso nunca encuentran.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Playa de Arienzo</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Una playa accesible solo por mar o bajando 300 escalones. En temporada alta está mucho menos concurrida que la Spiaggia Grande. Alquiler de barcos disponible desde el puerto.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Nocelle y el Sendero de los Dioses</h3>
              <p class="text-sm text-slate-600 leading-relaxed">El hamlet de Nocelle (418 m s.n.m.) sobre Positano se alcanza con un autobús lanzadera. Vistas panorámicas sobre el pueblo y el mar sin aglomeraciones.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Torre Trasita</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Una de las torres medievales sarracenas del pueblo, hoy alquilada como casa de vacaciones privada. Visible y fotografiable desde fuera a lo largo de la calle principal.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Desayuno auténtico al estilo local</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Evita los bares del paseo marítimo (precios turísticos) y busca los bares que frecuentan los locales en las calles altas del pueblo para un desayuno auténtico a precio normal.</p>
            </div>
          </div>
        </div>

        <!-- Consejo Local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Consejo Local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Desayuno auténtico en Positano</h3>
              <p class="text-white/70 leading-relaxed">Evita los bares del paseo (precios turísticos). Sube a las calles altas y busca los bares que frecuentan los locales. Prueba un cornetto de crema de limón con un espresso agitado viendo despertar el pueblo — la misma experiencia a mitad de precio.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Preguntas frecuentes sobre Positano</h2>
          <div class="space-y-4">

            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}

          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <!-- Datos Rápidos -->
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos Rápidos — Positano</p>
          <dl class="space-y-3">
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Ubicación</dt>
              <dd class="text-white font-medium text-sm text-right">Costa Amalfitana, SA</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Altitud</dt>
              <dd class="text-white font-medium text-sm text-right">0–350 m s.n.m.</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Población</dt>
              <dd class="text-white font-medium text-sm text-right">~3.800 habitantes</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">ZTL</dt>
              <dd class="text-white font-medium text-sm text-right">Sí, en verano</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Transporte</dt>
              <dd class="text-white font-medium text-sm text-right">Autobús SITA, Ferry</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Playa</dt>
              <dd class="text-white font-medium text-sm text-right">Guijarros oscuros</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Mejor época</dt>
              <dd class="text-white font-medium text-sm text-right">May–Jun / Sep–Oct</dd>
            </div>
            <div class="border-t border-white/5"></div>
            <div class="flex justify-between items-start gap-3">
              <dt class="text-white/40 text-sm font-light flex-shrink-0">Moneda</dt>
              <dd class="text-white font-medium text-sm text-right">Euro (€)</dd>
            </div>
          </dl>
        </div>

        <!-- Consejos de expertos -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Consejos de expertos</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Llega en ferry: la vista del pueblo desde el agua es la mejor foto que te llevarás a casa.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Lleva calzado cómodo: el centro tiene escalinatas empinadas, no aptas para tacones o chanclas.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Come en las calles altas, no en el paseo marítimo: los precios bajan y la calidad a menudo mejora.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Visita por la tarde: después de las 19:00 los autobuses turísticos se van y el pueblo recupera su alma.</span>
            </li>
          </ul>
        </div>

        <!-- Enlaces rápidos -->
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Explorar la Costa</p>
          <nav class="space-y-1">
            <a href="/es-es/costa-amalfitana/amalfi/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
              <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> Amalfi
            </a>
            <a href="/es-es/costa-amalfitana/ravello/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
              <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> Ravello
            </a>
            <a href="/es-es/costa-amalfitana/praiano/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
              <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> Praiano
            </a>
            <a href="/es-es/costa-amalfitana/maiori/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
              <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> Maiori
            </a>
            <a href="/es-es/costa-amalfitana/minori/" class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
              <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> Minori
            </a>
          </nav>
        </div>

      </aside>
    </div>
  </section>

  <CorrelationSlider
    heading="Explorar también la Costa"
    items={[
      { name: 'Amalfi',    href: '/es-es/costa-amalfitana/amalfi/',   tag: 'Arte e Historia',    desc: 'La Catedral de San Andrés, el Claustro del Paraíso y los callejones de la república marítima.' },
      { name: 'Ravello',   href: '/es-es/costa-amalfitana/ravello/',  tag: 'Música y Jardines', desc: 'Villa Rufolo, Villa Cimbrone y el Festival de Ravello a 350 m sobre el mar.' },
      { name: 'Praiano',   href: '/es-es/costa-amalfitana/praiano/', tag: 'Atardecer y Calma', desc: 'Atardecer desde San Gennaro, playa Gavitella y la Marina di Praia.' },
      { name: 'Maiori',    href: '/es-es/costa-amalfitana/maiori/',   tag: 'Playa y Relax', desc: 'La playa de arena más larga de la costa: 300 m de paseo marítimo.' },
      { name: 'Minori',    href: '/es-es/costa-amalfitana/minori/',   tag: 'Sabores y Cultura', desc: 'Villa romana del siglo I, scialatielli frescos y pastelerías artesanales.' },
      { name: 'Capri',     href: '/es-es/isole/capri/',                  tag: 'La más icónica',   desc: 'Gruta Azul, Faraglioni y la glamurosa Piazzetta.' },
    ]}
