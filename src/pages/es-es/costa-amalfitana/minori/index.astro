---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Costa Amalfitana', url: '/es-es/costa-amalfitana/' },
  { name: 'Minori', url: '/es-es/costa-amalfitana/minori/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Por qué es famosa Minori?",
      "acceptedAnswer": { "@type": "Answer", "text": "Minori es famosa por dos cosas: su villa romana del siglo I (una de las mejor conservadas de la costa) y su tradición de pastelería artesanal, en especial la pasta scialatielli y el pastel delizia al limone. Es el municipio más pequeño de la costa." }
    },
    {
      "@type": "Question",
      "name": "¿Cómo ir de Amalfi a Minori?",
      "acceptedAnswer": { "@type": "Answer", "text": "En autobús SITA desde Amalfi: unos 10–15 minutos, ~1,30 €. En ferry Travelmar (temporada, abril–octubre): unos 15 minutos. A pie por el sendero costero desde Maiori: unos 40 minutos." }
    },
    {
      "@type": "Question",
      "name": "¿La villa romana de Minori es gratuita?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sí, la villa romana del siglo I de Minori es gratuita. Está ubicada en el centro del pueblo, bajo el nivel de la calle moderna, y está abierta la mayoría de los días del año." }
    }
  ]
};

const fastFacts = [
  { dt: 'Ubicación', dd: 'Costa Amalfitana, SA' },
  { dt: 'Población', dd: '~2.800 hab.' },
  { dt: 'Desde Amalfi', dd: '~10 min (bus SITA)' },
  { dt: 'Desde Maiori', dd: '~5 min (bus SITA)' },
  { dt: 'Imprescindible', dd: 'Villa romana (s. I)' },
  { dt: 'Ideal para', dd: 'Gastronomía, historia' },
  { dt: 'Mejor época', dd: 'Abr–Oct' },
];
---

<BaseLayout
  title="Minori 2026: Guía Completa | Costa Amalfitana"
  description="Guía de Minori: la villa romana del siglo I, la pasta scialatielli, la delizia al limone y cómo llegar desde Amalfi. La tranquila capital gastronómica de la Costa Amalfitana."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/minori-hero.jpg" alt="Minori, Costa Amalfitana" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>{i > 0 && <span>/</span>}{i < breadcrumbs.length - 1 ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a> : <span class="text-white">{b.name}</span>}</>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costa Amalfitana · Sabores & Cultura</p>
        <h1 class="font-serif text-display text-white mb-4">Minori</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          El municipio más pequeño de la Costa Amalfitana esconde bajo sus calles una villa romana del siglo I, pastelerías artesanales a las que acuden habitantes de toda la costa, y la tranquila autenticidad que los destinos más famosos perdieron hace mucho tiempo.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Minori se encuentra entre Maiori y Atrani, a solo 10 minutos en autobús de Amalfi. El pueblo es lo suficientemente compacto como para explorarlo completamente a pie en una mañana, dejando libre la tarde para comer: la tradición pastelera aquí es seria, y los scialatielli —cintas de pasta gruesas y cortas, mejor servidas con mariscos— fueron inventados en este rincón de la costa.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabías que...?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">I</p><p class="text-white/60 text-xs italic mt-1">siglo d.C.: la villa romana bajo el pueblo</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">2.800</p><p class="text-white/60 text-xs italic mt-1">habitantes - municipio más pequeño de la costa</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">1978</p><p class="text-white/60 text-xs italic mt-1">invención de los scialatielli aquí</p></div>
          </div>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Qué ver y qué probar</h2>
          <div class="space-y-6">
            {[
              { title: 'Villa romana del siglo I', text: 'Descubierta en los años 50 bajo el centro del pueblo, es una de las villas marítimas romanas mejor conservadas de la costa. Bellamente decorada con frescos y suelos de mosaico. Entrada gratuita, abierta todo el año.' },
              { title: 'Pasta scialatielli', text: 'Inventada por el chef Enrico Cosentino en Minori en 1978, los scialatielli son cintas de pasta gruesas y cortas, mejores con almejas, mejillones y mariscos locales. Pruébalos en una de las trattorias tradicionales del pueblo.' },
              { title: 'Delizia al limone', text: 'Un bizcocho suave empapado en crema de limoncello y cubierto con un glaseado de crema pastelera de limón. Las pastelerías de Minori son consideradas las mejores de toda la costa para este clásico postre costero.' },
              { title: 'Gole di Sant\'Elia', text: 'Un corto paseo por el barranco (unos 1,5 km) que parte del centro del pueblo, siguiendo el torrente Regina hacia un valle frondoso y sombreado. Gratuito y fácil; no se requiere equipo técnico.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Cómo llegar</h2>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <thead><tr class="bg-med-blue/5 text-charcoal"><th class="text-left px-4 py-3 font-semibold">Transporte</th><th class="text-left px-4 py-3 font-semibold">Desde</th><th class="text-left px-4 py-3 font-semibold">Duración</th></tr></thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-medium">Bus SITA</td><td class="px-4 py-3 text-slate-600">Amalfi</td><td class="px-4 py-3 text-slate-500">~10–15 min, ~1,30 €</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-medium">Ferry</td><td class="px-4 py-3 text-slate-600">Salerno (Travelmar)</td><td class="px-4 py-3 text-slate-500">~45 min, temporada</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-medium">A pie</td><td class="px-4 py-3 text-slate-600">Maiori</td><td class="px-4 py-3 text-slate-500">~40 min por el sendero costero</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos Rápidos - Minori</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <><div class="flex justify-between items-start gap-3"><dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt><dd class="text-white font-medium text-sm text-right">{dd}</dd></div>{i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}</>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Costa Amalfitana</p>
          <nav class="space-y-1">
            {[['positano','Positano'],['amalfi','Amalfi'],['ravello','Ravello'],['praiano','Praiano'],['maiori','Maiori']].map(([s,l]) => (
              <a href={`/es-es/costa-amalfitana/${s}/`} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors"><span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {l}</a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Explorar también la costa"
    items={[
      { name: 'Maiori',   href: '/es-es/costa-amalfitana/maiori/',   tag: 'Playa & Vida local', desc: 'La playa de arena más larga de la costa y un pueblo auténtico.' },
      { name: 'Amalfi',   href: '/es-es/costa-amalfitana/amalfi/',   tag: 'Arte & Historia',    desc: 'La Catedral, el Museo del Papel y la República marítima.' },
      { name: 'Ravello',  href: '/es-es/costa-amalfitana/ravello/',  tag: 'Música & Jardines',  desc: 'Villa Rufolo, Villa Cimbrone y el Festival de Ravello.' },
      { name: 'Positano', href: '/es-es/costa-amalfitana/positano/', tag: 'Icónico',             desc: 'Casas de colores sobre el mar y la playa más famosa.' },
    ]}
  />

</BaseLayout>
