---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Costa Amalfitana', url: '/es-es/costa-amalfitana/' },
  { name: 'Maiori', url: '/es-es/costa-amalfitana/maiori/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cómo se llega a Maiori desde Salerno?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "En ferry Travelmar desde Salerno (unos 50 min, estacional de abril a octubre) o en autobús SITA desde Salerno o Amalfi. El autobús es la opción más frecuente durante todo el año."
      }
    },
    {
      "@type": "Question",
      "name": "¿Maiori tiene playa de arena?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí - Maiori tiene la playa de arena más larga de la Costa Amalfitana, unos 300 metros, con zonas públicas gratuitas y chiringuitos de pago. La arena aquí es más gruesa que los guijarros típicos de los otros pueblos de la costa."
      }
    },
    {
      "@type": "Question",
      "name": "¿Vale la pena visitar Maiori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, especialmente si prefieres una atmósfera más local y menos turística. Maiori es popular entre las familias italianas por su playa, su paseo marítimo y sus precios más bajos en comparación con Positano y Amalfi."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué hacer en Maiori además de la playa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La Abadía de Santa María de Olearia (siglo XI, tallada en la roca), los jardines del Palazzo Mezzacapo y la torre normanda son los principales puntos de interés. El paseo marítimo con sus cafés y restaurantes es perfecto para las noches de verano."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuándo es la mejor época para ir a Maiori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Junio a septiembre para disfrutar de la playa. En agosto se celebra la fiesta de Santa María a Mare con una procesión en el mar y fuegos artificiales el 15 de agosto. Mayo y octubre son ideales para evitar las multitudes."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Ubicación', dd: 'Costa Amalfitana, SA' },
  { dt: 'Población', dd: '~5.500 habitantes' },
  { dt: 'Desde Salerno', dd: '~50 min (ferry)' },
  { dt: 'Desde Amalfi', dd: '~20 min (autobús SITA)' },
  { dt: 'Playa', dd: 'Arena (300 m)' },
  { dt: 'Mejor para', dd: 'Playa, familias, vida local' },
  { dt: 'Mejor época', dd: 'Jun–Sep' },
  { dt: 'Moneda', dd: 'Euro (€)' },
];
---

<BaseLayout
  title="Maiori 2026: Guía Completa | Costa Amalfitana"
  description="Guía de Maiori: la playa de arena más larga de la Costa Amalfitana, los jardines Mezzacapo, la Abadía de Santa María de Olearia. Cómo llegar en ferry desde Salerno."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/maiori-hero.jpg" alt="Maiori, Costa Amalfitana" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costa Amalfitana · Playa y Vida Local</p>
        <h1 class="font-serif text-display text-white mb-4">Maiori</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La playa más larga de la Costa Amalfitana: 300 metros de arena en lugar de los guijarros que encuentras en todos los demás lugares. Maiori es el pueblo más relajado de la costa - un auténtico paseo marítimo, restaurantes locales y precios que no te quitan el aliento.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Maiori se asienta en la desembocadura del valle de la Regina, que corta tierra adentro desde la costa y da al pueblo la llanura costera más amplia - y por lo tanto la playa más ancha - de toda la Costa Amalfitana. Es un pueblo real con supermercado, oficina de correos y habitantes que viven aquí todo el año, lo que es inusual en este tramo de costa.
        </p>

        <!-- ¿Sabías que? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">¿Sabías que?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">300 m</p>
              <p class="text-white/60 text-xs italic mt-1">la playa de arena más larga de la costa</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">XI</p>
              <p class="text-white/60 text-xs italic mt-1">siglo: la Abadía de Santa María de Olearia</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">5.500</p>
              <p class="text-white/60 text-xs italic mt-1">residentes durante todo el año</p>
            </div>
          </div>
        </div>

        <!-- Qué ver -->
        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Qué ver en Maiori</h2>
          <div class="space-y-6">
            {[
              { title: 'La playa', text: 'La playa principal de arena con 300 m - la más larga de la Costa Amalfitana. Hay zonas públicas gratuitas y chiringuitos de pago. Un paseo marítimo con bares y restaurantes recorre el frente litoral.' },
              { title: 'Abadía de Santa María de Olearia', text: 'Una notable abadía benedictina del siglo XI tallada en el acantilado sobre la carretera costera, con tres capillas superpuestas y frescos medievales. Abierta para visitas; consulta los horarios estacionales.' },
              { title: 'Jardines del Palazzo Mezzacapo', text: 'Un jardín del siglo XIX con plantas raras, una terraza panorámica y vistas sobre la bahía. Acceso público gratuito.' },
              { title: 'Fuegos artificiales de Ferragosto (15 de agosto)', text: 'El 15 de agosto Maiori celebra la fiesta de Santa María a Mare con una procesión en el mar y fuegos artificiales sobre la bahía - uno de los mejores espectáculos de Ferragosto de la costa.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Cómo llegar</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Ferry (Estacional)</p>
              <p class="text-slate-700 font-medium mb-1">Travelmar desde Salerno</p>
              <p class="text-slate-500 text-sm">~50 min, abril–octubre. La opción más pintoresca llegando desde Salerno.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Autobús SITA</p>
              <p class="text-slate-700 font-medium mb-1">Desde Amalfi o Salerno</p>
              <p class="text-slate-500 text-sm">~20 min desde Amalfi. Servicio todo el año por la SS163.</p>
            </div>
          </div>
        </div>

        <!-- Horarios ferry -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Horarios de Ferry - Verano 2026
          </h3>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Travelmar - Salerno ↔ Maiori</caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Sale de Salerno</th>
                  <th class="text-left px-4 py-3 font-semibold">Llega a Maiori</th>
                  <th class="text-left px-4 py-3 font-semibold">Notas</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">07:15</td><td class="px-4 py-3 font-mono">08:05</td><td class="px-4 py-3 text-slate-500">Vía Cetara</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">09:00</td><td class="px-4 py-3 font-mono">09:50</td><td class="px-4 py-3 text-slate-500">-</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">11:00</td><td class="px-4 py-3 font-mono">11:50</td><td class="px-4 py-3 text-slate-500">-</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">14:15</td><td class="px-4 py-3 font-mono">15:05</td><td class="px-4 py-3 text-slate-500">-</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">16:30</td><td class="px-4 py-3 font-mono">17:20</td><td class="px-4 py-3 text-slate-500">-</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Horarios indicativos para 2026. Consulta travelmar.it para confirmar.</p>
        </div>

        <!-- Rincones escondidos -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Rincones escondidos de Maiori</h2>
          <p class="text-slate-500 mb-8">Más allá de la playa: cuatro rincones que los visitantes rara vez descubren.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Torre Normanna</h3>
              <p class="text-sm text-slate-600 leading-relaxed">La torre normanda medieval en el extremo oriental del paseo marítimo, visible desde la playa. Desde arriba se tiene una vista panorámica del golfo. Información disponible en el ayuntamiento.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Valle del Tramonti</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Detrás de Maiori se abre el valle del Tramonti, famoso por sus viñedos y su vino local. Una excursión de medio día entre viñas y pequeños caseríos, completamente fuera de las rutas turísticas.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Faro del Capo d'Orso</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Un sendero de 2 km desde el centro de Maiori lleva al Capo d'Orso, con su faro y vistas impresionantes sobre toda la costa. Sin turistas, con una vista de 180° sobre el Golfo de Salerno.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Mercado local del sábado</h3>
              <p class="text-sm text-slate-600 leading-relaxed">El mercado semanal de Maiori, los sábados por la mañana, es donde los locales compran fruta, verdura y ropa. El mejor lugar para sentir el pulso real del pueblo y comprar limones directamente a los agricultores.</p>
            </div>
          </div>
        </div>

        <!-- Consejo Local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Consejo Local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Usa Maiori como base de operaciones</h3>
              <p class="text-white/70 leading-relaxed">Alojarse en Maiori y hacer excursiones diarias a Positano, Amalfi y Ravello es una estrategia excelente: precios de alojamiento 30–40% más bajos, playa de arena a pocos pasos y autobuses SITA a todas las direcciones desde el paseo marítimo.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Preguntas frecuentes sobre Maiori</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Datos Rápidos - Maiori</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Consejos de expertos -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Consejos de expertos</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Si llegas en ferry desde Salerno, tienes la mejor vista de la playa y el paseo marítimo desde el mar.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>La playa es mejor por la mañana temprano: después de las 11:00 se llena con familias en verano.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>El pescado fresco en los restaurantes del paseo está a mitad de precio que en Amalfi o Positano.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Sube a Ravello en autobús SITA (cambio en Amalfi): la excursión perfecta desde Maiori.</span>
            </li>
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Costa Amalfitana</p>
          <nav class="space-y-1">
            {[
              { href: '/es-es/costa-amalfitana/positano/', label: 'Positano' },
              { href: '/es-es/costa-amalfitana/amalfi/', label: 'Amalfi' },
              { href: '/es-es/costa-amalfitana/ravello/', label: 'Ravello' },
              { href: '/es-es/costa-amalfitana/praiano/', label: 'Praiano' },
              { href: '/es-es/costa-amalfitana/minori/', label: 'Minori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Explorar también la Costa"
    items={[
      { name: 'Minori',   href: '/es-es/costa-amalfitana/minori/',   tag: 'Sabores y Cultura', desc: 'Villa romana del siglo I, scialatielli frescos y pastelerías artesanales.' },
      { name: 'Amalfi',   href: '/es-es/costa-amalfitana/amalfi/',   tag: 'Arte e Historia',    desc: 'La Catedral de San Andrés, el Museo del Papel y la República Marítima.' },
      { name: 'Ravello',  href: '/es-es/costa-amalfitana/ravello/',  tag: 'Música y Jardines',  desc: 'Villa Rufolo, Villa Cimbrone y el Festival de Ravello.' },
      { name: 'Positano', href: '/es-es/costa-amalfitana/positano/', tag: 'Icónico',             desc: 'Casas de colores sobre el mar y la playa más famosa.' },
    ]}
  />

</BaseLayout>
