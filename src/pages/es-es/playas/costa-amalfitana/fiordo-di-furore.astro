---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Costa Amalfitana', url: '/es-es/playas#costa-amalfitana' },
  { name: 'Fiordo di Furore', url: '/es-es/playas/costa-amalfitana/fiordo-di-furore' },
];

const facts = [
  { label: 'Suelo', value: 'Cantos rodados' },
  { label: 'Acceso', value: 'Escaleras (~200 peldaños)' },
  { label: 'Sombra', value: 'A partir de las 14:30 ⚠️' },
  { label: 'Equipamiento', value: 'Playa pública gratuita' },
  { label: 'Ideal para', value: 'Fotografía, parejas' },
];

const logistica = [
  { transport: 'Bus SITA', parada: 'Furore Fiordo', notas: 'Línea Amalfi–Positano' },
  { transport: 'Moto', parada: 'Ponte Furore', notas: 'Aparcamiento limitado en el arcén' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Fiordo di Furore",
  "description": "Una playa icónica encajada en un fiordo natural con aguas cristalinas y un puente monumental de 30 metros de altura.",
  "image": "https://amalficoast-travel.com/images/fiordo-furore.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6122",
    "longitude": "14.5534"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Furore",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "publicAccess": "true"
};
---

<BaseLayout
  title="Fiordo di Furore 2026: Guía, Acceso y Horas de Sol"
  description="Cómo visitar el Fiordo di Furore en 2026. Cuándo llega el sol a la playa, cómo ir en autobús y consejos para la foto perfecta."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/fiordo-furore-hero.jpg"
      alt="Fiordo di Furore, Costa Amalfitana"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costa Amalfitana</p>
      <h1 class="font-serif text-display text-white mb-6">Fiordo di Furore</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Una obra maestra de la naturaleza esculpida en la roca.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Un Icono de la Costa Amalfitana</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            El Fiordo di Furore es una de las imágenes más icónicas de Italia. No es una playa tradicional, sino una profunda grieta natural donde el mar se cuela bajo un puente monumental de 30 metros. En 2026, el acceso está regulado para proteger el enclave: la playa es pequeña y el agua suele ser más fresca que en la costa abierta.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Un paraíso para fotógrafos - pero ojo a la luz: el sol ilumina el fondo del fiordo solo a mediodía. Llega entre las 11 y las 13 h para las mejores fotos. Saltar desde el puente es una tradición local, pero está prohibido para los turistas: disfruta de las vistas desde arriba antes de bajar los 200 peldaños hasta la playa.
          </p>
        </div>

        <!-- Alerta Sombra -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Aviso de Sombra</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            El sol alcanza la playa solo entre las <strong>11 y las 14:30 h</strong>. Antes y después de esa ventana, el fiordo está completamente en sombra. Planifica tu visita si quieres sol para bañarte. Para fotos perfectas del agua turquesa iluminada, apunta a las 11:30 h aproximadamente.
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="overflow-hidden rounded-[2rem] border border-slate-100 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-charcoal text-white">
                  <th class="text-left p-4 font-medium">Transporte</th>
                  <th class="text-left p-4 font-medium">Parada</th>
                  <th class="text-left p-4 font-medium">Notas</th>
                </tr>
              </thead>
              <tbody>
                {logistica.map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                    <td class="p-4 font-medium text-slate-900">{row.transport}</td>
                    <td class="p-4 text-slate-600">{row.parada}</td>
                    <td class="p-4 text-slate-500">{row.notas}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Guías Prácticas -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-slate-900 mb-8">Guías Prácticas</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/es-es/cuando-visitar/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Cuándo visitar</p>
            <p class="text-xs text-slate-500">Mes a mes</p>
          </div>
        </a>
        <a href="/es-es/costa-amalfitana/come-arrivare/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Cómo llegar</p>
            <p class="text-xs text-slate-500">Ferries, autobús, coche</p>
          </div>
        </a>
        <a href="/es-es/playas/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17c3-3 6-3 9 0s6 3 9 0M3 12c3-3 6-3 9 0s6 3 9 0"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Las playas</p>
            <p class="text-xs text-slate-500">9 playas seleccionadas</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre otras playas de la Costa Amalfitana</h2>
      <a
        href="/es-es/playas"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de playas
      </a>
    </div>
  </section>

</BaseLayout>
