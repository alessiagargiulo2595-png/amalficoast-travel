---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Costa Amalfitana', url: '/es-es/playas#costa-amalfitana' },
  { name: 'Santa Croce', url: '/es-es/playas/costa-amalfitana/santa-croce-amalfi' },
];

const facts = [
  { label: 'Suelo', value: 'Cantos rodados blancos' },
  { label: 'Acceso', value: 'Solo por mar (taxi boat)' },
  { label: 'Sombra', value: 'A partir de las 16:00' },
  { label: 'Equipamiento', value: '2 restaurantes con lido' },
  { label: 'Ideal para', value: 'Escapada romántica, pescado fresco' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia di Santa Croce",
  "description": "Playa exclusiva accesible únicamente por mar desde Amalfi, famosa por sus aguas cristalinas y sus históricos restaurantes.",
  "isAccessibleForFree": "false",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Playa Santa Croce Amalfi: Cómo Llegar Solo por Mar"
  description="Santa Croce es la escapada perfecta desde Amalfi. Accesible solo en barco, con aguas cristalinas y restaurantes históricos que ofrecen lanzadera gratuita."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/santa-croce-amalfi.jpg"
      alt="Playa de Santa Croce, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfi · Solo por mar</p>
      <h1 class="font-serif text-display text-white mb-6">Santa Croce</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Una escapada secreta a pocos minutos del caos de Amalfi.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">La Escapada Perfecta desde Amalfi</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Santa Croce es el antídoto al gentío de julio y agosto en Amalfi. Accesible solo en pocos minutos de barco desde el embarcadero principal, ofrece un agua de transparencia extraordinaria sobre fondos rocosos. La playa de cantos rodados blancos está protegida entre altos acantilados que la resguardan del viento.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Los dos históricos restaurantes - Da Gemma y La Caravella - gestionan lidos privados en la playa y ofrecen lanzadera gratuita desde el embarcadero de Amalfi para sus clientes. Es la opción ideal para quien quiere una jornada de mar «salvaje» con el confort de una excelente comida de pescado fresco.
          </p>
        </div>

        <!-- Consejo local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Consejo Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Reserva el almuerzo en el restaurante con antelación: ofrecen <strong>lanzadera gratuita</strong> desde el embarcadero para sus clientes. Es la forma más barata - y más pintoresca - de llegar a Santa Croce.
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat ⭐ Único acceso</p>
              <p class="text-slate-700 font-medium mb-1">Desde el embarcadero de Amalfi</p>
              <p class="text-slate-500 text-sm">Unos 5 minutos de trayecto. Coste: 5–8 € por persona (ida y vuelta).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Lanzadera del Restaurante</p>
              <p class="text-slate-700 font-medium mb-1">Gratuita para clientes</p>
              <p class="text-slate-500 text-sm">Reserva el almuerzo y el trayecto está incluido en el servicio.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre otras playas de la Costa Amalfitana</h2>
      <a
        href="/es-es/playas"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de playas
      </a>
    </div>
  </section>

</BaseLayout>
