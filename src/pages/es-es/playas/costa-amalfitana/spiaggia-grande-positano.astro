---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Costa Amalfitana', url: '/es-es/playas#costa-amalfitana' },
  { name: 'Spiaggia Grande Positano', url: '/es-es/playas/costa-amalfitana/spiaggia-grande-positano' },
];

const facts = [
  { label: 'Suelo', value: 'Arena y guijarros' },
  { label: 'Acceso', value: 'Fácil (llano)' },
  { label: 'Sombra', value: 'A partir de las 17:30' },
  { label: 'Equipamiento', value: 'Chiringuitos de lujo, restaurantes, embarcadero' },
  { label: 'Ideal para', value: 'Ambiente, glamour, ver y ser visto' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia Grande di Positano",
  "description": "La playa principal de Positano, corazón de la vida social y de los chiringuitos de lujo de la Costa Amalfitana.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6273",
    "longitude": "14.4849"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Positano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Restaurantes", "value": "Sí" },
    { "@type": "LocationFeatureSpecification", "name": "Chiringuito", "value": "Sí" }
  ]
};
---

<BaseLayout
  title="Spiaggia Grande Positano 2026: Chiringuitos y Precios"
  description="Vive el corazón de Positano. Precios 2026 de hamacas, restaurantes y cómo llegar a la Spiaggia Grande por mar."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-grande-positano.jpg"
      alt="Spiaggia Grande di Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Positano · Costa Amalfitana</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia Grande</h1>
      <p class="text-lg md:text-xl font-light text-white/80">El corazón glamuroso de la Costa Amalfitana.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">El Glamour de la Costa</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La Spiaggia Grande es el centro de la vida social de Positano. Con la ciudad vertical de telón de fondo — casas de colores pastel que trepan hasta la iglesia de Santa Maria Assunta — el escenario es único en el mundo. En 2026, los chiringuitos exigen reservas con varias semanas de antelación en temporada alta.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Es también el punto de salida de todos los taxis acuáticos hacia las calas aisladas de la costa. Si quieres la mezcla perfecta de comodidad, cócteles exclusivos y ambiente de lujo, esta es tu playa. La zona pública gratuita, al este, se llena rápidamente después de las 9 h.
          </p>
        </div>

        <!-- Precios -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Precios 2026</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Una hamaca más sombrilla en los chiringuitos de la Spiaggia Grande cuesta de media <strong>35–60 € por persona</strong>. Los restaurantes en primera línea de mar (La Buca di Bacco, La Scalinatella) incluyen el servicio de sombrilla con el almuerzo.
          </p>
          <p class="text-slate-600 leading-relaxed">
            El <strong>aparcamiento</strong> en el centro de Positano está muy desaconsejado: llega en ferry desde Amalfi o Sorrento, o en bus SITA — bájate en la parada Sponda.
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Por mar ⭐ Recomendado</p>
              <p class="text-slate-700 font-medium mb-1">Ferry desde Amalfi o Sorrento</p>
              <p class="text-slate-500 text-sm">Desembarco directo en la playa. Disfruta del panorama desde el agua.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus SITA</p>
              <p class="text-slate-700 font-medium mb-1">Parada Sponda</p>
              <p class="text-slate-500 text-sm">Escalera empinada hasta la playa (unos 10 min a pie).</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre otras playas de la Costa Amalfitana</h2>
      <a
        href="/es-es/playas"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de playas
      </a>
    </div>
  </section>

</BaseLayout>
