---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Costa Amalfitana', url: '/es-es/playas#costa-amalfitana' },
  { name: 'Marina di Praia', url: '/es-es/playas/costa-amalfitana/marina-di-praia' },
];

const facts = [
  { label: 'Composición', value: 'Guijarros y rocas' },
  { label: 'Acceso', value: 'En barco o senderismo' },
  { label: 'Sombra', value: 'Mínima (expuesta)' },
  { label: 'Atmósfera', value: 'Salvaje, aislada' },
  { label: 'Ideal para', value: 'Aventureros, senderismo' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina di Praia",
  "description": "Una playa salvaje y escondida accesible solo en barco o senderismo. Acantilados dramáticos y aguas cristalinas para el snorkel.",
  "image": "https://amalficoast-travel.com/images/marina-di-praia.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5967",
    "longitude": "14.4883"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina di Praia 2026: Guía de la Playa Secreta"
  description="Marina di Praia es una playa salvaje y escondida entre Positano y Praiano. Guía de acceso en barco, senderismo y consejos."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-di-praia.jpg"
      alt="Marina di Praia, Costa Amalfitana"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costa Amalfitana · Gemas Ocultas</p>
      <h1 class="font-serif text-display text-white mb-6">Marina di Praia</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La playa salvaje entre Positano y Praiano, preservada del turismo masivo.</p>
    </div>
  </section>

  <!-- Contenido + Barra Lateral -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto Principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">El Secreto Salvaje de la Costa Amalfitana</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina di Praia es una pequeña playa dramática anidada bajo acantilados empinados entre Positano y Praiano. Ningún camino lleva aquí—el acceso es solo por mar o un desafiante sendero de senderismo. Este aislamiento la ha preservado como una de las últimas playas verdaderamente intactas de la costa.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            La playa es principalmente guijarros y rocas pequeñas, con algunos parches de arena. El agua cristalina y el excelente esnórquel la hacen un destino para nadadores aventureros. Los acantilados arriba son escarpados y dramáticos, ofreciendo vistas inolvidables.
          </p>
        </div>

        <!-- Cómo Llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">En Barco ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Desde Positano o Praiano</p>
              <p class="text-slate-500 text-sm">Taxi acuático o barco de alquiler. Opción más confiable. €20-30 ida y vuelta.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Sendero de Senderismo</p>
              <p class="text-slate-700 font-medium mb-1">45 minutos desde Praiano</p>
              <p class="text-slate-500 text-sm">Descenso empinado. Calzado adecuado esencial. No para todos.</p>
            </div>
          </div>
        </div>

        <!-- Por Qué es Especial -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Por Qué es Especial</h3>
          <div class="space-y-4 text-slate-600">
            <p class="leading-relaxed">
              <strong>Intacta:</strong> Sin chiringuitos, sin multitudes, sin comercialización. Solo naturaleza y el mar.
            </p>
            <p class="leading-relaxed">
              <strong>Esnórquel:</strong> El agua es tan clara que puedes ver 15+ metros de profundidad. Peces de colores y formaciones rocosas interesantes.
            </p>
            <p class="leading-relaxed">
              <strong>Fotografía:</strong> El drama de los acantilados combinado con agua turquesa crea imágenes impresionantes.
            </p>
          </div>
        </div>
      </div>

      <!-- Barra Lateral Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Rápidos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre más playas de la Costa Amalfitana</h2>
      <a
        href="/es-es/playas"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de playas
      </a>
    </div>
  </section>

</BaseLayout>
