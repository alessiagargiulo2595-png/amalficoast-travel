---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Islas del Golfo', url: '/es-es/playas#islas' },
  { name: 'Spiaggia dei Maronti', url: '/es-es/playas/islas/spiaggia-maronti' },
];

const facts = [
  { label: 'Suelo', value: 'Arena volcánica' },
  { label: 'Longitud', value: '3 km (la más larga de la isla)' },
  { label: 'Especial', value: 'Fumarolas naturales calientes' },
  { label: 'Sombra', value: 'A partir de las 19:00' },
  { label: 'Ideal para', value: 'Termalismo natural, familias, relax' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia dei Maronti",
  "description": "La playa volcánica de Ischia, la más larga de la isla (3 km), famosa por sus fumarolas naturales calientes y sus manantiales termales subterráneos.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Barano d'Ischia",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia dei Maronti Ischia 2026: Fumarolas y Arena Caliente"
  description="Los Maronti son la playa más larga de Ischia (3 km) con fumarolas termales naturales. Guía 2026: cómo llegar, qué esperar y consejos prácticos."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-maronti-ischia.jpg"
      alt="Spiaggia dei Maronti, Ischia"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Ischia · Islas del Golfo</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia dei Maronti</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Tres kilómetros de arena caliente calentada por el volcán.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Termalismo Natural</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Los Maronti ofrecen una experiencia única en Italia. La playa es inmensa - tres kilómetros de arena volcánica oscura - y la propia arena está calentada por el calor volcánico del subsuelo a través de las <strong>fumarolas</strong>: chorros de vapor caliente que emergen de la arena, alcanzando en algunos puntos temperaturas superiores a los 60 °C.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Perfecta para los que buscan escapar del bullicio de los puertos. La gran extensión garantiza que incluso en agosto siempre se encuentra un rincón tranquilo. El agua es tranquila e ideal para familias con niños pequeños.
          </p>
        </div>

        <!-- Fumarolas -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3z"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Las Fumarolas</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Las fumarolas se encuentran en la parte central de la playa (zona Fumarole Beach). Puedes enterrar los pies en la arena caliente para un efecto termal natural gratuito. <strong>No te acerques demasiado a los chorros de vapor</strong>: las temperaturas pueden ser muy elevadas. Los niños deben estar vigilados en esta zona.
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Línea 5</p>
              <p class="text-slate-700 font-medium mb-1">Desde Ischia Porto</p>
              <p class="text-slate-500 text-sm">Bajar en Barano. Luego sendero en bajada hacia la playa (15 min).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Acuático ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Desde Sant'Angelo</p>
              <p class="text-slate-500 text-sm">5 minutos en barco. Pintoresco y práctico. Desembarco directo en la playa.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre todo sobre Ischia</h2>
      <a
        href="/es-es/islas/ischia/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de Ischia
      </a>
    </div>
  </section>

</BaseLayout>
