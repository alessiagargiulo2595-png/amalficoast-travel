---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Islas de la Bahía', url: '/es-es/playas#islas' },
  { name: 'Faraglioni di Capri', url: '/es-es/playas/islas/faraglioni-capri' },
];

const facts = [
  { label: 'Tipo', value: 'Formaciones rocosas (sin playa)' },
  { label: 'Acceso', value: 'Solo en barco' },
  { label: 'Famoso por', value: 'Películas italianas & leyenda' },
  { label: 'Atmósfera', value: 'Icónico, dramático' },
  { label: 'Ideal para', value: 'Fotografía, natación' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Faraglioni di Capri",
  "description": "Tres formaciones rocosas icónicas que se alzan 109 metros del mar. Un símbolo de Capri y estrella de famosas películas italianas. Accesible en barco para nadar y bucear.",
  "image": "https://amalficoast-travel.com/images/faraglioni-capri.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5447",
    "longitude": "14.2277"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Faraglioni di Capri 2026: Rocas Icónicas & Guía de Natación"
  description="Los Faraglioni son tres enormes formaciones rocosas frente a la costa de Capri. Un ícono italiano, estrella de películas. Guía para visitar en barco y qué esperar."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/faraglioni-capri.jpg"
      alt="Faraglioni di Capri, Islas de la Bahía"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Islas de la Bahía · Ícono Italiano</p>
      <h1 class="font-serif text-display text-white mb-6">Faraglioni di Capri</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Tres formaciones rocosas legendarias que han cautivado a visitantes durante siglos.</p>
    </div>
  </section>

  <!-- Contenido + Barra Lateral -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto Principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Leyenda en Piedra</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Los Faraglioni di Capri son tres formaciones rocosas imponentes que se alzan 109 metros (357 pies) desde el Mar Tirreno. Son uno de los hitos naturales más fotografiados de Italia, símbolos instantáneamente reconocibles de Capri y la costa de Campania. Cada formación tiene un nombre: Faraglione Grande (la más grande), Faraglione di Mezzo (del medio) y Faraglione di Fuori (exterior).
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Estas rocas dramáticas han inspirado a innumerables artistas, cineastas y escritores. Aparecen en la película italiana clásica "El Talento de Sr. Ripley" y figuran prominentemente en la fotografía de viajes mundial. La leyenda local dice que pasar bajo el arco natural de la roca del medio trae buena suerte—y cientos de barcos lo hacen diariamente.
          </p>
        </div>

        <!-- Historias & Leyenda -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Historias & Leyenda</h2>
          <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
            <div class="space-y-6 text-slate-600">
              <div>
                <p class="font-semibold text-slate-900 mb-2">El Lagarto Azul</p>
                <p class="leading-relaxed">
                  La leyenda local habla del lagarto azul endémico (Podarcis sicula coerulea) que vive en las rocas. Una vez común, estas criaturas se han vuelto raras, ahora protegidas dentro de una reserva marina.
                </p>
              </div>
              <div>
                <p class="font-semibold text-slate-900 mb-2">En Cine & Arte</p>
                <p class="leading-relaxed">
                  Los Faraglioni han aparecido en numerosas películas italianas y sirven como símbolo visual de la dolce vita. Los artistas los han pintado durante siglos, capturando la luz y el drama de estas formaciones en diferentes horas del día.
                </p>
              </div>
              <div>
                <p class="font-semibold text-slate-900 mb-2">Maravilla Geológica</p>
                <p class="leading-relaxed">
                  Estas formaciones de piedra caliza son restos de antiguos acantilados erosionados por olas y viento. El arco natural en la roca del medio crea un pasaje utilizado por barcos—una experiencia emocionante y una oportunidad de foto.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Cómo Visitar -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Cómo Visitar</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            Los Faraglioni solo se pueden visitar en barco. Numerosos tours salen diariamente desde Capri, Positano y otras ciudades costeras. Los tours típicamente duran 2-3 horas e incluyen tiempo para nadar y bucear de superficie alrededor de las rocas.
          </p>
          <p class="text-slate-600 leading-relaxed">
            <strong>Mejor época para visitar:</strong> Mayo a septiembre, cuando el mar está más calmado. Los tours en barco por la mañana ofrecen la mejor luz para la fotografía. Se permite nadar, y el agua es excepcionalmente clara, haciendo que el buceo de superficie sea excepcional.
          </p>
        </div>
      </div>

      <!-- Barra Lateral Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Rápidos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre más de las Islas de la Bahía</h2>
      <a
        href="/es-es/playas"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de playas
      </a>
    </div>
  </section>

</BaseLayout>
