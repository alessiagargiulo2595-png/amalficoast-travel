---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Islas del Golfo', url: '/es-es/playas#islas' },
  { name: 'Marina Piccola Capri', url: '/es-es/playas/islas/marina-piccola-capri' },
];

const facts = [
  { label: 'Suelo', value: 'Guijarros y rocas' },
  { label: 'Acceso', value: 'Bus o escaleras (Via Mulo)' },
  { label: 'Sombra', value: 'A partir de las 16:00 ⚠️' },
  { label: 'Vistas', value: 'Faraglioni (las mejores de la isla)' },
  { label: 'Ideal para', value: 'Chiringuitos exclusivos, fotografía, snorkel' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina Piccola Capri",
  "description": "La playa más famosa de Capri, con la vista más cercana y dramática de los Faraglioni. Chiringuitos exclusivos y aguas protegidas.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5456",
    "longitude": "14.2344"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina Piccola Capri 2026: Guía de la Playa de los Faraglioni"
  description="Marina Piccola es la bahía más famosa de Capri. Guía 2026 con precios de chiringuitos, cómo llegar y la mejor vista de los Faraglioni."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-piccola-capri.jpg"
      alt="Marina Piccola, Capri, con los Faraglioni al fondo"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Capri · Islas del Golfo</p>
      <h1 class="font-serif text-display text-white mb-6">Marina Piccola</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Los Faraglioni parecen al alcance de la mano.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">La Leyenda de Capri</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina Piccola es la bahía resguardada donde se encuentran los chiringuitos más famosos de Capri. Desde aquí, los Faraglioni - las tres rocas icónicas que emergen del mar - parecen al alcance de la mano: es la vista más dramática y fotografiada de la isla.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            En 2026, el espacio de playa pública es mínimo, por lo que se recomienda encarecidamente reservar en un chiringuito como <strong>La Canzone del Mare</strong> (el más histórico, fundado en 1932 por Gracie Fields). Las aguas son protegidas e ideales para el snorkel.
          </p>
        </div>

        <!-- Aviso de Sombra -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Aviso de Sombra</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Marina Piccola queda en sombra <strong>a partir de las 16 h aproximadamente</strong>, por las montañas que la rodean. Si quieres sol por la tarde, considera la playa de Marina Grande o los chiringuitos del otro lado de la isla. La mañana y el mediodía son los mejores momentos.
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus naranja ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Desde el centro de Capri</p>
              <p class="text-slate-500 text-sm">Línea directa Marina Piccola. Económico y frecuente.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">A pie por Via Mulo</p>
              <p class="text-slate-700 font-medium mb-1">15 minutos de bajada</p>
              <p class="text-slate-500 text-sm">Panorámico. Disfrutas del paisaje de la isla durante todo el camino.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre todo sobre Capri</h2>
      <a
        href="/es-es/islas/capri/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de Capri
      </a>
    </div>
  </section>

</BaseLayout>
