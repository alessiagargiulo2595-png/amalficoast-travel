---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Islas del Golfo', url: '/es-es/playas#islas' },
  { name: 'Cala del Pozzo Vecchio', url: '/es-es/playas/islas/cala-del-pozzo-vecchio' },
];

const facts = [
  { label: 'Suelo', value: 'Arena negra volcánica' },
  { label: 'Ambiente', value: 'Poético y tranquilo' },
  { label: 'Acceso', value: '10 min a pie desde la parada de bus' },
  { label: 'Sombra', value: 'A partir de las 17:30' },
  { label: 'Ideal para', value: 'Cinéfilos, poesía, relax auténtico' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala del Pozzo Vecchio",
  "description": "La playa de Procida inmortalizada por la película Il Postino de Massimo Troisi. Arena negra volcánica y aguas esmeralda.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Procida",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Playa del Cartero Procida 2026: Cala del Pozzo Vecchio"
  description="La playa inmortalizada por la película Il Postino. Arena negra volcánica, agua esmeralda y el lado más auténtico de Procida. Guía 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-pozzo-vecchio-procida.jpg"
      alt="Cala del Pozzo Vecchio, Procida - la playa del Cartero"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Procida · Islas del Golfo</p>
      <h1 class="font-serif text-display text-white mb-6">Cala del Pozzo Vecchio</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La playa inmortalizada por Massimo Troisi.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">El Cine Hecho Playa</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La playa inmortalizada por Massimo Troisi en <em>Il Postino</em> (1994). Un arco de arena negra volcánica y agua color esmeralda que parece sacado directamente de la película. En cuanto llegas, entiendes de inmediato por qué Troisi y el director Michael Radford la eligieron como escenario principal.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Es el lado más auténtico y menos turístico de las islas campanas. Procida nunca ha conocido el turismo masivo de Capri o Ischia, y esta playa conserva esa alma: pocos visitantes, mucha poesía, un agua impecablemente limpia. Perfecta para el relax total y para quienes disfrutan de las atmósferas cinematográficas.
          </p>
        </div>

        <!-- Il Postino -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Il Postino (1994)</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            La película de Michael Radford con Massimo Troisi y Philippe Noiret ganó el Oscar a la mejor película de habla no inglesa. Esta playa es el corazón del film. Muchos visitantes vienen aquí para revivir las escenas icónicas - el cartero caminando por la orilla, la poesía del mar.
          </p>
          <p class="text-slate-600 leading-relaxed italic">
            «Il mondo è bello e tu sei un po' curioso» - Il Postino, 1994
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Línea C1 ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Desde el puerto de Procida</p>
              <p class="text-slate-500 text-sm">Parada Pozzo Vecchio. Luego 10 min a pie en bajada hacia la playa.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">A pie</p>
              <p class="text-slate-700 font-medium mb-1">Desde el centro de Procida</p>
              <p class="text-slate-500 text-sm">20–25 minutos. Pintoresco y agradable por los callejones de la isla.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre todo sobre Procida</h2>
      <a
        href="/es-es/islas/procida/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de Procida
      </a>
    </div>
  </section>

</BaseLayout>
