---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Península Sorrentina', url: '/es-es/playas#peninsula-sorrentina' },
  { name: 'Cala di Mitigliano', url: '/es-es/playas/peninsula-sorrentina/cala-mitigliano' },
];

const facts = [
  { label: 'Suelo', value: 'Guijarros y rocas' },
  { label: 'Acceso', value: 'Sendero empinado (30 min) o barco' },
  { label: 'Sombra', value: 'A partir de las 17:00' },
  { label: 'Vistas', value: 'Faraglioni de Capri (cara a cara)' },
  { label: 'Ideal para', value: 'Senderismo, snorkel, fotografía' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala di Mitigliano",
  "description": "Una cala salvaje con una vista impresionante frente a los Faraglioni de Capri. Accesible por un sendero empinado desde Massa Lubrense o en barco.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Massa Lubrense",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Cala di Mitigliano: Playa Secreta con Vistas a Capri"
  description="Cala di Mitigliano en Massa Lubrense: la cala escondida con las mejores vistas frente a los Faraglioni de Capri. Cómo llegar por sendero o en barco."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-mitigliano.jpg"
      alt="Cala di Mitigliano, Massa Lubrense, con Capri al fondo"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Massa Lubrense · Vistas a Capri</p>
      <h1 class="font-serif text-display text-white mb-6">Cala di Mitigliano</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La cala secreta con los Faraglioni de Capri justo enfrente.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Una Joya Escondida</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La Cala di Mitigliano es una joya escondida de la Península Sorrentina. Poco frecuentada por su exigente sendero de acceso, ofrece una vista espectacular frente a los Faraglioni de Capri - sin duda la mejor vista de Capri desde el continente. El agua es cristalina sobre fondos rocosos ideales para el snorkel.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Una cueva natural en la playa proporciona sombra durante las horas más calurosas. Un auténtico paraíso para los amantes del senderismo y la exploración. Al atardecer, la luz rasante transforma los Faraglioni en oro: no olvides la cámara.
          </p>
        </div>

        <!-- Vistas a Capri -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            <h3 class="text-xl font-bold text-slate-900">La Mejor Vista de Capri</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Desde la playa tienes una vista <strong>directa y cercana</strong> de los tres Faraglioni. Hacia la puesta de sol (a partir de las 17:30 aproximadamente) la luz es perfecta. Es la foto de Capri que los turistas no hacen - porque hay que hacer un poco de esfuerzo para llegar aquí.
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Sendero a pie</p>
              <p class="text-slate-700 font-medium mb-1">Desde Termini, Massa Lubrense</p>
              <p class="text-slate-500 text-sm">30 min de bajada empinada. Calzado de senderismo imprescindible. Sin equipamiento en la playa.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Acuático</p>
              <p class="text-slate-700 font-medium mb-1">Desde Sorrento o Marina del Cantone</p>
              <p class="text-slate-500 text-sm">La opción más sencilla. Reserva una excursión en barco con parada en la cala.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explora la Península Sorrentina</h2>
      <a
        href="/es-es/peninsula-sorrentina/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía de la Península Sorrentina
      </a>
    </div>
  </section>

</BaseLayout>
