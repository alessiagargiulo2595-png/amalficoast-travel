---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Península Sorrentina', url: '/es-es/playas#peninsula-sorrentina' },
  { name: 'Marina del Cantone', url: '/es-es/playas/peninsula-sorrentina/marina-del-cantone' },
];

const facts = [
  { label: 'Suelo', value: 'Guijarros grandes' },
  { label: 'Acceso', value: 'Muy fácil (llano)' },
  { label: 'Sombra', value: 'A partir de las 18:30' },
  { label: 'Equipamiento', value: 'Chiringuitos, restaurantes' },
  { label: 'Ideal para', value: 'Familias, gastronomía, snorkel' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina del Cantone",
  "description": "Una amplia playa de guijarros en Nerano, famosa por su gastronomía — cuna de los Spaghetti alla Nerano — y sus aguas cristalinas en la reserva marina de Punta Campanella.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Nerano",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina del Cantone Nerano: Playa y Restaurantes 2026"
  description="La playa más sabrosa de Italia: Marina del Cantone en Nerano une aguas cristalinas protegidas y los auténticos Spaghetti alla Nerano. Guía 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-del-cantone.jpg"
      alt="Marina del Cantone, Nerano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Nerano · Península Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Marina del Cantone</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La capital gastronómica frente al mar más puro de Campania.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Mar y Alta Cocina</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Nerano es la capital gastronómica de la Península Sorrentina. La playa de Marina del Cantone es amplia, limpia y soleada hasta última hora de la tarde. El agua está entre las más cristalinas de Campania, protegida por la reserva marina de Punta Campanella: el snorkel es excelente, con praderas de posidonia y una rica fauna marina.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Pero la fama mundial de Nerano es culinaria. Aquí nació el <strong>Spaghetti alla Nerano</strong> — calabacines fritos, provolone del Monaco, albahaca — y cada restaurante de la orilla sirve la versión original. Perfecta para familias y para quienes quieran combinar una bonita jornada de playa con una gastronomía de excepción.
          </p>
        </div>

        <!-- Consejo gastronómico -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Consejo Gastronómico</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            <strong>Lo Cantone</strong> y <strong>Maria Grazia</strong> son los templos del Spaghetti alla Nerano. Reserva mesa por la mañana — en verano las plazas se agotan rápido. Un almuerzo a pie de playa aquí es una experiencia gastronómica completa.
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus EAV</p>
              <p class="text-slate-700 font-medium mb-1">Desde Sorrento vía Massa Lubrense</p>
              <p class="text-slate-500 text-sm">Bajar en Nerano. Luego 10 min a pie hasta la playa.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Por mar</p>
              <p class="text-slate-700 font-medium mb-1">Taxi acuático desde Sorrento</p>
              <p class="text-slate-500 text-sm">Desembarco directo en la playa. Pintoresco y muy práctico.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explora la Península Sorrentina</h2>
      <a
        href="/es-es/peninsula-sorrentina/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía de la Península Sorrentina
      </a>
    </div>
  </section>

</BaseLayout>
