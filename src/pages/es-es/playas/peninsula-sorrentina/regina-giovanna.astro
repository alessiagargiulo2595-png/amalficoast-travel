---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Península Sorrentina', url: '/es-es/playas#peninsula-sorrentina' },
  { name: 'Regina Giovanna', url: '/es-es/playas/peninsula-sorrentina/regina-giovanna' },
];

const facts = [
  { label: 'Suelo', value: 'Rocoso' },
  { label: 'Acceso', value: 'Sendero 20 min (moderado)' },
  { label: 'Sombra', value: 'A partir de las 18:00' },
  { label: 'Equipamiento', value: 'Ninguno — playa salvaje' },
  { label: 'Ideal para', value: 'Arqueología, senderismo, snorkel' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Bagni della Regina Giovanna",
  "description": "Una piscina natural y yacimiento arqueológico romano cerca de Sorrento. Una joya escondida entre olivos, a 20 minutos a pie del centro.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6450",
    "longitude": "14.3540"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sorrento",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Regina Giovanna Sorrento: La Piscina Natural (2026)"
  description="Cómo llegar a los Bagni della Regina Giovanna cerca de Sorrento. Piscina natural entre ruinas romanas, sendero entre olivos y aguas esmeralda. Guía 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/regina-giovanna-sorrento.jpg"
      alt="Bagni della Regina Giovanna, Sorrento"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrento · Península Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Regina Giovanna</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La piscina natural escondida entre ruinas romanas.</p>
    </div>
  </section>

  <!-- Contenido + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Arqueología y Baño</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Los Bagni della Regina Giovanna son un yacimiento arqueológico al aire libre donde puedes zambullirte en un agua de color azul esmeralda. Una piscina natural enmarcada por los vestigios de una villa romana del siglo I — probablemente la de Publio Vedio Polión — se comunica con el mar abierto por un arco de roca. En 2026, sigue siendo un lugar salvaje: sin chiringuitos.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            El sendero que lleva a los baños atraviesa olivares milenarios con vistas espectaculares sobre el Golfo de Nápoles y la isla de Capri. Lleva calzado de senderismo ligero y agua suficiente — no hay bar ni tienda cerca.
          </p>
        </div>

        <!-- Playa salvaje -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Playa Salvaje</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Sin equipamiento, sin bar, sin chiringuito. Lleva <strong>agua, comida y escarpines</strong>. Es un lugar auténticamente local, frecuentado sobre todo por los sorrentinos que conocen el sitio.
          </p>
        </div>

        <!-- Cómo llegar -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cómo Llegar</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus EAV ⭐ Recomendado</p>
              <p class="text-slate-700 font-medium mb-1">Línea «Capo di Sorrento»</p>
              <p class="text-slate-500 text-sm">Desde Piazza Tasso. Luego 15–20 min a pie entre olivos.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">A pie desde el centro</p>
              <p class="text-slate-700 font-medium mb-1">Unos 40 minutos</p>
              <p class="text-slate-500 text-sm">Panorámico pero exigente. Seguir Via del Capo hacia Punta del Capo.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Clave
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explora la Península Sorrentina</h2>
      <a
        href="/es-es/peninsula-sorrentina/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía de la Península Sorrentina
      </a>
    </div>
  </section>

</BaseLayout>
