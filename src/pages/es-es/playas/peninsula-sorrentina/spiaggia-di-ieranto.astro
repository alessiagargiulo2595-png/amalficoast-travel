---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'es-es';

const breadcrumbs = [
  { name: 'Inicio', url: '/es-es/' },
  { name: 'Playas', url: '/es-es/playas' },
  { name: 'Península Sorrentina', url: '/es-es/playas#peninsula-sorrentina' },
  { name: 'Ieranto', url: '/es-es/playas/peninsula-sorrentina/spiaggia-di-ieranto' },
];

const facts = [
  { label: 'Composición', value: 'Arena y guijarros' },
  { label: 'Acceso', value: 'Solo senderismo' },
  { label: 'Dificultad', value: 'Senderismo moderado (30 min)' },
  { label: 'Atmósfera', value: 'Salvaje, intacta' },
  { label: 'Ideal para', value: 'Senderistas, buceo de superficie' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia di Ieranto",
  "description": "Una playa escondida accesible solo por sendero de montaña. Aguas cristalinas, acantilados salvajes y una reserva natural protegida.",
  "image": "https://amalficoast-travel.com/images/ieranto-hero.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5700",
    "longitude": "14.3683"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia di Ieranto 2026: Playa Secreta & Guía de Senderismo"
  description="Ieranto es una playa prístina en una reserva marina protegida. Accesible solo por sendero de senderismo desde Praiano. Guía de la ruta y qué esperar."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ieranto-hero.jpg"
      alt="Spiaggia di Ieranto, Península Sorrentina"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Península Sorrentina · Reserva Protegida</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia di Ieranto</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Una playa prístina escondida en una reserva marina protegida, accesible solo a pie.</p>
    </div>
  </section>

  <!-- Contenido + Barra Lateral -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texto Principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Una Playa Perdida en el Tiempo</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Spiaggia di Ieranto se encuentra dentro de una reserva marina protegida, una de las primeras creadas en Italia. Su aislamiento y protección la han preservado como un paraíso natural. Una caminata de 30 minutos desde Praiano, el esfuerzo se ve recompensado con arena prístina, aguas turquesas y un paisaje intacto.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            La playa tiene un pequeño manantial de agua dulce, históricamente utilizado por pastores. El agua cristalina la hace un destino de buceo de superficie excepcional. Parte de tu tarifa de entrada apoya la conservación marina.
          </p>
        </div>

        <!-- El Sendero de Senderismo -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">El Sendero de Senderismo</h2>
          <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
            <div class="space-y-4 text-slate-600">
              <p class="leading-relaxed">
                <strong>Duración:</strong> 30 minutos hacia abajo, 40 minutos hacia arriba (con exposición al sol en el regreso)
              </p>
              <p class="leading-relaxed">
                <strong>Dificultad:</strong> Moderada. Sendero bien mantenido con secciones de escaleras y áreas expuestas. Buen calzado esencial.
              </p>
              <p class="leading-relaxed">
                <strong>Punto de partida:</strong> Via Spiaggia del Gavitello en Praiano (aparcamiento disponible)
              </p>
              <p class="leading-relaxed">
                <strong>Qué llevar:</strong> Agua, protector solar, zapatos de senderismo cómodos. No hay instalaciones en la playa.
              </p>
            </div>
          </div>
        </div>

        <!-- Reserva Marina -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Reserva Marina Protegida</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            Ieranto es parte del Área Marina Protegida Limonium, creada para preservar este ecosistema excepcional. La natación y el buceo de superficie están permitidos, pero la pesca y el anclaje están prohibidos. La entrada es de 2,50 €/persona.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Respeta la reserva: no toques corales, no lleves souvenirs y usa solo protector solar seguro para los arrecifes.
          </p>
        </div>
      </div>

      <!-- Barra Lateral Datos Rápidos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Datos Rápidos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/es-es/playas"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Todas las playas
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Descubre más playas de la Península Sorrentina</h2>
      <a
        href="/es-es/playas"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guía completa de playas
      </a>
    </div>
  </section>

</BaseLayout>
