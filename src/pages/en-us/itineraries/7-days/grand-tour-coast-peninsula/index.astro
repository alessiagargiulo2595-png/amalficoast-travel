---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Itineraries', url: '/en-us/itineraries/' },
  { name: 'Grand Tour — 7 days', url: '/en-us/itineraries/7-days/grand-tour-coast-peninsula/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the best way to organise 7 days between the Amalfi Coast and Sorrentine Peninsula?",
      "acceptedAnswer": { "@type": "Answer", "text": "The classic route is: 2 nights in Naples (days 1–2), then move to Sorrento or Amalfi as base for the Coast (days 3–5), with a Capri excursion (day 4 or 5), then islands at the end (days 6–7). Using SITA bus, Circumvesuviana and hydrofoils avoids a car entirely." }
    },
    {
      "@type": "Question",
      "name": "How many nights in Naples before the Coast is worth doing?",
      "acceptedAnswer": { "@type": "Answer", "text": "1–2 nights are enough for Naples: Spaccanapoli, National Archaeological Museum, authentic pizza, Certosa di San Martino. With 2 nights you can include Herculaneum or Pompeii as a day trip. Naples is the natural arrival and departure point for the whole area." }
    }
  ]
};

const days = [
  { day: 'Day 1', title: 'Naples', items: ['Arrive in Naples. Spaccanapoli, UNESCO historic centre.', 'National Archaeological Museum: finds from Pompeii, mosaics, bronzes.', 'Authentic pizza in the historic quarter: Da Michele, Sorbillo or Brandi.'] },
  { day: 'Day 2', title: 'Pompeii or Herculaneum', items: ['Day trip by Circumvesuviana: Herculaneum excavations (morning, 2–3h) + Vesuvius (afternoon).', 'Alternative: all-day Pompeii (3–4h at the site).', 'Return to Naples for dinner.'] },
  { day: 'Day 3', title: 'Sorrento and arrival on the Coast', items: ['Circumvesuviana Naples→Sorrento (70 min). Check-in Sorrento or Amalfi.', 'Afternoon: Sorrento centre, Vallone dei Mulini, Marina Grande.', 'SITA bus to Positano (optional, 50 min): first taste of the Coast.'] },
  { day: 'Day 4', title: 'Capri', items: ['Hydrofoil from Sorrento to Capri (20–25 min). First service 07:30.', 'Blue Grotto early in the morning. Anacapri and Monte Solaro by chairlift.', 'Faraglioni in the afternoon. Aperitivo in La Piazzetta. Return in the evening.'] },
  { day: 'Day 5', title: 'Amalfi and Ravello', items: ['SITA bus Sorrento→Amalfi (90 min) or ferry Sorrento→Amalfi.', 'Cathedral, Cloister of Paradise, Paper Museum.', 'Bus to Ravello (25 min): Villa Rufolo, Villa Cimbrone. Dinner in Amalfi.'] },
  { day: 'Day 6', title: 'Positano and Boat Tour', items: ['SITA bus to Positano (45 min from Amalfi). Free morning on the beach.', 'Boat tour from Positano (Emerald Grotto, coves, ~€50–80, 4h).', 'Return to Amalfi or Positano. Dinner at the harbour.'] },
  { day: 'Day 7', title: 'Ischia or Procida and Departure', items: ['Ferry Amalfi/Naples→Ischia or Procida (half-day excursion).', 'Procida: Marina Corricella, Terra Murata, Pozzo Vecchio beach.', 'Return to Naples for departure.'] },
];
---

<BaseLayout
  title="Grand Tour Amalfi Coast 7 Days 2026 | Naples, Capri, Positano, Amalfi"
  description="Complete 7-day itinerary: Naples, Amalfi Coast, Capri and the Gulf Islands. Pompeii, Sorrento, Positano, Amalfi, Ravello — the Grand Tour of Southern Italy."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Grand Tour Amalfi Coast" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/en-us/itineraries/" class="hover:text-white transition-colors">Itineraries</a>
        <span>/</span>
        <span class="text-white">Grand Tour — 7 days</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerary · 7 days</p>
        <h1 class="font-serif text-display text-white mb-4">Grand Tour: Coast & Peninsula</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          One week to see everything: Naples, Pompeii, Sorrento, Capri, Positano, Amalfi, Ravello and an island. The Grand Tour of the Gulf of Naples — no car, public transport only.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duration</p>
          <p class="font-semibold text-charcoal">7 days / 6 nights</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Bases</p>
          <p class="font-semibold text-charcoal">Naples + Amalfi/Sorrento</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport</p>
          <p class="font-semibold text-charcoal">Train + bus + ferries</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport budget</p>
          <p class="font-semibold text-charcoal">~€80–120</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Day-by-Day Schedule</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Tips for the Grand Tour</p>
      <ul class="space-y-2">
        {[
          'Campania Express: day ticket on the Circumvesuviana (valid Naples–Sorrento–Pompeii–Herculaneum) ~€10.',
          'Book Capri and the Blue Grotto 1–2 days in advance in July–August.',
          'Change base mid-trip: 2 nights Naples + 3 nights Amalfi/Sorrento + optional 1 night island.',
          'The boat tour day is flexible: reschedule it depending on sea conditions.',
          'Bring comfortable shoes for Naples\' cobblestones and Positano\'s staircases.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
