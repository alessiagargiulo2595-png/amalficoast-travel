---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Itineraries', url: '/en-us/itineraries/' },
  { name: 'Slow Travel - 7 days', url: '/en-us/itineraries/7-days/slow-travel-villages-food/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is slow travel on the Amalfi Coast?",
      "acceptedAnswer": { "@type": "Answer", "text": "Slow travel on the Coast means staying more days in the same village instead of moving every day, eating in local restaurants (not tourist ones), walking lesser-known trails, going to the market, buying local products (lemons, anchovies, Ravello red wine). It is the opposite of the all-inclusive itinerary." }
    },
    {
      "@type": "Question",
      "name": "Which are the least touristy villages on the Amalfi Coast?",
      "acceptedAnswer": { "@type": "Answer", "text": "The least visited villages are: Praiano (between Positano and Amalfi, no ZTL, quiet beach), Cetara (famous for anchovy sauce, authentic), Furore (the village that doesn't exist, built in the gorge), Conca dei Marini (300 inhabitants, near the Emerald Grotto). All reachable by SITA bus on the SS163." }
    }
  ]
};

const days = [
  { day: 'Day 1', title: 'Arrival in Praiano', items: ['Praiano: the central village with no ZTL. Fewer tourists than Positano, lower prices.', 'Gavitella Beach: small, beautiful, accessible on foot.', 'Dinner in one of the harbour trattorias: fish of the day.'] },
  { day: 'Day 2', title: 'Path of the Gods', items: ['SITA bus to Amalfi, then to Agerola (trail start).', 'Path of the Gods (Agerola→Nocelle, 8 km, 3–4h, demanding).', 'Return to Praiano via Positano by SITA bus.'] },
  { day: 'Day 3', title: 'Amalfi and Furore', items: ['SITA bus to Amalfi. Morning: Thursday market (local produce, mozzarella, lemons).', 'Furore: the Fiordo di Furore, request stop on the SITA bus. The village in the gorge.', 'Amalfi Paper Museum: handmade paper produced since the 13th century.'] },
  { day: 'Day 4', title: 'Ravello and Scala', items: ['Bus to Ravello (25 min). Quiet morning with no crowds at 09:00.', 'Ravello→Scala trail: 4 km through olive groves and vineyards, views over the gulf. Lunch in Scala.', 'Afternoon: aperitivo with a view, Ravello red wine tasting.'] },
  { day: 'Day 5', title: 'Cetara and Vietri', items: ['SITA bus east to Cetara (famous for its DOP anchovy sauce). Fish market.', 'Visit to the Anchovy Sauce Museum and direct purchase from producers.', 'Vietri sul Mare: ceramics, Ceramics Museum. Walk along the seafront.'] },
  { day: 'Day 6', title: 'Valle delle Ferriere', items: ['Morning: Valle delle Ferriere hike from Amalfi (7 km return, 3h, easy–moderate). Waterfalls and tropical ferns.', 'Afternoon: swimming in the secluded coves near Amalfi or kayak tour.', 'Fresh fish dinner in Amalfi.'] },
  { day: 'Day 7', title: 'Market and Departure', items: ['Free morning at the local market. Buy typical products: artisan limoncello, anchovies, ceramics.', 'Long lunch in a trattoria. Farewells.', 'SITA bus to Salerno (60 min) or Sorrento (90 min) to reach trains or airport.'] },
];
---

<BaseLayout
  title="Slow Travel Amalfi Coast 7 Days 2026 | Villages, Food and Trails"
  description="7-day slow travel itinerary on the Amalfi Coast: Praiano, Furore, Cetara, Valle delle Ferriere and Path of the Gods. Authentic villages, local markets and food."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Slow travel Amalfi Coast" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/en-us/itineraries/" class="hover:text-white transition-colors">Itineraries</a>
        <span>/</span>
        <span class="text-white">Slow Travel - 7 days</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerary · 7 days</p>
        <h1 class="font-serif text-display text-white mb-4">Slow Travel: Villages & Food</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          A slow week among authentic villages, local markets and lesser-known trails. Praiano as base, Furore, Cetara, Valle delle Ferriere. The Amalfi Coast without hurry, without guided tours.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duration</p>
          <p class="font-semibold text-charcoal">7 days / 6 nights</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base</p>
          <p class="font-semibold text-charcoal">Praiano or Amalfi</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Best season</p>
          <p class="font-semibold text-charcoal">May–June / Sep–Oct</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Pace</p>
          <p class="font-semibold text-charcoal">Slow</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Day-by-Day Schedule</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Products not to miss</p>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <p class="font-semibold mb-1">Sfusato amalfitano lemon PGI</p>
          <p class="text-white/70">The Coast's enormous lemons: unique aroma, thick peel. Buy them directly from growers in Amalfi or Minori.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Cetara anchovy sauce (colatura) DOP</p>
          <p class="text-white/70">Modern garum: an amber liquid of fermented anchovies. Cetara produces Italy's finest DOP version.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Ravello wine</p>
          <p class="text-white/70">High-altitude vineyards produce a light, fragrant red. Tasting in Ravello's cellars.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Vietri sul Mare ceramics</p>
          <p class="text-white/70">Italy's ceramics capital: tiles, plates and artworks painted by hand. Choose local craft workshops.</p>
        </div>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
