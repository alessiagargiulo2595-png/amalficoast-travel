---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Itineraries', url: '/en-us/itineraries/' },
  { name: 'Islands: Ischia & Procida — 3 days', url: '/en-us/itineraries/3-days/islands-ischia-procida/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which is better for a weekend, Ischia or Procida?",
      "acceptedAnswer": { "@type": "Answer", "text": "It depends on what you're looking for: Ischia is large (46 km²), with thermal spas, varied beaches, castles and nightlife — it needs at least 2 days. Procida is small (4 km²), authentic, with iconic pastel colours, fishermen and few crowds. With 3 days you can spend 2 nights on Ischia and make a day trip to Procida." }
    },
    {
      "@type": "Question",
      "name": "How do you get to Ischia and Procida from Naples?",
      "acceptedAnswer": { "@type": "Answer", "text": "From Naples Beverello: hydrofoil to Ischia Porto (~50 min, €20–24) or ferry (~75 min, €12–14). For Procida: hydrofoil from Naples (~35 min, €15–18). From Pozzuoli: Medmar/Caremar ferry to Ischia and Procida, cheaper (~€10–13). Book online in summer." }
    }
  ]
};

const days = [
  {
    day: 'Day 1',
    title: 'Arrival in Ischia',
    items: [
      'Ferry or hydrofoil from Naples Beverello to Ischia Porto (50–75 min).',
      'Check-in. Afternoon: Ischia Ponte and the Aragonese Castle (entry ~€24, 2h).',
      'Maronti Beach (longest on the island, black volcanic sand) or aperitivo in Forio.',
      'Dinner in Lacco Ameno or Ischia Porto: Ischian cuisine, rabbit Ischian-style.',
    ],
  },
  {
    day: 'Day 2',
    title: 'Thermal Spas and Beaches',
    items: [
      'Morning: thermal gardens (Poseidon or Negombo, ~€35–40 entry). Thermal pools, saunas.',
      'Afternoon: Citara Beach (Forio), one of the island\'s finest.',
      'Sunset from the Sant\'Angelo belvedere, Ischia\'s most picturesque village.',
      'Dinner in Sant\'Angelo or return to Ischia Porto.',
    ],
  },
  {
    day: 'Day 3',
    title: 'Day Trip to Procida',
    items: [
      'Hydrofoil from Ischia to Procida (20 min, ~€9). First service 08:00.',
      'Marina Corricella: the fishermen\'s harbour, pastel-coloured houses, bar on the jetty.',
      'Terra Murata: the highest medieval village on the island, views over the Gulf.',
      'Pozzo Vecchio Beach (the beach from The Postman) for a midday swim.',
      'Return to Naples by hydrofoil from Procida (35 min).',
    ],
  },
];
---

<BaseLayout
  title="Ischia and Procida in 3 Days 2026 | Naples Gulf Islands Itinerary"
  description="3-day itinerary across Ischia and Procida: thermal spas, volcanic beaches, Marina Corricella and Aragonese Castle. How to get there, where to stay and what to see."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/isole-hero.jpg" alt="Ischia and Procida, Gulf of Naples" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/en-us/itineraries/" class="hover:text-white transition-colors">Itineraries</a>
        <span>/</span>
        <span class="text-white">Islands: Ischia & Procida</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerary · 3 days</p>
        <h1 class="font-serif text-display text-white mb-4">Islands: Ischia & Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Two islands, two opposite characters: Ischia large and thermal, Procida small and authentic. A perfect weekend in the Gulf of Naples, away from the Amalfi Coast crowds.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duration</p>
          <p class="font-semibold text-charcoal">3 days / 2 nights</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base</p>
          <p class="font-semibold text-charcoal">Ischia Porto or Forio</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport</p>
          <p class="font-semibold text-charcoal">Hydrofoils + island bus</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Day-by-Day Schedule</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Practical Tips</p>
      <ul class="space-y-2">
        {[
          'On Ischia the circular bus (CS/CD) runs all day: single ~€1.50, day pass ~€6.',
          'Book the thermal gardens online: Poseidon and Negombo sell out in summer.',
          'Procida as a day trip: take the first hydrofoil (08:00) to have time before the crowds arrive.',
          'Ischia off-season (October–November): spas open, few tourists, low prices.',
          'The hydrofoil doesn\'t run in rough seas: check the weather before booking.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
