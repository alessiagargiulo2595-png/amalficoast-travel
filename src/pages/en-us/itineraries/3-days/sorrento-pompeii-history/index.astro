---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Itineraries', url: '/en-us/itineraries/' },
  { name: 'Sorrento, Pompeii & History - 3 days', url: '/en-us/itineraries/3-days/sorrento-pompeii-history/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How long do you need to visit Pompeii?",
      "acceptedAnswer": { "@type": "Answer", "text": "For a thorough visit you need at least 3–4 hours. An essential visit (Forum, Via dell'Abbondanza, Casa del Fauno, amphitheatre) can be done in 2–2.5 hours. Arrive at opening time (09:00) to avoid afternoon heat and queues. Ticket ~€18–20, free for under-18s." }
    },
    {
      "@type": "Question",
      "name": "Is Herculaneum worth visiting as well as Pompeii?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, Herculaneum is often preferred by experienced visitors: smaller than Pompeii (2h is enough) but with better-preserved remains because it was buried in mud rather than ash. A combined Pompeii + Herculaneum ticket exists. With 3 days, visit Herculaneum in the afternoon of day 2 and Pompeii on the morning of day 3." }
    }
  ]
};

const days = [
  {
    day: 'Day 1',
    title: 'Sorrento',
    items: [
      'Arrive in Sorrento by Circumvesuviana from Naples (70 min, ~€3.90).',
      'Old town: Piazza Tasso, Cathedral, Vallone dei Mulini (volcanic valley in the city centre).',
      'Museo Correale: Roman artefacts and 18th-century views of Sorrento.',
      'Marina Grande: the fishermen\'s harbour, dinner with a view.',
    ],
  },
  {
    day: 'Day 2',
    title: 'Herculaneum and Vesuvius',
    items: [
      'Circumvesuviana to Herculaneum Scavi (20 min from Naples, 50 min from Sorrento).',
      'Herculaneum archaeological site: extraordinary preservation, 2–3 hours.',
      'Afternoon: bus/shuttle to Vesuvius (crater at 1,281 m, ~€12 entry + mandatory guide). Views over the Gulf of Naples.',
      'Return to Sorrento on Circumvesuviana.',
    ],
  },
  {
    day: 'Day 3',
    title: 'Pompeii',
    items: [
      'Circumvesuviana to Pompei Scavi – Villa dei Misteri (35 min from Naples, 45 min from Sorrento).',
      'Pompeii excavations: Forum, Baths, amphitheatre, patrician houses. At least 3h.',
      'Lunch in modern Pompeii, then visit to the Treasury Museum of San Gennaro (optional).',
      'Return towards Naples or Sorrento in the afternoon.',
    ],
  },
];
---

<BaseLayout
  title="Sorrento, Pompeii and Herculaneum in 3 Days 2026 | Historic Itinerary"
  description="3-day itinerary combining history and the sea: Sorrento, Herculaneum, Vesuvius and Pompeii. Circumvesuviana timetables, ticket prices and practical tips."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/sorrento-hero.jpg" alt="Sorrento and Pompeii" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/en-us/itineraries/" class="hover:text-white transition-colors">Itineraries</a>
        <span>/</span>
        <span class="text-white">Sorrento, Pompeii & History</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerary · 3 days</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrento, Pompeii & History</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Three days of archaeology and the Gulf of Naples: Sorrento as base, Herculaneum and Vesuvius on day two, Pompeii on day three. All by train, no car needed.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Duration</p>
          <p class="font-semibold text-charcoal">3 days / 2 nights</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Recommended base</p>
          <p class="font-semibold text-charcoal">Sorrento</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Key transport</p>
          <p class="font-semibold text-charcoal">Circumvesuviana</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Day-by-Day Schedule</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Practical Tips</p>
      <ul class="space-y-2">
        {[
          'Pompeii and Herculaneum: arrive at opening (09:00). Afternoon heat and queues make visiting difficult.',
          'Combined Pompeii + Herculaneum ticket: worth it if you visit both on the same or consecutive days.',
          'The Circumvesuviana is frequent but slow: Sorrento to Pompei Scavi ~45 min, from Naples ~35 min.',
          'Vesuvius: the shuttle bus departs from Herculaneum and Pompeii (check seasonal timetables). A guide is legally required.',
          'Sorrento in the evening is magnificent: aperitivo at Marina Grande, dinner on the main corso.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
