---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Itineraries', url: '/en-us/itineraries/' },
  { name: 'Path of the Gods Trek', url: '/en-us/itineraries/1-day/path-of-the-gods-trek/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you do the Path of the Gods in a day trip from Naples?",
      "acceptedAnswer": { "@type": "Answer", "text": "Leave Naples on the Circumvesuviana to Sorrento (70 min), then SITA bus to Amalfi (90 min), then local bus to Agerola (45 min). The Agerola→Nocelle trail is 8 km, 3–4h. From Nocelle take the local bus to Positano (15 min), then SITA bus or ferry to Sorrento and Circumvesuviana back to Naples." }
    },
    {
      "@type": "Question",
      "name": "Do you need to book the Path of the Gods in advance?",
      "acceptedAnswer": { "@type": "Answer", "text": "In high season (July–August) the Path of the Gods requires mandatory booking on the Parco dei Monti Lattari portal. The fee is nominal (~€5). Outside peak season no booking is required. Always check conditions on the official website before setting out." }
    },
    {
      "@type": "Question",
      "name": "What should you bring for the Path of the Gods?",
      "acceptedAnswer": { "@type": "Answer", "text": "Essential: hiking boots (not sandals or smooth-soled trainers), at least 1.5L of water, sunscreen, a hat. The trail has no water sources or shops. Bring a snack. In spring/autumn a light jacket is advisable for the wind at altitude." }
    }
  ]
};

const schedule = [
  { time: '07:00', place: 'Naples', action: 'Circumvesuviana to Sorrento (70 min, ~€3.90)', transport: 'train' },
  { time: '08:15', place: 'Sorrento', action: 'SITA bus to Amalfi (90 min, ~€3.50) — the 8:30 service', transport: 'bus' },
  { time: '10:00', place: 'Amalfi', action: 'Local bus to Agerola, San Lazzaro hamlet (45 min, ~€1.50). Start of trail.', transport: 'bus' },
  { time: '11:00', place: 'Agerola (618 m)', action: 'Departure on the Path of the Gods. 8 km, ~500 m descent, EE grade. Breathtaking scenery.', transport: 'walk' },
  { time: '14:30', place: 'Nocelle', action: 'Arrival at Nocelle. Break and lunch at one of the local rifugios/bars.', transport: 'visit' },
  { time: '15:15', place: 'Nocelle → Positano', action: 'Local bus to Positano centre (15 min, ~€1.50) or on foot (~1,000 steps, 45 min)', transport: 'bus' },
  { time: '16:00', place: 'Positano', action: 'Stroll, gelato, beach (1h free time)', transport: 'visit' },
  { time: '17:15', place: 'Positano → Naples', action: 'SITA bus to Sorrento (~50 min), then Circumvesuviana to Naples (70 min)', transport: 'bus' },
];

const tips = [
  'Best season: April–June and September–October. July–August is very hot and crowded.',
  'The bus from Amalfi to Agerola has limited services: check timetables on eavsrl.it the evening before.',
  'Always hike in the Agerola→Nocelle direction: almost entirely downhill, signage designed for this way.',
  'The trail has no water points: bring at least 1.5L. The last bar is in Agerola before you set off.',
  'From Nocelle you can descend to Positano on foot (~1,000 steps, 45 min) or by bus (15 min, ~€1.50).',
];

const transportBadge: Record<string, { label: string; cls: string }> = {
  train: { label: 'TRAIN', cls: 'bg-orange-100 text-orange-700' },
  ferry: { label: 'FERRY', cls: 'bg-blue-100 text-blue-700' },
  bus:   { label: 'BUS', cls: 'bg-green-100 text-green-700' },
  walk:  { label: 'TREK', cls: 'bg-red-100 text-red-700' },
  visit: { label: '', cls: '' },
};
---

<BaseLayout
  title="Path of the Gods Trek in 1 Day from Naples 2026 | Hiking Itinerary"
  description="How to do the Path of the Gods (Agerola–Nocelle) in a day from Naples: timetables, transport, booking and tips. 8 km of hiking with views over the Amalfi Coast."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/trekking-hero.jpg" alt="Path of the Gods, Amalfi Coast" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/en-us/itineraries/" class="hover:text-white transition-colors">Itineraries</a>
        <span>/</span>
        <span class="text-white">Path of the Gods — 1 day</span>
      </nav>
      <div class="max-w-2xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerary · Trek · 1 day</p>
        <h1 class="font-serif text-display text-white mb-4">Path of the Gods Trek</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          8 km from Agerola to Nocelle/Positano with the Amalfi Coast beneath your feet. The most spectacular trail in southern Italy — doable in a day from Naples by public transport.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-4xl mx-auto">
      <div class="grid grid-cols-4 gap-5">
        <div class="bg-white border border-slate-100 rounded-2xl p-5 text-center shadow-sm flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 12h18M3 12l4-4M3 12l4 4"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Distance</p><p class="font-bold text-charcoal">8 km</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-2xl p-5 text-center shadow-sm flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Elevation</p><p class="font-bold text-charcoal">~500 m ↓</p></div>
        </div>
        <div class="bg-white border border-red-100 rounded-2xl p-5 text-center shadow-sm flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Difficulty</p><p class="font-bold text-red-600">EE</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-2xl p-5 text-center shadow-sm flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Transport</p><p class="font-bold text-charcoal">~€12–18</p></div>
        </div>
      </div>
      <div class="mt-5 bg-red-50 border border-red-200 rounded-2xl px-5 py-4">
        <p class="font-semibold text-red-800 text-sm">Mandatory booking July–August — Parco dei Monti Lattari (~€5)</p>
      </div>
    </section>

    <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">
      <section class="lg:col-span-8">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Hour-by-Hour Schedule</h2>
        <div class="relative">
          <div class="space-y-12 border-l-2 border-slate-200 pl-8 ml-3">
            {schedule.map((s) => {
              const badge = transportBadge[s.transport] ?? transportBadge.visit;
              return (
                <div class="relative">
                  <div class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-med-blue ring-4 ring-white shadow-sm"></div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-med-blue font-bold text-sm">{s.time}</span>
                    {badge.label && <span class={`text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded ${badge.cls}`}>{badge.label}</span>}
                  </div>
                  <p class="font-semibold text-charcoal text-base leading-snug">{s.place}</p>
                  <p class="text-slate-600 text-sm mt-1 leading-relaxed">{s.action}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <aside class="lg:col-span-4 mt-12 lg:mt-0">
        <div class="lg:sticky lg:top-24 space-y-6">
          <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2a7 7 0 0 1 7 7c0 3-1.7 5.2-4 6.4V17a1 1 0 0 1-1 1H10a1 1 0 0 1-1-1v-1.6C6.7 14.2 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M10 21h4M12 17v4"/></svg>
              Insider Tips
            </p>
            <ul class="space-y-3">
              {tips.map(tip => (
                <li class="flex gap-2.5 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
              Quick Map
            </p>
            <a href="https://maps.google.com/maps?q=Sentiero+degli+Dei+Agerola" target="_blank" rel="noopener" class="flex items-center justify-between bg-slate-50 hover:bg-med-blue/5 rounded-xl px-4 py-3 text-sm text-med-blue font-medium transition-colors group">
              Open route in Google Maps
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </aside>
    </div>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
