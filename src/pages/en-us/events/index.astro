---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { events } from '../../../data/events-en';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
];

const amalfiCoastEvents = events.filter(e => e.area === 'amalfi-coast');
const islandEvents = events.filter(e => e.area === 'islands');
const peninsulaEvents = events.filter(e => e.area === 'sorrentine-peninsula');

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Events 2026 – Amalfi Coast & Sorrentine Peninsula",
  "description": "The best festivals and events of 2026 on the Amalfi Coast and Sorrentine Peninsula: Ravello Festival, Ferragosto fireworks, fish festivals and gastronomic celebrations.",
  "url": "https://amalficoast-travel.com/en-us/events/",
  "numberOfItems": events.length,
  "itemListElement": events.map((ev, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": ev.title,
    "url": `https://amalficoast-travel.com${ev.path}`,
  })),
};
---

<BaseLayout
  title="Events 2026 Amalfi Coast | Ravello Festival, Fireworks & Local Festivals"
  description="The best events of 2026 on the Amalfi Coast and Sorrentine Peninsula: Ravello Festival, Ferragosto fireworks, the Fish Festival in Positano and authentic local celebrations."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <img
      src="/images/ravello-hero.jpg"
      alt="Events on the Amalfi Coast 2026"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Events 2026</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Calendar 2026</p>
        <h1 class="font-serif text-display text-white mb-4">Events</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          From the Ravello Festival to the Ferragosto fireworks over the sea. The 2026 calendar of the Amalfi Coast and Sorrentine Peninsula.
        </p>
      </div>
    </div>
  </section>

  <!-- Amalfi Coast Events -->
  <section class="bg-med-cream py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Amalfi Coast</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Amalfi Coast Events</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {amalfiCoastEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Islands Events -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Islands</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Island Events</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {islandEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sorrentine Peninsula Events -->
  <section class="bg-med-cream py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Sorrentine Peninsula</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Sorrentine Peninsula Events</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {peninsulaEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
