---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Sagra del Mare Procida', url: '/en-us/events/islands/sagra-del-mare-graziella-procida/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Sagra del Mare Procida 2026",
  "startDate": "2026-07-01",
  "location": {
    "@type": "Place",
    "name": "Procida",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Procida",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/islands/sagra-del-mare-graziella-procida/"
};

const facts = [
  { dt: 'Period', dd: 'July 2026' },
  { dt: 'Focus', dd: 'Traditional costume & maritime identity' },
  { dt: 'Type', dd: 'Sea festival & historical re-enactment' },
  { dt: 'From Naples', dd: 'Ferry 35 min' },
  { dt: 'Entry', dd: 'Free' },
];
---

<BaseLayout
  title="Sagra del Mare Procida 2026 – The Graziella Tradition"
  description="The Sagra del Mare in Procida in July 2026. The re-enactment of the Graziella combines literary history and maritime traditions of the island."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/procida-hero.jpg"
      alt="Sagra del Mare, Procida"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">July 2026</span>
        <span class="text-white/70 text-sm">Procida, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Sagra del Mare</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        The legend of the Graziella between sea tradition and literary history.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>The Sagra del Mare is Procida's identity event. The re-enactment of the Graziella figure unites literary history and the island's maritime traditions. A must-see for anyone wishing to know authentic Procida, away from the spotlight of the Capital of Culture.</p>
            <p>La Graziella, immortalised by Alphonse de Lamartine's 19th-century novel, has become the symbol of the island: a Procida fisherwoman who embodies the beauty, simplicity and authenticity of the maritime community. The festival celebrates this figure with historical re-enactments, traditional costumes and the catch of the day.</p>
          </div>
        </div>

        <!-- The Festival -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Festival</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">The Graziella</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Literary symbol & tradition</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Young women dressed in the traditional Procida costume re-enact the role of the Graziella, the romantic heroine of Lamartine's novel, in a ceremony that blends literature, local pride and maritime tradition.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Seafood specialities</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The day's catch</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Stalls along the harbour serve the freshest fish straight from Procida's fishermen: totani (squid), mussels, sea urchins and a range of traditional grilled and fried preparations.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting to Procida</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">From Naples Calata Porta di Massa</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">35 minutes to Marina Grande, Procida</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Hydrofoil</td>
                  <td class="px-6 py-4 text-slate-600">From Naples or Pozzuoli</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Faster option, check schedules</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
