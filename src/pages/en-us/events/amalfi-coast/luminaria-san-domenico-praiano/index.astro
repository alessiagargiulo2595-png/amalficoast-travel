---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Luminaria di San Domenico', url: '/en-us/events/amalfi-coast/luminaria-san-domenico-praiano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Luminaria di San Domenico Praiano 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-04",
  "location": {
    "@type": "Place",
    "name": "Piazza San Gennaro, Praiano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Praiano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/amalfi-coast/luminaria-san-domenico-praiano/"
};

const facts = [
  { dt: 'Dates', dd: '1–4 August 2026' },
  { dt: 'Lighting', dd: '8:00 pm each evening' },
  { dt: 'Venue', dd: 'Piazza San Gennaro' },
  { dt: 'Entry', dd: 'Free' },
  { dt: 'Grand finale', dd: '4 Aug with fire & projections' },
];
---

<BaseLayout
  title="Luminaria di San Domenico Praiano 2026: Dates & Programme"
  description="The Luminaria di San Domenico in Praiano from 1 to 4 August 2026. Thousands of candles, fire performances and light projections in the fishing village."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/praiano-hero.jpg"
      alt="Luminaria di San Domenico, Praiano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">1–4 August 2026</span>
        <span class="text-white/70 text-sm">Praiano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Luminaria di San Domenico</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Thousands of candles transform Praiano into a village of light.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>The Luminaria di San Domenico transforms Praiano into a village of light. Thousands of candles are lit each evening to honour the Dominican tradition. On 4 August the grand finale features projections and fire performances.</p>
            <p>Traffic on the SS163 coastal road may be slow in the evening hours. It is advisable to arrive in Praiano in the late afternoon to ensure access to the pedestrian area.</p>
          </div>
        </div>

        <!-- Evening Programme -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Evening Programme</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">1–3 August</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The candle evenings</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Each evening at 8:00 pm the ceremonial lighting of thousands of candles illuminates the alleys, staircases and façades of the fishing village.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">4 August</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Grand finale: fire & light</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The closing show combines fire performances, artistic projections on building façades and live music in Piazza San Gennaro.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">SITA Bus</td>
                  <td class="px-6 py-4 text-slate-600">Amalfi–Positano line</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Delays expected on SS163 from 6:00 pm</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Private car</td>
                  <td class="px-6 py-4 text-slate-600">Paid parking</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Arrive by 4:00 pm recommended</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">From Amalfi or Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Available in summer months</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
