---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Fish Festival Positano', url: '/en-us/events/amalfi-coast/sagra-del-pesce-positano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Fish Festival Positano 2026",
  "startDate": "2026-09-26",
  "endDate": "2026-09-26",
  "location": {
    "@type": "Place",
    "name": "Fornillo Beach, Positano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/amalfi-coast/sagra-del-pesce-positano/"
};

const facts = [
  { dt: 'Date', dd: '26 September 2026' },
  { dt: 'Venue', dd: 'Fornillo Beach' },
  { dt: 'Access', dd: 'Free sea shuttle from the pier' },
  { dt: 'Speciality', dd: 'Frittura di paranza' },
  { dt: 'Atmosphere', dd: 'End-of-season' },
];
---

<BaseLayout
  title="Fish Festival Positano 2026 – Fornillo Beach"
  description="The Fish Festival in Positano on 26 September 2026. Frittura di paranza on Fornillo Beach with a free sea shuttle from the main pier."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Fish Festival, Fornillo Beach, Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">26 September 2026</span>
        <span class="text-white/70 text-sm">Positano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Fish Festival</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        The frittura di paranza on Fornillo Beach marks the end of summer in Positano.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>The Fish Festival marks the end of the main tourist season in Positano. A local-character event where you can enjoy frittura di paranza and traditional dishes on the beach. The free shuttle runs from Positano's main pier directly to Fornillo Beach.</p>
            <p>An authentic opportunity to experience the Positano of the residents: crowds are far smaller than in the summer months and the atmosphere is relaxed and convivial.</p>
          </div>
        </div>

        <!-- Festival Specialities -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Festival Specialities</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Frittura di paranza</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The local fishing tradition</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Small bottom-fish fried at the perfect temperature. A recipe from Positano's maritime tradition, prepared by local fishermen.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Seafood starters</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The catch of the day</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Octopus salad, marinated anchovies and gratinated mussels accompany the festival menu, with products straight from the local fish market.</p>
            </div>
          </div>
        </div>

        <!-- Getting to Fornillo -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting to Fornillo</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Sea shuttle</td>
                  <td class="px-6 py-4 text-slate-600">From Positano pier</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Free during the festival</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">On foot</td>
                  <td class="px-6 py-4 text-slate-600">Scenic path</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">10 minutes from Spiaggia Grande</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
