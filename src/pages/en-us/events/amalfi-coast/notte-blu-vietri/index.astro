---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Notte Blu Vietri sul Mare', url: '/en-us/events/amalfi-coast/notte-blu-vietri/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Notte Blu Vietri sul Mare 2026",
  "startDate": "2026-07-01",
  "location": {
    "@type": "Place",
    "name": "Historic centre, Vietri sul Mare",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vietri sul Mare",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/amalfi-coast/notte-blu-vietri/"
};

const facts = [
  { dt: 'Period', dd: 'July 2026' },
  { dt: 'Venue', dd: 'Historic centre, Vietri sul Mare' },
  { dt: 'Type', dd: 'Art & Music' },
  { dt: 'Entry', dd: 'Free' },
  { dt: 'Speciality', dd: 'Vietri ceramics' },
];
---

<BaseLayout
  title="Notte Blu Vietri sul Mare 2026 – Ceramics & Music"
  description="The Notte Blu in Vietri sul Mare in July 2026. Ceramic workshops open until late at night amid concerts and art installations in the historic centre."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/costiera-hero.jpg"
      alt="Notte Blu, Vietri sul Mare"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">July 2026</span>
        <span class="text-white/70 text-sm">Vietri sul Mare, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Notte Blu</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Art, ceramics and music until late in the heart of Vietri.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>An evening dedicated to ceramics and music. Workshops stay open until late at night amid concerts and art installations. Vietri sul Mare, famous for its centuries-old ceramic tradition, opens its ateliers to the public for a unique evening.</p>
            <p>The Notte Blu is the opportunity to discover the Vietri ceramic-making process directly from master craftsmen, in a festive atmosphere that extends throughout the historic centre.</p>
          </div>
        </div>

        <!-- The Night's Route -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Night's Route</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Open ateliers</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Vietri ceramics by night</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Dozens of workshops open their doors and show live pottery wheel work and the painting of ceramics with traditional lemon-leaf and fish motifs.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Music & installations</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Contemporary art meets tradition</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Light installations and live concerts animate the alleys and squares of the historic centre, creating a dialogue between traditional craftsmanship and contemporary art.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Train</td>
                  <td class="px-6 py-4 text-slate-600">Trenitalia from Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minutes from Salerno Centrale</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">SITA Bus</td>
                  <td class="px-6 py-4 text-slate-600">From Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Check night timetables</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Car</td>
                  <td class="px-6 py-4 text-slate-600">A3 motorway, Vietri exit</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Free parking on the outskirts</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
