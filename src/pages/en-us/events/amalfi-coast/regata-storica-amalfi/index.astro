---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Historic Maritime Regatta', url: '/en-us/events/amalfi-coast/regata-storica-amalfi/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Historic Maritime Regatta Amalfi 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-06-30",
  "location": {
    "@type": "Place",
    "name": "Porto di Amalfi",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Amalfi",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/amalfi-coast/regata-storica-amalfi/"
};

const facts = [
  { dt: 'Period', dd: 'June 2026' },
  { dt: 'Venue', dd: 'Porto di Amalfi' },
  { dt: 'Type', dd: 'Historical regatta & pageant' },
  { dt: 'Costumes', dd: 'Medieval, spectacular' },
  { dt: 'From Naples', dd: 'Ferry 1h30' },
];
---

<BaseLayout
  title="Historic Maritime Regatta Amalfi 2026 – Medieval Pageant and Rowing Race"
  description="The Historic Regatta of the Ancient Maritime Republics 2026 in Amalfi. Medieval costume processions and the rowing race between Amalfi, Venice, Genoa and Pisa in the harbour."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/amalfi-hero.jpg"
      alt="Historic Maritime Regatta, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">June 2026</span>
        <span class="text-white/70 text-sm">Amalfi, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Historic Maritime Regatta</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Amalfi, Venice, Genoa and Pisa race on the sea with medieval costume pageants.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>The Regatta of the Ancient Maritime Republics is one of Italy's most spectacular historical spectacles. Four cities that were medieval maritime powers — Amalfi, Venice, Genoa and Pisa — compete in a rowing race aboard historical galleys, preceded by a pageant of over three hundred participants in costume.</p>
            <p>When the regatta is held in Amalfi, the harbour transforms into an extraordinary medieval stage: the colourful houses on the clifftops, the cathedral in the background and the galleys with their coloured sails offer an unforgettable spectacle. The costumes, armour and banners of the four republics transport the city back to its glorious maritime past.</p>
          </div>
        </div>

        <!-- The Programme -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Programme</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">The Historical Pageant</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Three hundred costumed participants</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The historical procession winds through the streets of Amalfi's old town with over three hundred participants in medieval costume representing the four republics, their doges, captains and sailors.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">The Rowing Race</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Historical galleys on the sea</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Four crews of eight rowers compete on historical galleys in Amalfi harbour. The winning city keeps the trophy until the next edition held in one of the other four cities.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">From Naples</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">1h30, direct to Amalfi harbour</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">SITA Bus</td>
                  <td class="px-6 py-4 text-slate-600">From Sorrento or Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">SS163, stop Amalfi centro</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving early. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
