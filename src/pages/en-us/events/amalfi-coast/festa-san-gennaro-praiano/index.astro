---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Feast of San Gennaro Praiano', url: '/en-us/events/amalfi-coast/festa-san-gennaro-praiano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Feast of San Gennaro Praiano 2026",
  "startDate": "2026-09-19",
  "endDate": "2026-09-19",
  "location": {
    "@type": "Place",
    "name": "Vettica Maggiore, Praiano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Praiano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/amalfi-coast/festa-san-gennaro-praiano/"
};

const facts = [
  { dt: 'Date', dd: '19 September 2026' },
  { dt: 'Hamlet', dd: 'Vettica Maggiore' },
  { dt: 'Type', dd: 'Patron saint celebration' },
  { dt: 'Crowds', dd: 'Low – local event' },
  { dt: 'View', dd: 'Panorama over Capri' },
];
---

<BaseLayout
  title="Feast of San Gennaro Praiano 2026 – Procession at Vettica Maggiore"
  description="The Feast of San Gennaro in Praiano on 19 September 2026. A procession with a panoramic view over Capri in the hamlet of Vettica Maggiore."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/praiano-hero.jpg"
      alt="Feast of San Gennaro, Vettica Maggiore, Praiano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">19 September 2026</span>
        <span class="text-white/70 text-sm">Praiano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Feast of San Gennaro</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        An authentic procession with a view over Capri in the small hamlet of Vettica Maggiore.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Patron saint celebration in the hamlet of Vettica Maggiore. Less crowded than summer events, it offers a very atmospheric procession with a panoramic view over Capri. An event that lets you experience the true soul of the Praiano community.</p>
            <p>The intimate, authentic atmosphere of Vettica Maggiore in September — far from the summer tourist peaks — makes this feast a genuine experience of the local religious calendar.</p>
          </div>
        </div>

        <!-- The Celebration -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Celebration</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">The Procession</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Through the lanes of Vettica</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The procession winds through the hamlet's alleys with the statue of the Saint carried on the shoulders of the brotherhood. The route offers spectacular views over the Gulf of Salerno and the island of Capri.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Authentic & local</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Praiano out of season</h4>
              <p class="text-slate-600 text-sm leading-relaxed">In September Praiano finds its daily rhythm again. A perfect opportunity to explore the village, local restaurants and the coast without the summer queues.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">SITA Bus</td>
                  <td class="px-6 py-4 text-slate-600">Amalfi–Positano line</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Stop: Praiano–Vettica Maggiore</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Private car</td>
                  <td class="px-6 py-4 text-slate-600">SS163 Amalfitana</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Parking available in low season</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
