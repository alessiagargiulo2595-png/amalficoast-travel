---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Positano Arts & Culture', url: '/en-us/events/amalfi-coast/positano-mare-sole-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Positano Arts & Culture 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-31",
  "location": {
    "@type": "Place",
    "name": "Positano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/amalfi-coast/positano-mare-sole-cultura/"
};

const facts = [
  { dt: 'Period', dd: 'August 2026' },
  { dt: 'Venue', dd: 'Positano' },
  { dt: 'Type', dd: 'Arts & culture festival' },
  { dt: 'Setting', dd: 'Panoramic terraces' },
  { dt: 'From Naples', dd: 'Ferry 1h or SITA bus' },
];
---

<BaseLayout
  title="Positano Arts & Culture 2026 – Art, Music and Literature on the Coast"
  description="Positano Arts & Culture 2026 in August. A summer programme of art, music and literature with events on panoramic terraces and cultural spaces throughout Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Positano Arts and Culture Festival"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">August 2026</span>
        <span class="text-white/70 text-sm">Positano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Positano Arts & Culture</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Art, music and literature on the most famous beach of the Amalfi Coast.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Positano has always attracted artists, writers and musicians — from Picasso and Steinbeck to Nureyev, all were drawn to its extraordinary beauty. The Positano Arts & Culture festival continues this tradition every August, transforming the village's terraces, gardens and piazzas into open-air stages for contemporary and classical art.</p>
            <p>The programme spans the whole month of August with evening concerts on panoramic terraces overlooking the sea, art exhibitions in historic spaces, literary readings, dance performances and cinema screenings under the stars. It is a summer festival that complements rather than competes with Positano's natural beauty.</p>
          </div>
        </div>

        <!-- The Programme -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Programme</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Music & Dance</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Concerts on the terraces</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Evening concerts ranging from classical chamber music to contemporary performances, held on the most spectacular terraces in Positano with the sea and the Faraglioni as backdrop.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Art & Literature</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Exhibitions and literary readings</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Contemporary art exhibitions in historic spaces, author readings and open-air cinema screenings celebrate the village's long connection with international artists and writers.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">From Naples or Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Seasonal service, Positano pier</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">SITA Bus</td>
                  <td class="px-6 py-4 text-slate-600">From Sorrento or Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">SS163, stop Positano Sponda or Chiesa Nuova</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving early. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
