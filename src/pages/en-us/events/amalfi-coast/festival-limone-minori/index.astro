---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Lemon Festival – Minori', url: '/en-us/events/amalfi-coast/festival-limone-minori/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Lemon Festival Minori 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-31",
  "location": {
    "@type": "Place",
    "name": "Historic centre, Minori",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Minori",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/amalfi-coast/festival-limone-minori/"
};

const facts = [
  { dt: 'Period', dd: 'August 2026' },
  { dt: 'Venue', dd: 'Historic centre, Minori' },
  { dt: 'Product', dd: 'Amalfi Coast IGP lemon' },
  { dt: 'Speciality', dd: 'Delizia al limone' },
  { dt: 'Access', dd: 'SITA bus or ferry' },
];
---

<BaseLayout
  title="Lemon Festival Minori 2026 – Amalfi Coast IGP Lemon"
  description="The Lemon Festival in Minori in August 2026. Tastings, workshops and markets celebrating the IGP lemon of the Amalfi Coast in the medieval village of Minori."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/costiera-hero.jpg"
      alt="Lemon Festival, Minori"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">August 2026</span>
        <span class="text-white/70 text-sm">Minori, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Lemon Festival – Minori</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        The Amalfi Coast IGP lemon takes centre stage in the medieval village of Minori.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>The Lemon Festival of Minori celebrates the product that identifies the Amalfi Coast more than any other: the sfusato IGP lemon, cultivated on terraced gardens clinging to the cliffsides using techniques passed down over centuries. Minori, a medieval village with the most sheltered beach on the coast, is the ideal setting for this celebration of flavour.</p>
            <p>The festival features guided tastings of lemon-based products — from the delizia al limone (the sweet pastry that made Minori famous), to artisan limoncello, fresh pasta with lemon sauce — workshops with local producers, and a terrace lemon grove market where visitors can buy directly from the farmers.</p>
          </div>
        </div>

        <!-- Specialities -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Festival Specialities</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Lemon Pastries</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The Delizia al Limone</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The delizia al limone is the pastry that made Minori famous throughout Italy: a dome of sponge cake filled and coated in lemon cream, created in the village bakeries in the 1970s and now a symbol of the coast.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">The Sfusato Lemon</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The gold of the Amalfi Coast</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The sfusato amalfitano IGP lemon is distinguished by its thick, intensely fragrant rind, ideal for artisan limoncello. The terraced lemon groves are a cultural landscape being considered for UNESCO recognition.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">From Naples or Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Seasonal service, Minori pier</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">SITA Bus</td>
                  <td class="px-6 py-4 text-slate-600">SS163 from Amalfi or Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Stop Minori centro, 10 min from Amalfi</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving early. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
