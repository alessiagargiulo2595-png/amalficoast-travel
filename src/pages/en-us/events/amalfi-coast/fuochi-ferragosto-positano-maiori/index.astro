---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Ferragosto Fireworks', url: '/en-us/events/amalfi-coast/fuochi-ferragosto-positano-maiori/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Ferragosto Fireworks Amalfi Coast 2026",
  "startDate": "2026-08-15",
  "endDate": "2026-08-15",
  "location": {
    "@type": "Place",
    "name": "Positano and Maiori, Amalfi Coast",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/amalfi-coast/fuochi-ferragosto-positano-maiori/"
};

const facts = [
  { dt: 'Date', dd: '15 August 2026' },
  { dt: 'Positano', dd: 'Madonna Assunta' },
  { dt: 'Maiori', dd: 'Santa Maria a Mare' },
  { dt: 'Best view', dd: 'Boat tour or private gozzo' },
  { dt: 'Start time', dd: 'After 10:00 pm' },
];
---

<BaseLayout
  title="Ferragosto Fireworks Amalfi Coast 2026 – Positano & Maiori"
  description="Ferragosto fireworks 2026 at Positano (Madonna Assunta) and Maiori (Santa Maria a Mare). How to watch them from the sea with an organised boat tour."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Ferragosto Fireworks on the Amalfi Coast"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">15 August 2026</span>
        <span class="text-white/70 text-sm">Positano & Maiori, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Ferragosto Fireworks</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        The Coast lights up: Positano and Maiori celebrate Ferragosto on the sea.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Ferragosto on the Amalfi Coast means fireworks displays over the sea. In Positano the fireworks celebrate the Madonna Assunta, while in Maiori the celebration honours Santa Maria a Mare. The best viewpoint is from the water via an organised boat tour or private gozzo hire.</p>
            <p>Both displays start after 10:00 pm and take place simultaneously, creating a uniquely dramatic effect along the entire coast. Boat tours typically depart from Amalfi, Positano and Salerno.</p>
          </div>
        </div>

        <!-- The Two Celebrations -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Two Celebrations</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Positano</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Madonna Assunta</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Positano's fireworks illuminate the colourful cliff-side houses. A morning religious procession precedes the evening display over Spiaggia Grande.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Maiori</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Santa Maria a Mare</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Maiori offers one of the widest beaches on the Coast to enjoy the fireworks. The celebration includes a sea procession with the statue of the Patron Saint.</p>
            </div>
          </div>
        </div>

        <!-- How to Watch -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">How to Watch the Fireworks</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Option</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Description</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Boat tour</td>
                  <td class="px-6 py-4 text-slate-600">Departs from Amalfi or Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Booking essential, limited places</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Private gozzo</td>
                  <td class="px-6 py-4 text-slate-600">Hire with or without skipper</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Maximum flexibility to move between locations</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">From shore</td>
                  <td class="px-6 py-4 text-slate-600">Beaches and panoramic terraces</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Very busy — arrive early</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
