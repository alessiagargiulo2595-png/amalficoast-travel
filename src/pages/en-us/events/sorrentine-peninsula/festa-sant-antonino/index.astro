---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: "Feast of Sant'Antonino – Sorrento", url: '/en-us/events/sorrentine-peninsula/festa-sant-antonino/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Feast of Sant'Antonino Sorrento 2026",
  "startDate": "2026-02-14",
  "endDate": "2026-02-14",
  "location": {
    "@type": "Place",
    "name": "Basilica di Sant'Antonino, Sorrento",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sorrento",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/sorrentine-peninsula/festa-sant-antonino/"
};

const facts = [
  { dt: 'Date', dd: '14 February 2026' },
  { dt: 'Venue', dd: "Basilica di Sant'Antonino" },
  { dt: 'Type', dd: 'Patron saint feast' },
  { dt: 'Procession', dd: 'With the statue of the saint' },
  { dt: 'From Naples', dd: 'Circumvesuviana 70 min' },
];
---

<BaseLayout
  title="Feast of Sant'Antonino Sorrento 2026 – Patron Saint Festival"
  description="The patron saint festival of Sant'Antonino in Sorrento on 14 February 2026. Procession of the saint's effigy through the historic centre and traditional fireworks in the harbour."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Feast of Sant'Antonino, Sorrento"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">14 Feb 2026</span>
        <span class="text-white/70 text-sm">Sorrento, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Feast of Sant'Antonino</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Sorrento celebrates its patron saint with a solemn procession and fireworks.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Sant'Antonino Abate has been the patron saint of Sorrento since the 6th century AD, when according to tradition the hermit monk drove away a sea dragon that was terrorising the city. His feast day on 14 February is the most heartfelt religious celebration of the year for the people of Sorrento — far more intimate and authentic than the grand summer festivities.</p>
            <p>The procession of the saint's effigy winds through the streets of the historic centre in the late morning, accompanied by the municipal band, civil and religious authorities, and worshippers carrying votive candles. In the evening, fireworks illuminate Sorrento harbour in a rare and beautiful winter scene.</p>
          </div>
        </div>

        <!-- The Feast -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Patron Saint Feast</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">The Procession</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The effigy through the streets</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The precious silver effigy of Sant'Antonino is carried in procession through the streets of Sorrento's historic centre. A centuries-old tradition that unites the entire community.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">The Basilica</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The heart of Sorrento</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The Basilica di Sant'Antonino, in the heart of Sorrento's old town, houses the saint's relics. Its Romanesque crypts are filled with ex-voto offerings from sailors saved from shipwrecks.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">From Naples Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">70 min, stop Sorrento</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">On foot</td>
                  <td class="px-6 py-4 text-slate-600">From Sorrento town centre</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 min from Piazza Tasso</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving early. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
