---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Sorrento Meeting', url: '/en-us/events/sorrentine-peninsula/sorrento-meeting-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Sorrento Meeting 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Chiostro di San Francesco, Sorrento",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sorrento",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/sorrentine-peninsula/sorrento-meeting-cultura/"
};

const facts = [
  { dt: 'Period', dd: 'June–July 2026' },
  { dt: 'Venue', dd: 'Chiostro di San Francesco' },
  { dt: 'Type', dd: 'Literary review' },
  { dt: 'Access', dd: 'Advance booking recommended' },
  { dt: 'From Naples', dd: 'Circumvesuviana 70 min' },
];
---

<BaseLayout
  title="Sorrento Meeting 2026 – Literary Review at the Cloister of San Francesco"
  description="The Sorrento Meeting from June to July 2026. Evening meetings with international authors in the 14th-century Gothic-Arab Cloister of San Francesco."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Sorrento Meeting, Cloister of San Francesco"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">June–July 2026</span>
        <span class="text-white/70 text-sm">Sorrento, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Sorrento Meeting</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Literature and international journalism in the 14th-century Gothic-Arab cloister.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>A literary and journalistic review held in the Cloister of San Francesco. Evening meetings with internationally prominent authors. The 14th-century Gothic-Arab cloister offers a unique setting for the cultural encounters of this summer review.</p>
            <p>Meetings typically take place at sunset, making the most of the magical evening light in the cloister. Participants can then continue the evening in the restaurants and panoramic terraces of Sorrento's centre.</p>
          </div>
        </div>

        <!-- The Cultural Review -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Cultural Review</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Author meetings</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">International literature</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Writers, journalists and internationally renowned intellectuals take turns in the cloister to present their works and dialogue with the audience in an open, informal format.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">The Cloister</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">A unique setting</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The Cloister of San Francesco, with its 14th-century Gothic-Arab arches, is one of Sorrento's most evocative places and an active cultural hub throughout the summer.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">From Naples Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">70 minutes, Sorrento stop</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">From the coast or Naples</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Sorrento harbour, island connections</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">On foot</td>
                  <td class="px-6 py-4 text-slate-600">From Sorrento centre</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minutes from Piazza Tasso</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
