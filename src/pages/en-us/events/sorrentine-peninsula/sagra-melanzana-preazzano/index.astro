---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Aubergine Festival Preazzano', url: '/en-us/events/sorrentine-peninsula/sagra-melanzana-preazzano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Aubergine Festival Preazzano 2026",
  "startDate": "2026-08-09",
  "endDate": "2026-08-10",
  "location": {
    "@type": "Place",
    "name": "Preazzano, Vico Equense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vico Equense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/sorrentine-peninsula/sagra-melanzana-preazzano/"
};

const facts = [
  { dt: 'Dates', dd: '9–10 August 2026' },
  { dt: 'Speciality', dd: 'Chocolate aubergine' },
  { dt: 'Shuttle', dd: 'From Vico Equense station' },
  { dt: 'Entry', dd: 'Free' },
  { dt: 'Setting', dd: 'Medieval hamlet' },
];
---

<BaseLayout
  title="Aubergine Festival Preazzano 2026 – The Chocolate Variation"
  description="The Aubergine Festival in Preazzano on 9 and 10 August 2026. One of the oldest festivals in the area: the local aubergine in dozens of variations, including the famous chocolate version."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/vico-equense-hero.jpg"
      alt="Aubergine Festival, Preazzano, Vico Equense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">9–10 August 2026</span>
        <span class="text-white/70 text-sm">Preazzano, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Aubergine Festival</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        The medieval hamlet and the unmissable chocolate-aubergine speciality.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>One of the oldest festivals in the area. The medieval hamlet of Preazzano hosts food stalls where the aubergine takes centre stage, including the sweet chocolate variation. A shuttle is available from Vico Equense station.</p>
            <p>Preazzano, a small medieval hamlet in the heart of the Sorrentine Peninsula, transforms for two days into an open-air food laboratory. The local aubergine is served in dozens of variations: fried, stuffed, alla parmigiana and the surprising sweet chocolate version.</p>
          </div>
        </div>

        <!-- The Specialities -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Festival Specialities</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Savory variations</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The traditional aubergine</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Fried, stuffed, alla parmigiana, in pasta and in Campanian ragù: the aubergine is the protagonist of a dozen traditional recipes from the Sorrentine culinary tradition.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Sweet chocolate version</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The unmissable surprise</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Aubergine in chocolate is the surprising speciality that attracts visitors from all over Campania: slices of fried aubergine covered in dark chocolate — an unexpected combination that works perfectly.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Festival shuttle</td>
                  <td class="px-6 py-4 text-slate-600">From Vico Equense station</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Available during the festival days</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">From Naples or Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Alight at Vico Equense, then shuttle</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
