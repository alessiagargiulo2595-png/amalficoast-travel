---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Lemon Festival Massa Lubrense', url: '/en-us/events/sorrentine-peninsula/sagra-limone-massa-lubrense/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Lemon Festival Massa Lubrense 2026",
  "startDate": "2026-07-11",
  "endDate": "2026-07-12",
  "location": {
    "@type": "Place",
    "name": "Historic centre, Massa Lubrense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Massa Lubrense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/sorrentine-peninsula/sagra-limone-massa-lubrense/"
};

const facts = [
  { dt: 'Dates', dd: '11–12 July 2026' },
  { dt: 'Product', dd: 'Femminiello IGP Lemon' },
  { dt: 'Venue', dd: 'Historic centre, Massa Lubrense' },
  { dt: 'Access', dd: 'EAV bus from Sorrento every 20 min' },
  { dt: 'Entry', dd: 'Free' },
];
---

<BaseLayout
  title="Lemon Festival Massa Lubrense 2026 – Tastings & Markets"
  description="The Lemon Festival in Massa Lubrense on 11 and 12 July 2026. Tasting trails through the historic doorways of the village, celebrating the Femminiello IGP lemon."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/massa-lubrense-hero.jpg"
      alt="Lemon Festival, Massa Lubrense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">11–12 July 2026</span>
        <span class="text-white/70 text-sm">Massa Lubrense, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Lemon Festival</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        The IGP Femminiello lemon takes centre stage among the historic doorways of Massa Lubrense.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>A food and wine event dedicated to celebrating the local lemon. It features tasting trails through the historic doorways of the village and craft markets. Transport by EAV bus from Sorrento's Piazza Tasso every 20 minutes.</p>
            <p>The Femminiello lemon of the Sorrentine Peninsula is one of the symbols of local agriculture, protected by a geographical indication. The festival is an opportunity to meet local producers and taste limoncello, granita and specialities made with lemon.</p>
          </div>
        </div>

        <!-- Tasting Trails -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Tasting Trails</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Artisan limoncello</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">From the grove to the bottle</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Local producers open their workshops to show the production process of traditional limoncello using organic Femminiello zest.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Lemon cuisine</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Local gastronomy</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Lemon cakes, granita, lemon pasta and traditional sweets animate the gastronomic stalls along the trail through the village's historic doorways.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">EAV Bus</td>
                  <td class="px-6 py-4 text-slate-600">From Sorrento Piazza Tasso</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Every 20 minutes</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Car</td>
                  <td class="px-6 py-4 text-slate-600">SS145 Sorrentina</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Parking along the main road</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
