---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: "Madonna della Libera Sant'Agnello", url: '/en-us/events/sorrentine-peninsula/madonna-della-libera/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Madonna della Libera Sant'Agnello 2026",
  "startDate": "2026-09-13",
  "endDate": "2026-09-13",
  "location": {
    "@type": "Place",
    "name": "Sant'Agnello",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sant'Agnello",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/sorrentine-peninsula/madonna-della-libera/"
};

const facts = [
  { dt: 'Date', dd: '13 September 2026' },
  { dt: 'Town', dd: "Sant'Agnello" },
  { dt: 'Type', dd: 'Neighbourhood feast' },
  { dt: 'Atmosphere', dd: 'Traditional and authentic' },
  { dt: "From Sorrento", dd: '5 min by bus' },
];
---

<BaseLayout
  title="Madonna della Libera Sant'Agnello 2026 – Neighbourhood Feast"
  description="The feast of the Madonna della Libera in Sant'Agnello on 13 September 2026. Traditional neighbourhood celebration with the flavour of old-time Sorrentine Peninsula festivities."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Madonna della Libera, Sant'Agnello"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">13 September 2026</span>
        <span class="text-white/70 text-sm">Sant'Agnello, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Madonna della Libera</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        The neighbourhood feast with the flavour of old-time celebrations.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>A neighbourhood feast that preserves the flavour of old-style celebrations, with traditional illuminations and local produce. An opportunity to experience the Sorrentine Peninsula away from the summer tourist flows.</p>
            <p>Sant'Agnello, just minutes from Sorrento, maintains its own distinct community identity. The feast of the Madonna della Libera is one of those events that residents proudly defend as the heritage of their neighbourhood.</p>
          </div>
        </div>

        <!-- The Celebration -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">The Celebration</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Traditional illuminations</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The lights of the neighbourhood</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The streets of Sant'Agnello are decorated with traditional illuminations that recall the festive atmosphere of the old-style Southern Italian neighbourhood feast — intimate, warm and deeply local.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Local produce</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The taste of the territory</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Stalls of local products, street food based on Sorrentine specialities and the conviviality of the community make this feast an authentic slice of life on the Peninsula.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Local bus</td>
                  <td class="px-6 py-4 text-slate-600">From Sorrento Piazza Tasso</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minutes, very frequent</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">On foot</td>
                  <td class="px-6 py-4 text-slate-600">From Sorrento centre</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">20-minute pleasant walk along the coast road</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
