---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Events', url: '/en-us/events/' },
  { name: 'Gustamincanto Vico Equense', url: '/en-us/events/sorrentine-peninsula/gustamincanto-vico-equense/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Gustamincanto Vico Equense 2026",
  "startDate": "2026-09-01",
  "endDate": "2026-09-30",
  "location": {
    "@type": "Place",
    "name": "Historic centre, Vico Equense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vico Equense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/en-us/events/sorrentine-peninsula/gustamincanto-vico-equense/"
};

const facts = [
  { dt: 'Period', dd: 'September 2026' },
  { dt: 'Venue', dd: 'Historic centre, Vico Equense' },
  { dt: 'Type', dd: 'Food festival' },
  { dt: 'Speciality', dd: 'Provolone del Monaco DOP' },
  { dt: 'From Naples', dd: 'Circumvesuviana 50 min' },
];
---

<BaseLayout
  title="Gustamincanto Vico Equense 2026 – Food Festival"
  description="Gustamincanto in Vico Equense in September 2026. The gastronomic excellence of the Sorrentine Peninsula featuring Provolone del Monaco and Michelin-starred chefs."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/vico-equense-hero.jpg"
      alt="Gustamincanto, Vico Equense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Event 2026</span>
        <span class="text-white/70 text-sm">September 2026</span>
        <span class="text-white/70 text-sm">Vico Equense, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Gustamincanto</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        The gastronomic excellence of the Sorrentine Peninsula in the medieval streets of Vico Equense.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">About the Event</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>A food festival involving the territory's finest producers, from Provolone del Monaco makers to the city's Michelin-starred chefs. A food and wine trail through the medieval streets of Vico Equense's historic centre.</p>
            <p>Gustamincanto brings together local producers, restaurateurs and starred chefs in a single event celebrating the gastronomic biodiversity of the Sorrentine Peninsula. Provolone del Monaco DOP, IGP lemons and local wines are among the stars.</p>
          </div>
        </div>

        <!-- The Highlights -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Festival Highlights</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Provolone del Monaco</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">The king of local cheeses</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Provolone del Monaco DOP, produced exclusively on the Sorrentine Peninsula, is presented in its various maturation stages paired with local wines and chestnut honey.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Starred chefs</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Fine dining in the square</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The Peninsula's best chefs bring their cuisine to the street with open-air cooking shows and accessible tastings along the gastronomic trail.</p>
            </div>
          </div>
        </div>

        <!-- Getting There -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Getting There</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">From Naples Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">50 minutes, Vico Equense stop</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Car</td>
                  <td class="px-6 py-4 text-slate-600">A3 motorway, Castellammare exit</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Parking on the outskirts of the historic centre</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Event Details</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">We recommend arriving well in advance. Check the updated programme on official channels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
