---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en-us';

const translations = {
  'en-us': {
    title: 'Page Not Found',
    heading: '404',
    message: 'Oops! The page you\'re looking for seems to have rolled off the cliffs of Positano.',
    description: 'Let\'s get you back to discovering the Amalfi Coast.',
    backHome: 'Back to Home',
    otherLanguages: 'Visit in other languages:',
    browseGuides: 'Browse Our Guides:',
    locations: 'Destinations',
    beaches: 'Beaches',
    itineraries: 'Itineraries',
    transport: 'Transport',
    discover: 'Discover',
  },
};

const t = translations['en-us'];

const langHomepages = [
  { code: 'it-it', name: 'Italiano', url: '/it-it/' },
  { code: 'en-us', name: 'English (US)', url: '/en-us/' },
  { code: 'en-gb', name: 'English (UK)', url: '/en-gb/' },
  { code: 'de-de', name: 'Deutsch', url: '/de-de/' },
  { code: 'fr-fr', name: 'Français', url: '/fr-fr/' },
  { code: 'es-es', name: 'Español', url: '/es-es/' },
];

const guides = [
  { label: t.locations, url: '/en-us/cote-amalfitaine/' },
  { label: t.beaches, url: '/en-us/beaches/' },
  { label: t.itineraries, url: '/en-us/itineraries/' },
  { label: t.transport, url: '/en-us/how-to-get-there/' },
];
---

<BaseLayout
  title={t.title}
  description={t.description}
  lang={lang}
>
  <section class="relative min-h-screen flex items-center justify-center bg-gradient-to-br from-amber-50 via-yellow-50 to-orange-50 overflow-hidden">
    <div class="absolute top-10 left-10 text-6xl opacity-20 animate-pulse">🍋</div>
    <div class="absolute top-32 right-20 text-8xl opacity-15 animate-bounce">🍋</div>
    <div class="absolute bottom-32 left-20 text-7xl opacity-15 animate-pulse">🍋</div>
    <div class="absolute bottom-10 right-10 text-6xl opacity-20 animate-bounce" style="animation-delay: 0.5s"></div>

    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">
      <div class="mb-8">
        <span class="text-9xl md:text-[150px] font-serif font-bold text-amber-900 tracking-tight" style="text-shadow: 2px 2px 4px rgba(180,83,9,0.1);">404</span>
      </div>

      <h1 class="font-serif text-4xl md:text-5xl text-amber-900 leading-tight mb-6 tracking-tight">
        {t.heading}
      </h1>

      <p class="text-xl md:text-2xl text-amber-800 mb-6 font-light max-w-2xl mx-auto leading-relaxed">
        {t.message}
      </p>

      <p class="text-lg text-amber-700 mb-12 font-light max-w-xl mx-auto">
        {t.description}
      </p>

      <a href="/en-us/"
         class="inline-block bg-amber-600 text-white font-semibold px-10 py-4 rounded-full hover:bg-amber-700 hover:scale-105 transition-all duration-300 text-lg mb-20 shadow-lg hover:shadow-xl">
        🏠 {t.backHome}
      </a>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16">
        <h2 class="font-serif text-4xl md:text-5xl text-slate-900 tracking-tight mb-4">{t.browseGuides}</h2>
        <div class="w-20 h-1 bg-amber-600 rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {guides.map(guide => (
          <a href={guide.url} class="group bg-gradient-to-br from-amber-50 to-yellow-50 p-8 rounded-[2rem] border border-amber-200 hover:shadow-xl transition-all duration-300 hover:scale-[1.02]">
            <div class="text-4xl mb-4">🍋</div>
            <h3 class="font-serif text-xl text-amber-900 font-bold mb-2">{guide.label}</h3>
            <span class="text-sm font-medium text-amber-700 flex items-center gap-1 group-hover:text-amber-600 transition-colors">
              {t.discover}
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-amber-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-16">
        <h2 class="font-serif text-4xl md:text-5xl text-slate-900 tracking-tight mb-4">{t.otherLanguages}</h2>
        <div class="w-20 h-1 bg-amber-600 rounded-full"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {langHomepages.map(lang_option => (
          <a href={lang_option.url} class={`group p-6 rounded-[2rem] text-center font-medium transition-all duration-300 hover:scale-[1.05] border-2 ${
            lang_option.code === lang
              ? 'bg-amber-600 text-white border-amber-600'
              : 'bg-white text-amber-900 border-amber-200 hover:border-amber-600 hover:bg-amber-50'
          }`}>
            {lang_option.name}
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
