---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Sorrento Peninsula', url: '/en-us/sorrento-peninsula/' },
  { name: 'Sorrento', url: '/en-us/sorrento-peninsula/sorrento/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I get to Sorrento from Naples?",
      "acceptedAnswer": { "@type": "Answer", "text": "The Circumvesuviana train connects Naples Central to Sorrento in about 70 minutes (~€3.90). Alternative: hydrofoil from Molo Beverello in about 60 minutes. By car: about 1 hour without traffic (ZTL restricted zones in effect in the center during summer)." }
    },
    {
      "@type": "Question",
      "name": "Does Sorrento have sandy beaches?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. Sorrento's beaches are on volcanic rock, pebbles, or equipped platforms. Marina Grande and Marina Piccola are the two main bays, reachable via stairs or elevators from the cliffs." }
    },
    {
      "@type": "Question",
      "name": "Is it better to stay in Sorrento or Positano?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sorrento is the perfect base: it has the train station, hydrofoil port, and prices are 30-40% lower than Positano. Positano is more romantic but more expensive and isolated." }
    },
    {
      "@type": "Question",
      "name": "What should I eat in Sorrento?",
      "acceptedAnswer": { "@type": "Answer", "text": "Gnocchi alla sorrentina (with tomato, basil, and fior di latte), delizia al limone (spherical lemon cake), artisanal limoncello, and fresh daily catch. Avoid restaurants directly on Piazza Tasso for better value." }
    },
    {
      "@type": "Question",
      "name": "Can I visit Capri as a day trip from Sorrento?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, and it's the best way: hydrofoil from Sorrento to Capri in 25 minutes (~€22 return). Recommended departure at 8:00 to arrive before the tourist crowds. Last return around 18:30–19:00." }
    }
  ]
};

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Sorrento",
  "description": "Sorrento is the capital of the Sorrento Peninsula, famous for limoncello, wood inlay art, Piazza Tasso, and its strategic position as a base for Capri, Naples, and the Amalfi Coast.",
  "url": "https://amalficoast-travel.com/en-us/sorrento-peninsula/sorrento/",
  "touristType": ["Culture", "Gastronomy", "Sea", "Travel Hub"],
  "address": { "@type": "PostalAddress", "addressLocality": "Sorrento", "addressRegion": "Naples", "addressCountry": "IT" },
  "geo": { "@type": "GeoCoordinates", "latitude": 40.6260, "longitude": 14.3752 }
};

const fastFacts = [
  { dt: 'Location', dd: 'Sorrento Peninsula, NA' },
  { dt: 'Altitude', dd: '~50 m asl (cliffside)' },
  { dt: 'Population', dd: '~16,000 residents' },
  { dt: 'ZTL', dd: 'Yes, historic center' },
  { dt: 'From Naples', dd: '70 min (Circumvesuviana)' },
  { dt: 'To Capri', dd: '25 min (hydrofoil)' },
  { dt: 'Beaches', dd: 'Rock and pebbles' },
  { dt: 'Best Period', dd: 'Apr–Jun / Sep–Oct' },
  { dt: 'Specialties', dd: 'Limoncello, gnocchi, wood inlay' },
];

const tips = [
  'The Vallone dei Mulini — 2 minutes from Piazza Tasso — is free, virtually unknown to tourists, and extremely photogenic.',
  'For limoncello, buy from producers on via San Cesareo (historic center) rather than shops on the waterfront.',
  'Circumvesuviana is cheap but slow: if in a hurry, use the hydrofoil (more expensive but 45 min vs 70 min).',
  'Marina Grande (fishing village) is reachable via the stone steps of via Marina Grande: more authentic than Marina Piccola.',
];
---

<BaseLayout
  title="Sorrento 2026: Complete Guide | Piazza Tasso, Limoncello, and Travel Tips"
  description="Ultimate guide to Sorrento: Piazza Tasso, Marina Grande, and limoncello. How to get there from Naples and why it's the perfect base for Capri and the Amalfi Coast."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/sorrento-hero.jpg" alt="Sorrento, Italy" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrento Peninsula · Hub for Capri & Coast</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrento</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          The city of limoncello and wood inlay, perched on cliffs overlooking the Gulf of Naples with Vesuvius in front and Capri just 25 minutes away. Sorrento is the ideal starting point for all of Campania.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">Fast Facts</a>
          <a href="#getting-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Getting Here</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Sorrento is a city of contrasts: the bustling energy of Piazza Tasso and the silent alleys of the historic center, waterfront tourist spots and hidden trattorias where locals have dined for generations.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            World-famous for its limoncello (made here with PGI lemons), its inlaid wood art (a Renaissance tradition), and its status as the perfect logistical hub: from here, you can reach Naples, Pompeii, Capri, Positano, or Amalfi in about an hour.
          </p>
        </div>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Did you know?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">70 min</p><p class="text-white/60 text-xs italic mt-1">from Naples via Circumvesuviana</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">25 min</p><p class="text-white/60 text-xs italic mt-1">to Capri by hydrofoil</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">16,000</p><p class="text-white/60 text-xs italic mt-1">residents</p></div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            The name "Sorrento" may derive from the Greek <em>Surrentum</em> or from <em>Seirenoussai</em> (the Sirens): according to mythology, these shores were home to the sirens who tried to lure Ulysses.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">What to see in Sorrento</h2>
          <div class="space-y-8">
            {[
              { n: 1, title: 'Piazza Tasso', text: 'The heart of Sorrento: bars, restaurants, and the statue of Torquato Tasso. It is the mandatory evening meeting point for locals and tourists alike. All the main roads of the center depart from here.' },
              { n: 2, title: 'Cloister of San Francesco', text: "Sorrento's most beautiful monument: a 14th-century Gothic-Arabian cloister with interlaced arches and a wisteria garden. Free entry, open year-round. Hosts summer concerts and art exhibitions." },
              { n: 3, title: 'Villa Comunale & Belvedere', text: 'Public gardens with the most spectacular terrace in Sorrento: views of Vesuvius, the Gulf of Naples, and Capri on the horizon. Free, open all day. The best spot for a sunset aperitivo without the bar markup.' },
              { n: 4, title: 'Marina Grande', text: 'The fishing harbor, reachable via the stone steps of via Marina Grande (15 min from center). Colorful houses, beached boats, and authentic seafood restaurants. Less touristy than Marina Piccola.' },
              { n: 5, title: 'Vallone dei Mulini', text: 'A natural canyon steps away from Piazza Tasso, completely forgotten by tourists: an abandoned mill covered in tropical vegetation 40 m below street level. Visible for free from the via Fuorimura bridge.' }
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div><h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3><p class="text-slate-600 leading-relaxed">{text}</p></div>
              </div>
            ))}
          </div>
        </div>

        <div id="getting-here">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-6">Getting to Sorrento</h2>
          <div class="space-y-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-3 flex items-center gap-2">
                <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Circumvesuviana (from Naples)
              </h3>
              <p class="text-sm text-slate-600 leading-relaxed mb-3">EAV train from Naples Porta Nolana or Naples Central (Piazza Garibaldi) toward Sorrento. Duration: ~70 min. Cost: ~€3.90. Stops at Herculaneum (Scavi), Pompeii (Scavi Villa dei Misteri), Castellammare di Stabia, Vico Equense. Frequency: every 30–40 min from 6:00 to 22:00.</p>
              <p class="text-xs text-slate-400">* Watch for pickpockets. Check timetables at eavsrl.it</p>
            </div>

            <div class="overflow-x-auto rounded-2xl border border-slate-200">
              <table class="w-full text-sm">
                <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Hydrofoils from Naples Beverello → Sorrento</caption>
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Naples Depart</th>
                    <th class="text-left px-4 py-3 font-semibold">Sorrento Arrive</th>
                    <th class="text-left px-4 py-3 font-semibold">Company</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  {[
                    ['07:00', '08:05', 'Alilauro'],
                    ['08:30', '09:35', 'Alilauro'],
                    ['10:00', '11:05', 'Alilauro'],
                    ['12:00', '13:05', 'Alilauro'],
                    ['15:00', '16:05', 'Alilauro'],
                    ['17:00', '18:05', 'Alilauro'],
                  ].map(([p, a, c]) => (
                    <tr class="hover:bg-slate-50 transition-colors">
                      <td class="px-4 py-3 font-mono">{p}</td>
                      <td class="px-4 py-3 font-mono">{a}</td>
                      <td class="px-4 py-3 text-slate-500">{c}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-400 mt-1">* Indicative summer 2026 timetable. Check alilauro.it</p>
          </div>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-6">Sorrento off the beaten path</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Sedile Dominova', text: 'A 15th-century open loggia with original frescoes, hidden in an alley of the old town. Once the seat of the local noble assembly, today used as a social club by neighborhood elders. Free, always open.' },
              { title: 'Via San Cesareo', text: "The real Sorrento shopping street: wood inlay workshops, artisanal limoncello shops, delis and cheese makers. Much less expensive and more authentic than Corso Italia." },
              { title: 'Museum of Wood Inlay', text: "Sorrento's marquetry museum, housed in an 18th-century palazzo with frescoed ceilings. Collection of inlaid furniture and objects from the 16th to 19th century. Entry ~€8." },
              { title: 'Sunset at Capo di Sorrento', text: "The Roman ruins of the Bagni della Regina Giovanna at Capo di Sorrento: reachable on foot in 45 min from the center along the coastal path. Natural rock pools, sunset over open sea. Free." },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20"><svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg></div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Local Tip</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Vallone dei Mulini — free entry</h3>
              <p class="text-white/70 leading-relaxed">The Vallone dei Mulini is a deep gorge in the center of Sorrento with lush vegetation. View it from via Fuorimura for free: look for the railing on the road and peer down. A spot most tourists never find.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Frequently asked questions about Sorrento</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts — Sorrento</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Insider Tips</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Sorrento Peninsula</p>
          <nav class="space-y-1">
            {[
              { href: '/en-us/sorrento-peninsula/vico-equense/', label: 'Vico Equense' },
              { href: '/en-us/sorrento-peninsula/massa-lubrense/', label: 'Massa Lubrense' },
              { href: '/en-us/sorrento-peninsula/sant-agnello/', label: "Sant'Agnello" },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Explore also"
    items={[
      { name: 'Capri',          href: '/en-us/islands/capri/',                      tag: 'Most iconic',    desc: 'Blue Grotto, Faraglioni, and the Piazzetta — 25 min by hydrofoil.' },
      { name: 'Positano',       href: '/en-us/amalfi-coast/positano/',              tag: 'Fashion & Views', desc: 'The colorful cliffside houses of the Amalfi Coast.' },
      { name: 'Vico Equense',   href: '/en-us/sorrento-peninsula/vico-equense/',    tag: 'Authentic',      desc: 'Pizza by the meter at Da Gigino and the cliffside Giusso Castle.' },
      { name: 'Massa Lubrense', href: '/en-us/sorrento-peninsula/massa-lubrense/', tag: 'Nature & Cuisine', desc: 'Punta Campanella, Marina del Cantone, and Nerano spaghetti.' },
      { name: 'Ischia',         href: '/en-us/islands/ischia/',                     tag: 'Thermal & Nature', desc: 'Natural thermal baths and Aragonese Castle — 75 min by ferry.' },
    ]}
  />

</BaseLayout>
