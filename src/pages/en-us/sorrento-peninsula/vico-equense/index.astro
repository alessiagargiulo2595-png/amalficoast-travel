---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';
const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Sorrento Peninsula', url: '/en-us/sorrento-peninsula/' },
  { name: 'Vico Equense', url: '/en-us/sorrento-peninsula/vico-equense/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Where to eat pizza by the meter in Vico Equense?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pizza by the meter was invented by Gigino Dell'Amura in 1938 at Trattoria Università della Pizza, now known as Da Gigino." }
    },
    {
      "@type": "Question",
      "name": "How to get to Vico Equense from Naples?",
      "acceptedAnswer": { "@type": "Answer", "text": "Take the Circumvesuviana from Naples toward Sorrento: get off at Vico Equense (~50 min, €3.10)." }
    }
  ]
};

const fastFacts = [
  { dt: 'Location', dd: 'Sorrento Peninsula, NA' },
  { dt: 'From Naples', dd: '~50 min (Train)' },
  { dt: 'Specialty', dd: 'Pizza by the meter, fior di latte' },
  { dt: 'Best Period', dd: 'Apr–Oct' },
];
---

<BaseLayout
  title="Vico Equense 2026: Pizza by the Meter & Giusso Castle"
  description="Guide to Vico Equense: pizza by the meter, Giusso Castle, and the medieval center. How to get there from Naples."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>
  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/vico-equense-hero.jpg" alt="Vico Equense" class="absolute inset-0 w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 pb-16">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrento Peninsula · Pizza by the Meter</p>
      <h1 class="font-serif text-display text-white mb-4">Vico Equense</h1>
      <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
        The medieval town where pizza by the meter was born in 1938. Authentic center, Giusso Castle over the sea, and fewer tourists than Sorrento.
      </p>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">
      <div class="space-y-12">
        <h2 class="font-serif text-2xl font-semibold">What to See</h2>
        <div class="space-y-6">
          <h3 class="font-semibold">Castello Giusso</h3>
          <p class="text-sm text-slate-600">A 12th-century medieval castle perched on the cliff 105m above the sea.</p>

          <h3 class="font-semibold">Pizza by the Meter at Da Gigino</h3>
          <p class="text-sm text-slate-600">Known as the 'University of Pizza', still using the original recipe from 1938.</p>
        </div>
      </div>
      <aside class="bg-slate-900 text-white p-6 rounded-[3rem] self-start">
        <p class="text-med-gold text-xs font-bold mb-4 uppercase">Fast Facts</p>
        <dl class="space-y-3">
          {fastFacts.map(f => (
            <div class="flex justify-between text-sm">
              <dt class="text-white/40">{f.dt}</dt>
              <dd class="text-white">{f.dd}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>
  </section>
</BaseLayout>
