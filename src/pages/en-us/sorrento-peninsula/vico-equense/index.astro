---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Sorrento Peninsula', url: '/en-us/sorrento-peninsula/' },
  { name: 'Vico Equense', url: '/en-us/sorrento-peninsula/vico-equense/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Where to eat pizza by the meter in Vico Equense?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pizza by the meter was invented by Gigino Dell'Amura in 1938 at Trattoria Università della Pizza, now known as Da Gigino, on via Nicotera. You order by length (min 1 meter) with a choice of toppings for each section." }
    },
    {
      "@type": "Question",
      "name": "How to get to Vico Equense from Naples?",
      "acceptedAnswer": { "@type": "Answer", "text": "Circumvesuviana from Naples Central toward Sorrento: exit at Vico Equense (~50 min, ~€3.10). By car: A3 highway exit Castellammare di Stabia, then SS145 toward Sorrento." }
    },
    {
      "@type": "Question",
      "name": "Is Vico Equense worth a visit?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, especially if you want to avoid the Sorrento crowds. The medieval center, Giusso Castle, and the views are authentic and less touristy. Ideal for a half-day stop." }
    }
  ]
};

const fastFacts = [
  { dt: 'Location', dd: 'Sorrento Peninsula, NA' },
  { dt: 'Population', dd: '~21,000 residents' },
  { dt: 'From Naples', dd: '~50 min (Circumvesuviana)' },
  { dt: 'From Sorrento', dd: '~15 min (Circumvesuviana)' },
  { dt: 'Specialties', dd: 'Pizza by the meter, fior di latte' },
  { dt: 'Beaches', dd: 'Marina di Vico (pebbles)' },
  { dt: 'Best Period', dd: 'Apr–Oct' },
];
---

<BaseLayout
  title="Vico Equense 2026: Pizza by the Meter, Giusso Castle, and Travel Guide"
  description="Guide to Vico Equense: pizza by the meter at Da Gigino, Giusso Castle, and the medieval old town. How to get there from Naples via Circumvesuviana."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/vico-equense-hero.jpg" alt="Vico Equense, Italy" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrento Peninsula · Pizza by the Meter</p>
        <h1 class="font-serif text-display text-white mb-4">Vico Equense</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          The medieval town where pizza by the meter was born in 1938. An authentic center, Giusso Castle perched over the sea, and fewer tourists than Sorrento-just 15 minutes away by train.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Vico Equense is often overlooked by tourists heading straight to Sorrento. This is a mistake: the medieval center perched on the cliff, the 12th-century Giusso Castle, and especially Gigino's pizza by the meter deserve at least a half-day.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Did you know?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">1938</p><p class="text-white/60 text-xs italic mt-1">year pizza by the meter was invented</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">105 m</p><p class="text-white/60 text-xs italic mt-1">Castle altitude above sea</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">21,000</p><p class="text-white/60 text-xs italic mt-1">residents</p></div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Gigino Dell'Amura invented pizza by the meter in 1938 because customers wanted larger portions. His trattoria - now known as Università della Pizza - is still open with the same original recipe.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">What to see in Vico Equense</h2>
          <div class="space-y-6">
            {[
              { title: 'Giusso Castle', text: "A 12th-century medieval castle perched 105m above the sea. Today hosts cultural events and weddings. Viewable from outside for free; visits by appointment. Offers some of the peninsula's finest views of the Gulf of Naples." },
              { title: 'Pizza by the Meter at Da Gigino', text: "The inventor of pizza by the meter: Gigino Dell'Amura opened in 1938 what is now called Trattoria Università della Pizza. Order by the meter with different toppings per section. Honest prices (~€8–12/meter), almost always a queue in the evening. Via Nicotera 15." },
              { title: 'Vico Equense Cathedral', text: "The 14th-century Basilica della SS. Annunziata, one of the few Gothic buildings in Campania. Simple facade but interior with frescoes and a medieval crypt. Free entry, limited opening hours." },
              { title: 'Marina di Vico', text: 'A small harbor and pebble beach at the foot of the cliff, reachable by road from the center. Quieter than the Sorrento beaches, with a few beach clubs and fishing boats.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Frequently asked questions</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts - Vico Equense</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Sorrento Peninsula</p>
          <nav class="space-y-1">
            {[
              { href: '/en-us/sorrento-peninsula/sorrento/', label: 'Sorrento' },
              { href: '/en-us/sorrento-peninsula/massa-lubrense/', label: 'Massa Lubrense' },
              { href: '/en-us/sorrento-peninsula/sant-agnello/', label: "Sant'Agnello" },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Explore the Peninsula and Islands"
    items={[
      { name: 'Sorrento',       href: '/en-us/sorrento-peninsula/sorrento/',      tag: 'Ideal Base',     desc: 'Hub for Capri, Naples, and the Coast. Limoncello and Piazza Tasso.' },
      { name: 'Massa Lubrense', href: '/en-us/sorrento-peninsula/massa-lubrense/', tag: 'Nature',         desc: 'Punta Campanella, Marina del Cantone, and Nerano spaghetti.' },
      { name: 'Capri',          href: '/en-us/islands/capri/',                     tag: 'Most iconic',    desc: 'Blue Grotto, Faraglioni, and the famous Piazzetta.' },
      { name: 'Positano',       href: '/en-us/amalfi-coast/positano/',             tag: 'Fashion & Views', desc: 'The colorful cliffside houses of the Amalfi Coast.' },
    ]}
  />

</BaseLayout>
