---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Sorrento Peninsula', url: '/en-us/sorrento-peninsula/' },
];

const borghi = [
  {
    name: 'Sorrento',
    href: '/en-us/sorrento-peninsula/sorrento/',
    desc: 'The peninsula\'s capital: Piazza Tasso, the San Francesco cloister, limoncello, and hydrofoils to Capri and Naples.',
    tag: 'Ideal Base',
  },
  {
    name: 'Vico Equense',
    href: '/en-us/sorrento-peninsula/vico-equense/',
    desc: 'Home of "pizza by the meter" at Da Gigino and the cliffside Giusso Castle. Less touristy, more authentic.',
    tag: 'Authentic',
  },
  {
    name: 'Massa Lubrense',
    href: '/en-us/sorrento-peninsula/massa-lubrense/',
    desc: 'The southernmost town: Punta Campanella, Marina del Cantone, and the famous Nerano zucchini spaghetti.',
    tag: 'Nature & Cuisine',
  },
  {
    name: "Sant'Agnello",
    href: '/en-us/sorrento-peninsula/sant-agnello/',
    desc: 'Between Sorrento and Piano: historic villas, charming hotels, and a rare quietness just steps from the bustle.',
    tag: 'Quiet & Luxury',
  },
];

const destinationSchema = {
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": "Sorrento Peninsula",
  "description": "The Sorrento Peninsula stretches into the Gulf of Naples between Mount Vesuvius and the Amalfi Coast: Sorrento, Vico Equense, Massa Lubrense, and Sant'Agnello.",
  "url": "https://amalficoast-travel.com/en-us/sorrento-peninsula/",
  "touristType": ["Sea", "Culture", "Gastronomy", "Hiking"],
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6264,
    "longitude": 14.3757
  }
};
---

<BaseLayout
  title="Sorrento Peninsula 2026: Sorrento, Vico Equense, Massa Lubrense"
  description="Guide to the Sorrento Peninsula: Sorrento, Vico Equense, Massa Lubrense, and Sant'Agnello. How to get there by Circumvesuviana and hydrofoil, what to see, and where to eat."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[destinationSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/sorrento-hero.jpg" alt="Sorrento Peninsula, Gulf of Naples" class="absolute inset-0 w-full h-full object-cover opacity-50" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/30 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Sorrento Peninsula</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Gulf of Naples · Campania</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrento Peninsula</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          The headland dividing the Gulf of Naples from the Amalfi Coast. Glamorous Sorrento scented with lemons, Vico Equense with its pizza by the meter, and wild Massa Lubrense where Punta Campanella looks at Capri so closely you feel you could touch it.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-20">

    <section class="max-w-text">
      <p class="text-xl leading-relaxed text-charcoal">
        The Sorrento Peninsula is the natural starting point for exploring the entire coastal Campania region. From Sorrento, you can reach Capri in 25 minutes by hydrofoil, Naples in 70 minutes by Circumvesuviana train, Pompeii in 30 minutes, and Amalfi in less than 2 hours. It's not just a destination: it's the perfect hub.
      </p>
      <p class="mt-4 text-slate-600 leading-relaxed">
        The Circumvesuviana train connects Naples to Sorrento via Herculaneum, Pompeii, and Vico Equense. Ferries and hydrofoils reach Capri, Ischia, Positano, and Naples. SITA buses travel along the SS145 highway to Amalfi. From Sorrento, the world is just a ferry ride away.
      </p>
    </section>

    <section>
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-serif text-3xl font-semibold text-slate-900">Towns of the Peninsula</h2>
        <p class="text-sm text-slate-400 hidden sm:block">Gulf of Naples, Campania</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {borghi.map(b => (
          <a href={b.href} class="group bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm hover:border-med-blue/30 hover:shadow-xl transition-all duration-300">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-serif text-xl font-semibold text-slate-900 group-hover:text-med-blue transition-colors">{b.name}</h3>
              <span class="text-[10px] uppercase tracking-wide bg-med-blue/5 text-med-blue px-2 py-1 rounded-full font-medium flex-shrink-0 ml-2">{b.tag}</span>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">{b.desc}</p>
            <p class="text-med-blue text-sm font-medium mt-4 group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
              Explore {b.name}
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
            </p>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">How to Get to the Sorrento Peninsula</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold mb-3">Train</p>
          <p class="font-semibold text-charcoal mb-1">Circumvesuviana</p>
          <p class="text-sm text-slate-600 leading-relaxed">From Naples Central to Sorrento: ~70 min, ~€3.90. Stops at Herculaneum, Pompeii, Castellammare, Vico Equense. Frequency every 30–40 min.</p>
        </div>
        <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold mb-3">Ferry / Hydrofoil</p>
          <p class="font-semibold text-charcoal mb-1">From Naples or Amalfi</p>
          <p class="text-sm text-slate-600 leading-relaxed">Sorrento–Naples Molo Beverello: ~1h by hydrofoil. Sorrento–Capri: ~25 min. Sorrento–Positano: ~35 min (seasonal).</p>
        </div>
        <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold mb-3">Bus / Car</p>
          <p class="font-semibold text-charcoal mb-1">SS145 and SS163</p>
          <p class="text-sm text-slate-600 leading-relaxed">From Naples by car ~1h (no traffic). SITA bus from Amalfi via SS163 then SS145 to Sorrento: ~2h. ZTL in Sorrento center in summer.</p>
        </div>
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-10">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-8">The Peninsula in Numbers</p>
      <div class="grid sm:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">70 min</p>
          <p class="text-white/60 text-sm mt-2">Naples → Sorrento by Circumvesuviana</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">25 min</p>
          <p class="text-white/60 text-sm mt-2">Sorrento → Capri by hydrofoil</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">77 km</p>
          <p class="text-white/60 text-sm mt-2">Length of the Sorrento Peninsula</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">497 m</p>
          <p class="text-white/60 text-sm mt-2">Monte Faito, highest point</p>
        </div>
      </div>
    </section>

  </div>

</BaseLayout>
