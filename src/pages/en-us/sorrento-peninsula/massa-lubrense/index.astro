---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';
const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Sorrento Peninsula', url: '/en-us/sorrento-peninsula/' },
  { name: 'Massa Lubrense', url: '/en-us/sorrento-peninsula/massa-lubrense/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Best beach in Massa Lubrense?",
      "acceptedAnswer": { "@type": "Answer", "text": "Marina del Cantone, in the village of Nerano, is the most beautiful: light pebbles, crystal-clear water, and a protected marine area." }
    },
    {
      "@type": "Question",
      "name": "How to get to Massa Lubrense from Sorrento?",
      "acceptedAnswer": { "@type": "Answer", "text": "EAV bus from Sorrento (~20-30 min, ~€1.50). By car: SS145 from Sorrento toward Massa Lubrense." }
    },
    {
      "@type": "Question",
      "name": "What are Spaghetti alla Nerano?",
      "acceptedAnswer": { "@type": "Answer", "text": "Spaghetti with fried zucchini, Provolone del Monaco cheese, basil, and pecorino. Invented in the 1950s in Nerano." }
    }
  ]
};

const fastFacts = [
  { dt: 'Location', dd: 'Tip of Sorrento Peninsula' },
  { dt: 'Main Hamlets', dd: 'Nerano, Termini, Sant\'Agata' },
  { dt: 'From Sorrento', dd: '~20 min (Bus)' },
  { dt: 'Beaches', dd: 'Marina del Cantone (pebbles)' },
  { dt: 'Marine Reserve', dd: 'Punta Campanella' },
  { dt: 'Best Period', dd: 'May–Oct' },
];
---

<BaseLayout
  title="Massa Lubrense 2026: Punta Campanella, Marina del Cantone and Nerano"
  description="Guide to Massa Lubrense: Marina del Cantone beach, Spaghetti alla Nerano, and the Punta Campanella marine reserve."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>
  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/massa-lubrense-hero.jpg" alt="Massa Lubrense, Italy" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrento Peninsula · Nature & Cuisine</p>
        <h1 class="font-serif text-display text-white mb-4">Massa Lubrense</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          The southernmost tip of the peninsula overlooking Capri. Marine reserves, trekking, Marina del Cantone beach, and Spaghetti alla Nerano: a paradise for slow tourism.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 text-charcoal">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">
      <div class="space-y-12">
        <p class="text-xl leading-relaxed">
          Massa Lubrense is a municipality of 15 scattered hamlets. Nerano is for foodies, Sant'Agata offers the best dual-gulf views, and Marina del Cantone is the best beach on the peninsula.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Did you know?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">15</p><p class="text-white/60 text-xs italic mt-1">hamlets in the town</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">4.9 km</p><p class="text-white/60 text-xs italic mt-1">distance to Capri</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">1997</p><p class="text-white/60 text-xs italic mt-1">marine reserve founded</p></div>
          </div>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Must-See</h2>
          <div class="space-y-6">
            {[
              { title: 'Marina del Cantone', text: 'Crystal-clear water and light pebbles. Perfect for snorkeling and home to world-class seafood restaurants.' },
              { title: 'Spaghetti alla Nerano', text: 'Zucchini, Provolone del Monaco, and basil. Invented at Maria Grazia in the 1950s.' },
              { title: 'Punta Campanella', text: 'The rocky tip where an Athena temple once stood. Trek from Termini (45 min) for unmatched views of Capri.' },
              { title: "Sant'Agata sui Due Golfi", text: 'Spectacular viewpoint where you can see the Gulf of Naples and the Gulf of Salerno at the same time.' }
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }) => (
              <div class="flex justify-between text-sm"><dt class="text-white/40">{dt}</dt><dd>{dd}</dd></div>
            ))}
          </dl>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
