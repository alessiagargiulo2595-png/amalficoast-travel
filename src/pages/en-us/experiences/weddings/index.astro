---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-en';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Experiences', url: '/en-us/experiences/' },
  { name: 'Weddings', url: '/en-us/experiences/weddings/' },
];

const facts = [
  { label: 'Type', value: 'Civil or religious ceremony' },
  { label: 'Area', value: 'Sorrentine Peninsula · Amalfi Coast' },
  { label: 'Language', value: 'Italian, English, others on request' },
  { label: 'Best season', value: 'April – October' },
  { label: 'Ideal for', value: 'Destination Wedding, international couples' },
  { label: 'Organisation', value: 'Local wedding planner recommended' },
];

const otherExperiences = experiences.filter(e => e.id !== 'weddings');

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Weddings on the Amalfi Coast and Sorrentine Peninsula",
  "description": "Guide to the most beautiful venues for getting married on the Amalfi Coast and Sorrentine Peninsula: medieval cloisters, clifftop churches and historic villas for an unforgettable Destination Wedding.",
  "areaServed": {
    "@type": "Place",
    "name": "Amalfi Coast and Sorrentine Peninsula",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "provider": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Weddings Amalfi Coast 2026 | Venues, Churches & Destination Wedding"
  description="Getting married on the Amalfi Coast and Sorrentine Peninsula: the most beautiful venues for civil and religious ceremonies, from the Cloister of San Francesco to clifftop churches."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaService]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/matrimoni-chiostro-hero.jpg"
      alt="Cloister of San Francesco, Sorrento - venue for civil wedding ceremonies"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Wedding · Amalfi Coast</p>
      <h1 class="font-serif text-display text-white mb-6">Weddings</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Vows Suspended between Rock and Sea.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">The world capital of Destination Weddings</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            It is no coincidence that Sorrento and the Amalfi Coast rank among the world's most coveted Destination Wedding locations. Here beauty is not merely a backdrop but a silent accomplice: it lives in the golden light that caresses the villages at sunset, in the architecture of centuries-old churches, and in the intoxicating scent of orange blossom that fills the air in spring. To marry here means writing your love story into a legendary setting where every view seems painted expressly for an unforgettable wedding album.
          </p>
        </div>

        <!-- Civil ceremony -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">The Charm of the Civil Ceremony: History and Nature</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Beyond religious celebrations, the area offers breathtakingly beautiful municipal venues for civil ceremonies, allowing couples to say "I do" in settings that blend history and nature. Many local authorities have opened the doors of historic villas and botanical gardens, transforming bureaucracy into a moment of pure poetry.
          </p>

          <div class="space-y-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">The Cloister of San Francesco — Sorrento</h3>
              <p class="text-slate-600 leading-relaxed mb-4">
                Undoubtedly the most iconic venue for a civil ceremony on the Sorrentine Peninsula. This 14th-century cloister is a jewel of architecture where different styles — from Late Gothic to Renaissance — merge in an embrace of interlaced arches and tufa stone columns. The atmosphere is intimate, almost mystical, enlivened by climbing plants and flowers adorning the medieval walls.
              </p>
              <p class="text-slate-600 leading-relaxed">
                A short walk from the cloister, the Villa Comunale offers a natural terrace with a breathtaking view of Capri — perfect for the first photos as newlyweds immediately after the ceremony.
              </p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">Terraces and Museums</h3>
              <p class="text-slate-600 leading-relaxed">
                Beyond the Cloister, Sorrento offers venues such as the Correale di Terranova Museum or Villa Fondi in Piano di Sorrento, where clifftop gardens and archaeological finds bear witness to an eternal promise.
              </p>
            </div>
          </div>
        </div>

        <!-- Monumental churches -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Monumental Churches: Altars between Sky and Sea</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            For those dreaming of a religious ceremony, the Coast is home to some of the world's most spectacular places of worship, where faith meets the vertiginous coastline.
          </p>

          <div class="rounded-[2rem] overflow-hidden shadow-xl mb-6">
            <img
              src="/images/chiesa-annunziata-vico.webp"
              alt="Church of the Santissima Annunziata in Vico Equense, perched above the Gulf of Naples with Vesuvius in the background"
              class="w-full h-72 object-cover"
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          </div>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Church of the Santissima Annunziata — Vico Equense</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Often called "the most beautiful church in Italy", this Gothic gem with its pink façade perches on a cliff above the sea. Exchanging vows here means gazing out across the entire Gulf of Naples with Vesuvius on the horizon. It is the only church in the world that appears literally suspended above the waves.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">The Duomo of Amalfi — Sant'Andrea</h4>
                <p class="text-slate-600 text-sm leading-relaxed">For those who dream of a triumphal entrance. Its imposing staircase and Arab-Norman style offer timeless grandeur at the very heart of the Coast.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Santa Maria Assunta — Positano</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Famous for its yellow and green majolica dome glittering in the sun, steps from the main beach. Perfect for a glamorous, iconic wedding that breathes the spirit of the Dolce Vita.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Receptions -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Experiences and Receptions</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            From the historic estates of Ravello — such as Villa Cimbrone with its Terrace of Infinity — to secluded coves accessible only by boat for an exclusive party by the sea, the possibilities are endless. Many couples choose to welcome their guests with a traditional Sorrentine aperitivo among the lemon groves, transforming the wedding weekend into a journey of gastronomic discovery and relaxation.
          </p>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip for the Couple</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            If you choose the Santissima Annunziata in Vico Equense, plan your exit from the church at sunset: the light striking the pink façade creates a magical glow, perfect for filter-free photographs. For the Cloister of San Francesco, note that the acoustics are extraordinary — a harp or string quartet will make the civil ceremony a truly spine-tingling experience.
          </p>
          <p class="text-slate-600 leading-relaxed">
            A practical tip for brides: the narrow lanes of the Coast are beautiful but treacherous for stilettos. Pack a pair of luxury flats or jewelled wedges for moving between alleyways, and save the high heels for the reception!
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/en-us/experiences/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← All experiences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Other Experiences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Other Experiences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
