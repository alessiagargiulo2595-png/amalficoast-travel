---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-en';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Experiences', url: '/en-us/experiences/' },
  { name: 'Cooking Class', url: '/en-us/experiences/cooking-class/' },
];

const facts = [
  { label: 'Duration', value: '4–5 hours' },
  { label: 'Area', value: 'Sorrentine Peninsula · Amalfi Coast' },
  { label: 'Language', value: 'Italian, English' },
  { label: 'Included', value: 'Market visit, lesson, meal, recipes' },
  { label: 'Indicative price', value: 'from €75 per person' },
  { label: 'Ideal for', value: 'Couples, groups, food lovers' },
];

const otherExperiences = experiences.filter(e => e.id !== 'cooking-class');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Cooking Class: Secrets of Coastal Cuisine",
  "description": "Campanian cooking masterclass on the Sorrentine Peninsula and Amalfi Coast. Ravioli alla Caprese, Gnocchi alla Sorrentina, Delizia al Limone and much more.",
  "location": {
    "@type": "Place",
    "name": "Sorrentine Peninsula and Amalfi Coast",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Cooking Class Amalfi Coast 2026 | Authentic Campanian Cuisine"
  description="Cooking lessons on the Sorrentine Peninsula and Amalfi Coast: Ravioli alla Caprese, Totani e Patate, Delizia al Limone. From the market to the stove."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cooking-class-hero.jpg"
      alt="Cooking Class, Campanian tomato sauce - Sorrentine Peninsula"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Food · Sorrentine Peninsula</p>
      <h1 class="font-serif text-display text-white mb-6">Cooking Class</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Secrets of Coastal Cuisine.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">A plunge into Mediterranean culture</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Cooking lessons on the Sorrentine Peninsula and Amalfi Coast are not mere courses — they are genuine immersions in Mediterranean culture. Many of these experiences begin well before the stove is lit: the ritual starts among the stalls of local markets or in terraced orchards perched above the sea, where you learn to choose the perfect tomato and recognise the scent of broad-leaf "Neapolitan" basil.
          </p>
        </div>

        <!-- The Traditional Menu -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">The Traditional Menu: The Pillars of Flavour</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            During these masterclasses, participants have the opportunity to try their hand at recipes that represent the soul of Campania.
          </p>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Starter — Impepata di Cozze</h4>
                <p class="text-slate-600 text-sm leading-relaxed">A timeless classic that celebrates the freshness of the sea. Just a handful of ingredients — mussels, black pepper, parsley and Sorrento lemon — deliver all the flavour of the Gulf.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">First Course — Ravioli alla Caprese</h4>
                <p class="text-slate-600 text-sm leading-relaxed">The symbol of Sunday lunch. A fresh pasta made with a simple dough (water and flour), filled with local caciotta cheese and a pinch of fresh marjoram, served with a light tomato sauce.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Main Course — Totani e Patate alla Praianese</h4>
                <p class="text-slate-600 text-sm leading-relaxed">A fishermen's classic from the Amalfi Coast. The sweetness of squid merges with the creaminess of local potatoes, all deglazed with white wine and perfumed with garlic and chilli.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">4</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Dessert — Delizia al Limone</h4>
                <p class="text-slate-600 text-sm leading-relaxed">The queen of local pastry-making. A soft dome-shaped sponge, filled and coated in a silky cream perfumed with Amalfi sfusato or Sorrento IGP lemon.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Editorial image -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/cooking-class-pasta.jpg"
            alt="Fresh pasta preparation during a cooking class on the Amalfi Coast"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <!-- The Art of Making -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">The Art of Making</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            The aim of these masterclasses is to reveal the secrets of the Mediterranean diet. They often begin with fresh pasta preparation: learning to balance water and flour to create iconic Ravioli alla Caprese or Gnocchi alla Sorrentina, which demand a particular technique — and quick fingers! — to achieve the right porous texture that soaks up the tomato sauce and stretchy local fior di latte. The secrets of local pastry-making are never missing either, where precision meets the fragrance of citrus picked at dawn.
          </p>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            For an authentic experience, choose classes held in old farmhouses or directly in the citrus groves, in the shade of the "pagliarelle" straw lattices.
          </p>
          <p class="text-slate-600 leading-relaxed">
            A local secret for perfect gnocchi? Always use old potatoes: they contain less water and therefore need less flour when kneading. The result? An incredibly light gnocco that literally melts in the mouth.
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/en-us/experiences/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← All experiences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Other Experiences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Other Experiences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
