---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Experiences', url: '/en-us/experiences/' },
  { name: 'Boat Tours', url: '/en-us/experiences/boat-tours/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a boat tour on the Amalfi Coast cost?",
      "acceptedAnswer": { "@type": "Answer", "text": "A group boat tour on the Amalfi Coast (4-6 hours) costs €50-€80 per person. Private boat hire (without skipper) starts from €200/day for small vessels; with skipper from €400-800/day. In Capri, rowboat trips to the Blue Grotto cost ~€15." }
    },
    {
      "@type": "Question",
      "name": "Where do boat tours depart from?",
      "acceptedAnswer": { "@type": "Answer", "text": "Boat tours depart mainly from: Positano (for the Coast and Capri), Amalfi (for the Coast and grottos), Sorrento (for Capri and the Coast), Marina Grande di Capri (for Faraglioni and Blue Grotto). In summer, book 1-2 days in advance." }
    },
    {
      "@type": "Question",
      "name": "Are boat tours cancelled in bad weather?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, all boat tours are cancelled in rough seas (waves above 0.8-1m) or strong winds. Cancellations are frequent in April, October and with tramontana wind. Always check sea conditions the day before at windguru.cz or windy.com." }
    }
  ]
};

const tours = [
  { name: 'Faraglioni Tour, Capri', from: 'Marina Grande, Capri', duration: '1-2 hours', price: '~€18-25 p.p.', highlights: 'Faraglioni, Grotta Verde, passage under Mezzo arch, snorkelling', type: 'Group' },
  { name: 'Blue Grotto (rowboat)', from: 'Marina Grande, Capri', duration: '30 min (wait + grotto)', price: '~€15 + €14 entry', highlights: 'Unique blue light, rowing boats, unmissable experience', type: 'Individual' },
  { name: 'Amalfi Coast Tour from Positano', from: 'Positano, Spiaggia Grande', duration: '4-6 hours', price: '~€50-80 p.p.', highlights: 'Emerald Grotto, Praiano, Amalfi from the sea, snorkelling in hidden coves', type: 'Group' },
  { name: 'Coast Tour from Amalfi', from: 'Amalfi harbour', duration: '3-5 hours', price: '~€40-70 p.p.', highlights: 'Grotta dello Smeraldo, Positano, inaccessible coves, lunch at sea', type: 'Group' },
  { name: 'Private Boat Sorrento → Capri', from: 'Sorrento, Marina Piccola', duration: 'Full day', price: '~€400-800 (whole boat)', highlights: 'Custom itinerary, no crowds, snorkelling, on-board lunch', type: 'Private' },
];
---

<BaseLayout
  title="Boat Tours Amalfi Coast 2026 | Capri, Positano, Blue Grotto"
  description="Best boat tours on the Amalfi Coast: Capri Faraglioni, Blue Grotto, tours from Positano and Amalfi. Prices, durations and tips for choosing the right tour."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/capri-hero.jpg" alt="Boat tour, Amalfi Coast" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/60">Experiences</span>
        <span>/</span>
        <span class="text-white">Boat Tours</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Experiences</p>
        <h1 class="font-serif text-display text-white mb-4">Boat Tours</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          The Amalfi Coast from the sea is a different world: grottos unreachable by land, hidden coves, the Faraglioni towering above your head. From budget group tours to full private charters.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Most popular tours</h2>
      <div class="space-y-4">
        {tours.map(t => (
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6 hover:border-med-blue/30 transition-colors">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-semibold text-charcoal text-lg">{t.name}</h3>
              <span class={`text-[10px] uppercase tracking-wide px-2 py-1 rounded-full font-medium flex-shrink-0 ${t.type === 'Private' ? 'bg-med-cream text-med-gold' : t.type === 'Individual' ? 'bg-med-blue/5 text-med-blue' : 'bg-slate-50 text-slate-500'}`}>
                {t.type}
              </span>
            </div>
            <div class="grid sm:grid-cols-3 gap-3 text-sm mb-3">
              <div><span class="text-slate-400">Departure</span><br /><span class="font-medium">{t.from}</span></div>
              <div><span class="text-slate-400">Duration</span><br /><span class="font-medium">{t.duration}</span></div>
              <div><span class="text-slate-400">Price</span><br /><span class="font-mono font-medium text-med-blue">{t.price}</span></div>
            </div>
            <p class="text-xs text-slate-500">{t.highlights}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Tips for choosing the right tour</p>
      <ul class="space-y-2">
        {[
          'For the Blue Grotto in Capri: arrive before 10:00. The afternoon queue can be 2 hours.',
          'Group tours from Positano are great for solo travellers: meet people, see the Coast, spend less.',
          'With family (children): choose 3-4h max tours and avoid speedboats/RIBs (more rolling).',
          'The Emerald Grotto from Amalfi is also walkable (€5 entry): you don\'t need a tour if you have transport.',
          'Book online at least 1-2 days ahead in July-August: spots sell out fast.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-gold/50 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

  <CorrelationSlider
    heading="Explore tour destinations"
    items={[
      { name: 'Capri',    href: '/en-us/isole/capri/',                 tag: 'Faraglioni',    desc: 'Blue Grotto, Faraglioni tour and inaccessible coves.' },
      { name: 'Positano', href: '/en-us/amalfi-coast/positano/',       tag: 'Coast Tours',   desc: 'Departure point for Coast tours heading east.' },
      { name: 'Amalfi',   href: '/en-us/amalfi-coast/amalfi/',         tag: 'Emerald Grotto', desc: 'The Emerald Grotto and tours towards Positano.' },
      { name: 'Procida',  href: '/en-us/isole/procida/',               tag: 'Authentic Isle', desc: 'Boat trips around this small fisherman\'s island.' },
    ]}
  />

</BaseLayout>
