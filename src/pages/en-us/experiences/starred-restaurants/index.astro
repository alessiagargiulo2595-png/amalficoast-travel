---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-en';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Experiences', url: '/en-us/experiences/' },
  { name: 'Starred Restaurants', url: '/en-us/experiences/starred-restaurants/' },
];

const facts = [
  { label: 'Guide', value: 'Michelin 2026' },
  { label: 'Area', value: 'Sorrentine Peninsula · Amalfi Coast' },
  { label: 'Top address', value: 'Quattro Passi - 3 Michelin Stars' },
  { label: 'Reservation', value: '3–4 months ahead (weekends)' },
  { label: 'Ideal for', value: 'Foodies, special occasions, anniversaries' },
  { label: 'Not to miss', value: 'Visit to the rock-carved wine cellar' },
];

const otherExperiences = experiences.filter(e => e.id !== 'starred-restaurants');

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Michelin Starred Restaurants 2026 - Sorrento and Amalfi Coast",
  "description": "The 2026 ranking of the best Michelin starred restaurants between the Sorrentine Peninsula and Amalfi Coast: Quattro Passi, Il Buco, Don Alfonso 1890 and more.",
  "url": "https://amalficoast-travel.com/en-us/experiences/starred-restaurants/",
  "numberOfItems": 8,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Quattro Passi - Nerano (3 Michelin Stars)" },
    { "@type": "ListItem", "position": 2, "name": "Il Buco - Sorrento" },
    { "@type": "ListItem", "position": 3, "name": "Lorelei - Sorrento" },
    { "@type": "ListItem", "position": 4, "name": "Terrazza Bosquet - Sorrento" },
    { "@type": "ListItem", "position": 5, "name": "Don Alfonso 1890 - Sant'Agata sui Due Golfi" },
    { "@type": "ListItem", "position": 6, "name": "La Caravella - Amalfi" },
    { "@type": "ListItem", "position": 7, "name": "Glicine - Positano" },
    { "@type": "ListItem", "position": 8, "name": "Zass e Li Galli - Positano" },
  ],
};
---

<BaseLayout
  title="Michelin Starred Restaurants Amalfi Coast 2026 | Michelin Guide"
  description="Guide to the best Michelin starred restaurants 2026 between Sorrento and the Amalfi Coast: Quattro Passi (3 stars), Il Buco, Don Alfonso 1890 and the gems of Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/stellati-hero.jpg"
      alt="Fine dining dish at a Michelin starred restaurant, Amalfi Coast"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Fine Dining · Amalfi Coast</p>
      <h1 class="font-serif text-display text-white mb-6">Starred Restaurants</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The Constellation of Taste 2026.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">A pilgrimage into the heart of gastronomic excellence</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            If there is a land where haute cuisine feels at home, it is the region embracing Sorrento and the Amalfi Coast. In 2026, the Michelin Guide confirms this territory as the brightest in Italy: Campania is not only at the top for the total number of stars, but holds a unique record for gastronomic density.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Consider that, despite being one of Italy's smallest regions by area, Campania is home to roughly <strong>12% of the starred restaurants on the entire Italian peninsula</strong>, surpassing in concentration per square kilometre such taste titans as Piedmont and Lombardy. In this tiny strip of land suspended above the sea, excellence in cuisine is not the exception but a genuine territorial calling.
          </p>
        </div>

        <!-- The 2026 ranking -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">The 2026 Ranking: The Stars</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            The 2026 gastronomic landscape sees the great names reconfirmed — the ones that have made this area a pilgrimage destination for foodies worldwide.
          </p>

          <div class="space-y-6">

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Quattro Passi — Nerano, Massa Lubrense</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">The Absolute Pinnacle</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                The legendary Quattro Passi in Nerano retains its prestigious 3 Michelin Stars, the only restaurant in the region to reach the world's summit. Its cuisine is a hymn to the purity of marine flavours reinterpreted with flawless technique.
              </p>
            </div>

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">The Stars of Sorrento</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">One city, three unmissable addresses</span>
                </div>
              </div>
              <div class="space-y-4 mt-4">
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Il Buco</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Set in an evocative former monastery ramp, where the building's history dialogues with territorial cuisine.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Lorelei</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Avant-garde cuisine on a breathtaking terrace: two sensory experiences in one.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Terrazza Bosquet</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Iconic temple of taste inside the Excelsior Vittoria: luxury, history and haute cuisine under one roof.</p>
                </div>
              </div>
            </div>

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Icons and New Discoveries</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">From Sant'Agata to Positano</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                You cannot claim to have experienced the Coast without mentioning <strong>Don Alfonso 1890</strong> in Sant'Agata sui Due Golfi, a pioneer of sustainability, or the gems of Amalfi and Positano: <strong>La Caravella</strong>, <strong>Glicine</strong>, <strong>Zass</strong> and <strong>Li Galli</strong>.
              </p>
            </div>

          </div>
        </div>

        <!-- Beyond the plate -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">An Experience Beyond the Plate</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Dining at a starred restaurant between Sorrento and Amalfi is not just a dinner but a sensory journey. It ranges from the architecture of the dishes to the obsessive care for "zero kilometre" ingredients from the vertical gardens dominating the coast. Here luxury meets the land: it is not uncommon to find humble ingredients such as anchovies or lemon transformed into masterpieces of high gastronomic engineering.
          </p>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Many of these great restaurants have historic cellars carved directly into the limestone or tufa rock. Even if you are not a sommelier, always ask to visit them: they are true underground museums preserving rare vintages of "heroic wines" produced on the terraced vineyards of Furore and Tramonti.
          </p>
          <p class="text-slate-600 leading-relaxed">
            A local secret? For the most celebrated restaurants on the Coast, weekend reservations must be made at least <strong>3–4 months in advance</strong>: the view is included, but the table must be earned!
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/en-us/experiences/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← All experiences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Other Experiences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Other Experiences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
