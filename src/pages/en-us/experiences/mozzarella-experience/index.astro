---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-en';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Experiences', url: '/en-us/experiences/' },
  { name: 'Mozzarella Experience', url: '/en-us/experiences/mozzarella-experience/' },
];

const facts = [
  { label: 'Duration', value: '3–4 hours' },
  { label: 'Area', value: 'Sorrentine Peninsula' },
  { label: 'Language', value: 'Italian, English' },
  { label: 'Included', value: 'Tasting, apron, recipes' },
  { label: 'Indicative price', value: 'from €65 per person' },
  { label: 'Ideal for', value: 'Couples, families, food lovers' },
];

const otherExperiences = experiences.filter(e => e.id !== 'mozzarella-experience');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Mozzarella Experience: The Art of the Cheesemaker",
  "description": "An authentic dairy experience on the Sorrentine Peninsula. Learn to make mozzarella and discover the legendary Provolone del Monaco DOP.",
  "location": {
    "@type": "Place",
    "name": "Sorrentine Peninsula",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Mozzarella Experience Sorrentine Peninsula 2026 | Art of the Cheesemaker"
  description="Learn to make mozzarella and discover Provolone del Monaco DOP with a master cheesemaker on the Sorrentine Peninsula."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/mozzarella-provolone-hero.jpg"
      alt="Provolone del Monaco DOP, Sorrentine Peninsula"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Food · Sorrentine Peninsula</p>
      <h1 class="font-serif text-display text-white mb-6">Mozzarella Experience</h1>
      <p class="text-lg md:text-xl font-light text-white/80">From stretchy curd to the aged treasure of the Monti Lattari.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">The Art of the Cheesemaker</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            On the Sorrentine Peninsula, the art of cheesemaking is a vocation passed down through centuries. Taking part in this experience does not just mean tasting — it means getting your hands on the raw material born from the unspoiled pastures of the Monti Lattari. From the immediate freshness of mozzarella to the complexity of Provolone del Monaco, we will reveal the secrets of Campanian dairy excellence.
          </p>
        </div>

        <!-- Editorial image -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/mozzarella-cagliata.jpg"
            alt="Fresh curd worked by the master cheesemaker"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Provolone del Monaco DOP: The Story Behind a Legendary Name</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            If mozzarella is the "queen", Provolone del Monaco is without doubt the undisputed "king" of our mountains. But why this unusual name?
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            The story goes back to the 1700s, when shepherds living on the Monti Lattari would descend at dawn towards the port of Naples to sell their products. To protect themselves from the moisture and cold of the night during the long sea journey, the cheesemakers wrapped themselves in heavy dark sackcloth cloaks, similar to a monk's habit. When they arrived at the Naples market, people began to call them familiarly "the monks" and, consequently, the exquisite cheese they brought with them became known to all as Provolone del Monaco.
          </p>

          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-4">A Rigorous Specification</h3>
          <p class="text-slate-600 text-lg leading-relaxed">
            Today this cheese is protected by the DOP mark. It is produced exclusively with cow's milk, of which at least 20% must come from the Agerolese breed, a prized and rare breed that gives the cheese a unique flavour: sweet and buttery at first, but with a spicy, aromatic finish that intensifies with ageing (which must last at least 6 months).
          </p>
        </div>

        <!-- Programme -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">What happens during a mozzarella experience</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Live Stretching</h4>
                <p class="text-slate-600 text-sm leading-relaxed">You will watch the master cheesemaker transform milk into braids and morsels right before your eyes.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Hands-On</h4>
                <p class="text-slate-600 text-sm leading-relaxed">You will have the chance to "mozzare" (cut and shape) fresh mozzarella with your own hands, feeling the warmth and texture of the stretchy curd.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Ageing Vertical Tasting</h4>
                <p class="text-slate-600 text-sm leading-relaxed">A guided tasting that starts from the freshest fior di latte and ends with Provolone del Monaco DOP, accompanied by local honey and Sorrento walnuts.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            When tasting Provolone del Monaco, look for the small holes (occhiature): they should be the size of a peppercorn. But the real secret is the pairing: try it with a glass of <strong>cold sparkling Gragnano</strong>. The bubbles cleanse the palate of the cheese's richness, enhancing the spicy note of the Agerolese.
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/experiences/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All experiences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Other Experiences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Other Experiences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
