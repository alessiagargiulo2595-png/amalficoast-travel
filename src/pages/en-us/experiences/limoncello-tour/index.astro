---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-en';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Experiences', url: '/en-us/experiences/' },
  { name: 'Limoncello Tour', url: '/en-us/experiences/limoncello-tour/' },
];

const facts = [
  { label: 'Duration', value: '2–3 hours' },
  { label: 'Area', value: 'Sorrentine Peninsula' },
  { label: 'Language', value: 'Italian, English' },
  { label: 'Included', value: 'Citrus grove visit, workshop, tasting' },
  { label: 'Indicative price', value: 'from €55 per person' },
  { label: 'Ideal for', value: 'Couples, families, food lovers' },
];

const otherExperiences = experiences.filter(e => e.id !== 'limoncello-tour');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Limoncello Tour: The Golden Liqueur and the Femminiello Legend",
  "description": "A sensory journey through the scents of the Sorrento IGP Lemon. Visit a historic citrus grove, infusion workshop and artisan Limoncello tasting.",
  "location": {
    "@type": "Place",
    "name": "Sorrentine Peninsula",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Limoncello Tour Sorrento 2026 | Femminiello IGP and Historic Citrus Grove"
  description="Visit a historic citrus grove on the Sorrentine Peninsula, discover the secret of the Femminiello IGP Lemon and learn to make artisan Limoncello. Tasting included."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/limoncello-mercato-hero.jpg"
      alt="Femminiello IGP lemons at the market, Sorrentine Peninsula"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Food · Sorrentine Peninsula</p>
      <h1 class="font-serif text-display text-white mb-6">Limoncello Tour</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The Golden Liqueur and the Legend of the Sorrento IGP Femminiello.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">A journey through the scents of the IGP Lemon</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Walking through a Sorrentine citrus grove is not just an agricultural tour — it is an immersion in a protected ecosystem where time seems to have stood still. Here reigns the Femminiello, the lemon variety that made Sorrento famous worldwide and that today holds the prestigious IGP (Protected Geographical Indication) mark.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">The History and the Name: A Thousand-Year Legacy</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            The name "Femminiello" comes from the extraordinary fertility of this plant, which flowers several times a year producing fruit with an almost "maternal" consistency. Its roots go back to Roman times — frescoes depicting it have even been found in the Pompeii excavations — but it was thanks to Jesuit monks in the 1600s that its cultivation spread widely.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            This lemon is unique for two fundamental reasons:
          </p>

          <div class="space-y-6">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">The Pergolas</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The plants grow under the typical "pagliarelle" (straw lattices) that protect the fruit from cold and wind, delaying ripening and allowing fresh lemons to be available all year round.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">The Volcanic Soil</h4>
              <p class="text-slate-600 text-sm leading-relaxed">The fertile peninsula soil, rich in minerals from the ancient Vesuvius eruptions, gives the Femminiello an acidic but balanced flavour and a peel extremely rich in essential oils.</p>
            </div>
          </div>
        </div>

        <!-- Editorial image -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/limoncello-femminiello.jpg"
            alt="Femminiello IGP Lemons hand-picked on the Sorrentine Peninsula"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">What makes the Femminiello special?</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Unlike the Sfusato Amalfitano — its Amalfi Coast "cousin", longer and larger — the Sorrento Femminiello has an elliptical shape and medium size. Its true magic lies in the peel: thick, intensely fragrant and rich in terpenes. It is precisely this yellow layer, the "zest", that — infused in pure alcohol — releases the unmistakable aroma of real Limoncello.
          </p>
        </div>

        <!-- Programme -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">What happens during a Limoncello Tour</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Guided walk under the pergolas</h4>
                <p class="text-slate-600 text-sm leading-relaxed">A stroll beneath the historic straw lattices with your guide recounting the story of the ancient lemon-growing families and the secrets of IGP cultivation.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Infusion workshop visit</h4>
                <p class="text-slate-600 text-sm leading-relaxed">You will discover every stage of artisan production: from selecting and scraping the zest to infusing in pure alcohol, through to blending with sugar syrup.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Tasting</h4>
                <p class="text-slate-600 text-sm leading-relaxed">A sip of iced Limoncello, lemon marmalade on toasted bread and the famous candied peel coated in dark chocolate.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Pay attention to the peel colour during the tour. A perfect Femminiello should have a brilliant citrine yellow. If you lightly rub the peel with your thumb and the scent lingers on your fingers for hours, you have found the gold of Sorrento. Another secret? Real Sorrentines also eat the white part (the albedo): it is sweet, spongy and packed with vitamins!
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/experiences/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All experiences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Other Experiences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Other Experiences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
