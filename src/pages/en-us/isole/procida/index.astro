---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Islands', url: '/en-us/isole/' },
  { name: 'Procida', url: '/en-us/isole/procida/' },
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Procida",
    "description": "Procida is the smallest and most authentic island in the Gulf of Naples: colourful houses at Marina Corricella, the medieval Terra Murata, Italian Capital of Culture 2022, and the beach made famous by The Postman film.",
    "url": "https://amalficoast-travel.com/en-us/isole/procida/",
    "touristType": ["Culture", "Authenticity", "Sea", "Literature"],
    "address": { "@type": "PostalAddress", "addressLocality": "Procida", "addressRegion": "Naples", "addressCountry": "IT", "postalCode": "80079" },
    "geo": { "@type": "GeoCoordinates", "latitude": 40.7620, "longitude": 14.0270 }
  },
  {
    "@context": "https://schema.org",
    "@type": "Place",
    "name": "Procida, Gulf of Naples",
    "geo": { "@type": "GeoCoordinates", "latitude": 40.7620, "longitude": 14.0270 },
    "containedInPlace": { "@type": "AdministrativeArea", "name": "Gulf of Naples" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you get to Procida from Naples?",
        "acceptedAnswer": { "@type": "Answer", "text": "From Naples Molo Beverello hydrofoils depart for Procida (~35 min, SNAV/Caremar). From Pozzuoli, Caremar ferries take ~15 min and are the cheapest and most frequent connection. In summer daily crossings are very numerous." }
      },
      {
        "@type": "Question",
        "name": "Why has Procida become famous?",
        "acceptedAnswer": { "@type": "Answer", "text": "Procida has always been loved by artists: Elsa Morante set her novel 'Arturo's Island' (1957) here, Massimo Troisi filmed 'The Postman' (Il Postino, 1994) on the island. International fame exploded in 2022 when it was named Italian Capital of Culture, bringing millions of tourists to discover it." }
      },
      {
        "@type": "Question",
        "name": "Is Marina Corricella worth visiting?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes, Marina Corricella is one of the most beautiful and photographed fishing villages in Italy: multi-coloured houses in yellow, orange, pink and blue facing directly onto the sea with no road for cars. Reachable on foot in 15 minutes from Marina Grande. The sunset from here is unforgettable." }
      },
      {
        "@type": "Question",
        "name": "Is Procida good for a day trip?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes, Procida is small (4.1 km²) and can comfortably be explored in a day. In one day you can visit Marina Grande, Marina Corricella, Terra Murata, Spiaggia del Pozzo Vecchio and La Chiaiolella. Ferries from Pozzuoli let you leave in the morning and return in the evening." }
      },
      {
        "@type": "Question",
        "name": "What is the best beach on Procida?",
        "acceptedAnswer": { "@type": "Answer", "text": "Spiaggia del Pozzo Vecchio (known as 'Arturo's Island beach' after the film) is the most famous and evocative. La Chiaiolella is the largest and best equipped. Spiaggia di Ciraccio is quieter. All Procida's beaches have very clear water thanks to the island's open position on the Tyrrhenian." }
      }
    ]
  }
];

const faqSchema = schemas[2];

const fastFacts = [
  { dt: 'Location',    dd: 'Gulf of Naples, NA' },
  { dt: 'Area',        dd: '4.1 km²' },
  { dt: 'Population',  dd: '~10,000 inhabitants' },
  { dt: 'Capital of Culture', dd: '2022' },
  { dt: 'From Naples', dd: '~35 min (hydrofoil)' },
  { dt: 'From Pozzuoli', dd: '~15 min (ferry)' },
  { dt: 'Beaches',     dd: 'Dark and light sand' },
  { dt: 'Best time',   dd: 'May–Jun / Sep–Oct' },
  { dt: 'Currency',    dd: 'Euro (€)' },
];

const tips = [
  'Take the ferry from Pozzuoli rather than Naples: cheaper, faster and less crowded.',
  'Rent a bike or scooter: Procida is small but walking everywhere in summer heat is tiring.',
  'Visit Marina Corricella around sunset: the play of light on the coloured houses is extraordinary.',
  'Try the langoustine (scampi): Procida is famous for its langoustines - any seafood restaurant will have them fresh.',
];
---

<BaseLayout
  title="Procida 2026: Complete Guide | Marina Corricella & The Postman Island"
  description="Complete guide to Procida: Marina Corricella, Terra Murata, Spiaggia del Pozzo Vecchio. How to get there from Naples and Pozzuoli, ferry timetables, what to see."
  lang={lang}
  pageKey="procida"
  breadcrumbs={breadcrumbs}
  schema={schemas}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/procida-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Island · Gulf of Naples · Italian Capital of Culture 2022</p>
        <h1 class="font-serif text-display text-white mb-4">Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          The smallest, most authentic and - many would say - most beautiful island in the Gulf of Naples. Procida has no luxury hotels, no designer boutiques, no famous caves. What it has is something rarer: a genuine fishing community, a palette of pastel colours that looks impossible, and a pace of life that has not changed in centuries.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Fast Facts
          </a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            How to Get Here
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <!-- Main Content -->
      <div class="space-y-16">

        <!-- Intro -->
        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            If Capri is the celebrity island and Ischia is the wellness island, Procida is the soul island. Only 4 km² in area, it is Italy's smallest inhabited island - and among its most moving. The writer Elsa Morante chose it as the setting for her masterpiece <em>Arturo's Island</em> (1957). Massimo Troisi filmed his last role here in <em>The Postman</em> (1994). In 2022 it was named Italian Capital of Culture.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            What makes Procida special is exactly what it lacks: no mass tourism infrastructure, no crowds of day-trippers from cruise ships, no international hotel chains. The island works on its own terms - langoustine fishing boats go out at dawn, children play in the alleys of Terra Murata, and the bars close when the last fisherman goes home.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Did You Know?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">4.1 km²</p>
              <p class="text-white/60 text-xs italic mt-1">Italy's smallest inhabited island</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1994</p>
              <p class="text-white/60 text-xs italic mt-1">Il Postino filmed here, Oscar for Best Score</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">2022</p>
              <p class="text-white/60 text-xs italic mt-1">Italian Capital of Culture</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Procida's langoustines (scampi di Procida) are considered among the finest in Italy. Local fishermen still go out in their boats every morning - look for restaurants serving "gamberi di paranza" straight from the morning catch.
          </p>
        </div>

        <!-- What to See -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">What to See on Procida</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Marina Corricella',
                text: 'The most beautiful fishing village in the Mediterranean: houses in yellow, orange, pink, blue and white stacked on a hillside, all facing the sea, with no road for vehicles. Reachable on foot in 15 minutes from Marina Grande. Boats, fishing nets, cats. Stay for the sunset.',
              },
              {
                n: 2,
                title: 'Terra Murata',
                text: 'The medieval fortified village at the top of the island (91 m), with the Abbey of San Michele Arcangelo and panoramic views over the entire Gulf of Naples. The old houses inside the walls are partly abandoned and partly inhabited - a uniquely atmospheric place. Free to visit.',
              },
              {
                n: 3,
                title: 'Spiaggia del Pozzo Vecchio',
                text: 'Known as the "Arturo\'s Island beach" after the Elsa Morante novel and the film. A small, photogenic cove with dark sand, clear water and a natural cave. Less crowded than La Chiaiolella. Reachable on foot from Marina Grande in 20 minutes.',
              },
              {
                n: 4,
                title: 'La Chiaiolella',
                text: 'Procida\'s largest and most equipped beach, at the western end of the island. Crescent-shaped, with light sand and warm shallow water suitable for families. Boat hire available. The village of Chiaiolella nearby has excellent restaurants and a lively evening atmosphere.',
              },
              {
                n: 5,
                title: 'Abbey of San Michele Arcangelo',
                text: 'The spiritual heart of the island, founded in the 11th century and rebuilt several times. Houses a collection of paintings by local artists, a 17th-century painted ceiling and catacombs. The view from the terrace over Terra Murata and the sea below is extraordinary. Entry ~€3.',
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to Get Here -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">How to Get to Procida</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Procida is the closest island to the mainland. The quickest option is the ferry from Pozzuoli (15 min). From Naples Beverello, hydrofoils take about 35 minutes.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">From Pozzuoli</h3><p class="text-white/50 text-sm leading-relaxed">Caremar ferry ~15 min. The cheapest and most convenient option - take Naples Metro Line 2 to Pozzuoli Solfatara, then walk 10 min to the port.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">From Naples</h3><p class="text-white/50 text-sm leading-relaxed">Hydrofoil ~35 min (SNAV, Caremar) from Molo Beverello. Multiple daily departures. Slightly more expensive than Pozzuoli but more convenient from the city centre.</p></div>
              </div>
            </div>
            <a href="/en-us/guide/ferries/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Full ferry guide
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Ferry Schedules -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Ferry Schedules - Summer 2026
          </h3>
          <p class="text-sm text-slate-500 mb-4">Services run year-round. In summer departures from both Pozzuoli and Naples are very frequent. Check caremar.it for current timetables.</p>

          <div class="overflow-x-auto rounded-2xl border border-slate-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Ferry - Pozzuoli → Marina Grande, Procida (Caremar, ~15 min)
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Departs Pozzuoli</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrives Procida</th>
                  <th class="text-left px-4 py-3 font-semibold">Duration</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['06:00', '06:15', '~15 min'],
                  ['07:30', '07:45', '~15 min'],
                  ['09:00', '09:15', '~15 min'],
                  ['11:00', '11:15', '~15 min'],
                  ['13:30', '13:45', '~15 min'],
                  ['16:00', '16:15', '~15 min'],
                  ['18:30', '18:45', '~15 min'],
                  ['20:00', '20:15', '~15 min'],
                ].map(([dep, arr, dur]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{dur}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Hydrofoil - Naples Beverello → Marina Grande, Procida (~35 min)
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Departs Naples</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrives Procida</th>
                  <th class="text-left px-4 py-3 font-semibold">Company</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['07:00', '07:35', 'SNAV'],
                  ['09:15', '09:50', 'Caremar'],
                  ['12:00', '12:35', 'SNAV'],
                  ['15:00', '15:35', 'Caremar'],
                  ['18:00', '18:35', 'SNAV'],
                ].map(([dep, arr, co]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{co}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Indicative schedules for summer 2026. Check caremar.it and snav.it to confirm current timetables.</p>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Procida Off the Beaten Path</h2>
          <p class="text-slate-500 mb-8">An island this authentic has no shortage of hidden moments.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Morning at the Fish Market', text: 'At 7 am at Marina Grande, fishermen unload their catch of the night. The fish market runs for about an hour. Watch the langoustines, totani squid and fresh fish being sold directly from the boat - a slice of genuine island life.' },
              { title: 'Via Vittorio Emanuele at Dusk', text: 'The main street of the island becomes a passeggiata at 7 pm. Locals come out to walk, children play, the bars fill. No tourists, no selfie sticks. Have a Spritz at a local bar and watch the community at its most authentic.' },
              { title: 'Spiaggia di Ciraccio', text: 'The quietest beach on the island, on the north-western coast. Darker sand, fewer people even in peak season, beautiful water. Reachable by scooter or on foot in 30 minutes from Marina Grande. Perfect for a morning swim before the crowds arrive.' },
              { title: 'Palazzo d\'Avalos', text: 'The former royal palace that became a prison in the 18th century and closed only in 1988. The building on the promontory is still partly derelict but the exterior with its views over the sea is deeply atmospheric. Restoration works are ongoing - check if guided tours have resumed.' },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Local Tip</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Order the langoustines</h3>
              <p class="text-white/70 leading-relaxed">Procida's scampi (langoustines) are famous throughout the Bay of Naples. Ask for "gamberi di Procida" or "scampi alla griglia" - any restaurant on the island will have them. The sweetest, freshest shellfish you will find anywhere on the coast, at about a third of the Capri price.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Frequently Asked Questions about Procida</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts - Procida</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Insider Tips</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Other Islands</p>
          <nav class="space-y-1">
            {[
              { href: '/en-us/isole/capri/', label: 'Capri' },
              { href: '/en-us/isole/ischia/', label: 'Ischia' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
