---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Islands', url: '/en-us/isole/' },
  { name: 'Ischia', url: '/en-us/isole/ischia/' },
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Ischia",
    "description": "Ischia is the largest volcanic island in the Gulf of Naples: natural thermal parks, the Aragonese Castle, Maronti Beach and Monte Epomeo make it the ideal destination for travellers seeking nature, relaxation and culture.",
    "url": "https://amalficoast-travel.com/en-us/isole/ischia/",
    "touristType": ["Spas", "Nature", "Culture", "Sea"],
    "address": { "@type": "PostalAddress", "addressLocality": "Ischia", "addressRegion": "Naples", "addressCountry": "IT", "postalCode": "80077" },
    "geo": { "@type": "GeoCoordinates", "latitude": 40.7300, "longitude": 13.9000 }
  },
  {
    "@context": "https://schema.org",
    "@type": "Place",
    "name": "Ischia, Gulf of Naples",
    "geo": { "@type": "GeoCoordinates", "latitude": 40.7300, "longitude": 13.9000 },
    "containedInPlace": { "@type": "AdministrativeArea", "name": "Gulf of Naples" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you get to Ischia from Naples?",
        "acceptedAnswer": { "@type": "Answer", "text": "From Naples Molo Beverello ferries (Caremar, Medmar, ~75 min) and hydrofoils (~50 min) depart throughout the day. From Pozzuoli, Caremar ferries take ~35 min and are the cheapest option. In summer, book your return ticket in advance, especially on Sundays." }
      },
      {
        "@type": "Question",
        "name": "Are the thermal parks on Ischia free?",
        "acceptedAnswer": { "@type": "Answer", "text": "Most thermal parks charge admission (€15–35 per person for a full day). The most famous are Negombo, Poseidon and Terme di Citara. There are also some free natural thermal springs, such as the thermal beach at Sant'Angelo where the sea is warmed by volcanic activity." }
      },
      {
        "@type": "Question",
        "name": "Is the Aragonese Castle on Ischia worth visiting?",
        "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. The Aragonese Castle is one of the best-preserved medieval castles in Italy, built on a rocky islet connected to the island by a bridge. Inside you will find a cathedral, a convent, monastic cells and a terrace with extraordinary views. Entry ~€12." }
      },
      {
        "@type": "Question",
        "name": "Is Ischia better than Capri?",
        "acceptedAnswer": { "@type": "Answer", "text": "It depends on your preferences. Capri is more glamorous, exclusive and expensive. Ischia is larger, greener, with natural spas, black sand beaches and a less elitist atmosphere. For families and those who love nature and relaxation, Ischia is often the better choice. For glamour and iconic views, Capri wins." }
      },
      {
        "@type": "Question",
        "name": "How many days do you need for Ischia?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ischia is large (46 km²) and deserves at least 2–3 days. With one day you can see Ischia Ponte, the Aragonese Castle and one thermal park. With 2 days, add Sant'Angelo, Maronti Beach and the Monte Epomeo hike." }
      }
    ]
  }
];

const faqSchema = schemas[2];

const fastFacts = [
  { dt: 'Location',    dd: 'Gulf of Naples, NA' },
  { dt: 'Area',        dd: '46.3 km²' },
  { dt: 'Population',  dd: '~62,000 inhabitants' },
  { dt: 'Volcano',     dd: 'Epomeo (789 m)' },
  { dt: 'From Naples', dd: '50–75 min' },
  { dt: 'From Pozzuoli', dd: '~35 min (ferry)' },
  { dt: 'Beaches',     dd: 'Dark volcanic sand' },
  { dt: 'Spas',        dd: 'Natural & spa parks' },
  { dt: 'Currency',    dd: 'Euro (€)' },
];

const tips = [
  'Book your thermal park in advance: Negombo and Poseidon sell out quickly in July and August.',
  'Rent a scooter or car to get around: local buses exist but are slow and crowded in summer.',
  'Visit Sant\'Angelo in the evening: this traffic-free village is at its most magical at sunset.',
  'Hike Monte Epomeo early morning (start by 7 am): the summit view is worth every step and you beat the heat.',
];
---

<BaseLayout
  title="Ischia 2026: Complete Guide | Thermal Parks, Castle & Beaches"
  description="Complete guide to Ischia: Aragonese Castle, thermal parks, Maronti Beach, Monte Epomeo. How to get there from Naples and Pozzuoli, ferry timetables, what to see."
  lang={lang}
  pageKey="ischia"
  breadcrumbs={breadcrumbs}
  schema={schemas}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/ischia-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Volcanic Island · Gulf of Naples · Natural Thermal Parks</p>
        <h1 class="font-serif text-display text-white mb-4">Ischia</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          The green island of the Gulf: volcanic in origin, rich in thermal springs, dense with history. Ischia offers a different experience from Capri - wilder, more authentic, with black sand beaches, a medieval castle perched on the sea, and the silence of Monte Epomeo at 789 metres.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Fast Facts
          </a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            How to Get Here
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <!-- Main Content -->
      <div class="space-y-16">

        <!-- Intro -->
        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Ischia is the largest of the three islands in the Gulf of Naples - and, to many travellers, the most rewarding to spend real time on. Unlike Capri, which exhausts itself in a day, Ischia rewards those who stay: a different thermal park each morning, a long lunch in a fishing village, a hike to a volcanic summit with views stretching to Vesuvius.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            The island has six municipalities, each with a distinct character: bustling Ischia Porto, medieval Ischia Ponte, laid-back Sant'Angelo, quiet Lacco Ameno. Getting a rental scooter or small car is the best way to explore them all.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Did You Know?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">100+</p>
              <p class="text-white/60 text-xs italic mt-1">natural thermal springs on the island</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">789 m</p>
              <p class="text-white/60 text-xs italic mt-1">altitude of Monte Epomeo, the volcanic peak</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">474 BC</p>
              <p class="text-white/60 text-xs italic mt-1">first Greek colony on the island (Pithecusa)</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            The name "Ischia" may derive from the Latin "Iscla" (island), or from the Greek word for the volcanic rock tuff that makes up much of the island. Ischia was the site of the first Greek colony in the western Mediterranean.
          </p>
        </div>

        <!-- What to See -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">What to See on Ischia</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Aragonese Castle (Castello Aragonese)',
                text: 'One of the best-preserved medieval castles in southern Italy, built on a rocky islet connected to Ischia Ponte by a stone bridge. Inside: a cathedral, an eerie monastic cemetery, gardens and a spectacular panoramic terrace. Entry ~€12. Allow 2–3 hours.',
              },
              {
                n: 2,
                title: 'Thermal Parks',
                text: 'Ischia\'s thermal parks are its greatest treasure. Negombo (Lacco Ameno) is the most beautiful, set in a botanical garden facing the sea. Poseidon (Forio) is the largest with 22 pools. Terme di Citara (Forio) is the most affordable. Book online at least a day in advance in summer.',
              },
              {
                n: 3,
                title: 'Monte Epomeo',
                text: 'The volcanic summit at 789 m offers a 360° view over the entire Gulf of Naples, Vesuvius and, on clear days, the Amalfi Coast. The hike from Fontana takes about 1.5 hours each way. The final stretch is steep but on a well-maintained mule track. A small café awaits at the top.',
              },
              {
                n: 4,
                title: 'Sant\'Angelo',
                text: 'A car-free fishing village on the southern coast, with colourful houses on a narrow promontory connected to the island by a sandy beach. The most atmospheric village on Ischia - have lunch by the water, explore the boutiques, and swim off the rocks below the promontory.',
              },
              {
                n: 5,
                title: 'Maronti Beach',
                text: 'Ischia\'s longest beach (almost 2 km) with dark volcanic sand and warm thermal water bubbling up from the ground in some spots. The eastern end near Sant\'Angelo is accessible only by water taxi (worth the few euros). Very popular in summer - arrive early.',
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to Get Here -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">How to Get to Ischia</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Ischia is accessible by ferry and hydrofoil from Naples (Beverello and Mergellina) and from Pozzuoli. The Pozzuoli option is often faster, cheaper and less crowded.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">From Naples</h3><p class="text-white/50 text-sm leading-relaxed">Ferry ~75 min (Caremar, Medmar) or hydrofoil ~50 min. Departs from Molo Beverello and Mergellina. Frequent daily services year-round.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">From Pozzuoli</h3><p class="text-white/50 text-sm leading-relaxed">Caremar ferry ~35 min. The most economical option - shorter crossing, lower fares and frequent departures. Recommended for day-trippers.</p></div>
              </div>
            </div>
            <a href="/en-us/guide/ferries/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Full ferry guide
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Ferry Schedules -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Ferry Schedules - Summer 2026
          </h3>
          <p class="text-sm text-slate-500 mb-4">Services run year-round from Naples and Pozzuoli. In summer departures increase significantly. Always check caremar.it and medmar.it for current timetables.</p>

          <div class="overflow-x-auto rounded-2xl border border-slate-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Ferry - Naples Beverello → Ischia Porto
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Departs Naples</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrives Ischia</th>
                  <th class="text-left px-4 py-3 font-semibold">Company</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['06:00', '07:15', 'Caremar'],
                  ['08:00', '09:15', 'Medmar'],
                  ['10:00', '11:15', 'Caremar'],
                  ['12:00', '13:15', 'Medmar'],
                  ['14:30', '15:45', 'Caremar'],
                  ['17:00', '18:15', 'Medmar'],
                  ['19:30', '20:45', 'Caremar'],
                ].map(([dep, arr, co]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{co}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Ferry - Pozzuoli → Ischia Porto (Caremar, ~35 min)
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Departs Pozzuoli</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrives Ischia</th>
                  <th class="text-left px-4 py-3 font-semibold">Duration</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['05:30', '06:05', '~35 min'],
                  ['08:00', '08:35', '~35 min'],
                  ['10:30', '11:05', '~35 min'],
                  ['13:00', '13:35', '~35 min'],
                  ['15:30', '16:05', '~35 min'],
                  ['18:00', '18:35', '~35 min'],
                  ['20:30', '21:05', '~35 min'],
                ].map(([dep, arr, dur]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{dur}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Indicative schedules for summer 2026. Check caremar.it and medmar.it to confirm current timetables.</p>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Lesser-Known Corners of Ischia</h2>
          <p class="text-slate-500 mb-8">Away from the main resorts, Ischia hides some extraordinary places.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'La Mortella Gardens', text: 'Created by composer William Walton and his wife Susana in 1956, this extraordinary botanical garden in Forio contains over 1,000 species of rare and exotic plants. One of Italy\'s finest private gardens. Entry ~€14. Open Tuesday to Sunday, April to November.' },
              { title: 'Spiaggia dei Pescatori (Ischia Ponte)', text: 'A small beach right next to the Aragonese Castle, used mainly by locals. Almost no tourists. The view of the castle from the water at sunset is spectacular. Free, small and often overlooked by the guidebooks.' },
              { title: 'Free Thermal Beach at Sant\'Angelo', text: 'Near the village of Sant\'Angelo, volcanic hot springs warm the seawater in a specific stretch of beach. You can enjoy a natural thermal bath for free - just bring a towel and avoid peak hours (before 9 am or after 5 pm).' },
              { title: 'Lacco Ameno and Villa Arbusto', text: 'The most elegant municipality on Ischia, with the famous Fungo (mushroom-shaped rock) in the sea and the Villa Arbusto museum, which houses the Pithecusa archaeological collection - finds from the earliest Greek colony in the western Mediterranean.' },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Local Tip</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Take the Pozzuoli ferry</h3>
              <p class="text-white/70 leading-relaxed">Most tourists take the ferry from Naples Beverello. The locals use Pozzuoli: the crossing is 35 minutes shorter, the ticket costs less and there are plenty of seats. From Naples, take the Metro Line 2 to Pozzuoli and you are at the port in 20 minutes.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Frequently Asked Questions about Ischia</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts - Ischia</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Insider Tips</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Other Islands</p>
          <nav class="space-y-1">
            {[
              { href: '/en-us/isole/capri/', label: 'Capri' },
              { href: '/en-us/isole/procida/', label: 'Procida' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
