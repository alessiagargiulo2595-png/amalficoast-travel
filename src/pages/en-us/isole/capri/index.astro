---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Islands', url: '/en-us/isole/' },
  { name: 'Capri', url: '/en-us/isole/capri/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Capri",
  "description": "Capri is the most famous island in the Gulf of Naples: the Blue Grotto, the Faraglioni sea stacks, the glamorous Piazzetta and the imperial villas of Augustus and Tiberius make it unique in the world.",
  "url": "https://amalficoast-travel.com/en-us/isole/capri/",
  "image": "https://amalficoast-travel.com/images/capri-hero.jpg",
  "touristType": ["Culture", "Luxury", "Sea", "Hiking"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "Naples",
    "addressCountry": "IT",
    "postalCode": "80073"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.5530,
    "longitude": 14.2270
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Capri, Gulf of Naples",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.5530,
    "longitude": 14.2270
  },
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Gulf of Naples"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you get to Capri from Naples?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "From Naples Molo Beverello you can reach Capri by ferry (~50 min, Caremar/SNAV) or hydrofoil (~40 min, NLG/Alilauro). From Sorrento the hydrofoil takes only 20–25 minutes. Buy tickets online or at the ticket office. In summer, book your return journey well in advance."
      }
    },
    {
      "@type": "Question",
      "name": "Can you take a car to Capri?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Capri has an almost total ban on private cars: only residents may bring vehicles. Tourists get around on foot, by local bus, open-air taxi or funicular. This is one of the reasons the island is so pleasant to visit."
      }
    },
    {
      "@type": "Question",
      "name": "How much does it cost to enter the Blue Grotto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Entrance to the Blue Grotto costs around €14 per person (includes the rowboat ride inside the cave). The boat from Marina Grande costs extra (~€15 return). In peak season queues can be 1–2 hours. Going early in the morning is strongly recommended."
      }
    },
    {
      "@type": "Question",
      "name": "Capri or Anacapri - which is better?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Capri (the main town) is more glamorous, with the Piazzetta and luxury shops. Anacapri, at the top of the island, is quieter and more authentic, with Villa San Michele and the chairlift to Monte Solaro. For a full day, visit both; for half a day, choose based on your style."
      }
    },
    {
      "@type": "Question",
      "name": "When is the best time to visit Capri?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "May, June and September are ideal: perfect weather, a warm sea and manageable crowds. July and August are very hot and overcrowded (daily visitor numbers exceed 10,000). April and October are quiet but some services are reduced."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Location',    dd: 'Gulf of Naples, NA' },
  { dt: 'Area',        dd: '10.4 km²' },
  { dt: 'Population',  dd: '~14,000 inhabitants' },
  { dt: 'Private cars',dd: 'Banned for tourists' },
  { dt: 'From Naples', dd: '40–50 min (hydrofoil/ferry)' },
  { dt: 'From Sorrento', dd: '20–25 min (hydrofoil)' },
  { dt: 'Beaches',     dd: 'Rocks and pebbles' },
  { dt: 'Best time',   dd: 'May–Jun / Sep' },
  { dt: 'Currency',    dd: 'Euro (€)' },
];

const tips = [
  'Take the first hydrofoil of the morning (7:00–8:00): you arrive before the crowds and find the Blue Grotto queue-free.',
  'Skip the taxi from the marina: take the funicular to Capri or the bus to Anacapri - it costs a tenth of the price.',
  'The Piazzetta is expensive but an aperitivo there is almost obligatory: pick a spot, sit down and enjoy the show.',
  'The Gardens of Augustus (entry ~€1) give you the Faraglioni postcard view - free before 10:00 am.',
];
---

<BaseLayout
  title="Capri 2026: Complete Guide | Blue Grotto, Faraglioni & Piazzetta"
  description="Complete guide to Capri: Blue Grotto, Faraglioni, Piazzetta, Villa San Michele, Monte Solaro. How to get there from Naples and Sorrento, ferry timetables, what to see."
  lang={lang}
  pageKey="capri"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, placeSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/capri-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Island · Gulf of Naples · No private cars</p>
        <h1 class="font-serif text-display text-white mb-4">Capri</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          A limestone island rising from the Tyrrhenian with unsurpassed visual force. The Blue Grotto illuminating the water in electric blue, the Faraglioni sea stacks soaring from the sea, the Piazzetta where the world has kept its appointment for a century. Capri never disappoints.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Fast Facts
          </a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            How to Get Here
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <!-- Main Content -->
      <div class="space-y-16">

        <!-- Intro -->
        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Capri is probably Italy's most famous island. Roman emperors, 20th-century intellectuals, Hollywood stars - all have surrendered to its charm. It is not a cheap destination, it is not a quiet destination in summer - but it is an experience that stays with you.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            The island is divided into two municipalities: Capri (below, more glamorous) and Anacapri (above, quieter). Marina Grande is the main port. From there, funicular or taxi whisk you to the centre in minutes. Without cars, you move on foot, by bus or open-air taxi - which contributes enormously to the charm of the place.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Did You Know?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">27 BC</p>
              <p class="text-white/60 text-xs italic mt-1">Augustus bought Capri from Naples</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">12</p>
              <p class="text-white/60 text-xs italic mt-1">Roman imperial villas on the island</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">10,000+</p>
              <p class="text-white/60 text-xs italic mt-1">visitors per day in August</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            The Blue Grotto was already known to the Romans as "Tiberius's bath". It was rediscovered by European artists in 1826 and has since become one of Italy's most visited attractions.
          </p>
        </div>

        <!-- What to See -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">What to See in Capri</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Blue Grotto (Grotta Azzurra)',
                text: 'The most famous sea cave in the Mediterranean: sunlight filters through a submerged opening and illuminates the water in an unreal electric blue. You enter lying flat in tiny rowboats. Entry ~€14. Reachable by boat from Marina Grande or on foot (then by boat). Avoid in rough seas.',
              },
              {
                n: 2,
                title: 'The Faraglioni',
                text: 'The three great rocks rising from the sea to the east of the island are the absolute symbol of Capri. Admire them from the Gardens of Augustus, the Punta Tragara belvedere, or up close on a boat tour. The boat passes through the natural arch of the middle Faraglione - an unforgettable moment.',
              },
              {
                n: 3,
                title: 'The Piazzetta (Piazza Umberto I)',
                text: 'The drawing room of the world: four café terraces, the clock tower, the steps of Santo Stefano church. An aperitivo here is pricey (~€8–12) but sitting at the Piazzetta is a rite of passage. It comes alive even more in the evening.',
              },
              {
                n: 4,
                title: 'Villa San Michele (Anacapri)',
                text: 'Built by Swedish physician Axel Munthe in the late 1800s on the ruins of a Tiberius villa, it is one of Italy\'s most romantic gardens. The view over the coast and the Gulf of Naples from the belvedere is extraordinary. Entry ~€8. Open all year.',
              },
              {
                n: 5,
                title: 'Monte Solaro (Anacapri)',
                text: 'The island\'s highest peak (589 m) reachable by chairlift from Anacapri (~15 min, ~€12 return). 360° panorama over Capri, Ischia, Procida, the coast and Vesuvius. At the top: absolute silence, a café and the Sanctuary of the Madonna del Soccorso. Not to be missed.',
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to Get Here -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">How to Get to Capri</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Capri has no bridge or airport. The only way to arrive is by sea - ferry or hydrofoil from Naples, Sorrento, Positano and Amalfi (the latter two seasonal).</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">From Naples</h3><p class="text-white/50 text-sm leading-relaxed">Hydrofoil ~40 min (NLG, Alilauro) or ferry ~50 min (Caremar, SNAV) from Molo Beverello. Multiple departures daily, year-round.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">From Sorrento</h3><p class="text-white/50 text-sm leading-relaxed">Hydrofoil only ~20–25 min. The fastest and most convenient option if you're already on the Sorrentine Peninsula.</p></div>
              </div>
            </div>
            <a href="/en-us/guide/ferries/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Full ferry guide
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Ferry Schedules -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Hydrofoil Schedules - Summer 2026
          </h3>
          <p class="text-sm text-slate-500 mb-4">Services operate year-round from Naples; Sorrento routes are frequent in summer. Always verify on official company websites.</p>

          <div class="overflow-x-auto rounded-2xl border border-slate-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Hydrofoils - Naples Beverello → Marina Grande, Capri
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Departs Naples</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrives Capri</th>
                  <th class="text-left px-4 py-3 font-semibold">Company</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['07:15', '07:55', 'NLG'],
                  ['08:00', '08:40', 'Alilauro'],
                  ['09:15', '09:55', 'NLG'],
                  ['10:30', '11:10', 'SNAV'],
                  ['12:00', '12:40', 'NLG'],
                  ['14:30', '15:10', 'Alilauro'],
                  ['16:00', '16:40', 'NLG'],
                ].map(([dep, arr, co]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{co}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Hydrofoils - Sorrento → Marina Grande, Capri
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Departs Sorrento</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrives Capri</th>
                  <th class="text-left px-4 py-3 font-semibold">Duration</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['08:00', '08:25', '~25 min'],
                  ['09:30', '09:55', '~25 min'],
                  ['11:00', '11:25', '~25 min'],
                  ['13:30', '13:55', '~25 min'],
                  ['15:30', '15:55', '~25 min'],
                  ['17:30', '17:55', '~25 min'],
                ].map(([dep, arr, dur]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{dur}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Indicative schedules for summer 2026. Check nlg.it, alilauro.it, snav.it to confirm.</p>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Hidden Corners of Capri</h2>
          <p class="text-slate-500 mb-8">Beyond the postcards: four spots the passing tourist never finds.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Arco Naturale', text: 'A limestone arch 185 m above the sea, reachable on foot from central Capri in 40 minutes. Almost no queues, spectacular views over the eastern sea. The path passes by Villa Malaparte (photographable from outside).' },
              { title: 'Punta Cannone Belvedere', text: 'A little-known belvedere behind the Certosa di San Giacomo with a direct view of the Faraglioni. Free, no queues, reachable on foot in 10 minutes from the Piazzetta. The Faraglioni photo from here beats the Gardens of Augustus shot.' },
              { title: 'Grotta di Matromania', text: 'An ancient cave sacred to the nymphs, later converted into a Roman nymphaeum. Reachable on foot from Arco Naturale in 15 minutes. Almost no tourists. Nearby is Villa Malaparte, the iconic red house on the cliff.' },
              { title: 'Bagni di Tiberio', text: 'The remains of Tiberius\'s maritime villa on the north shore of Capri, reachable by boat from Marina Grande or on foot in 20 minutes. Free entry. In the nearby bay you can swim in exceptionally clear water.' },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Local Tip</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">How to beat the crowds on Capri</h3>
              <p class="text-white/70 leading-relaxed">Take the very first hydrofoil (7:00–7:30 am). By 8:30 you are already at the Blue Grotto with no queue. By the time the day-trippers pour in at 10:00 am, you will have already seen the island's best before heading to Anacapri for lunch in total peace.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Frequently Asked Questions about Capri</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <!-- Fast Facts -->
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts - Capri</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Insider Tips -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Insider Tips</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Quick Links -->
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Other Islands</p>
          <nav class="space-y-1">
