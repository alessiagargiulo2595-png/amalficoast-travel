---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Travel Guide', url: '/en-us/guide/' },
  { name: 'SITA Bus', url: '/en-us/guide/sita-bus/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does the SITA bus work on the Amalfi Coast?",
      "acceptedAnswer": { "@type": "Answer", "text": "The SITA bus (now SITA Sud, operated by EAV) runs along the SS163 between Sorrento and Salerno, stopping at Positano, Praiano, Amalfi, Maiori and Minori. Tickets must be purchased before boarding at a tobacconist or newsagent - they are not sold on the bus. Cost: ~€2.50–4 per journey." }
    },
    {
      "@type": "Question",
      "name": "How long does the bus take from Sorrento to Amalfi?",
      "acceptedAnswer": { "@type": "Answer", "text": "In normal conditions: 90–100 min. In summer (July–August) it can stretch to 2–2.5 hours due to traffic on the SS163. The Amalfi–Positano leg is about 45–50 min; Amalfi–Ravello ~25 min (different bus, SITA to Ravello)." }
    },
    {
      "@type": "Question",
      "name": "Can I bring large luggage on the SITA bus?",
      "acceptedAnswer": { "@type": "Answer", "text": "SITA buses on the SS163 are small (they need to navigate the tight bends). In summer they are packed. Large suitcases are difficult to manage: use a compact wheeled bag or backpack. Trolleys can go in the front luggage area if available." }
    }
  ]
};
---

<BaseLayout
  title="SITA Bus Amalfi Coast 2026 | Sorrento–Positano–Amalfi Timetable"
  description="How to use the SITA bus on the Amalfi Coast: Sorrento–Positano–Amalfi–Salerno route along the SS163. Schedules, prices, where to buy tickets and practical tips."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/bus-sita-hero.jpg" alt="SITA bus on the coastal road" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/60">Travel Guide</span>
        <span>/</span>
        <span class="text-white">SITA Bus</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Travel Guide</p>
        <h1 class="font-serif text-display text-white mb-4">SITA Bus - SS163</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          The most used (and slowest) transport on the Coast: the SITA bus runs along the SS163 between Sorrento and Salerno, stopping at every village. Cheap, scenic, often crowded. Here's everything you need to know.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <p class="text-xl leading-relaxed text-charcoal">
        The SS163 Amalfitana is one of the most spectacular and challenging roads in Europe: 40 km of bends, tunnels and viaducts between Vietri sul Mare and Positano. The SITA bus runs it daily, year-round, with extra services in summer.
      </p>
      <p class="mt-4 text-slate-600 leading-relaxed">
        Tickets are not sold on the bus - buy them in advance at a tobacconist, newsagent or bar displaying the SITA/EAV sign. Without a ticket, the driver won't let you on. In summer, buses fill up fast: consider leaving early in the morning.
      </p>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Main timetables (indicative)</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="overflow-x-auto rounded-2xl border border-slate-200">
          <table class="w-full text-sm">
            <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Sorrento → Amalfi (via Positano, Praiano)</caption>
            <thead>
              <tr class="bg-med-blue/5 text-charcoal">
                <th class="text-left px-4 py-3 font-semibold">Sorrento</th>
                <th class="text-left px-4 py-3 font-semibold">Positano</th>
                <th class="text-left px-4 py-3 font-semibold">Amalfi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {[['06:25','07:30','08:20'],['08:30','09:35','10:25'],['09:30','10:35','11:25'],['11:00','12:05','12:55'],['14:00','15:05','15:55'],['16:30','17:35','18:25'],['18:00','19:05','19:55']].map(([s,p,a]) => (
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-2.5 font-mono">{s}</td>
                  <td class="px-4 py-2.5 font-mono">{p}</td>
                  <td class="px-4 py-2.5 font-mono">{a}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <div class="overflow-x-auto rounded-2xl border border-slate-200">
          <table class="w-full text-sm">
            <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Amalfi → Sorrento (via Positano)</caption>
            <thead>
              <tr class="bg-med-blue/5 text-charcoal">
                <th class="text-left px-4 py-3 font-semibold">Amalfi</th>
                <th class="text-left px-4 py-3 font-semibold">Positano</th>
                <th class="text-left px-4 py-3 font-semibold">Sorrento</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {[['07:00','07:50','08:55'],['09:00','09:50','10:55'],['10:30','11:20','12:25'],['13:00','13:50','14:55'],['15:30','16:20','17:25'],['17:30','18:20','19:25'],['19:00','19:50','20:55']].map(([a,p,s]) => (
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-2.5 font-mono">{a}</td>
                  <td class="px-4 py-2.5 font-mono">{p}</td>
                  <td class="px-4 py-2.5 font-mono">{s}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      <p class="text-xs text-slate-400 mt-2">* Indicative summer 2026 timetable. Check sitasudtrasporti.it or eavsrl.it for the official updated schedule.</p>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Prices and how to buy tickets</h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-med-blue/5 text-charcoal">
              <th class="text-left px-4 py-3 font-semibold">Route</th>
              <th class="text-left px-4 py-3 font-semibold">Indicative price</th>
              <th class="text-left px-4 py-3 font-semibold">Duration</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {[
              ['Sorrento → Positano', '~€2.50', '~50 min'],
              ['Sorrento → Amalfi', '~€3.50', '~90 min'],
              ['Amalfi → Ravello (local bus)', '~€1.50', '~25 min'],
              ['Amalfi → Salerno (via SS163)', '~€2.80', '~60 min'],
              ['Day ticket (Amalfi Coast zone)', '~€7.50', 'Unlimited'],
            ].map(([t,p,d]) => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3">{t}</td>
                <td class="px-4 py-3 font-mono">{p}</td>
                <td class="px-4 py-3 text-slate-500">{d}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Practical tips for the SITA bus</p>
      <ul class="space-y-2">
        {[
          'Buy your ticket BEFORE boarding: at a tobacconist, bar or newsagent. Not available on the bus.',
          'In summer the 9:00 bus from Sorrento to Positano is already full - take the 7:30 one or wait until 10:30.',
          'The bus stops at many points along the SS163: if you\'re unsure where to get off, ask the driver.',
          'The right side of the bus (coming from Sorrento) has the best sea views.',
          'Don\'t expect punctuality: traffic on the SS163 is unpredictable. Always allow 30 min buffer.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Frequently asked questions</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
