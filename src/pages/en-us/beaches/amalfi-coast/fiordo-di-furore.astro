---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Amalfi Coast', url: '/en-us/beaches#amalfi-coast' },
  { name: 'Fiordo di Furore', url: '/en-us/beaches/amalfi-coast/fiordo-di-furore' },
];

const facts = [
  { label: 'Surface', value: 'Pebbles' },
  { label: 'Access', value: 'Steps (~200)' },
  { label: 'Shade', value: 'From 14:30 ⚠️' },
  { label: 'Facilities', value: 'Free public beach' },
  { label: 'Best for', value: 'Photography, couples' },
];

const logistica = [
  { transport: 'SITA Bus', stop: 'Furore Fiordo', notes: 'Amalfi–Positano line' },
  { transport: 'Scooter', stop: 'Ponte Furore', notes: 'Limited roadside parking' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Fiordo di Furore",
  "description": "An iconic beach set inside a natural fjord with crystal-clear waters and a monumental 30-metre bridge overhead.",
  "image": "https://amalficoast-travel.com/images/fiordo-furore.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6122",
    "longitude": "14.5534"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Furore",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "publicAccess": "true",
  "amenityFeature": {
    "@type": "LocationFeatureSpecification",
    "name": "Shade Window",
    "value": "From 14:30"
  }
};
---

<BaseLayout
  title="Fiordo di Furore 2026: Guide, Access & Sun Hours"
  description="How to visit Fiordo di Furore in 2026. When the sun reaches the beach, how to get there by bus, and tips for the perfect shot."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/fiordo-furore-hero.jpg"
      alt="Fiordo di Furore, Amalfi Coast"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfi Coast</p>
      <h1 class="font-serif text-display text-white mb-6">Fiordo di Furore</h1>
      <p class="text-lg md:text-xl font-light text-white/80">A masterpiece of nature carved into the rock.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">An Icon of the Amalfi Coast</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Fiordo di Furore is one of the most iconic images in Italy. Not a traditional beach, but a deep natural rift where the sea creeps beneath a monumental 30-metre bridge. In 2026 access is regulated to protect the site: the beach is small and the water is usually cooler than on the open coast.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            A paradise for photographers — but watch the light: the sun illuminates the floor of the fjord only in the middle of the day. Arrive between 11:00 and 13:00 for the best shots. Diving off the bridge is a local tradition but is forbidden to tourists: enjoy the view from above before descending the 200 steps to the beach.
          </p>
        </div>

        <!-- Shade Alert -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Shade Alert</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Sunlight reaches the beach only between <strong>11:00 and 14:30</strong>. Before and after that window the fjord is in full shade. Plan your visit accordingly if you want sun for swimming. For perfect turquoise-water photos, aim for around 11:30.
          </p>
        </div>

        <!-- Getting there -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="overflow-hidden rounded-[2rem] border border-slate-100 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-charcoal text-white">
                  <th class="text-left p-4 font-medium">Transport</th>
                  <th class="text-left p-4 font-medium">Stop</th>
                  <th class="text-left p-4 font-medium">Notes</th>
                </tr>
              </thead>
              <tbody>
                {logistica.map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                    <td class="p-4 font-medium text-slate-900">{row.transport}</td>
                    <td class="p-4 text-slate-600">{row.stop}</td>
                    <td class="p-4 text-slate-500">{row.notes}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Discover more Amalfi Coast beaches</h2>
      <a
        href="/en-us/beaches"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Complete beach guide
      </a>
    </div>
  </section>

</BaseLayout>
