---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Amalfi Coast', url: '/en-us/beaches#amalfi-coast' },
  { name: 'Marina di Praia', url: '/en-us/beaches/amalfi-coast/marina-di-praia' },
];

const facts = [
  { label: 'Surface', value: 'Pebbles and rock' },
  { label: 'Access', value: 'By boat or hiking trail' },
  { label: 'Shade', value: 'Minimal (exposed)' },
  { label: 'Atmosphere', value: 'Wild, secluded' },
  { label: 'Best for', value: 'Adventure seekers, hiking' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina di Praia",
  "description": "A wild, hidden beach accessible only by boat or hiking trail. Untouched, dramatic cliffs, and crystal waters for snorkeling.",
  "image": "https://amalficoast-travel.com/images/marina-di-praia.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5967",
    "longitude": "14.4883"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina di Praia 2026: Hidden Beach Guide & How to Get There"
  description="Marina di Praia is a wild, secret beach between Positano and Praiano. Guide to access by boat, hiking trail, and what to expect."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-di-praia.jpg"
      alt="Marina di Praia, Amalfi Coast"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfi Coast · Hidden Gems</p>
      <h1 class="font-serif text-display text-white mb-6">Marina di Praia</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The wild beach between Positano and Praiano, untouched by mass tourism.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">The Wild Secret of the Amalfi Coast</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina di Praia is a small, dramatic beach tucked beneath towering cliffs between Positano and Praiano. No road leads here—access is by sea or a challenging hiking trail. This isolation has preserved it as one of the last truly untouched beaches on the coast.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            The beach is mostly pebbles and small rocks, with a few sandy patches. Crystal-clear water and excellent snorkeling make it a destination for adventurous swimmers. The cliffs above are sheer and dramatic, offering unforgettable views and excellent photo opportunities.
          </p>
        </div>

        <!-- How to Access -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">By Boat ⭐</p>
              <p class="text-slate-700 font-medium mb-1">From Positano or Praiano</p>
              <p class="text-slate-500 text-sm">Water taxi or rental boat. Most reliable option. €20-30 return.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Hiking Trail</p>
              <p class="text-slate-700 font-medium mb-1">45 minutes from Praiano</p>
              <p class="text-slate-500 text-sm">Steep descent. Proper footwear essential. Not for everyone.</p>
            </div>
          </div>
        </div>

        <!-- Why Visit -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Why It's Special</h3>
          <div class="space-y-4 text-slate-600">
            <p class="leading-relaxed">
              <strong>Untouched:</strong> No beach clubs, no crowds, no commercialization. Just nature and the sea.
            </p>
            <p class="leading-relaxed">
              <strong>Snorkeling:</strong> The water is so clear you can see 15+ meters down. Colorful fish, sea urchins, and interesting rock formations.
            </p>
            <p class="leading-relaxed">
              <strong>Photography:</strong> The drama of the cliffs combined with turquoise water creates stunning images.
            </p>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Discover more Amalfi Coast beaches</h2>
      <a
        href="/en-us/beaches"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Complete beach guide
      </a>
    </div>
  </section>

</BaseLayout>
