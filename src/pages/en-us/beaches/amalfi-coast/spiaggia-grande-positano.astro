---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Amalfi Coast', url: '/en-us/beaches#amalfi-coast' },
  { name: 'Spiaggia Grande Positano', url: '/en-us/beaches/amalfi-coast/spiaggia-grande-positano' },
];

const facts = [
  { label: 'Surface', value: 'Sand & pebbles' },
  { label: 'Access', value: 'Easy (flat)' },
  { label: 'Shade', value: 'From 17:30' },
  { label: 'Facilities', value: 'Luxury beach clubs, restaurants, pier' },
  { label: 'Best for', value: 'Atmosphere, glamour, VIP-watching' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia Grande di Positano",
  "description": "The main beach of Positano, heart of the glamorous social scene and luxury beach clubs of the Amalfi Coast.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6273",
    "longitude": "14.4849"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Positano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Restaurants", "value": "Yes" },
    { "@type": "LocationFeatureSpecification", "name": "Beach Club", "value": "Yes" }
  ]
};
---

<BaseLayout
  title="Spiaggia Grande Positano 2026: Beach Clubs & Prices"
  description="Experience the heart of Positano. 2026 sun-lounger prices, restaurants, and how to reach Spiaggia Grande by sea."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-grande-positano.jpg"
      alt="Spiaggia Grande di Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Positano · Amalfi Coast</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia Grande</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The glamorous heart of the Amalfi Coast.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">The Glamour of the Coast</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Spiaggia Grande is the social centre of Positano. With the vertical town rising behind it — pastel-coloured houses climbing up to the church of Santa Maria Assunta — the setting is unlike anywhere else in the world. In 2026, beach clubs require reservations weeks in advance during peak season.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            It is also the departure point for all taxi-boats heading to secluded coves along the coast. If you want the perfect combination of comfort, signature cocktails, and an exclusive atmosphere, this is your beach. The free public section, to the east, fills up quickly after 9 am.
          </p>
        </div>

        <!-- Prices box -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
            <h3 class="text-xl font-bold text-slate-900">2026 Prices</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            A sun-lounger plus umbrella at the Spiaggia Grande beach clubs costs on average <strong>€35–€60 per person</strong>. Seafront restaurants (La Buca di Bacco, La Scalinatella) include an umbrella service with lunch.
          </p>
          <p class="text-slate-600 leading-relaxed">
            <strong>Parking</strong> in central Positano is strongly discouraged: arrive by ferry from Amalfi or Sorrento, or by SITA bus — alight at the Sponda stop.
          </p>
        </div>

        <!-- Getting there -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">By Sea ⭐ Recommended</p>
              <p class="text-slate-700 font-medium mb-1">Ferry from Amalfi or Sorrento</p>
              <p class="text-slate-500 text-sm">Lands directly on the beach. Enjoy the panorama from the water.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">SITA Bus</p>
              <p class="text-slate-700 font-medium mb-1">Sponda stop</p>
              <p class="text-slate-500 text-sm">Steep stairway down to the beach (about 10 min on foot).</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Discover more Amalfi Coast beaches</h2>
      <a
        href="/en-us/beaches"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Complete beach guide
      </a>
    </div>
  </section>

</BaseLayout>
