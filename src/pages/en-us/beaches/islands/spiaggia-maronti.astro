---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Gulf Islands', url: '/en-us/beaches#islands' },
  { name: 'Spiaggia dei Maronti', url: '/en-us/beaches/islands/spiaggia-maronti' },
];

const facts = [
  { label: 'Surface', value: 'Volcanic sand' },
  { label: 'Length', value: '3 km (longest on the island)' },
  { label: 'Special', value: 'Natural hot fumaroles' },
  { label: 'Shade', value: 'From 19:00' },
  { label: 'Best for', value: 'Natural spa, families, relaxation' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia dei Maronti",
  "description": "Ischia's volcanic beach - the longest on the island at 3 km - famous for natural hot fumaroles and underground thermal springs.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Barano d'Ischia",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia dei Maronti Ischia 2026: Fumaroles & Hot Sand"
  description="Maronti is Ischia's longest beach (3 km) with natural thermal fumaroles. 2026 guide: how to get there, what to expect, practical tips."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-maronti-ischia.jpg"
      alt="Spiaggia dei Maronti, Ischia"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Ischia · Gulf Islands</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia dei Maronti</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Three kilometres of warm sand heated from below by the volcano.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Natural Thermal Wellness</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Maronti offers a one-of-a-kind experience in Italy. The beach is vast - three kilometres of dark volcanic sand - and the sand itself is warmed by volcanic heat through the ground via <strong>fumaroles</strong>: jets of hot steam that emerge from the sand, reaching temperatures above 60 °C in some spots.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Perfect for walkers and anyone wanting to escape the bustle of the ports. The sheer length means even in August you can always find a quiet corner. The water is calm and ideal for families with young children.
          </p>
        </div>

        <!-- Fumaroles box -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3z"/></svg>
            <h3 class="text-xl font-bold text-slate-900">The Fumaroles</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            The fumaroles are located in the central section of the beach (Fumarole Beach area). You can bury your feet in the warm sand for a free natural thermal effect. <strong>Do not get too close to the steam vents</strong>: temperatures can be very high. Children must be supervised in this area.
          </p>
        </div>

        <!-- Getting there -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Line 5</p>
              <p class="text-slate-700 font-medium mb-1">From Ischia Porto</p>
              <p class="text-slate-500 text-sm">Alight at Barano. Then downhill path to the beach (15 min).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat ⭐</p>
              <p class="text-slate-700 font-medium mb-1">From Sant'Angelo</p>
              <p class="text-slate-500 text-sm">5 minutes by boat. Scenic and convenient. Direct landing on the beach.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Discover everything about Ischia</h2>
      <a
        href="/en-us/islands/ischia/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Complete Ischia guide
      </a>
    </div>
  </section>

</BaseLayout>
