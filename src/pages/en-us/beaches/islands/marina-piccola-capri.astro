---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Gulf Islands', url: '/en-us/beaches#islands' },
  { name: 'Marina Piccola Capri', url: '/en-us/beaches/islands/marina-piccola-capri' },
];

const facts = [
  { label: 'Surface', value: 'Pebbles & rock' },
  { label: 'Access', value: 'Bus or steps (Via Mulo)' },
  { label: 'Shade', value: 'From 16:00 ⚠️' },
  { label: 'View', value: 'Faraglioni (best on the island)' },
  { label: 'Best for', value: 'Exclusive clubs, photography, snorkelling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina Piccola Capri",
  "description": "Capri's most famous beach, offering the closest and most dramatic view of the Faraglioni. Exclusive clubs and sheltered waters.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5456",
    "longitude": "14.2344"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina Piccola Capri 2026: Guide to the Faraglioni Beach"
  description="Marina Piccola is Capri's most famous bay. 2026 guide with club prices, how to get there, and the best view of the Faraglioni."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-piccola-capri.jpg"
      alt="Marina Piccola, Capri, with the Faraglioni in the background"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Capri · Gulf Islands</p>
      <h1 class="font-serif text-display text-white mb-6">Marina Piccola</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The Faraglioni feel close enough to touch.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">The Legend of Capri</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina Piccola is the sheltered bay where Capri's most famous beach clubs are found. From here, the Faraglioni — the three iconic rocks rising from the sea — look close enough to touch: this is the island's most dramatic and most photographed view.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            In 2026 free public beach space is minimal, so booking at a club such as <strong>La Canzone del Mare</strong> (the most historic, founded in 1932 by Gracie Fields) is strongly recommended. The water is sheltered and ideal for snorkelling.
          </p>
        </div>

        <!-- Shade Alert -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Shade Alert</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Marina Piccola falls into shade <strong>from around 16:00</strong>, because of the mountains that surround it. If you want afternoon sun, consider Marina Grande beach or the clubs on the other side of the island. Morning and early afternoon are the best times.
          </p>
        </div>

        <!-- Getting there -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Orange Bus ⭐</p>
              <p class="text-slate-700 font-medium mb-1">From Capri town centre</p>
              <p class="text-slate-500 text-sm">Direct Marina Piccola line. Cheap and frequent.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">On foot via Via Mulo</p>
              <p class="text-slate-700 font-medium mb-1">15-minute descent</p>
              <p class="text-slate-500 text-sm">Scenic. You enjoy the island's landscape throughout.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Discover everything about Capri</h2>
      <a
        href="/en-us/islands/capri/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Complete Capri guide
      </a>
    </div>
  </section>

</BaseLayout>
