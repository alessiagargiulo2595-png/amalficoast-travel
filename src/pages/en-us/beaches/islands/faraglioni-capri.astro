---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Islands of the Bay', url: '/en-us/beaches#islands' },
  { name: 'Faraglioni di Capri', url: '/en-us/beaches/islands/faraglioni-capri' },
];

const facts = [
  { label: 'Type', value: 'Rock formations (no beach)' },
  { label: 'Access', value: 'By boat only' },
  { label: 'Featured in', value: 'Italian films & legend' },
  { label: 'Atmosphere', value: 'Iconic, dramatic' },
  { label: 'Best for', value: 'Photography, swimming' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Faraglioni di Capri",
  "description": "Three iconic rock formations rising 109 meters from the sea. A symbol of Capri and featured in famous Italian films. Accessible by boat for swimming and diving.",
  "image": "https://amalficoast-travel.com/images/faraglioni-capri.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5447",
    "longitude": "14.2277"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Faraglioni di Capri 2026: Iconic Rocks & Swimming Guide"
  description="The Faraglioni are three massive rock formations off the coast of Capri. An Italian icon, featured in films. Guide to visiting by boat and what to expect."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/faraglioni-capri.jpg"
      alt="Faraglioni di Capri, Islands of the Bay"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Islands of the Bay · Italian Icon</p>
      <h1 class="font-serif text-display text-white mb-6">Faraglioni di Capri</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Three legendary rock formations that have captivated visitors for centuries.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Legend in Stone</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            The Faraglioni di Capri are three towering rock formations rising 109 meters (357 feet) from the Tyrrhenian Sea. They are among the most photographed natural landmarks in Italy, instantly recognizable symbols of Capri and the Campania coast. Each formation has a name: Faraglione Grande (the largest), Faraglione di Mezzo (middle), and Faraglione di Fuori (outer).
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            These dramatic rocks have inspired countless artists, filmmakers, and writers. They appear in the classic Italian film "The Talented Mr. Ripley" and feature prominently in travel photography worldwide. Local legend says that passing through the natural arch of the middle rock brings good fortune—and hundreds of boats do so daily.
          </p>
        </div>

        <!-- History & Stories -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Stories & History</h2>
          <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
            <div class="space-y-6 text-slate-600">
              <div>
                <p class="font-semibold text-slate-900 mb-2">The Blue Lizard</p>
                <p class="leading-relaxed">
                  Local lore speaks of the endemic blue lizard (Podarcis sicula coerulea) that lives on the rocks. Once common, these creatures have become rare, protected now within a marine reserve.
                </p>
              </div>
              <div>
                <p class="font-semibold text-slate-900 mb-2">In Cinema & Art</p>
                <p class="leading-relaxed">
                  The Faraglioni have appeared in numerous Italian films and serve as a visual symbol of la dolce vita. Artists have painted them for centuries, capturing the light and drama of these formations at different times of day.
                </p>
              </div>
              <div>
                <p class="font-semibold text-slate-900 mb-2">Geological Marvel</p>
                <p class="leading-relaxed">
                  These limestone formations are remnants of ancient cliffs eroded by waves and wind. The natural arch in the middle rock creates a passage used by boats—a thrilling experience and photo opportunity.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- How to Visit -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">How to Visit</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            The Faraglioni can only be visited by boat. Numerous tours depart daily from Capri, Positano, and other coastal towns. Tours typically last 2-3 hours and include time for swimming and snorkeling around the rocks.
          </p>
          <p class="text-slate-600 leading-relaxed">
            <strong>Best time to visit:</strong> May to September, when the sea is calmest. Morning boat tours offer the best light for photography. Swimming is permitted, and the water is exceptionally clear, making snorkeling outstanding.
          </p>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explore more of the Islands of the Bay</h2>
      <a
        href="/en-us/beaches"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Complete beach guide
      </a>
    </div>
  </section>

</BaseLayout>
