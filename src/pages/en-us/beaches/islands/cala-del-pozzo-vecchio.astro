---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Gulf Islands', url: '/en-us/beaches#islands' },
  { name: 'Cala del Pozzo Vecchio', url: '/en-us/beaches/islands/cala-del-pozzo-vecchio' },
];

const facts = [
  { label: 'Surface', value: 'Black volcanic sand' },
  { label: 'Vibe', value: 'Poetic and peaceful' },
  { label: 'Access', value: '10 min walk from the bus stop' },
  { label: 'Shade', value: 'From 17:30' },
  { label: 'Best for', value: 'Cinema lovers, poetry, authentic relaxation' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala del Pozzo Vecchio",
  "description": "The Procida beach made immortal by Massimo Troisi's film Il Postino. Black volcanic sand and emerald-green water.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Procida",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Il Postino Beach Procida 2026: Cala del Pozzo Vecchio"
  description="The beach made immortal by the film Il Postino. Black volcanic sand, emerald water, and the most authentic side of Procida. 2026 guide."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-pozzo-vecchio-procida.jpg"
      alt="Cala del Pozzo Vecchio, Procida - Il Postino beach"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Procida · Gulf Islands</p>
      <h1 class="font-serif text-display text-white mb-6">Cala del Pozzo Vecchio</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The beach made immortal by Massimo Troisi.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Cinema Made Beach</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            The beach made immortal by Massimo Troisi in <em>Il Postino</em> (1994). A crescent of black volcanic sand and emerald-green water that looks as if it stepped straight out of the film. The moment you arrive, you understand immediately why Troisi and director Michael Radford chose it as the main set.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            This is the most authentic and least touristy side of the Campanian islands. Procida has never had the mass tourism of Capri or Ischia, and this beach preserves its soul: few visitors, a great deal of poetry, spotlessly clean water. Perfect for total relaxation and those who love cinematic atmospheres.
          </p>
        </div>

        <!-- Il Postino box -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Il Postino (1994)</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Michael Radford's film starring Massimo Troisi and Philippe Noiret won the Academy Award for Best Foreign Language Film. This beach is the heart of the movie. Many visitors come here to relive the iconic scenes - the postman walking along the shore, the poetry of the sea.
          </p>
          <p class="text-slate-600 leading-relaxed italic">
            "Il mondo è bello e tu sei un po' curioso" - Il Postino, 1994
          </p>
        </div>

        <!-- Getting there -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Line C1 ⭐</p>
              <p class="text-slate-700 font-medium mb-1">From Procida port</p>
              <p class="text-slate-500 text-sm">Pozzo Vecchio stop. Then 10 min walk downhill to the beach.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">On foot</p>
              <p class="text-slate-700 font-medium mb-1">From Procida town centre</p>
              <p class="text-slate-500 text-sm">20–25 minutes. Scenic and pleasant through the island's narrow lanes.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Discover everything about Procida</h2>
      <a
        href="/en-us/islands/procida/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Complete Procida guide
      </a>
    </div>
  </section>

</BaseLayout>
