---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Sorrentine Peninsula', url: '/en-us/beaches#sorrentine-peninsula' },
  { name: 'Ieranto', url: '/en-us/beaches/sorrentine-peninsula/spiaggia-di-ieranto' },
];

const facts = [
  { label: 'Surface', value: 'Sand and pebbles' },
  { label: 'Access', value: 'Hiking trail only' },
  { label: 'Difficulty', value: 'Moderate hike (30 min)' },
  { label: 'Atmosphere', value: 'Wild, untouched' },
  { label: 'Best for', value: 'Hikers, snorkeling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia di Ieranto",
  "description": "A hidden beach accessible only by hiking trail. Crystal waters, wild cliffs, and a protected nature reserve.",
  "image": "https://amalficoast-travel.com/images/spiaggia-di-ieranto.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5700",
    "longitude": "14.3683"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia di Ieranto 2026: Hidden Beach & Hiking Guide"
  description="Ieranto is a pristine beach in a protected marine reserve. Accessible only by hiking trail from Praiano. Guide to the hike and what to expect."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-di-ieranto.jpg"
      alt="Spiaggia di Ieranto, Sorrentine Peninsula"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrentine Peninsula · Protected Reserve</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia di Ieranto</h1>
      <p class="text-lg md:text-xl font-light text-white/80">A pristine beach hidden in a protected marine reserve, reachable only on foot.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">A Beach Lost in Time</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Spiaggia di Ieranto lies within a protected marine reserve, one of the first created in Italy. Its isolation and protection have preserved it as a natural paradise. A 30-minute hike from Praiano, the effort is rewarded with pristine sand, turquoise waters, and an untouched landscape.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            The beach has a small freshwater spring, historically used by shepherds. The clear waters make it an exceptional snorkeling destination. Part of your entry fee supports marine conservation.
          </p>
        </div>

        <!-- The Hike -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">The Hiking Trail</h2>
          <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
            <div class="space-y-4 text-slate-600">
              <p class="leading-relaxed">
                <strong>Duration:</strong> 30 minutes down, 40 minutes up (with the sun exposure on return)
              </p>
              <p class="leading-relaxed">
                <strong>Difficulty:</strong> Moderate. Well-maintained path with sections of stairs and exposed areas. Good shoes essential.
              </p>
              <p class="leading-relaxed">
                <strong>Starting point:</strong> Via Spiaggia del Gavitello in Praiano (parking available)
              </p>
              <p class="leading-relaxed">
                <strong>What to bring:</strong> Water, sunscreen, comfortable hiking shoes. There are no facilities at the beach.
              </p>
            </div>
          </div>
        </div>

        <!-- Marine Reserve -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Protected Marine Reserve</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            Ieranto is part of the Limonium Marine Protected Area, created to preserve this exceptional ecosystem. Swimming and snorkeling are allowed, but fishing and anchoring are prohibited. Entrance is €2.50/person.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Respect the reserve: don't touch corals, don't take souvenirs, and use reef-safe sunscreen only.
          </p>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Discover more Sorrentine Peninsula beaches</h2>
      <a
        href="/en-us/beaches"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Complete beach guide
      </a>
    </div>
  </section>

</BaseLayout>
