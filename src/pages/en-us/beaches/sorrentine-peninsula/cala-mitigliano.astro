---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Sorrentine Peninsula', url: '/en-us/beaches#sorrentine-peninsula' },
  { name: 'Cala di Mitigliano', url: '/en-us/beaches/sorrentine-peninsula/cala-mitigliano' },
];

const facts = [
  { label: 'Surface', value: 'Pebbles & rock' },
  { label: 'Access', value: 'Steep trail (30 min) or boat' },
  { label: 'Shade', value: 'From 17:00' },
  { label: 'View', value: 'Faraglioni di Capri (head-on)' },
  { label: 'Best for', value: 'Hiking, snorkelling, photography' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala di Mitigliano",
  "description": "A wild cove with a breathtaking head-on view of Capri's Faraglioni stacks. Reachable by steep trail from Massa Lubrense or by boat.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Massa Lubrense",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Cala di Mitigliano: Secret Beach with Capri View"
  description="Cala di Mitigliano at Massa Lubrense: the hidden cove with the best head-on view of Capri's Faraglioni. How to get there by trail or boat."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-mitigliano.jpg"
      alt="Cala di Mitigliano, Massa Lubrense, with Capri in the background"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Massa Lubrense · Capri View</p>
      <h1 class="font-serif text-display text-white mb-6">Cala di Mitigliano</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The secret cove with Capri's Faraglioni right before your eyes.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">A Hidden Pearl</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Cala di Mitigliano is a hidden gem of the Sorrentine Peninsula. Rarely visited because of its demanding access trail, it offers a breathtaking head-on view of Capri and its Faraglioni stacks — arguably the finest view of Capri from the mainland. The water is crystal-clear over rocky seabeds ideal for snorkelling.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            A natural cave on the beach provides shade during the hottest hours. A true paradise for hiking and exploration lovers. At sunset, the raking light turns the Faraglioni golden: bring your camera.
          </p>
        </div>

        <!-- Capri view highlight -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            <h3 class="text-xl font-bold text-slate-900">The Best View of Capri</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            From the beach you get a <strong>direct, close-up view</strong> of all three Faraglioni stacks. Around sunset (from about 17:30) the light is perfect. It is the Capri shot that tourists never take — because it takes a bit of legwork to get here.
          </p>
        </div>

        <!-- Getting there -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">On foot (trail)</p>
              <p class="text-slate-700 font-medium mb-1">From Termini, Massa Lubrense</p>
              <p class="text-slate-500 text-sm">30 min steep descent. Hiking footwear essential. No facilities on site.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat</p>
              <p class="text-slate-700 font-medium mb-1">From Sorrento or Marina del Cantone</p>
              <p class="text-slate-500 text-sm">The easiest option. Book a boat tour with a stop at the cove.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explore the Sorrentine Peninsula</h2>
      <a
        href="/en-us/sorrento-peninsula/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Sorrentine Peninsula guide
      </a>
    </div>
  </section>

</BaseLayout>
