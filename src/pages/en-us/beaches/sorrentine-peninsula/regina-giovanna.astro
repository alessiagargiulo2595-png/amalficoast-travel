---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Sorrentine Peninsula', url: '/en-us/beaches#sorrentine-peninsula' },
  { name: 'Regina Giovanna', url: '/en-us/beaches/sorrentine-peninsula/regina-giovanna' },
];

const facts = [
  { label: 'Surface', value: 'Rocky' },
  { label: 'Access', value: '20-min trail (moderate)' },
  { label: 'Shade', value: 'From 18:00' },
  { label: 'Facilities', value: 'None - wild beach' },
  { label: 'Best for', value: 'Archaeology, hiking, snorkelling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Bagni della Regina Giovanna",
  "description": "A natural swimming pool and Roman archaeological site near Sorrento. A hidden gem among olive groves, 20 minutes on foot from the town centre.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6450",
    "longitude": "14.3540"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sorrento",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Regina Giovanna Sorrento: The Natural Pool (2026)"
  description="How to reach Bagni della Regina Giovanna near Sorrento. A natural pool amid Roman ruins, an olive-grove trail, and emerald-green waters. 2026 guide."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/regina-giovanna-sorrento.jpg"
      alt="Bagni della Regina Giovanna, Sorrento"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrento · Sorrentine Peninsula</p>
      <h1 class="font-serif text-display text-white mb-6">Regina Giovanna</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The natural pool hidden among Roman ruins.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Archaeology Meets Swimming</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            The Bagni della Regina Giovanna are an open-air archaeological site where you can dive into emerald-blue water. A natural pool enclosed within the ruins of a 1st-century Roman villa - likely belonging to Publius Vedius Pollio - connects to the open sea through a rock arch. In 2026 it remains a wild spot: no beach clubs, no facilities.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            The trail leading down to the baths passes through ancient olive groves with spectacular views across the Gulf of Naples and the island of Capri. Wear light hiking shoes and bring enough water - there are no bars or shops nearby.
          </p>
        </div>

        <!-- Wild beach note -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Wild Beach</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            No facilities, no bar, no beach club. Bring <strong>water, food, and water shoes</strong>. This is a genuinely local spot, frequented mainly by Sorrentines who know the place - a true authentic corner of the peninsula.
          </p>
        </div>

        <!-- Getting there -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">EAV Bus ⭐ Recommended</p>
              <p class="text-slate-700 font-medium mb-1">"Capo di Sorrento" line</p>
              <p class="text-slate-500 text-sm">From Piazza Tasso. Then 15–20 min walk through the olive groves.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">On foot from the centre</p>
              <p class="text-slate-700 font-medium mb-1">About 40 minutes</p>
              <p class="text-slate-500 text-sm">Scenic but strenuous. Follow Via del Capo towards Punta del Capo.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explore the Sorrentine Peninsula</h2>
      <a
        href="/en-us/sorrento-peninsula/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Sorrentine Peninsula guide
      </a>
    </div>
  </section>

</BaseLayout>
