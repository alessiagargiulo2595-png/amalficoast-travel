---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Beaches', url: '/en-us/beaches' },
  { name: 'Sorrentine Peninsula', url: '/en-us/beaches#sorrentine-peninsula' },
  { name: 'Marina del Cantone', url: '/en-us/beaches/sorrentine-peninsula/marina-del-cantone' },
];

const facts = [
  { label: 'Surface', value: 'Large pebbles' },
  { label: 'Access', value: 'Very easy (flat)' },
  { label: 'Shade', value: 'From 18:30' },
  { label: 'Facilities', value: 'Beach clubs, starred restaurants' },
  { label: 'Best for', value: 'Families, food, snorkelling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina del Cantone",
  "description": "A wide pebble beach at Nerano, celebrated for its gastronomy — home of the original Spaghetti alla Nerano — and crystal-clear waters inside the Punta Campanella Marine Reserve.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Nerano",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina del Cantone Nerano: Beach & Restaurants 2026"
  description="Italy's tastiest beach: Marina del Cantone at Nerano combines protected crystal-clear waters with the original Spaghetti alla Nerano. 2026 guide."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-del-cantone.jpg"
      alt="Marina del Cantone, Nerano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Nerano · Sorrentine Peninsula</p>
      <h1 class="font-serif text-display text-white mb-6">Marina del Cantone</h1>
      <p class="text-lg md:text-xl font-light text-white/80">The gastronomic capital on the cleanest sea in Campania.</p>
    </div>
  </section>

  <!-- Content + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Main text -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Sea and Serious Cuisine</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Nerano is the gastronomic capital of the Sorrentine Peninsula. The beach at Marina del Cantone is wide, clean, and catches the sun well into the evening. The water is among the clearest in Campania, protected by the Punta Campanella Marine Reserve: snorkelling is superb, with seagrass meadows and rich marine life.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            But Nerano's worldwide fame is culinary. This is the birthplace of <strong>Spaghetti alla Nerano</strong> — fried courgettes, provolone del Monaco, basil — and every restaurant on the seafront serves the original version. Perfect for families and anyone who wants to combine a great beach day with world-class cooking.
          </p>
        </div>

        <!-- Foodie tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Foodie Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            <strong>Lo Cantone</strong> and <strong>Maria Grazia</strong> are the temples of Spaghetti alla Nerano. Book your table in the morning — in summer seats run out fast. A beach lunch here is a complete gastronomic experience.
          </p>
        </div>

        <!-- Getting there -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">How to Get There</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">EAV Bus</p>
              <p class="text-slate-700 font-medium mb-1">From Sorrento via Massa Lubrense</p>
              <p class="text-slate-500 text-sm">Alight at Nerano. Then 10 min walk down to the beach.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">By Sea</p>
              <p class="text-slate-700 font-medium mb-1">Taxi boat from Sorrento</p>
              <p class="text-slate-500 text-sm">Direct landing on the beach. Scenic and very convenient.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/en-us/beaches"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← All beaches
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explore the Sorrentine Peninsula</h2>
      <a
        href="/en-us/sorrento-peninsula/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Sorrentine Peninsula guide
      </a>
    </div>
  </section>

</BaseLayout>
