---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Amalfi Coast', url: '/en-us/amalfi-coast/' },
];

const borghi = [
  {
    name: 'Positano',
    href: '/en-us/amalfi-coast/positano/',
    desc: 'The most photographed village on the coast, with colorful houses perched over the sea and the famous Spiaggia Grande.',
    tag: 'Most iconic',
  },
  {
    name: 'Amalfi',
    href: '/en-us/amalfi-coast/amalfi/',
    desc: 'Historic capital of the coast, with the Cathedral of Sant\'Andrea and the paper museum.',
    tag: 'Historic capital',
  },
  {
    name: 'Ravello',
    href: '/en-us/amalfi-coast/ravello/',
    desc: 'At 350 m above the sea, the "city of music" with Villa Rufolo and Villa Cimbrone.',
    tag: 'Panoramic view',
  },
  {
    name: 'Praiano',
    href: '/en-us/amalfi-coast/praiano/',
    desc: 'The best-kept secret: fewer crowds, spectacular sunsets from the Bay of Praia.',
    tag: 'Most authentic',
  },
  {
    name: 'Maiori',
    href: '/en-us/amalfi-coast/maiori/',
    desc: 'The longest sandy beach on the coast: ideal for those seeking the sea without sacrificing comfort.',
    tag: 'Sandy beach',
  },
  {
    name: 'Minori',
    href: '/en-us/amalfi-coast/minori/',
    desc: 'Village of lemon groves, with the remains of a 1st-century Roman villa and excellent pastry shops.',
    tag: 'Authentic flavors',
  },
];

const destinationSchema = {
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": "Amalfi Coast",
  "description": "The Amalfi Coast is a 50 km coastal stretch in Campania, a UNESCO World Heritage Site since 1997, with colorful villages, cliffs and the blue of the Tyrrhenian Sea.",
  "url": "https://amalficoast-travel.com/en-us/amalfi-coast/",
  "touristType": ["Culture", "Sea", "Nature", "Gastronomy", "Hiking"],
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6333,
    "longitude": 14.6027
  }
};
---

<BaseLayout
  title="Amalfi Coast 2026: Complete Guide to the Villages"
  description="Guide to the Amalfi Coast: villages to visit, beaches, how to get there, when to go. From Positano to Amalfi, everything you need to know."
  lang={lang}
  pageKey="costiera-amalfitana"
  breadcrumbs={breadcrumbs}
  schema={[destinationSchema]}
>

  <!-- Hero -->
  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager"  referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/en-us/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Amalfi Coast</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">UNESCO World Heritage</p>
        <h1 class="font-serif text-display text-white mb-4">Amalfi Coast</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Fifty kilometres of cliffs, colourful villages and turquoise waters. Italy's most famous coastline in a complete, up-to-date 2026 guide.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-20">

    <!-- Intro -->
    <section class="max-w-text">
      <p class="text-xl leading-relaxed text-charcoal">
        The Amalfi Coast is one of those places that exceeds every expectation. No matter how many photographs you have seen: the reality — the scent of lemons, the shimmer of sunlight on the sea, the houses clinging to the rock — is always more intense.
      </p>
      <p class="mt-4 text-slate-600 leading-relaxed">
        Recognized as a UNESCO World Heritage Site in 1997, it stretches for 50 km from the Sorrento Peninsula to Vietri sul Mare, in the province of Salerno. At its heart is the SS163, a winding road carved into the rock that connects 13 municipalities, each with its own history, landscape and flavour.
      </p>
    </section>

    <!-- Borghi Grid -->
    <section>
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-serif text-3xl font-semibold text-slate-900">Villages of the Coast</h2>
        <p class="text-sm text-slate-400 hidden sm:block">From west to east along the SS163</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {borghi.map(b => (
          <a href={b.href} class="group bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm hover:border-med-blue/30 hover:shadow-xl transition-all duration-300">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-serif text-xl font-semibold text-slate-900 group-hover:text-med-blue transition-colors">{b.name}</h3>
              <span class="text-[10px] uppercase tracking-wide bg-med-blue/5 text-med-blue px-2 py-1 rounded-full font-medium flex-shrink-0 ml-2">{b.tag}</span>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">{b.desc}</p>
            <p class="text-med-blue text-sm font-medium mt-4 group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
              Explore {b.name}
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
            </p>
          </a>
        ))}
      </div>
    </section>

    <!-- Did You Know -->
    <section class="bg-charcoal text-white rounded-[2rem] p-10">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-8">The coast in numbers</p>
      <div class="grid sm:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">50 km</p>
          <p class="text-white/60 text-sm mt-2">of UNESCO coastline</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">13</p>
          <p class="text-white/60 text-sm mt-2">coastal municipalities</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">1997</p>
          <p class="text-white/60 text-sm mt-2">UNESCO year</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">2 mln+</p>
          <p class="text-white/60 text-sm mt-2">tourists/year</p>
        </div>
      </div>
    </section>

    <!-- Quick Links -->
    <section>
      <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Practical guides</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/en-us/amalfi-coast/come-arrivare/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">How to get there</p>
            <p class="text-xs text-slate-500">Ferries, bus, car</p>
          </div>
        </a>
        <a href="/en-us/quando-visitare/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">When to go</p>
            <p class="text-xs text-slate-500">Month by month</p>
          </div>
        </a>
        <a href="/en-us/spiagge/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17c3-3 6-3 9 0s6 3 9 0M3 12c3-3 6-3 9 0s6 3 9 0"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">The beaches</p>
            <p class="text-xs text-slate-500">8 selected beaches</p>
          </div>
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
