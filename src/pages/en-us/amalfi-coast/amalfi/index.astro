---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'en-us';

const breadcrumbs = [
  { name: 'Home', url: '/en-us/' },
  { name: 'Amalfi Coast', url: '/en-us/amalfi-coast/' },
  { name: 'Amalfi', url: '/en-us/amalfi-coast/amalfi/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Amalfi",
  "description": "Amalfi is the historic capital of the Amalfi Coast, once a powerful medieval Maritime Republic. Famous for the Cathedral of Sant'Andrea, the Paper Museum and its characteristic historic centre.",
  "url": "https://amalficoast-travel.com/en-us/amalfi-coast/amalfi/",
  "image": "https://amalficoast-travel.com/images/amalfi-hero.jpg",
  "touristType": ["Culture", "History", "Sea", "Gastronomy"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84011"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6339,
    "longitude": 14.6027
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you get to Amalfi from Naples?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "From Naples you can reach Amalfi by ferry from Molo Beverello (about 90–105 min, seasonal) or by SITA bus from Sorrento via the SS163 (about 90 min). By car the SS163 is spectacular but winding: in summer it is best avoided."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best time to visit Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "April–June and September–October are ideal: mild weather, manageable crowds, reasonable prices. July and August are peak tourist season. November–March is quiet but with risk of rain and reduced services."
      }
    },
    {
      "@type": "Question",
      "name": "How much does the ferry from Salerno to Amalfi cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Travelmar ferry from Salerno to Amalfi costs about €8–10 each way. Tickets can be purchased online or at the harbour ticket office. The service runs approximately from April to October."
      }
    },
    {
      "@type": "Question",
      "name": "What to see in Amalfi in one day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In one day you can visit the Cathedral of Sant'Andrea and the Cloister of Paradise, the Paper Museum, the historic centre with Piazza del Duomo, and take a walk to the Valle delle Ferriere. In the evening, dinner at one of the seafront restaurants."
      }
    },
    {
      "@type": "Question",
      "name": "Is there parking in Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Parking is scarce and expensive (Luna Rossa and Flavio Gioia car parks: about €4–5/hour). In summer a ZTL restricted traffic zone applies in the historic centre. It is recommended to arrive by ferry or SITA bus to avoid the traffic on the SS163."
      }
    }
  ]
};
---

<BaseLayout
  title="Amalfi 2026: Complete Guide | Amalfi Coast"
  description="Everything about Amalfi: how to get there, the Cathedral, Paper Museum, ferry and bus schedules, what to see, when to go. The complete guide to the historic capital of the Amalfi Coast."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/amalfi-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfi Coast</p>
        <h1 class="font-serif text-display text-white mb-4">Amalfi</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          The historic capital of the coast: a medieval Maritime Republic whose paper-making tradition still lives in its workshops, and whose Cathedral remains the most impressive church on the Tyrrhenian shore.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Fast Facts</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">How to Get Here</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Amalfi is more than a postcard. Between the 9th and 13th centuries it was one of the most powerful maritime republics in the Mediterranean — on a par with Venice, Genoa and Pisa. Today, 5,000 inhabitants live on the slopes of a dramatic gorge cut by the Canneto torrent, between towers, convents and a cathedral that alone justifies the journey.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            The town also gave the world the Amalfi Tables — the oldest maritime code in the Western world, dating to around the 11th century — and a paper-making tradition that produced the first watermarked paper in Europe.
          </p>
        </div>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Did You Know?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">IX</p>
              <p class="text-white/60 text-xs italic mt-1">century: founding of the Maritime Republic</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">62</p>
              <p class="text-white/60 text-xs italic mt-1">steps of the Cathedral staircase</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">5,000</p>
              <p class="text-white/60 text-xs italic mt-1">inhabitants today</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            The Amalfi Tables (Tabula Amalfitana), the oldest maritime code in the Western world, governed commerce across the Mediterranean from the 11th to the 16th century.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">What to See in Amalfi</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Cathedral of Sant'Andrea</h3>
                <p class="text-slate-600 leading-relaxed">The Arab-Norman facade with its striking black and white mosaic and the 62 steps leading up from Piazza del Duomo are the iconic image of Amalfi. The Cloister of Paradise (Chiostro del Paradiso), a 13th-century Arab-Norman cloister, is included in the cathedral ticket. Open daily.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Paper Museum (Museo della Carta)</h3>
                <p class="text-slate-600 leading-relaxed">Set in a 13th-century paper mill in the Valle dei Mulini, this museum traces the history of paper-making in Amalfi. Live demonstrations show how sheets are made by hand using traditional techniques. Entrance ~€4.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Arsenal of the Maritime Republic</h3>
                <p class="text-slate-600 leading-relaxed">The only surviving medieval shipyard of the Republic, with vaulted halls where galleys were built. Today it hosts temporary exhibitions and the Museum of the Compass.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Valle delle Ferriere</h3>
                <p class="text-slate-600 leading-relaxed">A protected nature reserve above the town with a scenic waterfall and lush vegetation. The trail starts from the Paper Museum and takes about 2 hours return. Free access.</p>
              </div>
            </div>
          </div>
        </div>

        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">How to Get to Amalfi</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Amalfi is well connected by ferry and bus. By car, the SS163 road is spectacular but congested in summer — public transport is strongly recommended.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">By Ferry</h3><p class="text-white/50 text-sm leading-relaxed">Travelmar from Salerno (April–October). NLG / Alilauro from Naples Molo Beverello (seasonal). The most scenic option.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">SITA Bus</h3><p class="text-white/50 text-sm leading-relaxed">From Sorrento along the SS163 (~90 min, ~€2.50). From Salerno direct (~75 min). Year-round service.</p></div>
              </div>
            </div>
            <a href="/en-us/guide/ferries/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Full transport guide
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Ferry Schedules — Summer 2026
          </h3>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Travelmar — Salerno ↔ Amalfi</caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Departs Salerno</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrives Amalfi</th>
                  <th class="text-left px-4 py-3 font-semibold">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">07:15</td><td class="px-4 py-3 font-mono">08:30</td><td class="px-4 py-3 text-slate-500">Via Cetara, Maiori</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">09:00</td><td class="px-4 py-3 font-mono">10:15</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">11:00</td><td class="px-4 py-3 font-mono">12:15</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">14:15</td><td class="px-4 py-3 font-mono">15:30</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">16:30</td><td class="px-4 py-3 font-mono">17:45</td><td class="px-4 py-3 text-slate-500">—</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Indicative schedules for 2026. Check travelmar.it to confirm.</p>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Frequently Asked Questions about Amalfi</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts — Amalfi</p>
          <dl class="space-y-3">
            {[
              { dt: 'Location', dd: 'Amalfi Coast, SA' },
              { dt: 'Population', dd: '~5,000 inhabitants' },
              { dt: 'From Naples', dd: '~90 min (ferry)' },
              { dt: 'From Sorrento', dd: '~90 min (SITA bus)' },
              { dt: 'ZTL', dd: 'Yes, in summer' },
              { dt: 'Beach', dd: 'Pebbles (town centre)' },
              { dt: 'Best time', dd: 'Apr–Jun / Sep–Oct' },
              { dt: 'Currency', dd: 'Euro (€)' },
            ].map(({ dt, dd }, i, arr) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < arr.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Explore the Coast</p>
          <nav class="space-y-1">
            {[
              { href: '/en-us/amalfi-coast/positano/', label: 'Positano' },
              { href: '/en-us/amalfi-coast/ravello/', label: 'Ravello' },
              { href: '/en-us/amalfi-coast/praiano/', label: 'Praiano' },
              { href: '/en-us/amalfi-coast/maiori/', label: 'Maiori' },
              { href: '/en-us/amalfi-coast/minori/', label: 'Minori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Also Explore the Coast"
    items={[
      { name: 'Positano',  href: '/en-us/amalfi-coast/positano/',  tag: 'Iconic',         desc: 'Coloured houses over the sea, fashion boutiques and the most famous beach.' },
      { name: 'Ravello',   href: '/en-us/amalfi-coast/ravello/',   tag: 'Music & Gardens', desc: 'Villa Rufolo, Villa Cimbrone and the Festival 350 m above the sea.' },
      { name: 'Praiano',   href: '/en-us/amalfi-coast/praiano/',  tag: 'Sunset & Quiet',  desc: 'The sunset from San Gennaro and the Marina di Praia beach.' },
      { name: 'Capri',     href: '/en-us/isole/capri/',                   tag: 'The most iconic', desc: 'Blue Grotto, Faraglioni sea stacks and the glamorous Piazzetta.' },
    ]}
  />

</BaseLayout>
