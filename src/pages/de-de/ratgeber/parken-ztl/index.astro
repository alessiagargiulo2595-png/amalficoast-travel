---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Reiseratgeber', url: '/de-de/ratgeber/' },
  { name: 'Parken & ZTL', url: '/de-de/ratgeber/parken-ztl/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Kann ich mit dem Auto nach Positano fahren?",
      "acceptedAnswer": { "@type": "Answer", "text": "Im Sommer ist Positano von 9:00 bis 18:00 Uhr für den Verkehr gesperrt (ZTL). Nur Anwohner und Hotelgäste dürfen einfahren. Bester Rat: Auto in Sorrent oder Praiano parken und mit SITA-Bus oder Fähre fahren." }
    },
    {
      "@type": "Question",
      "name": "Wo soll ich parken, um die Amalfiküste zu besuchen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Beste Optionen: 1) Auto in Salerno oder Vietri sul Mare lassen und Bus/Fähre nehmen. 2) In Sorrent parken (Garage Achille Lauro, ~€2/Std.) und SITA-Bus oder Tragflügelboot nehmen. 3) Parkplätze in Amalfi nutzen (Luna Rossa, Flavio Gioia, ~€4–5/Std.)." }
    },
    {
      "@type": "Question",
      "name": "Was kostet das Parken in Amalfi?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die Hauptparkplätze in Amalfi (Luna Rossa und Flavio Gioia) kosten ~€4–5/Stunde oder ~€25–30/Tag. Im Juli und August fast immer voll. Empfehlung: vor 9:00 Uhr ankommen oder öffentliche Verkehrsmittel nutzen." }
    }
  ]
};

const ztlData = [
  { location: 'Positano', ztl: 'Ja', period: 'Jun–Sep (9:00–18:00)', note: 'Zugang nur für Anwohner und Hotelgäste. SITA-Bus oder Fähre empfohlen.' },
  { location: 'Amalfi', ztl: 'Ja', period: 'Ganzjährig (Zentrum)', note: 'Permanente ZTL im historischen Kern. Kostenpflichtige Parkplätze an der Uferpromenade (~€4/Std.).' },
  { location: 'Ravello', ztl: 'Ja', period: 'Sommer (10:00–19:00)', note: 'Nur SITA-Bus ab Amalfi (25 Min., ~€1,50) oder Auto mit Hotelgenehmigung.' },
  { location: 'Sorrent', ztl: 'Ja', period: 'Sommer (Zentrum)', note: 'Parkhäuser verfügbar. Piazza Lauro ~€2/Std.' },
  { location: 'Praiano', ztl: 'Nein', period: '—', note: 'Kostenlose und kostenpflichtige Parkplätze an der SS163. Guter Haltepunkt.' },
  { location: 'Maiori', ztl: 'Nein', period: '—', note: 'Parkplätze an der Uferpromenade. Einfacher als die westlichen Dörfer.' },
  { location: 'Minori', ztl: 'Nein', period: '—', note: 'Parkplätze an der Uferpromenade, kostenlos oder günstig.' },
];
---

<BaseLayout
  title="Parken & ZTL Amalfiküste 2026 | Wo das Auto abstellen"
  description="Vollständiger Leitfaden zu Parkplätzen und ZTL-Zonen an der Amalfiküste: Positano, Amalfi, Ravello, Sorrent. Wo parken und wie die Dörfer stressfrei erreichen."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/parcheggi-hero.jpg" alt="Sorrent, Halbinsel Sorrent" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Startseite</a>
        <span>/</span>
        <span class="text-white/60">Reiseratgeber</span>
        <span>/</span>
        <span class="text-white">Parken & ZTL</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Reiseratgeber</p>
        <h1 class="font-serif text-display text-white mb-4">Parken & ZTL-Zonen</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Die Amalfiküste ist im Sommer ein Albtraum für Autofahrer: ZTL überall, enge Straßen und teure Parkplätze. Hauptempfehlung: Auto stehen lassen und öffentliche Verkehrsmittel nutzen. So geht's.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="bg-red-50 border border-red-200 rounded-[2rem] p-6 mb-8">
        <p class="font-semibold text-red-800 mb-2">⚠️ ZTL-Warnung</p>
        <p class="text-sm text-red-700">ZTL-Zonen an der Amalfiküste werden mit Kameras überwacht. Einfahren ohne Genehmigung führt zu einem Bußgeld von €80–160, das direkt an die Mietwagengesellschaft oder Ihre Heimatadresse geschickt wird.</p>
      </div>
      <p class="text-xl leading-relaxed text-charcoal">
        Die beste Strategie ist das „strategische Parken": Auto an einem gut erreichbaren Punkt abstellen (Salerno, Vietri, Sorrent oder Praiano) und von dort Busse, Fähren oder Tragflügelboote nutzen.
      </p>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">ZTL und Parken für jedes Dorf</h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-med-blue/5 text-charcoal">
              <th class="text-left px-4 py-3 font-semibold">Ort</th>
              <th class="text-left px-4 py-3 font-semibold">ZTL</th>
              <th class="text-left px-4 py-3 font-semibold">Zeitraum</th>
              <th class="text-left px-4 py-3 font-semibold">Empfehlung</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {ztlData.map(r => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-semibold text-charcoal">{r.location}</td>
                <td class="px-4 py-3">
                  {r.ztl === 'Ja'
                    ? <span class="text-[10px] bg-red-50 text-red-600 px-2 py-0.5 rounded-full font-medium">Ja</span>
                    : <span class="text-[10px] bg-med-blue/5 text-med-blue px-2 py-0.5 rounded-full font-medium">Nein</span>
                  }
                </td>
                <td class="px-4 py-3 text-slate-500">{r.period}</td>
                <td class="px-4 py-3 text-slate-600 text-xs">{r.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
