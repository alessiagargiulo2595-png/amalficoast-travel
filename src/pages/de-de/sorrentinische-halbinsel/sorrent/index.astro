---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Sorrentinische Halbinsel', url: '/de-de/sorrentinische-halbinsel/' },
  { name: 'Sorrent', url: '/de-de/sorrentinische-halbinsel/sorrent/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie kommt man von Sorrent nach Capri?",
      "acceptedAnswer": { "@type": "Answer", "text": "Tragflügelboot vom Sorrenter Hafen (Marina Piccola): ~25 Min., ~€20-22. Erste Abfahrt gegen 07:30 Uhr. In der Hochsaison (Juli-August) im Voraus buchen. Anbieter: Alilauro, NLG, SNAV." }
    },
    {
      "@type": "Question",
      "name": "Wo kauft man echten Limoncello in Sorrent?",
      "acceptedAnswer": { "@type": "Answer", "text": "Limone di Sorrento IGP ist das Authentizitätssiegel. Direkt bei Produzenten kaufen: Limonoro (via San Cesareo), Profumi della Costiera oder in den Gewölben der Villa Comunale. Industrielle Flaschen aus dem Supermarkt vermeiden." }
    },
    {
      "@type": "Question",
      "name": "Lohnt sich Sorrent als Reiseziel?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, vor allem als logistische Basis. Sorrent ist 25 Min. von Capri mit dem Tragflügelboot, 70 Min. von Neapel mit dem Zug, 30 Min. von Pompeji entfernt. Altstadt, Piazza Tasso, Vallone dei Mulini und Marina Grande sind einen halben Tag wert." }
    },
    {
      "@type": "Question",
      "name": "Wie reist man von Neapel nach Sorrent?",
      "acceptedAnswer": { "@type": "Answer", "text": "Circumvesuviana ab Neapel Centrale (Porta Nolana) Richtung Sorrent: ~70 Min., ~€3,90. Abfahrten alle 30-40 Min. Auf Taschendiebe im Zug achten. Alternative: Tragflügelboot Molo Beverello - Sorrent ~1h." }
    },
    {
      "@type": "Question",
      "name": "Kann man Capri als Tagesausflug von Sorrent aus machen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, das ist der beste Ausgangspunkt. Tragflügelboot 25 Min., erste Abfahrt 07:30 Uhr. Einen vollen Tag einplanen für die Blaue Grotte (morgens), Anacapri (Monte Solaro mit Sessellift), Faraglioni. Letzte Rückfahrt gegen 19-20 Uhr. Transportkosten ~€40-45 hin und zurück." }
    }
  ]
};

const fastFacts = [
  { dt: 'Lage', dd: 'Sorrentinische Halbinsel, NA' },
  { dt: 'Einwohner', dd: '~19.000' },
  { dt: 'Ab Neapel', dd: '~70 Min. (Circumvesuviana)' },
  { dt: 'Ab Capri', dd: '~25 Min. (Tragflügelboot)' },
  { dt: 'Spezialitäten', dd: 'Limoncello, Spaghetti alle vongole' },
  { dt: 'Hafen', dd: 'Marina Piccola (Tragflügelboote), Marina Grande (Fähren)' },
  { dt: 'Beste Reisezeit', dd: 'Apr-Okt' },
];
---

<BaseLayout
  title="Sorrent 2026: Reiseführer - Tragflügelboot Capri, Limoncello, Piazza Tasso"
  description="Reiseführer Sorrent: Wie kommt man nach Capri, wo kauft man Limoncello, Piazza Tasso, Vallone dei Mulini. Die perfekte Basis für die Amalfiküste."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[65vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/sorrento-hero.jpg" alt="Sorrent, Italien" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrentinische Halbinsel · Ideale Basis</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrent</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Die Hauptstadt der Sorrentinischen Halbinsel und der perfekte Hub für den Golf von Neapel. Capri in 25 Minuten, Neapel in 70 Minuten, Pompeji in 30 Minuten. Und abends: Limoncello, Piazza Tasso und Blick auf den Vesuv.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Sorrent ist nicht nur eine schöne Stadt - es ist der praktischste logistische Hub Süditaliens. In einem einzigen Aufenthalt kann man Capri, Neapel, Pompeji, Herculaneum und die Amalfiküste besuchen, ohne das Hotel zu wechseln.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wussten Sie das?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">25 Min.</p><p class="text-white/60 text-xs italic mt-1">Sorrent - Capri mit Tragflügelboot</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">77 m</p><p class="text-white/60 text-xs italic mt-1">Tiefe des Vallone dei Mulini</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">IGP</p><p class="text-white/60 text-xs italic mt-1">Siegel des Limone di Sorrento</p></div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Der Name "Sorrent" kommt vom griechischen "Surrentum", was "Stadt der Sirenen" bedeutet. Der Sage nach war es vor der Sorrentinischen Halbinsel, wo Odysseus sich an den Mast binden ließ, um dem Gesang der Sirenen zu widerstehen.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Sehenswürdigkeiten in Sorrent</h2>
          <ol class="space-y-6 list-none">
            {[
              { n: '01', title: 'Piazza Tasso', text: "Das Wohnzimmer Sorrents: Caféterrassen, Blick auf den Hafen und den Vesuv. Ausgangspunkt aller Spaziergänge. Abends belebt mit Aperitivo unter freiem Himmel." },
              { n: '02', title: 'Vallone dei Mulini', text: "Eine natürliche 40 m tiefe Schlucht mitten im Stadtzentrum mit Ruinen von Mühlen aus dem 15. Jahrhundert, überwuchert von Vegetation. Zugänglich von der via Fuorimura. Freier Eintritt von der Terrasse." },
              { n: '03', title: 'Kreuzgang von San Francesco', text: "Der Kreuzgang aus dem 14. Jahrhundert mit Säulen aus abwechselndem Tuffstein und Marmor. Abends werden hier Klassikkonzerte veranstaltet. Freier Eintritt." },
              { n: '04', title: 'Marina Grande', text: "Der alte Fischerhafen am Fuß der Klippe mit bunten Häusern und Fischrestaurants. Authentischer als das touristische Zentrum. Zu Fuß über die via Marina Grande erreichbar." },
              { n: '05', title: 'Museo Correale', text: "Sammlung neapolitanischer Keramik, Silber und Gemälde aus dem 17.-18. Jahrhundert in einer Villa mit Klippengarten. ~€8, Di-So geöffnet." },
            ].map(({ n, title, text }) => (
              <li class="flex gap-5">
                <span class="font-serif text-3xl font-bold text-med-blue/20 flex-shrink-0 leading-none mt-1">{n}</span>
                <div>
                  <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                  <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Anreise nach Sorrent</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-slate-50 text-left">
                  <th class="px-4 py-3 font-semibold text-charcoal border-b border-slate-200">Ab</th>
                  <th class="px-4 py-3 font-semibold text-charcoal border-b border-slate-200">Verkehrsmittel</th>
                  <th class="px-4 py-3 font-semibold text-charcoal border-b border-slate-200">Dauer</th>
                  <th class="px-4 py-3 font-semibold text-charcoal border-b border-slate-200">Preis</th>
                </tr>
              </thead>
              <tbody>
                {[
                  { from: 'Neapel', how: 'Circumvesuviana', time: '~70 Min.', price: '~€3,90' },
                  { from: 'Neapel', how: 'Tragflügelboot', time: '~1h', price: '~€14' },
                  { from: 'Capri', how: 'Tragflügelboot', time: '~25 Min.', price: '~€20' },
                  { from: 'Positano', how: 'Fähre (Saison)', time: '~35 Min.', price: '~€15' },
                  { from: 'Amalfi', how: 'SITA-Bus', time: '~90 Min.', price: '~€2,50' },
                ].map((r, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50/50'}>
                    <td class="px-4 py-3 text-charcoal border-b border-slate-100">{r.from}</td>
                    <td class="px-4 py-3 text-slate-600 border-b border-slate-100">{r.how}</td>
                    <td class="px-4 py-3 text-slate-600 border-b border-slate-100">{r.time}</td>
                    <td class="px-4 py-3 font-medium text-med-blue border-b border-slate-100">{r.price}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="bg-med-blue/5 border border-med-blue/20 rounded-[2rem] p-6">
          <p class="font-semibold text-med-blue mb-2">Lokaler Tipp</p>
          <p class="text-sm text-slate-700 leading-relaxed">Das Sorrenter Stadtzentrum ist im Sommer eine ZTL-Zone (eingeschränkte Verkehrszone). Wer mit dem Auto anreist, parkt außerhalb (Piazza Lauro, Via degli Aranci) und setzt die Reise zu Fuß oder mit dem Bus fort. Die Circumvesuviana ist das praktischste Verkehrsmittel für die Region.</p>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Steckbrief - Sorrent</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Sorrentinische Halbinsel</p>
          <nav class="space-y-1">
            {[
              { href: '/de-de/sorrentinische-halbinsel/vico-equense/', label: 'Vico Equense' },
              { href: '/de-de/sorrentinische-halbinsel/massa-lubrense/', label: 'Massa Lubrense' },
              { href: '/de-de/sorrentinische-halbinsel/sant-agnello/', label: "Sant'Agnello" },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Halbinsel und Inseln entdecken"
    items={[
      { name: 'Capri',          href: '/de-de/inseln/capri/',                           tag: 'Unverzichtbar', desc: 'Blaue Grotte, Faraglioni und die berühmte Piazzetta.' },
      { name: 'Vico Equense',   href: '/de-de/sorrentinische-halbinsel/vico-equense/',   tag: 'Authentisch',   desc: 'Pizza al metro und Burg Giusso, weniger touristisch.' },
      { name: 'Massa Lubrense', href: '/de-de/sorrentinische-halbinsel/massa-lubrense/', tag: 'Natur',         desc: 'Punta Campanella, Marina del Cantone und Nerano-Spaghetti.' },
      { name: 'Positano',       href: '/de-de/amalfikueste/positano/',                   tag: 'Mode & Aussicht', desc: 'Die bunten Häuser an der Amalfiküste.' },
    ]}
  />

</BaseLayout>
