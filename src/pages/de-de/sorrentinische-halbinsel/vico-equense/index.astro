---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Sorrentinische Halbinsel', url: '/de-de/sorrentinische-halbinsel/' },
  { name: 'Vico Equense', url: '/de-de/sorrentinische-halbinsel/vico-equense/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wo isst man Pizza al metro in Vico Equense?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pizza al metro wurde 1938 von Gigino Dell'Amura in der Trattoria Università della Pizza, bekannt als Da Gigino, in der Via Nicotera erfunden. Man bestellt nach Länge (mindestens 1 Meter) mit verschiedenen Belägen pro Abschnitt." }
    },
    {
      "@type": "Question",
      "name": "Wie kommt man von Neapel nach Vico Equense?",
      "acceptedAnswer": { "@type": "Answer", "text": "Circumvesuviana ab Neapel Centrale Richtung Sorrent: Ausstieg Vico Equense (~50 Min., ~€3,10). Mit dem Auto: Autobahn A3, Ausfahrt Castellammare di Stabia, dann SS145 Richtung Sorrent." }
    },
    {
      "@type": "Question",
      "name": "Lohnt sich ein Besuch in Vico Equense?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, besonders wenn man den Massentourismus in Sorrent vermeiden möchte. Das mittelalterliche Zentrum, die Burg Giusso und die Aussichten sind authentisch und weniger touristisch. Ideal für einen halben Tag." }
    }
  ]
};

const fastFacts = [
  { dt: 'Lage', dd: 'Sorrentinische Halbinsel, NA' },
  { dt: 'Einwohner', dd: '~21.000' },
  { dt: 'Ab Neapel', dd: '~50 Min. (Circumvesuviana)' },
  { dt: 'Ab Sorrent', dd: '~15 Min. (Circumvesuviana)' },
  { dt: 'Spezialitäten', dd: 'Pizza al metro, Fior di latte' },
  { dt: 'Strand', dd: 'Marina di Vico (Kiesel)' },
  { dt: 'Beste Reisezeit', dd: 'Apr-Okt' },
];
---

<BaseLayout
  title="Vico Equense 2026: Pizza al Metro, Burg Giusso - Reiseführer"
  description="Reiseführer Vico Equense: Pizza al metro bei Da Gigino, Burg Giusso und mittelalterliche Altstadt. Anreise von Neapel mit der Circumvesuviana."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/vico-equense-hero.jpg" alt="Vico Equense, Italien" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrentinische Halbinsel · Pizza al Metro</p>
        <h1 class="font-serif text-display text-white mb-4">Vico Equense</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Die mittelalterliche Stadt, in der 1938 die Pizza al metro erfunden wurde. Ein authentisches Zentrum, die Burg Giusso über dem Meer und weniger Touristen als in Sorrent - nur 15 Minuten mit dem Zug entfernt.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Vico Equense wird von Touristen, die direkt nach Sorrent fahren, oft übersehen. Ein Fehler: Das mittelalterliche Zentrum auf der Klippe, die Burg Giusso aus dem 12. Jahrhundert und vor allem Giginos Pizza al metro verdienen mindestens einen halben Tag.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wussten Sie das?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">1938</p><p class="text-white/60 text-xs italic mt-1">Jahr der Erfindung der Pizza al metro</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">105 m</p><p class="text-white/60 text-xs italic mt-1">Höhe der Burg über dem Meer</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">21.000</p><p class="text-white/60 text-xs italic mt-1">Einwohner</p></div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Gigino Dell'Amura erfand die Pizza al metro 1938, weil seine Kunden größere Portionen wollten. Seine Trattoria - heute bekannt als Università della Pizza - ist noch immer mit demselben Originalrezept geöffnet.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Sehenswürdigkeiten in Vico Equense</h2>
          <div class="space-y-6">
            {[
              { title: 'Burg Giusso', text: "Eine mittelalterliche Burg aus dem 12. Jahrhundert, 105 m über dem Meer. Heute Schauplatz von Kulturveranstaltungen und Hochzeiten. Von außen kostenlos besichtigbar; Innenbesichtigungen nach Vereinbarung. Bietet einige der schönsten Ausblicke auf den Golf von Neapel." },
              { title: 'Pizza al metro bei Da Gigino', text: "Der Erfinder der Pizza al metro: Gigino Dell'Amura eröffnete 1938 die heutige Trattoria Università della Pizza. Bestellen nach Metern mit verschiedenen Belägen pro Abschnitt. Faire Preise (~€8-12/Meter), abends fast immer Schlange. Via Nicotera 15." },
              { title: 'Dom von Vico Equense', text: "Die Basilika della SS. Annunziata aus dem 14. Jahrhundert, eines der wenigen gotischen Gebäude Kampaniens. Schlichte Fassade, aber Innenraum mit Fresken und mittelalterlicher Krypta. Freier Eintritt, begrenzte Öffnungszeiten." },
              { title: 'Marina di Vico', text: 'Ein kleiner Hafen und Kieselstrand am Fuß der Klippe, von der Stadt aus per Straße erreichbar. Ruhiger als die Strände in Sorrent, mit einigen Strandbädern und Fischerbooten.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Steckbrief - Vico Equense</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Sorrentinische Halbinsel</p>
          <nav class="space-y-1">
            {[
              { href: '/de-de/sorrentinische-halbinsel/sorrent/', label: 'Sorrent' },
              { href: '/de-de/sorrentinische-halbinsel/massa-lubrense/', label: 'Massa Lubrense' },
              { href: '/de-de/sorrentinische-halbinsel/sant-agnello/', label: "Sant'Agnello" },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Halbinsel und Inseln entdecken"
    items={[
      { name: 'Sorrent',        href: '/de-de/sorrentinische-halbinsel/sorrent/',       tag: 'Ideale Basis',  desc: 'Hub für Capri, Neapel und die Küste. Limoncello und Piazza Tasso.' },
      { name: 'Massa Lubrense', href: '/de-de/sorrentinische-halbinsel/massa-lubrense/', tag: 'Natur',         desc: 'Punta Campanella, Marina del Cantone und Nerano-Spaghetti.' },
      { name: 'Capri',          href: '/de-de/inseln/capri/',                             tag: 'Unverzichtbar', desc: 'Blaue Grotte, Faraglioni und die berühmte Piazzetta.' },
      { name: 'Positano',       href: '/de-de/amalfikueste/positano/',                   tag: 'Mode & Aussicht', desc: 'Die bunten Häuser an der Amalfiküste.' },
    ]}
  />

</BaseLayout>
