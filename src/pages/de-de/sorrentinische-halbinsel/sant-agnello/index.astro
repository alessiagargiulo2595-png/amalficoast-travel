---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Sorrentinische Halbinsel', url: '/de-de/sorrentinische-halbinsel/' },
  { name: "Sant'Agnello", url: '/de-de/sorrentinische-halbinsel/sant-agnello/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was gibt es in Sant'Agnello zu sehen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sant'Agnello ist eine Wohngemeinde. Die wichtigsten Sehenswürdigkeiten sind der Parco dei Principi (Hotel mit Gärten von Gio Ponti), die Villa Crawford und der Spaziergang Colli di San Pietro." }
    },
    {
      "@type": "Question",
      "name": "Wie kommt man nach Sant'Agnello?",
      "acceptedAnswer": { "@type": "Answer", "text": "Circumvesuviana ab Neapel: Haltestelle Sant'Agnello (60 Min.), eine Station vor Sorrent. Per Bus: EAV ab Sorrent (~5 Min.). Zu Fuß: ~20 Min. über den Corso Italia." }
    }
  ]
};

const fastFacts = [
  { dt: 'Lage', dd: 'Sorrentinische Halbinsel, NA' },
  { dt: 'Einwohner', dd: '~9.000' },
  { dt: 'Ab Neapel', dd: '~60 Min. (Circumvesuviana)' },
  { dt: 'Ab Sorrent', dd: '~5 Min. (Bus/zu Fuß)' },
  { dt: 'Atmosphäre', dd: 'Wohngebiet, ruhig' },
  { dt: 'Beste Reisezeit', dd: 'Apr-Okt' },
];
---

<BaseLayout
  title="Sant'Agnello 2026: Ruhige Alternative zu Sorrent - Reiseführer"
  description="Reiseführer Sant'Agnello: die ruhige und günstigere Alternative zu Sorrent. Parco dei Principi, Villa Crawford und Spaziergang Colli di San Pietro."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[50vh] flex items-end bg-charcoal overflow-hidden text-white">
    <img src="/images/sorrento-hero.jpg" alt="Sant'Agnello, Italien" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
    <div class="relative z-10 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrentinische Halbinsel · Ruhe & Luxus</p>
        <h1 class="font-serif text-display mb-4">Sant'Agnello</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Nur 5 Minuten von Sorrent entfernt, aber mit der Ruhe eines Wohndorfes. Die ideale Wahl für alle, die auf der Halbinsel übernachten wollen, ohne die Preise des Sorrenter Zentrums zu zahlen.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 text-charcoal">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed">
          Sant'Agnello hat keine Postkarten-Sehenswürdigkeiten, aber etwas Selteneres: Ruhe. Schöne historische Villen, Charme-Hotels und Preise 20-30% niedriger als in Sorrent.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wussten Sie das?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">5 Min.</p><p class="text-white/60 text-xs italic mt-1">ab Sorrent per Bus oder zu Fuß</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">-30%</p><p class="text-white/60 text-xs italic mt-1">Hotelpreis gegenüber Sorrent</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">9.000</p><p class="text-white/60 text-xs italic mt-1">Einwohner</p></div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Der Parco dei Principi in Sant'Agnello, mit Gärten nach Entwurf von Gio Ponti aus den 1960er Jahren, gilt als eines der besten Beispiele rationalistischer Architektur im mediterranen Gastgewerbe.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold mb-6">Sehenswürdigkeiten in Sant'Agnello</h2>
          <div class="space-y-6">
            {[
              { title: 'Parco dei Principi', text: "Das Hotel und die Gärten nach Entwurf von Gio Ponti aus den 1960er Jahren: ein Meisterwerk des rationalistischen Designs mit Pool auf der Klippe. Auch wenn man nicht dort übernachtet, sind die öffentlichen Gärten einen Besuch wert. Zugang über die via Rivo." },
              { title: 'Spaziergang Colli di San Pietro', text: "Ein Panoramaweg, der Sant'Agnello mit Piano di Sorrento entlang der Klippe verbindet, mit Ausblicken auf den Golf von Neapel. Länge: ~3 km. Kostenlos und verkehrsfrei. Am besten bei Sonnenaufgang oder -untergang." },
              { title: 'Villa Crawford', text: "Wohnhaus des amerikanischen Schriftstellers Francis Marion Crawford (1854-1909), der hier 30 Jahre lang historische Romane schrieb. Nur von außen besichtigbar; Privatbesitz. Die Gärten gehören zu den schönsten der Halbinsel." },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
          <p class="font-semibold text-charcoal mb-2">Warum Sant'Agnello als Basis wählen?</p>
          <p class="text-sm text-slate-600 leading-relaxed">Wer mit begrenztem Budget auf der Halbinsel übernachten möchte, findet in Sant'Agnello Hotels mit denselben Ausblicken wie in Sorrent zu günstigeren Preisen. Die Circumvesuviana hält hier, ebenso wie EAV-Busse nach Sorrent (5 Min.) und Massa Lubrense. Kein Mietwagen nötig.</p>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold mb-6">Häufig gestellte Fragen</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Steckbrief - Sant'Agnello</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Sorrentinische Halbinsel</p>
          <nav class="space-y-1">
            {[
              { href: '/de-de/sorrentinische-halbinsel/sorrent/', label: 'Sorrent' },
              { href: '/de-de/sorrentinische-halbinsel/vico-equense/', label: 'Vico Equense' },
              { href: '/de-de/sorrentinische-halbinsel/massa-lubrense/', label: 'Massa Lubrense' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Halbinsel entdecken"
    items={[
      { name: 'Sorrent',        href: '/de-de/sorrentinische-halbinsel/sorrent/',       tag: 'Ideale Basis',  desc: 'Piazza Tasso, Limoncello und Tragflügelboote nach Capri.' },
      { name: 'Capri',          href: '/de-de/inseln/capri/',                             tag: 'Unverzichtbar', desc: 'Blaue Grotte und Faraglioni - 25 Min. mit dem Tragflügelboot.' },
      { name: 'Massa Lubrense', href: '/de-de/sorrentinische-halbinsel/massa-lubrense/', tag: 'Natur',         desc: 'Punta Campanella und der schönste Strand der Halbinsel.' },
      { name: 'Positano',       href: '/de-de/amalfikueste/positano/',                   tag: 'Mode & Aussicht', desc: 'Die bunten Häuser an der Amalfiküste.' },
    ]}
  />

</BaseLayout>
