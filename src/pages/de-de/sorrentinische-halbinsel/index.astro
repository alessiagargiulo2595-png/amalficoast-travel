---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Sorrentinische Halbinsel', url: '/de-de/sorrentinische-halbinsel/' },
];

const borghi = [
  {
    name: 'Sorrent',
    href: '/de-de/sorrentinische-halbinsel/sorrent/',
    desc: 'Die Hauptstadt der Halbinsel: Piazza Tasso, das Kreuzgang von San Francesco, Limoncello und Tragflügelboote nach Capri und Neapel.',
    tag: 'Ideale Basis',
  },
  {
    name: 'Vico Equense',
    href: '/de-de/sorrentinische-halbinsel/vico-equense/',
    desc: 'Geburtsort der Pizza al metro bei Da Gigino und Burg Giusso über dem Meer. Weniger touristisch, authentischer.',
    tag: 'Authentisch',
  },
  {
    name: 'Massa Lubrense',
    href: '/de-de/sorrentinische-halbinsel/massa-lubrense/',
    desc: 'Die südlichste Gemeinde: Punta Campanella, Marina del Cantone und die berühmten Spaghetti aus Nerano.',
    tag: 'Natur & Küche',
  },
  {
    name: "Sant'Agnello",
    href: '/de-de/sorrentinische-halbinsel/sant-agnello/',
    desc: 'Zwischen Sorrent und Piano: historische Villen, Charme-Hotels und außergewöhnliche Ruhe nur wenige Schritte vom Trubel entfernt.',
    tag: 'Ruhe & Luxus',
  },
];

const destinationSchema = {
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": "Sorrentinische Halbinsel",
  "description": "Die Sorrentinische Halbinsel erstreckt sich in den Golf von Neapel zwischen dem Vesuv und der Amalfiküste: Sorrent, Vico Equense, Massa Lubrense und Sant'Agnello.",
  "url": "https://amalficoast-travel.com/de-de/sorrentinische-halbinsel/",
  "touristType": ["Meer", "Kultur", "Gastronomie", "Wandern"],
  "geo": { "@type": "GeoCoordinates", "latitude": 40.6264, "longitude": 14.3757 }
};
---

<BaseLayout
  title="Sorrentinische Halbinsel 2026: Sorrent, Vico Equense, Massa Lubrense"
  description="Reiseführer Sorrentinische Halbinsel: Sorrent, Vico Equense, Massa Lubrense und Sant'Agnello. Anreise mit Circumvesuviana und Tragflügelboot, Sehenswürdigkeiten und Restaurants."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[destinationSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/sorrento-hero.jpg" alt="Sorrentinische Halbinsel, Golf von Neapel" class="absolute inset-0 w-full h-full object-cover opacity-50" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/30 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Startseite</a>
        <span>/</span>
        <span class="text-white">Sorrentinische Halbinsel</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Golf von Neapel · Kampanien</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrentinische Halbinsel</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Das Vorgebirge, das den Golf von Neapel von der Amalfiküste trennt. Das glamouröse, nach Zitronen duftende Sorrent, Vico Equense mit seiner Pizza al metro und das wilde Massa Lubrense, wo Punta Campanella so nah an Capri blickt, dass man es fast berühren kann.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-20">

    <section class="max-w-text">
      <p class="text-xl leading-relaxed text-charcoal">
        Die Sorrentinische Halbinsel ist der natürliche Ausgangspunkt für die gesamte Küste Kampaniens. Von Sorrent aus erreicht man Capri in 25 Minuten mit dem Tragflügelboot, Neapel in 70 Minuten mit der Circumvesuviana, Pompeji in 30 Minuten und Amalfi in weniger als 2 Stunden. Nicht nur ein Reiseziel - der perfekte Hub.
      </p>
      <p class="mt-4 text-slate-600 leading-relaxed">
        Die Circumvesuviana verbindet Neapel mit Sorrent über Herculaneum, Pompeji und Vico Equense. Fähren und Tragflügelboote fahren nach Capri, Ischia, Positano und Neapel. Der SITA-Bus fährt die SS145 bis Amalfi entlang. Von Sorrent aus ist die Welt nur eine Fährfahrt entfernt.
      </p>
    </section>

    <section>
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-serif text-3xl font-semibold text-slate-900">Orte der Halbinsel</h2>
        <p class="text-sm text-slate-400 hidden sm:block">Golf von Neapel, Kampanien</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-6">
        {borghi.map(b => (
          <a href={b.href} class="group bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm hover:border-med-blue/30 hover:shadow-xl transition-all duration-300">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-serif text-xl font-semibold text-slate-900 group-hover:text-med-blue transition-colors">{b.name}</h3>
              <span class="text-[10px] uppercase tracking-wide bg-med-blue/5 text-med-blue px-2 py-1 rounded-full font-medium flex-shrink-0 ml-2">{b.tag}</span>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">{b.desc}</p>
            <p class="text-med-blue text-sm font-medium mt-4 group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
              {b.name} entdecken
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
            </p>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Anreise zur Sorrentinischen Halbinsel</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold mb-3">Zug</p>
          <p class="font-semibold text-charcoal mb-1">Circumvesuviana</p>
          <p class="text-sm text-slate-600 leading-relaxed">Von Neapel Centrale nach Sorrent: ~70 Min., ~€3,90. Hält in Herculaneum, Pompeji, Castellammare, Vico Equense. Takt alle 30-40 Min.</p>
        </div>
        <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold mb-3">Fähre / Tragflügelboot</p>
          <p class="font-semibold text-charcoal mb-1">Ab Neapel oder Amalfi</p>
          <p class="text-sm text-slate-600 leading-relaxed">Sorrent-Neapel Molo Beverello: ~1h mit Tragflügelboot. Sorrent-Capri: ~25 Min. Sorrent-Positano: ~35 Min. (Saison).</p>
        </div>
        <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-semibold mb-3">Bus / Auto</p>
          <p class="font-semibold text-charcoal mb-1">SS145 und SS163</p>
          <p class="text-sm text-slate-600 leading-relaxed">Ab Neapel mit dem Auto ~1h (ohne Stau). SITA-Bus ab Amalfi über SS163 und SS145 bis Sorrent: ~2h. ZTL-Zone im Sorrenter Zentrum im Sommer.</p>
        </div>
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-10">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-8">Die Halbinsel in Zahlen</p>
      <div class="grid sm:grid-cols-4 gap-8 text-center">
        <div><p class="font-serif text-5xl font-bold text-med-gold">70 Min.</p><p class="text-white/60 text-sm mt-2">Neapel - Sorrent mit Circumvesuviana</p></div>
        <div><p class="font-serif text-5xl font-bold text-med-gold">25 Min.</p><p class="text-white/60 text-sm mt-2">Sorrent - Capri mit Tragflügelboot</p></div>
        <div><p class="font-serif text-5xl font-bold text-med-gold">77 km</p><p class="text-white/60 text-sm mt-2">Länge der Sorrentinischen Halbinsel</p></div>
        <div><p class="font-serif text-5xl font-bold text-med-gold">497 m</p><p class="text-white/60 text-sm mt-2">Monte Faito, höchster Punkt</p></div>
      </div>
    </section>

  </div>

</BaseLayout>
