---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Reiserouten', url: '/de-de/reiserouten/' },
  { name: 'Slow Travel - 7 Tage', url: '/de-de/reiserouten/7-tage/slow-travel-doerfer-kulinarik/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was bedeutet Slow Travel an der Amalfiküste?",
      "acceptedAnswer": { "@type": "Answer", "text": "Slow Travel bedeutet an der Küste: mehr Tage im selben Dorf bleiben statt täglich umziehen, in einheimischen Restaurants essen (nicht in Touristenrestaurants), weniger bekannte Wege gehen, den Markt besuchen, lokale Produkte kaufen (Zitronen, Sardellen, Ravello-Rotwein). Das Gegenteil des All-inclusive-Programms." }
    },
    {
      "@type": "Question",
      "name": "Welche sind die am wenigsten touristischen Dörfer an der Amalfiküste?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die am wenigsten besuchten Dörfer sind: Praiano (zwischen Positano und Amalfi, keine ZTL, ruhiger Strand), Cetara (berühmt für Sardellensoße, authentisch), Furore (das Dorf, das nicht existiert, in der Schlucht gebaut), Conca dei Marini (300 Einwohner, bei der Smaragdgrotte). Alle mit dem SITA-Bus auf der SS163 erreichbar." }
    }
  ]
};

const days = [
  { day: 'Tag 1', title: 'Ankunft in Praiano', items: ['Praiano: das zentrale Dorf ohne ZTL. Weniger Touristen als Positano, günstigere Preise.', 'Strand Gavitella: klein, wunderschön, zu Fuß erreichbar.', 'Abendessen in einer der Haftertrattorien: Tagesfang.'] },
  { day: 'Tag 2', title: 'Götterweg', items: ['SITA-Bus nach Amalfi, dann nach Agerola (Wanderstart).', 'Götterweg (Agerola→Nocelle, 8 km, 3–4 Std., anspruchsvoll).', 'Rückkehr nach Praiano über Positano per SITA-Bus.'] },
  { day: 'Tag 3', title: 'Amalfi und Furore', items: ['SITA-Bus nach Amalfi. Morgens: Donnerstagmarkt (regionale Produkte, Mozzarella, Zitronen).', 'Furore: die Fiordo di Furore, auf Wunsch Haltestelle des SITA-Busses. Das Dorf in der Schlucht.', 'Papiermuseum Amalfi: handgeschöpftes Papier seit dem 13. Jahrhundert.'] },
  { day: 'Tag 4', title: 'Ravello und Scala', items: ['Bus nach Ravello (25 Min.). Ruhiger Morgen ohne Menschenmassen um 09:00.', 'Wanderung Ravello→Scala: 4 km durch Olivenhaine und Weinberge, Blick über den Golf. Mittagessen in Scala.', 'Nachmittag: Aperitivo mit Ausblick, Verkostung des Ravello-Rotweins.'] },
  { day: 'Tag 5', title: 'Cetara und Vietri', items: ['SITA-Bus ostwärts nach Cetara (berühmt für DOP-Sardellensoße). Fischmarkt.', 'Besuch des Museums der Sardellensoße und Direktkauf bei Produzenten.', 'Vietri sul Mare: Keramik, Keramikmuseum. Spaziergang am Meer.'] },
  { day: 'Tag 6', title: 'Valle delle Ferriere', items: ['Morgens: Wanderung Valle delle Ferriere ab Amalfi (7 km hin und zurück, 3 Std., leicht–mittel). Wasserfälle und tropische Farne.', 'Nachmittag: Schwimmen in abgeschiedenen Buchten bei Amalfi oder Kajakausflug.', 'Frischer Fisch zum Abendessen in Amalfi.'] },
  { day: 'Tag 7', title: 'Markt und Abreise', items: ['Freier Morgen auf dem lokalen Markt. Typische Produkte kaufen: handgemachter Limoncello, Sardellen, Keramik.', 'Langes Mittagessen in einer Trattoria. Abschied.', 'SITA-Bus nach Salerno (60 Min.) oder Sorrent (90 Min.) für Züge oder Flughafen.'] },
];
---

<BaseLayout
  title="Slow Travel Amalfiküste 7 Tage 2026 | Dörfer, Kulinarik und Wanderwege"
  description="7-Tage-Slow-Travel-Reiseroute an der Amalfiküste: Praiano, Furore, Cetara, Valle delle Ferriere und Götterweg. Authentische Dörfer, lokale Märkte und Gastronomie."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Slow Travel Amalfiküste" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/de-de/reiserouten/" class="hover:text-white transition-colors">Reiserouten</a>
        <span>/</span>
        <span class="text-white">Slow Travel - 7 Tage</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Reiseroute · 7 Tage</p>
        <h1 class="font-serif text-display text-white mb-4">Slow Travel: Dörfer & Kulinarik</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Eine langsame Woche in authentischen Dörfern, auf lokalen Märkten und abseits bekannter Wege. Praiano als Basis, Furore, Cetara, Valle delle Ferriere. Die Amalfiküste ohne Hast, ohne Führungen.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Dauer</p>
          <p class="font-semibold text-charcoal">7 Tage / 6 Nächte</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Basis</p>
          <p class="font-semibold text-charcoal">Praiano oder Amalfi</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Beste Saison</p>
          <p class="font-semibold text-charcoal">Mai–Juni / Sep–Okt</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Tempo</p>
          <p class="font-semibold text-charcoal">Langsam</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Tagesplan</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Produkte, die man nicht verpassen darf</p>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <p class="font-semibold mb-1">Sfusato amalfitano Zitrone g.g.A.</p>
          <p class="text-white/70">Die riesigen Zitronen der Küste: einzigartiges Aroma, dicke Schale. Direkt bei Bauern in Amalfi oder Minori kaufen.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Cetara Sardellensoße (colatura) g.U.</p>
          <p class="text-white/70">Modernes Garum: eine goldene Flüssigkeit aus fermentierten Sardellen. Cetara produziert Italiens feinste g.U.-Version.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Ravello-Wein</p>
          <p class="text-white/70">Weinberge in der Höhe produzieren einen leichten, duftenden Rotwein. Verkostung in Ravellos Weinkellern.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Vietri sul Mare Keramik</p>
          <p class="text-white/70">Italiens Keramikhauptstadt: handbemalte Fliesen, Teller und Kunstwerke. Lokale Kunsthandwerksbetriebe wählen.</p>
        </div>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
