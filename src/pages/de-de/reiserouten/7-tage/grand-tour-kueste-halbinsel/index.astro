---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Reiserouten', url: '/de-de/reiserouten/' },
  { name: 'Grand Tour — 7 Tage', url: '/de-de/reiserouten/7-tage/grand-tour-kueste-halbinsel/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie organisiert man am besten 7 Tage zwischen Amalfiküste und Sorrentinischer Halbinsel?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die klassische Route: 2 Nächte in Neapel (Tage 1–2), dann nach Sorrent oder Amalfi als Basis für die Küste (Tage 3–5), mit einem Capri-Ausflug (Tag 4 oder 5), dann Inseln zum Abschluss (Tage 6–7). Mit SITA-Bus, Circumvesuviana und Tragflügelbooten ist kein Auto nötig." }
    },
    {
      "@type": "Question",
      "name": "Wie viele Nächte in Neapel lohnen sich vor der Küste?",
      "acceptedAnswer": { "@type": "Answer", "text": "1–2 Nächte reichen für Neapel: Spaccanapoli, Nationales Archäologisches Museum, authentische Pizza, Certosa di San Martino. Mit 2 Nächten können Sie Herculaneum oder Pompeji als Tagesausflug einschließen. Neapel ist der natürliche Ankunfts- und Abfahrtspunkt für die gesamte Region." }
    }
  ]
};

const days = [
  { day: 'Tag 1', title: 'Neapel', items: ['Ankunft in Neapel. Spaccanapoli, historisches UNESCO-Zentrum.', 'Nationales Archäologisches Museum: Funde aus Pompeji, Mosaiken, Bronzen.', 'Authentische Pizza im historischen Viertel: Da Michele, Sorbillo oder Brandi.'] },
  { day: 'Tag 2', title: 'Pompeji oder Herculaneum', items: ['Tagesausflug per Circumvesuviana: Ausgrabungen Herculaneum (Morgen, 2–3 Std.) + Vesuv (Nachmittag).', 'Alternative: ganztägig Pompeji (3–4 Std. vor Ort).', 'Rückkehr nach Neapel zum Abendessen.'] },
  { day: 'Tag 3', title: 'Sorrent und Ankunft an der Küste', items: ['Circumvesuviana Neapel→Sorrent (70 Min.). Check-in Sorrent oder Amalfi.', 'Nachmittag: Stadtzentrum Sorrent, Vallone dei Mulini, Marina Grande.', 'SITA-Bus nach Positano (optional, 50 Min.): erster Eindruck der Küste.'] },
  { day: 'Tag 4', title: 'Capri', items: ['Tragflügelboot von Sorrent nach Capri (20–25 Min.). Erste Abfahrt 07:30.', 'Blaue Grotte früh morgens. Anacapri und Monte Solaro per Sessellift.', 'Faraglioni am Nachmittag. Aperitivo auf der Piazzetta. Abends zurück.'] },
  { day: 'Tag 5', title: 'Amalfi und Ravello', items: ['SITA-Bus Sorrent→Amalfi (90 Min.) oder Fähre Sorrent→Amalfi.', 'Dom, Kreuzgang des Paradieses, Papiermuseum.', 'Bus nach Ravello (25 Min.): Villa Rufolo, Villa Cimbrone. Abendessen in Amalfi.'] },
  { day: 'Tag 6', title: 'Positano und Bootsausflug', items: ['SITA-Bus nach Positano (45 Min. von Amalfi). Freier Morgen am Strand.', 'Bootsausflug ab Positano (Smaragdgrotte, Buchten, ~€50–80, 4 Std.).', 'Rückkehr nach Amalfi oder Positano. Abendessen am Hafen.'] },
  { day: 'Tag 7', title: 'Ischia oder Procida und Abreise', items: ['Fähre Amalfi/Neapel→Ischia oder Procida (halbtägiger Ausflug).', 'Procida: Marina Corricella, Terra Murata, Strand Pozzo Vecchio.', 'Rückkehr nach Neapel zur Abreise.'] },
];
---

<BaseLayout
  title="Grand Tour Amalfiküste 7 Tage 2026 | Neapel, Capri, Positano, Amalfi"
  description="Vollständige 7-Tage-Reiseroute: Neapel, Amalfiküste, Capri und Golfinseln. Pompeji, Sorrent, Positano, Amalfi, Ravello — der Grand Tour Süditaliens."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Grand Tour Amalfiküste" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/de-de/reiserouten/" class="hover:text-white transition-colors">Reiserouten</a>
        <span>/</span>
        <span class="text-white">Grand Tour — 7 Tage</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Reiseroute · 7 Tage</p>
        <h1 class="font-serif text-display text-white mb-4">Grand Tour: Küste & Halbinsel</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Eine Woche, um alles zu sehen: Neapel, Pompeji, Sorrent, Capri, Positano, Amalfi, Ravello und eine Insel. Der Grand Tour des Golfes von Neapel — kein Auto, nur öffentliche Verkehrsmittel.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Dauer</p>
          <p class="font-semibold text-charcoal">7 Tage / 6 Nächte</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Basen</p>
          <p class="font-semibold text-charcoal">Neapel + Amalfi/Sorrent</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport</p>
          <p class="font-semibold text-charcoal">Zug + Bus + Fähren</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transportbudget</p>
          <p class="font-semibold text-charcoal">~€80–120</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Tagesplan</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Tipps für den Grand Tour</p>
      <ul class="space-y-2">
        {[
          'Campania Express: Tageskarte für die Circumvesuviana (gültig Neapel–Sorrent–Pompeji–Herculaneum) ~€10.',
          'Capri und Blaue Grotte 1–2 Tage im Voraus buchen (Juli–August).',
          'Basis wechseln: 2 Nächte Neapel + 3 Nächte Amalfi/Sorrent + optional 1 Nacht Insel.',
          'Der Bootsausflug ist flexibel: je nach Wetterbedingungen umlegen.',
          'Bequeme Schuhe mitbringen für Neapels Kopfsteinpflaster und Positanos Treppen.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
