---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Reiserouten', url: '/de-de/reiserouten/' },
  { name: 'Klassische Amalfiküste - 3 Tage', url: '/de-de/reiserouten/3-tage/klassische-amalfikueste/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wo übernachten für 3 Tage an der Amalfiküste?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die besten Stützpunkte sind Amalfi (zentral gelegen, gute Hotel- und B&B-Auswahl, gut mit Bus und Fähre erreichbar) oder Positano (romantischer, aber teurer). Sorrent ist ideal für alle, die eine komfortablere Stadt mit mehr Angeboten und günstigeren Preisen wünschen, mit Tagesausflügen zur Küste." }
    },
    {
      "@type": "Question",
      "name": "3 Tage an der Küste: besser Hoch- oder Nebensaison?",
      "acceptedAnswer": { "@type": "Answer", "text": "Mai–Juni und September–Oktober sind die besten Monate: perfektes Klima, weniger Menschenmassen als im Juli–August, günstigere Preise. Im Juli–August sind die Busse überfüllt, die Parkplätze belegt und die Strände voll. Im Winter schließen viele Betriebe, aber die Dörfer sind ruhig und authentisch." }
    }
  ]
};

const days = [
  {
    day: 'Tag 1',
    title: 'Ankunft und Positano',
    items: [
      'Ankunft in Sorrent oder Amalfi. Check-in.',
      'Nachmittag in Positano: Spiaggia Grande, Via Cristoforo Colombo, Kirche Santa Maria Assunta.',
      'Aperitivo mit Ausblick vom Aussichtspunkt über dem Dorf.',
      'Abendessen in Positano oder Rückfahrt per Bus nach Amalfi.',
    ],
  },
  {
    day: 'Tag 2',
    title: 'Amalfi und Ravello',
    items: [
      'Morgens: Dom von Amalfi, Kreuzgang des Paradieses, Papiermuseum (Amalfitanisches Papier, 13. Jh.).',
      'SITA-Bus nach Ravello (25 Min.). Villa Rufolo, Villa Cimbrone, Panoramablick auf die Küste.',
      'Mittagessen in Ravello, dann nachmittags zurück nach Amalfi.',
      'Abendessen am Hafen von Amalfi: Tagesfang, Büffelmozzarella.',
    ],
  },
  {
    day: 'Tag 3',
    title: 'Praiano und Smaragdgrotte',
    items: [
      'Morgens: SITA-Bus Richtung Positano, Haltestelle Praiano (ruhiger Spaziergang, Strand Gavitella).',
      'Smaragdgrotte bei Conca dei Marini: Eintritt ~€5, spektakuläres grünes Licht.',
      'Freier Nachmittag in Amalfi oder Bootsausflug (Küstenrundfahrt ab Amalfi, ~€40–70 p.P.).',
      'Abfahrt am späten Nachmittag Richtung Neapel/Salerno.',
    ],
  },
];
---

<BaseLayout
  title="Amalfiküste in 3 Tagen 2026 | Klassische Reiseroute"
  description="Klassische 3-Tage-Reiseroute an der Amalfiküste: Positano, Amalfi, Ravello und Smaragdgrotte. Wo übernachten, was besichtigen und wie man sich fortbewegt."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Klassische Amalfiküste" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/de-de/reiserouten/" class="hover:text-white transition-colors">Reiserouten</a>
        <span>/</span>
        <span class="text-white">Klassische Amalfiküste - 3 Tage</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Reiseroute · 3 Tage</p>
        <h1 class="font-serif text-display text-white mb-4">Klassische Amalfiküste</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Drei Tage, um das Beste der Küste zu sehen: Positano, Amalfi, Ravello und die Smaragdgrotte. Die klassische Route, optimiert für Reisende mit öffentlichen Verkehrsmitteln.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Dauer</p>
          <p class="font-semibold text-charcoal">3 Tage / 2 Nächte</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Empfohlene Basis</p>
          <p class="font-semibold text-charcoal">Amalfi oder Positano</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport</p>
          <p class="font-semibold text-charcoal">SITA-Bus + Fähren</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Tagesplan</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Tipps für 3 Tage an der Küste</p>
      <ul class="space-y-2">
        {[
          'Basis in Amalfi: zentrale Lage, günstiger als Positano, gute Bus- und Fährverbindungen.',
          'SITA-Fahrkarten in der Tabak-Trafik en bloc kaufen: spart morgens Zeit.',
          'Ravello hat keine Strände, bietet aber den schönsten Aussichtspunkt der Küste: mindestens einen halben Tag einplanen.',
          'Bootsausflug an Tag 3 ist optional, aber ein Erlebnis: am Vortag buchen.',
          'Im Sommer: bis 9:00 Uhr losfahren, um überfüllte Busse und Warteschlangen zu vermeiden.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
