---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Reiserouten', url: '/de-de/reiserouten/' },
  { name: 'Inseln: Ischia & Procida - 3 Tage', url: '/de-de/reiserouten/3-tage/inseln-ischia-procida/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was ist besser für ein Wochenende: Ischia oder Procida?",
      "acceptedAnswer": { "@type": "Answer", "text": "Das hängt davon ab, was Sie suchen: Ischia ist groß (46 km²), mit Thermalbädern, vielfältigen Stränden, Burgen und Nachtleben - es braucht mindestens 2 Tage. Procida ist klein (4 km²), authentisch, mit ikonischen Pastellfarben, Fischern und wenig Trubel. Mit 3 Tagen können Sie 2 Nächte auf Ischia verbringen und einen Tagesausflug nach Procida machen." }
    },
    {
      "@type": "Question",
      "name": "Wie kommt man von Neapel nach Ischia und Procida?",
      "acceptedAnswer": { "@type": "Answer", "text": "Von Neapel Beverello: Tragflügelboot nach Ischia Porto (~50 Min., €20–24) oder Fähre (~75 Min., €12–14). Nach Procida: Tragflügelboot von Neapel (~35 Min., €15–18). Von Pozzuoli: Medmar/Caremar-Fähre nach Ischia und Procida, günstiger (~€10–13). Im Sommer online buchen." }
    }
  ]
};

const days = [
  {
    day: 'Tag 1',
    title: 'Ankunft auf Ischia',
    items: [
      'Fähre oder Tragflügelboot von Neapel Beverello nach Ischia Porto (50–75 Min.).',
      'Check-in. Nachmittag: Ischia Ponte und das Aragonische Kastell (Eintritt ~€24, 2 Std.).',
      'Strand Maronti (längster der Insel, schwarzer Vulkansand) oder Aperitivo in Forio.',
      'Abendessen in Lacco Ameno oder Ischia Porto: Ischitanische Küche, Kaninchen nach Ischitaner Art.',
    ],
  },
  {
    day: 'Tag 2',
    title: 'Thermalquellen und Strände',
    items: [
      'Morgens: Thermalgärten (Poseidon oder Negombo, ~€35–40 Eintritt). Thermalbecken, Saunen.',
      'Nachmittag: Strand Citara (Forio), einer der schönsten der Insel.',
      'Sonnenuntergang vom Aussichtspunkt Sant\'Angelo, dem malerischsten Dorf Ischias.',
      'Abendessen in Sant\'Angelo oder Rückkehr nach Ischia Porto.',
    ],
  },
  {
    day: 'Tag 3',
    title: 'Tagesausflug nach Procida',
    items: [
      'Tragflügelboot von Ischia nach Procida (20 Min., ~€9). Erste Abfahrt 08:00.',
      'Marina Corricella: der Fischerhafen, pastellfarbene Häuser, Bar am Pier.',
      'Terra Murata: das höchste mittelalterliche Dorf der Insel, Blick über den Golf.',
      'Strand Pozzo Vecchio (der Strand aus "Der Postmann") für ein Mittagsbad.',
      'Rückreise nach Neapel per Tragflügelboot von Procida (35 Min.).',
    ],
  },
];
---

<BaseLayout
  title="Ischia und Procida in 3 Tagen 2026 | Inseln im Golf von Neapel"
  description="3-Tage-Reiseroute auf Ischia und Procida: Thermalbäder, Vulkanstrände, Marina Corricella und Aragonisches Kastell. Anreise, Unterkunft und Sehenswürdigkeiten."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/isole-hero.jpg" alt="Ischia und Procida, Golf von Neapel" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/de-de/reiserouten/" class="hover:text-white transition-colors">Reiserouten</a>
        <span>/</span>
        <span class="text-white">Inseln: Ischia & Procida</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Reiseroute · 3 Tage</p>
        <h1 class="font-serif text-display text-white mb-4">Inseln: Ischia & Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Zwei Inseln, zwei gegensätzliche Charaktere: Ischia groß und thermal, Procida klein und authentisch. Ein perfektes Wochenende im Golf von Neapel, abseits des Trubels der Amalfiküste.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Dauer</p>
          <p class="font-semibold text-charcoal">3 Tage / 2 Nächte</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Basis</p>
          <p class="font-semibold text-charcoal">Ischia Porto oder Forio</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport</p>
          <p class="font-semibold text-charcoal">Tragflügelboote + Inselbus</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Tagesplan</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Praktische Tipps</p>
      <ul class="space-y-2">
        {[
          'Auf Ischia fährt der Rundbus (CS/CD) ganztägig: Einzelfahrt ~€1,50, Tagesticket ~€6.',
          'Thermalgärten online buchen: Poseidon und Negombo sind im Sommer ausgebucht.',
          'Procida als Tagesausflug: erstes Tragflügelboot (08:00) nehmen, um vor der Menge da zu sein.',
          'Ischia in der Nebensaison (Oktober–November): Thermen geöffnet, kaum Touristen, günstige Preise.',
          'Das Tragflügelboot fährt bei starkem Seegang nicht: Wetter vor der Buchung prüfen.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
