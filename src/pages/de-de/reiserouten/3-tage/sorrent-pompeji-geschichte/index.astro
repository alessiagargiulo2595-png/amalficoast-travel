---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Reiserouten', url: '/de-de/reiserouten/' },
  { name: 'Sorrent, Pompeji & Geschichte — 3 Tage', url: '/de-de/reiserouten/3-tage/sorrent-pompeji-geschichte/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie lange braucht man für den Besuch von Pompeji?",
      "acceptedAnswer": { "@type": "Answer", "text": "Für einen gründlichen Besuch benötigen Sie mindestens 3–4 Stunden. Ein wesentlicher Besuch (Forum, Via dell'Abbondanza, Casa del Fauno, Amphitheater) ist in 2–2,5 Stunden möglich. Kommen Sie bei Öffnung (09:00), um Nachmittagshitze und Warteschlangen zu vermeiden. Eintrittspreis ~€18–20, kostenlos für unter 18-Jährige." }
    },
    {
      "@type": "Question",
      "name": "Lohnt sich ein Besuch von Herculaneum zusätzlich zu Pompeji?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, Herculaneum wird von erfahrenen Besuchern oft bevorzugt: kleiner als Pompeji (2 Std. reichen), aber besser erhalten, da es in Schlamm statt Asche begraben wurde. Es gibt ein Kombi-Ticket Pompeji + Herculaneum. Mit 3 Tagen: Herculaneum am Nachmittag von Tag 2, Pompeji am Morgen von Tag 3." }
    }
  ]
};

const days = [
  {
    day: 'Tag 1',
    title: 'Sorrent',
    items: [
      'Ankunft in Sorrent per Circumvesuviana von Neapel (70 Min., ~€3,90).',
      'Altstadt: Piazza Tasso, Dom, Vallone dei Mulini (Vulkanschlucht im Stadtzentrum).',
      'Museo Correale: Römische Artefakte und Stadtansichten aus dem 18. Jahrhundert.',
      'Marina Grande: der Fischerhafen, Abendessen mit Meerblick.',
    ],
  },
  {
    day: 'Tag 2',
    title: 'Herculaneum und Vesuv',
    items: [
      'Circumvesuviana nach Herculaneum Scavi (20 Min. von Neapel, 50 Min. von Sorrent).',
      'Archäologische Stätte Herculaneum: außergewöhnliche Erhaltung, 2–3 Stunden.',
      'Nachmittag: Bus/Shuttle zum Vesuv (Krater auf 1.281 m, ~€12 + Pflichtführer). Blick über den Golf von Neapel.',
      'Rückkehr nach Sorrent per Circumvesuviana.',
    ],
  },
  {
    day: 'Tag 3',
    title: 'Pompeji',
    items: [
      'Circumvesuviana nach Pompei Scavi – Villa dei Misteri (35 Min. von Neapel, 45 Min. von Sorrent).',
      'Ausgrabungen von Pompeji: Forum, Thermen, Amphitheater, Patrizierhäuser. Mindestens 3 Std.',
      'Mittagessen im modernen Pompeji, dann Besuch des Schatzmuseums San Gennaro (optional).',
      'Rückreise nach Neapel oder Sorrent am Nachmittag.',
    ],
  },
];
---

<BaseLayout
  title="Sorrent, Pompeji und Herculaneum in 3 Tagen 2026 | Historische Reiseroute"
  description="3-Tage-Reiseroute mit Geschichte und Meer: Sorrent, Herculaneum, Vesuv und Pompeji. Circumvesuviana-Fahrplan, Eintrittspreise und praktische Tipps."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/sorrento-hero.jpg" alt="Sorrent und Pompeji" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/de-de/reiserouten/" class="hover:text-white transition-colors">Reiserouten</a>
        <span>/</span>
        <span class="text-white">Sorrent, Pompeji & Geschichte</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Reiseroute · 3 Tage</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrent, Pompeji & Geschichte</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Drei Tage Archäologie und Golf von Neapel: Sorrent als Basis, Herculaneum und Vesuv an Tag zwei, Pompeji an Tag drei. Alles per Zug, kein Auto nötig.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Dauer</p>
          <p class="font-semibold text-charcoal">3 Tage / 2 Nächte</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Empfohlene Basis</p>
          <p class="font-semibold text-charcoal">Sorrent</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Schlüsseltransport</p>
          <p class="font-semibold text-charcoal">Circumvesuviana</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Tagesplan</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Praktische Tipps</p>
      <ul class="space-y-2">
        {[
          'Pompeji und Herculaneum: bei Öffnung ankommen (09:00). Nachmittagshitze und Warteschlangen erschweren den Besuch.',
          'Kombi-Ticket Pompeji + Herculaneum: lohnt sich, wenn Sie beide an denselben oder aufeinanderfolgenden Tagen besuchen.',
          'Die Circumvesuviana ist häufig, aber langsam: Sorrent nach Pompei Scavi ~45 Min., von Neapel ~35 Min.',
          'Vesuv: Shuttle-Bus fährt von Herculaneum und Pompeji (saisonale Zeiten prüfen). Ein Führer ist gesetzlich vorgeschrieben.',
          'Sorrent am Abend ist wunderbar: Aperitivo an der Marina Grande, Abendessen auf dem Corso.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
