---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Reiserouten', url: '/de-de/reiserouten/' },
  { name: '1 Tag von Neapel', url: '/de-de/reiserouten/1-tag/amalfikueste-von-neapel/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie kommt man von Neapel zur Amalfiküste für einen Tagesausflug?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die praktischste Route: Zug Neapel→Salerno (40 Min., Trenitalia/Italo, ~€5–12), dann Fähre Travelmar Salerno→Amalfi (45 Min., ~€8, saisonal Apr.–Okt.) oder SITA-Bus ab Salerno. Alternativ: Zug Neapel→Sorrent (Circumvesuviana, 70 Min.) und SITA-Bus Sorrent→Amalfi (90 Min.)." }
    },
    {
      "@type": "Question",
      "name": "Was kann man an einem Tag an der Amalfiküste ab Neapel sehen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Mit einem Tag: Ankunft in Amalfi (Dom, Altstadt, 2h), dann Ravello mit dem Bus (25 Min., Villa Rufolo und Aussichtspunkte, 1,5h), danach zurück nach Amalfi und Bus nach Positano (45 Min., Spaziergang und Strand, 1,5h). Rückfahrt von Positano mit Bus oder Fähre." }
    },
    {
      "@type": "Question",
      "name": "Um wie viel Uhr sollte man von Neapel zur Amalfiküste aufbrechen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Spätestens um 7:30–8:00 Uhr ab Neapel aufbrechen. Der Zug um 7:45 Uhr kommt um 8:25 Uhr in Salerno an; die Travelmar-Fähre fährt gegen 9:00 Uhr ab und erreicht Amalfi vor 10:00 Uhr. Das gibt 8–9 Stunden Besichtigungszeit vor der Rückkehr." }
    }
  ]
};

const schedule = [
  { time: '07:45', place: 'Neapel Centrale', action: 'Zug nach Salerno (Trenitalia/Italo, 40 Min., ~€5–12)', transport: 'train' },
  { time: '09:00', place: 'Salerno', action: 'Fähre Travelmar nach Amalfi (45 Min., ~€8, saisonal Apr.–Okt.)', transport: 'ferry' },
  { time: '09:45', place: 'Amalfi', action: 'Dom Sant\'Andrea, Kreuzgang des Paradieses, Corso und Altstadt (2h)', transport: 'visit' },
  { time: '12:00', place: 'Amalfi → Ravello', action: 'Lokaler SITA-Bus nach Ravello (25 Min., ~€1,50). Mittagessen auf dem Platz.', transport: 'bus' },
  { time: '13:30', place: 'Ravello', action: 'Villa Rufolo, Aussichtspunkt, Villa Cimbrone (1,5h)', transport: 'visit' },
  { time: '15:15', place: 'Ravello → Amalfi → Positano', action: 'Bus nach Amalfi (25 Min.), dann SITA-Bus nach Positano (45 Min.)', transport: 'bus' },
  { time: '16:30', place: 'Positano', action: 'Spaziergang Via Cristoforo Colombo, Spiaggia Grande, Aperitivo (1,5h)', transport: 'visit' },
  { time: '18:30', place: 'Positano → Neapel', action: 'SITA-Bus nach Sorrent (50 Min.), dann Circumvesuviana nach Neapel (70 Min.)', transport: 'bus' },
];

const tips = [
  'Die Travelmar-Fähre ab Salerno ist saisonal (Apr.–Okt.): Im Winter den SITA-Bus ab Salerno nehmen.',
  'SITA-Bustickets in einer Tabakhandlung kaufen, bevor man einsteigt — sie werden nicht an Bord verkauft.',
  'Im Juli–August kann der Bus Amalfi→Positano statt 45 Min. bis zu 1,5h dauern: Puffer einplanen.',
  'Ravello lohnt den Umweg: Villa Rufolo (€7) ist einer der schönsten Aussichtspunkte der Küste.',
  'Die Rückfahrt von Positano mit dem SITA-Bus ist langsam (Kurven + Verkehr) — mindestens 1h nach Sorrent einkalkulieren.',
];

const transportBadge: Record<string, { label: string; cls: string }> = {
  train: { label: 'ZUG', cls: 'bg-orange-100 text-orange-700' },
  ferry: { label: 'FÄHRE', cls: 'bg-blue-100 text-blue-700' },
  bus:   { label: 'BUS', cls: 'bg-green-100 text-green-700' },
  walk:  { label: 'ZU FUSS', cls: 'bg-gray-100 text-slate-500' },
  visit: { label: '', cls: '' },
};
---

<BaseLayout
  title="Amalfiküste in 1 Tag ab Neapel 2026 | Komplette Reiseroute"
  description="Tagesausflug zur Amalfiküste ab Neapel: Amalfi, Ravello und Positano mit Zug, Fähre und SITA-Bus. Fahrzeiten, Preise und praktische Tipps."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <!-- Hero -->
  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Amalfiküste von Neapel" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/de-de/reiserouten/" class="hover:text-white transition-colors">Reiserouten</a>
        <span>/</span>
        <span class="text-white">Amalfiküste ab Neapel — 1 Tag</span>
      </nav>
      <div class="max-w-2xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Reiseroute · 1 Tag</p>
        <h1 class="font-serif text-display text-white mb-4">Amalfiküste von Neapel</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Amalfi, Ravello und Positano an einem Tag ohne Auto. Zug bis Salerno, Fähre bis Amalfi, dann SITA-Bus entlang der Küste. Machbar, spektakulär, günstig.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <!-- Fast Facts Bar -->
    <section class="max-w-4xl mx-auto">
      <div class="grid grid-cols-3 gap-6">
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          <div>
            <p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Dauer</p>
            <p class="font-bold text-charcoal text-lg">1 Tag</p>
          </div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/>
          </svg>
          <div>
            <p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Kosten Transport</p>
            <p class="font-bold text-charcoal text-lg">~€25–40</p>
          </div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
          <div>
            <p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Schwierigkeit</p>
            <p class="font-bold text-charcoal text-lg">Einfach</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Two-column layout -->
    <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">

      <!-- Timeline (col-span-8) -->
      <section class="lg:col-span-8">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Stunde-für-Stunde-Programm</h2>
        <div class="relative">
          <div class="space-y-12 border-l-2 border-slate-200 pl-8 ml-3">
            {schedule.map((s, i) => {
              const badge = transportBadge[s.transport] ?? transportBadge.visit;
              return (
                <div class="relative">
                  <div class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-med-blue ring-4 ring-white shadow-sm"></div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-med-blue font-bold text-sm">{s.time}</span>
                    {badge.label && (
                      <span class={`text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded ${badge.cls}`}>{badge.label}</span>
                    )}
                  </div>
                  <p class="font-semibold text-charcoal text-base leading-snug">{s.place}</p>
                  <p class="text-slate-600 text-sm mt-1 leading-relaxed">{s.action}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- Sidebar (col-span-4) -->
      <aside class="lg:col-span-4 mt-12 lg:mt-0">
        <div class="lg:sticky lg:top-24 space-y-6">

          <!-- Insider Tips -->
          <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 2a7 7 0 0 1 7 7c0 3-1.7 5.2-4 6.4V17a1 1 0 0 1-1 1H10a1 1 0 0 1-1-1v-1.6C6.7 14.2 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M10 21h4M12 17v4"/>
              </svg>
              Insider-Tipps
            </p>
            <ul class="space-y-3">
              {tips.map(tip => (
                <li class="flex gap-2.5 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Schnellkarte -->
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/>
              </svg>
              Schnellkarte
            </p>
            <a href="https://maps.google.com/maps?q=Amalfi,Italy" target="_blank" rel="noopener" class="flex items-center justify-between bg-slate-50 hover:bg-med-blue/5 rounded-xl px-4 py-3 text-sm text-med-blue font-medium transition-colors group">
              Route in Google Maps öffnen
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

        </div>
      </aside>
    </div>

    <!-- FAQ -->
    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
