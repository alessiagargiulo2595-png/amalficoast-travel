---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Reiserouten', url: '/de-de/reiserouten/' },
  { name: 'Trekking Weg der Götter', url: '/de-de/reiserouten/1-tag/weg-der-goetter-trekking/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie organisiert man den Weg der Götter an einem Tag ab Neapel?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ab Neapel mit der Circumvesuviana nach Sorrent (70 Min.), dann SITA-Bus nach Amalfi (90 Min.), dann lokaler Bus nach Agerola (45 Min.). Der Wanderweg Agerola→Nocelle ist 8 km, 3–4h. Von Nocelle lokaler Bus nach Positano (15 Min.), dann SITA-Bus oder Fähre nach Sorrent und Circumvesuviana nach Neapel." }
    },
    {
      "@type": "Question",
      "name": "Muss man den Weg der Götter vorbuchen?",
      "acceptedAnswer": { "@type": "Answer", "text": "In der Hochsaison (Juli–August) ist für den Weg der Götter eine Pflichtbuchung über das Portal des Parco dei Monti Lattari erforderlich. Die Kosten sind symbolisch (~€5). Außerhalb der Saison ist keine Buchung notwendig. Vor der Abreise immer die aktuellen Bedingungen auf der offiziellen Website prüfen." }
    },
    {
      "@type": "Question",
      "name": "Was muss man für den Weg der Götter mitbringen?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pflichtausrüstung: Wanderschuhe (keine Sandalen oder glatten Sneaker), mindestens 1,5 L Wasser, Sonnenschutz, Hut. Der Weg hat weder Brunnen noch Läden. Einen Snack mitnehmen. Im Frühling/Herbst eine leichte Jacke gegen den Wind in der Höhe empfohlen." }
    }
  ]
};

const schedule = [
  { time: '07:00', place: 'Neapel', action: 'Circumvesuviana nach Sorrent (70 Min., ~€3,90)', transport: 'train' },
  { time: '08:15', place: 'Sorrent', action: 'SITA-Bus nach Amalfi (90 Min., ~€3,50) - Abfahrt 8:30 Uhr', transport: 'bus' },
  { time: '10:00', place: 'Amalfi', action: 'Lokaler Bus nach Agerola, Ortsteil San Lazzaro (45 Min., ~€1,50). Wanderbeginn.', transport: 'bus' },
  { time: '11:00', place: 'Agerola (618 m)', action: 'Start Weg der Götter. 8 km, ~500 m Abstieg, EE. Atemberaubende Landschaften.', transport: 'walk' },
  { time: '14:30', place: 'Nocelle', action: 'Ankunft Nocelle. Pause und Mittagessen in einem der lokalen Rifugi/Bars.', transport: 'visit' },
  { time: '15:15', place: 'Nocelle → Positano', action: 'Lokaler Bus nach Positano Zentrum (15 Min., ~€1,50) oder zu Fuß (~1.000 Stufen, 45 Min.)', transport: 'bus' },
  { time: '16:00', place: 'Positano', action: 'Spaziergang, Eis, Strand (1h frei)', transport: 'visit' },
  { time: '17:15', place: 'Positano → Neapel', action: 'SITA-Bus nach Sorrent (~50 Min.), dann Circumvesuviana nach Neapel (70 Min.)', transport: 'bus' },
];

const tips = [
  'Ideale Saison: April–Juni und September–Oktober. Juli–August ist sehr heiß und überfüllt.',
  'Der Bus von Amalfi nach Agerola fährt selten: Abfahrtzeiten am Vorabend auf eavsrl.it prüfen.',
  'Immer in Richtung Agerola→Nocelle gehen: fast durchgehend bergab, Beschilderung für diese Richtung.',
  'Kein Trinkwasser auf dem Weg: mindestens 1,5 L mitbringen. Die letzte Bar ist in Agerola vor dem Start.',
  'Von Nocelle nach Positano: zu Fuß bergab (~1.000 Stufen, 45 Min.) oder mit Bus (15 Min., ~€1,50).',
];

const transportBadge: Record<string, { label: string; cls: string }> = {
  train: { label: 'ZUG', cls: 'bg-orange-100 text-orange-700' },
  ferry: { label: 'FÄHRE', cls: 'bg-blue-100 text-blue-700' },
  bus:   { label: 'BUS', cls: 'bg-green-100 text-green-700' },
  walk:  { label: 'TREKKING', cls: 'bg-red-100 text-red-700' },
  visit: { label: '', cls: '' },
};
---

<BaseLayout
  title="Weg der Götter in 1 Tag ab Neapel 2026 | Trekking-Reiseroute"
  description="Der Weg der Götter (Agerola–Nocelle) an einem Tag ab Neapel: Fahrzeiten, Transportmittel, Buchung und Tipps. 8 km Trekking mit Blick auf die Amalfiküste."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/trekking-hero.jpg" alt="Weg der Götter, Amalfiküste" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/de-de/reiserouten/" class="hover:text-white transition-colors">Reiserouten</a>
        <span>/</span>
        <span class="text-white">Weg der Götter - 1 Tag</span>
      </nav>
      <div class="max-w-2xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Reiseroute · Trekking · 1 Tag</p>
        <h1 class="font-serif text-display text-white mb-4">Trekking Weg der Götter</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          8 km von Agerola nach Nocelle/Positano mit der Amalfiküste zu Füßen. Der spektakulärste Wanderweg Süditaliens - an einem Tag ab Neapel mit öffentlichen Verkehrsmitteln machbar.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-4xl mx-auto">
      <div class="grid grid-cols-4 gap-5">
        <div class="bg-white border border-slate-100 rounded-2xl p-5 text-center shadow-sm flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 12h18M3 12l4-4M3 12l4 4"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Distanz</p><p class="font-bold text-charcoal">8 km</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-2xl p-5 text-center shadow-sm flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Höhenunterschied</p><p class="font-bold text-charcoal">~500 m ↓</p></div>
        </div>
        <div class="bg-white border border-red-100 rounded-2xl p-5 text-center shadow-sm flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Schwierigkeit</p><p class="font-bold text-red-600">EE</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-2xl p-5 text-center shadow-sm flex flex-col items-center gap-2">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Transportmittel</p><p class="font-bold text-charcoal">~€12–18</p></div>
        </div>
      </div>
      <div class="mt-5 bg-red-50 border border-red-200 rounded-2xl px-5 py-4">
        <p class="font-semibold text-red-800 text-sm">Pflichtbuchung Juli–August - Parco dei Monti Lattari (~€5)</p>
      </div>
    </section>

    <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">
      <section class="lg:col-span-8">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Stunde-für-Stunde-Programm</h2>
        <div class="relative">
          <div class="space-y-12 border-l-2 border-slate-200 pl-8 ml-3">
            {schedule.map((s) => {
              const badge = transportBadge[s.transport] ?? transportBadge.visit;
              return (
                <div class="relative">
                  <div class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-med-blue ring-4 ring-white shadow-sm"></div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-med-blue font-bold text-sm">{s.time}</span>
                    {badge.label && <span class={`text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded ${badge.cls}`}>{badge.label}</span>}
                  </div>
                  <p class="font-semibold text-charcoal text-base leading-snug">{s.place}</p>
                  <p class="text-slate-600 text-sm mt-1 leading-relaxed">{s.action}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <aside class="lg:col-span-4 mt-12 lg:mt-0">
        <div class="lg:sticky lg:top-24 space-y-6">
          <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2a7 7 0 0 1 7 7c0 3-1.7 5.2-4 6.4V17a1 1 0 0 1-1 1H10a1 1 0 0 1-1-1v-1.6C6.7 14.2 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M10 21h4M12 17v4"/></svg>
              Insider-Tipps
            </p>
            <ul class="space-y-3">
              {tips.map(tip => (
                <li class="flex gap-2.5 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
              Schnellkarte
            </p>
            <a href="https://maps.google.com/maps?q=Sentiero+degli+Dei+Agerola" target="_blank" rel="noopener" class="flex items-center justify-between bg-slate-50 hover:bg-med-blue/5 rounded-xl px-4 py-3 text-sm text-med-blue font-medium transition-colors group">
              Route in Google Maps öffnen
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </aside>
    </div>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
