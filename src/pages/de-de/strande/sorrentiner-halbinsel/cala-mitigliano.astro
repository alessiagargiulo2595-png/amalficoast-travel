---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Sorrentiner Halbinsel', url: '/de-de/strande#sorrentiner-halbinsel' },
  { name: 'Cala di Mitigliano', url: '/de-de/strande/sorrentiner-halbinsel/cala-mitigliano' },
];

const facts = [
  { label: 'Untergrund', value: 'Kiesel und Felsen' },
  { label: 'Zugang', value: 'Steiler Wanderweg (30 Min.) oder Boot' },
  { label: 'Schatten', value: 'Ab 17:00 Uhr' },
  { label: 'Aussicht', value: 'Faraglioni di Capri (direkt gegenüber)' },
  { label: 'Ideal für', value: 'Wandern, Schnorcheln, Fotografie' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala di Mitigliano",
  "description": "Eine wilde Bucht mit atemberaubendem Blick auf die Faraglioni di Capri. Erreichbar über einen steilen Wanderpfad ab Massa Lubrense oder per Boot.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Massa Lubrense",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Cala di Mitigliano: Geheimer Strand mit Capri-Blick"
  description="Cala di Mitigliano bei Massa Lubrense: die versteckte Bucht mit dem besten Blick direkt auf die Faraglioni di Capri. Anreise per Wanderweg oder Boot."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-mitigliano.jpg"
      alt="Cala di Mitigliano, Massa Lubrense, mit Capri im Hintergrund"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Massa Lubrense · Capri-Blick</p>
      <h1 class="font-serif text-display text-white mb-6">Cala di Mitigliano</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Die geheime Bucht mit den Faraglioni di Capri direkt gegenüber.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Ein Verstecktes Juwel</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Die Cala di Mitigliano ist ein verstecktes Juwel der Sorrentiner Halbinsel. Wegen des anspruchsvollen Zugangswegs kaum besucht, bietet sie einen spektakulären Blick direkt auf die Faraglioni di Capri — zweifellos der schönste Capri-Blick vom Festland. Das Wasser ist kristallklar über Felsengrund, ideal zum Schnorcheln.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Eine natürliche Höhle am Strand spendet Schatten in den heißesten Stunden. Ein echtes Paradies für Wanderer und Entdecker. Beim Sonnenuntergang taucht das Streiflicht die Faraglioni in Gold: Kamera nicht vergessen.
          </p>
        </div>

        <!-- Capri-Blick -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Der Schönste Capri-Blick</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Vom Strand aus hat man einen <strong>direkten und nahen Blick</strong> auf alle drei Faraglioni. Gegen Sonnenuntergang (ab ca. 17:30 Uhr) ist das Licht perfekt. Das ist das Capri-Foto, das Touristen nicht machen — weil man etwas Mühe auf sich nehmen muss, um hierher zu gelangen.
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Wanderweg zu Fuß</p>
              <p class="text-slate-700 font-medium mb-1">Ab Termini, Massa Lubrense</p>
              <p class="text-slate-500 text-sm">30 Min. steiler Abstieg. Wanderschuhe unbedingt erforderlich. Keine Einrichtungen vor Ort.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat</p>
              <p class="text-slate-700 font-medium mb-1">Von Sorrent oder Marina del Cantone</p>
              <p class="text-slate-500 text-sm">Die einfachste Option. Bootsausflug mit Halt an der Bucht buchen.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Die Sorrentiner Halbinsel erkunden</h2>
      <a
        href="/de-de/sorrentinische-halbinsel/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Reiseführer Sorrentiner Halbinsel
      </a>
    </div>
  </section>

</BaseLayout>
