---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Sorrentiner Halbinsel', url: '/de-de/strande#sorrentiner-halbinsel' },
  { name: 'Marina del Cantone', url: '/de-de/strande/sorrentiner-halbinsel/marina-del-cantone' },
];

const facts = [
  { label: 'Untergrund', value: 'Großer Kiesel' },
  { label: 'Zugang', value: 'Sehr einfach (eben)' },
  { label: 'Schatten', value: 'Ab 18:30 Uhr' },
  { label: 'Ausstattung', value: 'Lidos, Restaurants' },
  { label: 'Ideal für', value: 'Familien, Kulinarik, Schnorcheln' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina del Cantone",
  "description": "Ein breiter Kiesstrand in Nerano, berühmt für seine Gastronomie - Geburtsort der Spaghetti alla Nerano - und kristallklares Wasser im Meeresschutzgebiet Punta Campanella.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Nerano",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina del Cantone Nerano: Strand und Restaurants 2026"
  description="Italiens kulinarischster Strand: Marina del Cantone in Nerano verbindet kristallklares Wasser und die authentischen Spaghetti alla Nerano. Reiseführer 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-del-cantone.jpg"
      alt="Marina del Cantone, Nerano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Nerano · Sorrentiner Halbinsel</p>
      <h1 class="font-serif text-display text-white mb-6">Marina del Cantone</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Die kulinarische Hauptstadt am reinsten Meer Kampaniens.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Meer und Haute Cuisine</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Nerano ist die kulinarische Hauptstadt der Sorrentiner Halbinsel. Der Strand von Marina del Cantone ist breit, sauber und bis spät abends sonnig. Das Wasser gehört zu den klarsten Kampaniens, geschützt durch das Meeresschutzgebiet Punta Campanella: Schnorcheln ist hervorragend, mit Posidonia-Wiesen und reichem Meeresleben.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Aber Neranos Weltruhm ist kulinarisch. Hier wurden die <strong>Spaghetti alla Nerano</strong> erfunden - frittierte Zucchini, Provolone del Monaco, Basilikum - und jedes Restaurant am Strand serviert die Originalrezeptur. Perfekt für Familien und alle, die einen schönen Strandtag mit außergewöhnlicher Gastronomie verbinden möchten.
          </p>
        </div>

        <!-- Kulinarischer Tipp -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Kulinarischer Tipp</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            <strong>Lo Cantone</strong> und <strong>Maria Grazia</strong> sind die Tempel der Spaghetti alla Nerano. Tisch morgens reservieren - im Sommer sind Plätze schnell vergeben. Ein Mittagessen am Strand hier ist ein vollständiges gastronomisches Erlebnis.
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">EAV-Bus</p>
              <p class="text-slate-700 font-medium mb-1">Von Sorrent über Massa Lubrense</p>
              <p class="text-slate-500 text-sm">In Nerano aussteigen. Dann 10 Min. zu Fuß zum Strand.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Per Boot</p>
              <p class="text-slate-700 font-medium mb-1">Taxi Boat von Sorrent</p>
              <p class="text-slate-500 text-sm">Direkte Anlandung am Strand. Malerisch und sehr praktisch.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Die Sorrentiner Halbinsel erkunden</h2>
      <a
        href="/de-de/sorrentinische-halbinsel/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Reiseführer Sorrentiner Halbinsel
      </a>
    </div>
  </section>

</BaseLayout>
