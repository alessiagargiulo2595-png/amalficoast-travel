---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Sorrentiner Halbinsel', url: '/de-de/strande#sorrentiner-halbinsel' },
  { name: 'Regina Giovanna', url: '/de-de/strande/sorrentiner-halbinsel/regina-giovanna' },
];

const facts = [
  { label: 'Untergrund', value: 'Felsig' },
  { label: 'Zugang', value: 'Wanderweg 20 Min. (moderat)' },
  { label: 'Schatten', value: 'Ab 18:00 Uhr' },
  { label: 'Ausstattung', value: 'Keine — wilder Strand' },
  { label: 'Ideal für', value: 'Archäologie, Wandern, Schnorcheln' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Bagni della Regina Giovanna",
  "description": "Ein Naturpool und antikes römisches Archäologiegebiet bei Sorrent. Ein verstecktes Juwel zwischen Olivenbäumen, 20 Gehminuten vom Zentrum entfernt.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6450",
    "longitude": "14.3540"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sorrent",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Regina Giovanna Sorrent: Der Naturpool (2026)"
  description="So erreichen Sie die Bagni della Regina Giovanna bei Sorrent. Naturpool zwischen römischen Ruinen, Wanderweg durch Olivenhaine und smaragdgrünes Wasser. Reiseführer 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/regina-giovanna-sorrento.jpg"
      alt="Bagni della Regina Giovanna, Sorrent"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrent · Sorrentiner Halbinsel</p>
      <h1 class="font-serif text-display text-white mb-6">Regina Giovanna</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Der versteckte Naturpool zwischen römischen Ruinen.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Archäologie und Baden</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Die Bagni della Regina Giovanna sind ein archäologisches Freiluftgelände, wo man in smaragdgrünes Wasser eintauchen kann. Ein natürlicher Pool, eingerahmt von den Überresten einer römischen Villa aus dem 1. Jahrhundert — wahrscheinlich die des Publius Vedius Pollio — verbindet sich durch einen Felsenbogen mit dem offenen Meer. 2026 ist es noch immer ein wilder Ort: keine Einrichtungen.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Der Weg zu den Bädern führt durch jahrtausendealte Olivenhaine mit spektakulären Blicken auf den Golf von Neapel und die Insel Capri. Leichte Wanderschuhe mitnehmen und genug Wasser — es gibt weder Bar noch Geschäft in der Nähe.
          </p>
        </div>

        <!-- Wilder Strand -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Wilder Strand</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Keine Einrichtungen, keine Bar, kein Lido. <strong>Wasser, Proviant und Wasserschuhe</strong> mitbringen. Ein authentisch lokaler Ort, hauptsächlich von Einheimischen besucht, die ihn kennen.
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">EAV-Bus ⭐ Empfohlen</p>
              <p class="text-slate-700 font-medium mb-1">Linie «Capo di Sorrento»</p>
              <p class="text-slate-500 text-sm">Ab Piazza Tasso. Dann 15–20 Min. zu Fuß durch die Olivenhaine.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Zu Fuß vom Zentrum</p>
              <p class="text-slate-700 font-medium mb-1">Ca. 40 Minuten</p>
              <p class="text-slate-500 text-sm">Panoramisch aber anspruchsvoll. Via del Capo Richtung Punta del Capo folgen.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Die Sorrentiner Halbinsel erkunden</h2>
      <a
        href="/de-de/sorrentinische-halbinsel/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Reiseführer Sorrentiner Halbinsel
      </a>
    </div>
  </section>

</BaseLayout>
