---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Amalfiküste', url: '/de-de/strande#amalfikuste' },
  { name: 'Spiaggia Grande Positano', url: '/de-de/strande/amalfikuste/spiaggia-grande-positano' },
];

const facts = [
  { label: 'Untergrund', value: 'Sand und Kiesel' },
  { label: 'Zugang', value: 'Einfach (eben)' },
  { label: 'Schatten', value: 'Ab 17:30 Uhr' },
  { label: 'Ausstattung', value: 'Luxus-Lidos, Restaurants, Anleger' },
  { label: 'Ideal für', value: 'Atmosphäre, Glamour, Prominente beobachten' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia Grande di Positano",
  "description": "Der Hauptstrand von Positano, Herzstück des gesellschaftlichen Lebens und der Luxus-Lidos an der Amalfiküste.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6273",
    "longitude": "14.4849"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Positano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Restaurants", "value": "Ja" },
    { "@type": "LocationFeatureSpecification", "name": "Lido", "value": "Ja" }
  ]
};
---

<BaseLayout
  title="Spiaggia Grande Positano 2026: Lidos und Preise"
  description="Das Herz von Positano erleben. Preise 2026 für Liegestühle, Restaurants und wie man die Spiaggia Grande per Boot erreicht."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-grande-positano.jpg"
      alt="Spiaggia Grande di Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Positano · Amalfiküste</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia Grande</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Das glamouröse Herz der Amalfiküste.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Der Glamour der Küste</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Die Spiaggia Grande ist das Zentrum des gesellschaftlichen Lebens in Positano. Mit der vertikalen Stadt als Kulisse - pastellfarbene Häuser, die bis zur Kirche Santa Maria Assunta hinaufklettern - ist das Ambiente einzigartig auf der Welt. 2026 verlangen die Lidos in der Hochsaison Reservierungen mehrere Wochen im Voraus.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Es ist auch der Ausgangspunkt aller Taxi Boats zu den abgelegenen Buchten der Küste. Wer die perfekte Mischung aus Komfort, Signature-Cocktails und exklusiver Atmosphäre sucht, ist hier genau richtig. Der kostenlose öffentliche Bereich im Osten füllt sich nach 9 Uhr schnell.
          </p>
        </div>

        <!-- Preise -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Preise 2026</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Ein Liegestuhl plus Sonnenschirm in den Lidos der Spiaggia Grande kostet im Durchschnitt <strong>35–60 € pro Person</strong>. Die Restaurants direkt am Meer (La Buca di Bacco, La Scalinatella) bieten den Sonnenschirmservice beim Mittagessen inklusive an.
          </p>
          <p class="text-slate-600 leading-relaxed">
            <strong>Parken</strong> im Zentrum Positanos ist dringend abzuraten: Mit der Fähre von Amalfi oder Sorrent anreisen oder mit dem SITA-Bus - Haltestelle Sponda.
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Per Fähre ⭐ Empfohlen</p>
              <p class="text-slate-700 font-medium mb-1">Von Amalfi oder Sorrent</p>
              <p class="text-slate-500 text-sm">Direkte Anlandung am Strand. Panorama vom Wasser aus genießen.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">SITA-Bus</p>
              <p class="text-slate-700 font-medium mb-1">Haltestelle Sponda</p>
              <p class="text-slate-500 text-sm">Steile Treppe zum Strand (ca. 10 Min. zu Fuß).</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Weitere Strände der Amalfiküste entdecken</h2>
      <a
        href="/de-de/strande"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Vollständiger Strandführer
      </a>
    </div>
  </section>

</BaseLayout>
