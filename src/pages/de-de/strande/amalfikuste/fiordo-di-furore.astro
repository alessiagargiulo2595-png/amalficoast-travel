---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Amalfiküste', url: '/de-de/strande#amalfikuste' },
  { name: 'Fiordo di Furore', url: '/de-de/strande/amalfikuste/fiordo-di-furore' },
];

const facts = [
  { label: 'Untergrund', value: 'Kiesel' },
  { label: 'Zugang', value: 'Treppen (~200 Stufen)' },
  { label: 'Schatten', value: 'Ab 14:30 Uhr ⚠️' },
  { label: 'Ausstattung', value: 'Öffentlicher Strand, kostenlos' },
  { label: 'Ideal für', value: 'Fotografie, Paare' },
];

const logistik = [
  { transport: 'SITA-Bus', haltestelle: 'Furore Fiordo', hinweise: 'Linie Amalfi–Positano' },
  { transport: 'Motorroller', haltestelle: 'Ponte Furore', hinweise: 'Begrenztes Parken am Straßenrand' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Fiordo di Furore",
  "description": "Ein ikonischer Strand in einem natürlichen Fjord mit kristallklarem Wasser und einer monumentalen 30 Meter hohen Brücke.",
  "image": "https://amalficoast-travel.com/images/fiordo-furore.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6122",
    "longitude": "14.5534"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Furore",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "publicAccess": "true"
};
---

<BaseLayout
  title="Fiordo di Furore 2026: Reiseführer, Anreise und Sonnenstunden"
  description="So besuchen Sie den Fiordo di Furore 2026. Wann die Sonne den Strand erreicht, Anreise mit dem Bus und Tipps für das perfekte Foto."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/fiordo-furore-hero.jpg"
      alt="Fiordo di Furore, Amalfiküste"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfiküste</p>
      <h1 class="font-serif text-display text-white mb-6">Fiordo di Furore</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Ein Meisterwerk der Natur, in den Fels gehauen.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Eine Ikone der Amalfiküste</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Der Fiordo di Furore gehört zu den ikonischsten Bildern Italiens. Es ist kein gewöhnlicher Strand, sondern eine tiefe natürliche Felsspalte, in die das Meer unter einer monumentalen 30 Meter hohen Brücke eindringt. 2026 ist der Zugang reglementiert, um das Naturdenkmal zu schützen: Der Strand ist klein, und das Wasser ist meist kühler als an der offenen Küste.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Ein Paradies für Fotografen — aber Vorsicht beim Licht: Die Sonne beleuchtet den Fjordgrund nur zur Mittagszeit. Kommen Sie zwischen 11 und 13 Uhr für die besten Aufnahmen. Das Springen von der Brücke ist eine lokale Tradition, für Touristen aber verboten: Genießen Sie die Aussicht von oben, bevor Sie die 200 Stufen zum Strand hinuntergehen.
          </p>
        </div>

        <!-- Schatten-Warnung -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Schatten-Warnung</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Die Sonne erreicht den Strand nur zwischen <strong>11 und 14:30 Uhr</strong>. Außerhalb dieses Zeitfensters liegt der Fjord vollständig im Schatten. Planen Sie Ihren Besuch entsprechend, wenn Sie Sonne zum Schwimmen wünschen. Für perfekte Fotos des türkisfarbenen erleuchteten Wassers empfiehlt sich die Zeit um 11:30 Uhr.
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="overflow-hidden rounded-[2rem] border border-slate-100 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-charcoal text-white">
                  <th class="text-left p-4 font-medium">Verkehrsmittel</th>
                  <th class="text-left p-4 font-medium">Haltestelle</th>
                  <th class="text-left p-4 font-medium">Hinweise</th>
                </tr>
              </thead>
              <tbody>
                {logistik.map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                    <td class="p-4 font-medium text-slate-900">{row.transport}</td>
                    <td class="p-4 text-slate-600">{row.haltestelle}</td>
                    <td class="p-4 text-slate-500">{row.hinweise}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Weitere Strände der Amalfiküste entdecken</h2>
      <a
        href="/de-de/strande"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Vollständiger Strandführer
      </a>
    </div>
  </section>

</BaseLayout>
