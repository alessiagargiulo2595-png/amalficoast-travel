---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Amalfiküste', url: '/de-de/strande#amalfikuste' },
  { name: 'Santa Croce', url: '/de-de/strande/amalfikuste/santa-croce-amalfi' },
];

const facts = [
  { label: 'Untergrund', value: 'Weißer Kiesel' },
  { label: 'Zugang', value: 'Nur per Boot (Taxi Boat)' },
  { label: 'Schatten', value: 'Ab 16:00 Uhr' },
  { label: 'Ausstattung', value: '2 Restaurants mit Lido' },
  { label: 'Ideal für', value: 'Romantischer Ausflug, frischer Fisch' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia di Santa Croce",
  "description": "Exklusiver Strand, der nur per Boot von Amalfi aus erreichbar ist, bekannt für kristallklares Wasser und historische Restaurants.",
  "isAccessibleForFree": "false",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Strand Santa Croce Amalfi: Anreise nur per Boot"
  description="Santa Croce ist der perfekte Ausflug von Amalfi. Nur per Boot erreichbar, mit kristallklarem Wasser und historischen Restaurants mit kostenlosem Shuttle."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/santa-croce-amalfi.jpg"
      alt="Strand Santa Croce, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfi · Nur per Boot</p>
      <h1 class="font-serif text-display text-white mb-6">Santa Croce</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Ein geheimer Rückzugsort wenige Minuten vom Trubel Amalfis entfernt.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Das perfekte Ausflugsziel von Amalfi</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Santa Croce ist das Gegenmittel zum Gedränge in Amalfi im Juli und August. Nur wenige Minuten per Boot vom Hauptanleger entfernt, bietet dieser Strand außergewöhnlich klares Wasser über Felsengrund. Der Kieselstrand liegt geschützt zwischen hohen Klippen, die ihn vor dem Wind abschirmen.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Die beiden historischen Restaurants - Da Gemma und La Caravella - betreiben private Lidos am Strand und bieten ihren Gästen einen kostenlosen Shuttle vom Anleger in Amalfi an. Ideal für alle, die einen „wilden" Strandtag mit dem Komfort eines exzellenten Fischmittags verbinden möchten.
          </p>
        </div>

        <!-- Lokaler Tipp -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Lokaler Tipp</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Reservieren Sie das Mittagessen im Restaurant im Voraus: Sie erhalten den <strong>kostenlosen Shuttle</strong> vom Anleger für ihre Gäste. Das ist die günstigste - und malerischste - Art, Santa Croce zu erreichen.
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat ⭐ Einziger Zugang</p>
              <p class="text-slate-700 font-medium mb-1">Vom Anleger Amalfi</p>
              <p class="text-slate-500 text-sm">Ca. 5 Minuten Fahrt. Kosten: 5–8 € pro Person (Hin- und Rückfahrt).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Restaurant-Shuttle</p>
              <p class="text-slate-700 font-medium mb-1">Kostenlos für Gäste</p>
              <p class="text-slate-500 text-sm">Mittagessen reservieren und die Überfahrt ist im Service inbegriffen.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Weitere Strände der Amalfiküste entdecken</h2>
      <a
        href="/de-de/strande"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Vollständiger Strandführer
      </a>
    </div>
  </section>

</BaseLayout>
