---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Sorrentinische Halbinsel', url: '/de-de/strande#sorrentinische-halbinsel' },
  { name: 'Ieranto', url: '/de-de/strande/sorrentinische-halbinsel/spiaggia-di-ieranto' },
];

const facts = [
  { label: 'Beschaffenheit', value: 'Sand und Kiesel' },
  { label: 'Zugang', value: 'Nur Wanderweg' },
  { label: 'Schwierigkeit', value: 'Moderate Wanderung (30 Min)' },
  { label: 'Atmosphäre', value: 'Wild, unberührt' },
  { label: 'Geeignet für', value: 'Wanderer, Schnorcheln' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia di Ieranto",
  "description": "Ein versteckter Strand, der nur per Wanderweg erreichbar ist. Kristallklares Wasser, wilde Klippen und ein geschütztes Naturschutzgebiet.",
  "image": "https://amalficoast-travel.com/images/spiaggia-di-ieranto.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5700",
    "longitude": "14.3683"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia di Ieranto 2026: Geheimer Strand & Wanderführer"
  description="Ieranto ist ein unberührter Strand in einem geschützten Meeresschutzgebiet. Nur per Wanderweg von Praiano erreichbar. Wanderführer und was dich erwartet."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-di-ieranto.jpg"
      alt="Spiaggia di Ieranto, Sorrentinische Halbinsel"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrentinische Halbinsel · Geschütztes Naturschutzgebiet</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia di Ieranto</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Ein unberührter Strand versteckt in einem geschützten Meeresschutzgebiet, nur zu Fuß erreichbar.</p>
    </div>
  </section>

  <!-- Inhalt + Seitenleiste -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Ein Strand aus einer anderen Zeit</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Spiaggia di Ieranto liegt in einem geschützten Meeresschutzgebiet, einem der ersten, die in Italien gegründet wurden. Seine Abgeschiedenheit und der Schutz haben ihn als natürliches Paradies bewahrt. Eine 30-minütige Wanderung von Praiano wird mit unberührtem Sand, türkisfarbenen Gewässern und einer unberührten Landschaft belohnt.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Der Strand hat eine kleine Süßwasserquelle, die historisch von Hirten genutzt wurde. Das kristallklare Wasser macht ihn zu einem außergewöhnlichen Schnorchelziel. Ein Teil Ihrer Eintrittsgebühr unterstützt den Meeresschutz.
          </p>
        </div>

        <!-- Der Wanderweg -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Der Wanderweg</h2>
          <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
            <div class="space-y-4 text-slate-600">
              <p class="leading-relaxed">
                <strong>Dauer:</strong> 30 Minuten hinab, 40 Minuten hinauf (mit Sonneneinstrahlung auf dem Rückweg)
              </p>
              <p class="leading-relaxed">
                <strong>Schwierigkeit:</strong> Moderat. Gut gepflegter Pfad mit Treppenstufen und freigelegten Bereichen. Gute Schuhe erforderlich.
              </p>
              <p class="leading-relaxed">
                <strong>Startpunkt:</strong> Via Spiaggia del Gavitello in Praiano (Parkplatz vorhanden)
              </p>
              <p class="leading-relaxed">
                <strong>Was man mitbringen sollte:</strong> Wasser, Sonnencreme, bequeme Wanderschuhe. Es gibt keine Einrichtungen am Strand.
              </p>
            </div>
          </div>
        </div>

        <!-- Geschütztes Meeresschutzgebiet -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Geschütztes Meeresschutzgebiet</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            Ieranto ist Teil des Limonium-Meeresschutzgebiets, das gegründet wurde, um dieses außergewöhnliche Ökosystem zu bewahren. Schwimmen und Schnorcheln sind erlaubt, aber Fischen und Ankern sind verboten. Der Eintritt beträgt 2,50 €/Person.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Respektieren Sie das Schutzgebiet: Berühren Sie keine Korallen, nehmen Sie keine Souvenirs mit und verwenden Sie nur riffschonende Sonnencreme.
          </p>
        </div>
      </div>

      <!-- Seitenleiste Schnellfakten -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Schnellfakten
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Entdecken Sie mehr Strände der Sorrentinischen Halbinsel</h2>
      <a
        href="/de-de/strande"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Vollständiger Strandführer
      </a>
    </div>
  </section>

</BaseLayout>
