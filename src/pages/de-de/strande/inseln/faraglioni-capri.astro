---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Inseln der Bucht', url: '/de-de/strande#inseln' },
  { name: 'Faraglioni di Capri', url: '/de-de/strande/inseln/faraglioni-capri' },
];

const facts = [
  { label: 'Typ', value: 'Felsenformationen (kein Strand)' },
  { label: 'Zugang', value: 'Nur per Boot' },
  { label: 'Berühmte Auftritte', value: 'Italienische Filme & Legende' },
  { label: 'Atmosphäre', value: 'Ikonisch, dramatisch' },
  { label: 'Geeignet für', value: 'Fotografie, Schwimmen' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Faraglioni di Capri",
  "description": "Drei ikonische Felsenformationen, die sich 109 Meter aus dem Meer erheben. Ein Symbol Capris und Vedette berühmter italienischer Filme. Zugänglich per Boot zum Schwimmen und Tauchen.",
  "image": "https://amalficoast-travel.com/images/faraglioni-capri.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5447",
    "longitude": "14.2277"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Faraglioni di Capri 2026: Ikonische Felsen & Schwimmführer"
  description="Die Faraglioni sind drei massive Felsenformationen vor der Küste von Capri. Ein italienisches Wahrzeichen, Vedette von Filmen. Anleitung zum Besuch per Boot und was dich erwartet."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/faraglioni-capri.jpg"
      alt="Faraglioni di Capri, Inseln der Bucht"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Inseln der Bucht · Italienisches Symbol</p>
      <h1 class="font-serif text-display text-white mb-6">Faraglioni di Capri</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Drei legendäre Felsenformationen, die seit Jahrhunderten Besucher faszinieren.</p>
    </div>
  </section>

  <!-- Inhalt + Seitenleiste -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Legende aus Stein</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Die Faraglioni di Capri sind drei imposante Felsenformationen, die sich 109 Meter (357 Fuß) aus dem Tyrrhenischen Meer erheben. Sie gehören zu den meistfotografierten Natursehenswürdigkeiten Italiens und sind unmittelbar erkennbare Symbole von Capri und der Küste von Campania. Jede Formation hat einen Namen: Faraglione Grande (die größte), Faraglione di Mezzo (mittlere) und Faraglione di Fuori (äußere).
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Diese dramatischen Felsen haben unzählige Künstler, Filmemacher und Schriftsteller inspiriert. Sie erscheinen im klassischen italienischen Film "Der talentierte Mr. Ripley" und sind in der weltweiten Reisefotografie prominent vertreten. Einer lokalen Legende nach bringt das Durchfahren unter dem natürlichen Bogen der mittleren Felsenformation Glück—und hunderte von Booten tun dies täglich.
          </p>
        </div>

        <!-- Geschichten & Geschichte -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Geschichten & Legende</h2>
          <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
            <div class="space-y-6 text-slate-600">
              <div>
                <p class="font-semibold text-slate-900 mb-2">Die Blaue Eidechse</p>
                <p class="leading-relaxed">
                  Die Legende spricht von der endemischen blauen Eidechse (Podarcis sicula coerulea), die auf den Felsen lebt. Einst verbreitet, sind diese Geschöpfe selten geworden und sind jetzt in einem Meeresschutzgebiet geschützt.
                </p>
              </div>
              <div>
                <p class="font-semibold text-slate-900 mb-2">Im Kino & in der Kunst</p>
                <p class="leading-relaxed">
                  Die Faraglioni erscheinen in zahlreichen italienischen Filmen und dienen als visuelles Symbol der Dolce Vita. Künstler haben sie seit Jahrhunderten gemalt und das Licht und Drama dieser Formationen zu verschiedenen Tageszeiten eingefangen.
                </p>
              </div>
              <div>
                <p class="font-semibold text-slate-900 mb-2">Geologisches Wunderwerk</p>
                <p class="leading-relaxed">
                  Diese Kalksteinformationen sind Überreste alter, durch Wellen und Wind erodierter Klippen. Der natürliche Bogen in der mittleren Felsenformation schafft einen von Booten genutzten Durchgang—ein aufregendes Abenteuer und eine Fotogelegenheit.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Wie man besucht -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Wie Man Besucht</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            Die Faraglioni können nur per Boot besucht werden. Zahlreiche Touren starten täglich von Capri, Positano und anderen Küstenstädten. Touren dauern normalerweise 2-3 Stunden und beinhalten Zeit zum Schwimmen und Schnorcheln um die Felsen.
          </p>
          <p class="text-slate-600 leading-relaxed">
            <strong>Beste Reisezeit:</strong> Mai bis September, wenn das Meer am ruhigsten ist. Boottouren am Morgen bieten das beste Licht für Fotografie. Schwimmen ist erlaubt, und das Wasser ist außergewöhnlich klar, was das Schnorcheln hervorragend macht.
          </p>
        </div>
      </div>

      <!-- Seitenleiste Schnellfakten -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Schnellfakten
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Entdecken Sie mehr der Inseln der Bucht</h2>
      <a
        href="/de-de/strande"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Vollständiger Strandführer
      </a>
    </div>
  </section>

</BaseLayout>
