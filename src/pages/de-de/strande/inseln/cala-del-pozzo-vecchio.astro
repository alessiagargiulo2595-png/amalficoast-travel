---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Golfinseln', url: '/de-de/strande#inseln' },
  { name: 'Cala del Pozzo Vecchio', url: '/de-de/strande/inseln/cala-del-pozzo-vecchio' },
];

const facts = [
  { label: 'Untergrund', value: 'Schwarzer Vulkansand' },
  { label: 'Atmosphäre', value: 'Poetisch und ruhig' },
  { label: 'Zugang', value: '10 Min. zu Fuß ab Bushaltestelle' },
  { label: 'Schatten', value: 'Ab 17:30 Uhr' },
  { label: 'Ideal für', value: 'Filmfans, Poesie, authentische Entspannung' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala del Pozzo Vecchio",
  "description": "Procidas Strand, unsterblich gemacht durch den Film Il Postino von Massimo Troisi. Schwarzer Vulkansand und smaragdgrünes Wasser.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Procida",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Postino-Strand Procida 2026: Cala del Pozzo Vecchio"
  description="Der durch den Film Il Postino unsterblich gewordene Strand. Schwarzer Vulkansand, smaragdgrünes Wasser und das authentischste Procida. Reiseführer 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-pozzo-vecchio-procida.jpg"
      alt="Cala del Pozzo Vecchio, Procida - der Postino-Strand"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Procida · Golfinseln</p>
      <h1 class="font-serif text-display text-white mb-6">Cala del Pozzo Vecchio</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Der durch Massimo Troisi unsterblich gewordene Strand.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Kino Wird Zum Strand</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Der durch Massimo Troisi in <em>Il Postino</em> (1994) unsterblich gemachte Strand. Ein Halbmond aus schwarzem Vulkansand und smaragdgrünem Wasser, der direkt aus dem Film zu stammen scheint. Sobald man ankommt, versteht man sofort, warum Troisi und Regisseur Michael Radford ihn als Hauptschauplatz gewählt haben.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Das ist das authentischste und am wenigsten touristisch erschlossene Gesicht der kampanischen Inseln. Procida hat den Massentourismus von Capri oder Ischia nie erlebt, und dieser Strand bewahrt diese Seele: wenige Besucher, viel Poesie, makellos sauberes Wasser. Perfekt für totale Entspannung und alle, die cinematografische Atmosphären lieben.
          </p>
        </div>

        <!-- Il Postino -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Il Postino (1994)</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Michael Radfords Film mit Massimo Troisi und Philippe Noiret gewann den Oscar für den besten fremdsprachigen Film. Dieser Strand ist das Herzstück des Films. Viele Besucher kommen hierher, um die ikonischen Szenen nachzuerleben - der Briefträger, der am Ufer entlanggeht, die Poesie des Meeres.
          </p>
          <p class="text-slate-600 leading-relaxed italic">
            «Il mondo è bello e tu sei un po' curioso» - Il Postino, 1994
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Linie C1 ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Ab dem Hafen von Procida</p>
              <p class="text-slate-500 text-sm">Haltestelle Pozzo Vecchio. Dann 10 Min. zu Fuß bergab zum Strand.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Zu Fuß</p>
              <p class="text-slate-700 font-medium mb-1">Vom Zentrum Procidas</p>
              <p class="text-slate-500 text-sm">20–25 Minuten. Malerisch und angenehm durch die Gassen der Insel.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Alles über Procida entdecken</h2>
      <a
        href="/de-de/inseln/procida/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Vollständiger Procida-Reiseführer
      </a>
    </div>
  </section>

</BaseLayout>
