---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Golfinseln', url: '/de-de/strande#inseln' },
  { name: 'Marina Piccola Capri', url: '/de-de/strande/inseln/marina-piccola-capri' },
];

const facts = [
  { label: 'Untergrund', value: 'Kiesel und Felsen' },
  { label: 'Zugang', value: 'Bus oder Treppe (Via Mulo)' },
  { label: 'Schatten', value: 'Ab 16:00 Uhr ⚠️' },
  { label: 'Aussicht', value: 'Faraglioni (schönste der Insel)' },
  { label: 'Ideal für', value: 'Exklusive Lidos, Fotografie, Schnorcheln' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina Piccola Capri",
  "description": "Capris berühmtester Strand mit dem nächsten und dramatischsten Blick auf die Faraglioni. Exklusive Lidos und geschützte Gewässer.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5456",
    "longitude": "14.2344"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina Piccola Capri 2026: Reiseführer zum Faraglioni-Strand"
  description="Marina Piccola ist Capris berühmteste Bucht. Reiseführer 2026 mit Lido-Preisen, Anreisemöglichkeiten und dem schönsten Faraglioni-Blick."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-piccola-capri.jpg"
      alt="Marina Piccola, Capri, mit den Faraglioni im Hintergrund"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Capri · Golfinseln</p>
      <h1 class="font-serif text-display text-white mb-6">Marina Piccola</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Die Faraglioni scheinen zum Greifen nah.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Die Legende von Capri</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina Piccola ist die geschützte Bucht mit Capris berühmtesten Lidos. Von hier erscheinen die Faraglioni - die drei ikonischen Felsen, die aus dem Meer ragen - zum Greifen nah: Es ist der dramatischste und meistfotografierte Blick der Insel.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            2026 ist der öffentliche Strandbereich minimal, daher empfiehlt sich die Reservierung in einem Lido wie <strong>La Canzone del Mare</strong> (dem historischsten, 1932 von Gracie Fields gegründet). Die Gewässer sind geschützt und ideal zum Schnorcheln.
          </p>
        </div>

        <!-- Schatten-Warnung -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Schatten-Warnung</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Marina Piccola liegt <strong>ab ca. 16 Uhr</strong> im Schatten der umliegenden Berge. Wer nachmittags Sonne möchte, sollte den Strand von Marina Grande oder Lidos auf der anderen Inselseite in Betracht ziehen. Morgen und früher Nachmittag sind die besten Zeiten.
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Orangener Bus ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Vom Zentrum Capri</p>
              <p class="text-slate-500 text-sm">Direktlinie Marina Piccola. Günstig und häufig.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Zu Fuß via Via Mulo</p>
              <p class="text-slate-700 font-medium mb-1">15 Minuten Abstieg</p>
              <p class="text-slate-500 text-sm">Panoramisch. Die Insellandschaft während des gesamten Weges genießen.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Alles über Capri entdecken</h2>
      <a
        href="/de-de/inseln/capri/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Vollständiger Capri-Reiseführer
      </a>
    </div>
  </section>

</BaseLayout>
