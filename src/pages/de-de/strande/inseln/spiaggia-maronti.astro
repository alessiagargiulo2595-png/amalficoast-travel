---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Strände', url: '/de-de/strande' },
  { name: 'Golfinseln', url: '/de-de/strande#inseln' },
  { name: 'Spiaggia dei Maronti', url: '/de-de/strande/inseln/spiaggia-maronti' },
];

const facts = [
  { label: 'Untergrund', value: 'Vulkansand' },
  { label: 'Länge', value: '3 km (längster Strand der Insel)' },
  { label: 'Besonderheit', value: 'Natürliche heiße Fumarolen' },
  { label: 'Schatten', value: 'Ab 19:00 Uhr' },
  { label: 'Ideal für', value: 'Natürliche Thermalbehandlung, Familien, Entspannung' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia dei Maronti",
  "description": "Ischias Vulkanstrand, der längste der Insel (3 km), bekannt für natürliche heiße Fumarolen und unterirdische Thermalquellen.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Barano d'Ischia",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia dei Maronti Ischia 2026: Fumarolen und heißer Sand"
  description="Die Maronti sind Ischias längster Strand (3 km) mit natürlichen Thermalfumarolen. Reiseführer 2026: Anreise, Erwartungen und praktische Tipps."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-maronti-ischia.jpg"
      alt="Spiaggia dei Maronti, Ischia"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Ischia · Golfinseln</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia dei Maronti</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Drei Kilometer heißer Sand, beheizt vom Vulkan.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Natürliches Thermalvergnügen</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Die Maronti bieten ein einzigartiges Erlebnis in Italien. Der Strand ist riesig - drei Kilometer dunkler Vulkansand - und der Sand selbst wird durch die vulkanische Erdwärme über <strong>Fumarolen</strong> erhitzt: heiße Dampfstrahlen, die aus dem Sand aufsteigen und stellenweise Temperaturen von über 60 °C erreichen.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Perfekt für Wanderer und alle, die dem Trubel der Häfen entfliehen möchten. Die riesige Ausdehnung garantiert, dass man auch im August immer ein ruhiges Eckchen findet. Das Wasser ist ruhig und ideal für Familien mit kleinen Kindern.
          </p>
        </div>

        <!-- Fumarolen -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3z"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Die Fumarolen</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Die Fumarolen befinden sich im mittleren Teil des Strandes (Zone Fumarole Beach). Man kann die Füße in den heißen Sand vergraben für ein kostenloses natürliches Thermalerlebnis. <strong>Nicht zu nahe an die Dampfstrahlen herantreten</strong>: Die Temperaturen können sehr hoch sein. Kinder müssen in diesem Bereich beaufsichtigt werden.
          </p>
        </div>

        <!-- Anreise -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Anreise</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Linie 5</p>
              <p class="text-slate-700 font-medium mb-1">Ab Ischia Porto</p>
              <p class="text-slate-500 text-sm">In Barano aussteigen. Dann Abstiegsweg zum Strand (15 Min.).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Ab Sant'Angelo</p>
              <p class="text-slate-500 text-sm">5 Minuten per Boot. Malerisch und praktisch. Direkte Anlandung am Strand.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Kurzinfos -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Kurzinfos
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/strande"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Strände
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Alles über Ischia entdecken</h2>
      <a
        href="/de-de/inseln/ischia/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Vollständiger Ischia-Reiseführer
      </a>
    </div>
  </section>

</BaseLayout>
