---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocalePath } from '../../i18n/translations';
import { homeContent } from '../../i18n/content';

const lang = 'de-de';
const t = getTranslations(lang);
const content = homeContent[lang];

const townImages: Record<string, string> = {
  positano: '/images/positano-hero.jpg',
  amalfi: '/images/amalfi-hero.jpg',
  ravello: '/images/ravello-hero.jpg',
  praiano: '/images/praiano-hero.jpg',
  maiori: '/images/maiori-hero.jpg',
  minori: '/images/minori-hero.jpg',
};
---

<BaseLayout
  title={t.meta.destinations_title}
  description={t.meta.destinations_description}
  lang={lang}
  pageKey="destinations"
>
  <!-- Hero -->
  <section class="relative bg-charcoal text-white py-20 overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Amalfiküste" class="absolute inset-0 w-full h-full object-cover opacity-20" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-charcoal/80"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-white/80 text-sm uppercase tracking-[0.3em] mb-3">Amalfiküste</p>
      <h1 class="text-4xl md:text-5xl font-bold font-serif mb-4">Städte & Reiseziele</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">Vom glamourösen Positano bis zum ruhigen Cetara: jeder Ort an der Amalfiküste hat einen einzigartigen Charakter.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-lg text-slate-600 leading-relaxed">
      Die Amalfiküste ist kein einzelnes Reiseziel, sondern eine Reihe außergewöhnlich unterschiedlicher Orte, die sich auf 50 Kilometern Steilküste aneinanderreihen. Jeder hat seine eigene Geschichte, Architektur und seinen eigenen Charakter. Positano zieht Modebewusste und Fotografen an; Amalfi bewahrt die Monumente einer Seerepublik, die einst eine Weltmacht war; Ravello lebt für Musik und Gärten; kleinere Orte wie Praiano, Cetara und Vietri bieten ein authentisches Italien abseits der Touristenströme.
    </p>
  </section>

  <!-- Towns -->
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {content.towns.map((town, i) => (
          <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 items-center`}>
            <div class="lg:w-1/2">
              <div class="relative rounded-[2rem] h-64 overflow-hidden shadow-lg">
                <img src={townImages[town.slug] ?? '/images/costiera-hero.jpg'} alt={town.name} class="w-full h-full object-cover" loading="lazy" referrerpolicy="no-referrer"/>
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <p class="absolute bottom-4 left-5 text-white font-serif font-bold text-2xl">{town.name}</p>
              </div>
            </div>
            <div class="lg:w-1/2">
              <h2 class="text-3xl font-bold font-serif text-slate-900 mb-2">{town.name}</h2>
              <p class="text-med-blue font-medium mb-4">{town.tagline}</p>
              <p class="text-slate-600 leading-relaxed mb-6">{town.description}</p>
              <div>
                <h3 class="font-semibold text-slate-900 mb-3">Sehenswürdigkeiten:</h3>
                <ul class="space-y-2">
                  {town.highlights.map(h => (
                    <li class="flex items-center gap-2 text-slate-600 text-sm">
                      <svg class="w-4 h-4 text-med-blue flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      {h}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fortbewegung zwischen den Orten -->
  <section class="bg-med-blue py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-serif text-slate-900 mb-6">Fortbewegung zwischen den Orten</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-3xl mb-3">⛴️</div>
          <h3 class="font-bold text-slate-900 mb-2">Fähre</h3>
          <p class="text-slate-600 text-sm">Die schönste und oft schnellste Möglichkeit. Fähren verbinden Positano, Amalfi und Salerno von April bis Oktober.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-3xl mb-3">🚌</div>
          <h3 class="font-bold text-slate-900 mb-2">SITA Bus</h3>
          <p class="text-slate-600 text-sm">Öffentlicher Bus fährt das ganze Jahr auf der SS163. Günstig, aber in der Hochsaison langsam. Tickets an Bord oder in Tabakläden.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-3xl mb-3">🚗</div>
          <h3 class="font-bold text-slate-900 mb-2">Privatauto</h3>
          <p class="text-slate-600 text-sm">Nicht empfohlen im Juli und August. Im Frühling und Herbst praktisch, aber Parkplätze sind rar und teuer.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Bereit, Ihre Reise zu planen?</h2>
      <p class="text-slate-600 mb-8">Entdecken Sie unsere empfohlenen Reiserouten für die Amalfiküste.</p>
      <a href={getLocalePath(lang, 'itineraries')}
        class="inline-block bg-med-blue text-white font-semibold px-8 py-3 rounded-full hover:bg-med-blue transition-colors">
        Reiserouten ansehen
      </a>
    </div>
  </section>
</BaseLayout>
