---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { erlebnisse } from '../../../data/experiences-de';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Erlebnisse', url: '/de-de/erlebnisse/' },
];

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Erlebnisse an der Amalfiküste",
  "description": "Die besten authentischen Erlebnisse an der Amalfiküste und der Sorrentiner Halbinsel: Wandern, Bootstouren, lokale Küche und Handwerk.",
  "url": "https://amalficoast-travel.com/de-de/erlebnisse/",
  "numberOfItems": erlebnisse.length,
  "itemListElement": erlebnisse.map((exp, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": exp.title,
    "url": `https://amalficoast-travel.com${exp.path}`,
  })),
};
---

<BaseLayout
  title="Erlebnisse Amalfiküste 2026 | Wandern, Bootstouren, Kochen"
  description="Die authentischen Erlebnisse an der Amalfiküste, die man nicht verpassen darf: Götterweg, Bootstouren zu den Grotten, kampanische Kochkurse und vieles mehr."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <img
      src="/images/esperienze-hero.jpg"
      alt="Authentische Erlebnisse an der Amalfiküste"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Startseite</a>
        <span>/</span>
        <span class="text-white">Erlebnisse</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Ratgeber 2026</p>
        <h1 class="font-serif text-display text-white mb-4">Erlebnisse</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Jenseits von Stränden und Aussichtspunkten. Entdecken Sie die Amalfiküste durch die Hände ihrer Handwerker, ihre Wanderwege und ihr Meer.
        </p>
      </div>
    </div>
  </section>

  <!-- Erlebnisse-Raster -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {erlebnisse.map((exp) => (
          <a href={exp.path} class="group block">
            <div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden mb-6 shadow-2xl">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-8 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-2">{exp.category}</span>
                <h2 class="font-serif text-2xl font-bold text-white mb-2 leading-tight">{exp.title}</h2>
                <p class="text-white/70 text-sm leading-relaxed">{exp.description}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-2">{exp.subtitle}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Redaktionelle Einleitung -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Warum ein lokales Erlebnis?</h2>
      <p class="text-slate-600 text-lg leading-relaxed mb-6">
        Die Amalfiküste gehört zu den meistfotografierten Orten der Welt. Aber die wahre Seele dieses Territoriums findet sich in den Käsereien der Sorrentiner Halbinsel, den Wanderwegen über Positano, den Meeresgrotten, die nur per Boot erreichbar sind. Diese Erlebnisse bucht man nicht aus einem Touristenkatalog: Man findet sie, indem man die richtigen Menschen kennt.
      </p>
      <p class="text-slate-600 text-lg leading-relaxed">
        Die Erlebnisse, über die wir schreiben, werden nach Authentizität ausgewählt, nicht nach Popularität.
      </p>
    </div>
  </section>

</BaseLayout>
