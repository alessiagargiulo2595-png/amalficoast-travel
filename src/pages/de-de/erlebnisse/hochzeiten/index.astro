---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { erlebnisse } from '../../../../data/experiences-de';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Erlebnisse', url: '/de-de/erlebnisse/' },
  { name: 'Hochzeiten', url: '/de-de/erlebnisse/hochzeiten/' },
];

const facts = [
  { label: 'Art', value: 'Standesamtliche oder kirchliche Trauung' },
  { label: 'Region', value: 'Sorrentiner Halbinsel · Amalfiküste' },
  { label: 'Sprache', value: 'Italienisch, Englisch, weitere auf Anfrage' },
  { label: 'Beste Jahreszeit', value: 'April – Oktober' },
  { label: 'Ideal für', value: 'Destination Wedding, internationale Paare' },
  { label: 'Organisation', value: 'Lokaler Hochzeitsplaner empfohlen' },
];

const otherExperiences = erlebnisse.filter(e => e.id !== 'hochzeiten');

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Hochzeiten an der Amalfiküste und Sorrentiner Halbinsel",
  "description": "Führer zu den schönsten Hochzeitslocations an der Amalfiküste und Sorrentiner Halbinsel: mittelalterliche Kreuzgänge, Klippen-Kirchen und historische Villen für eine unvergessliche Destination Wedding.",
  "areaServed": {
    "@type": "Place",
    "name": "Amalfiküste und Sorrentiner Halbinsel",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "provider": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Hochzeiten Amalfiküste 2026 | Locations, Kirchen & Destination Wedding"
  description="Heiraten an der Amalfiküste und Sorrentiner Halbinsel: die schönsten Orte für standesamtliche und kirchliche Trauungen, vom Kreuzgang San Francesco bis zu Kirchen auf den Klippen."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaService]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/matrimoni-chiostro-hero.jpg"
      alt="Kreuzgang San Francesco, Sorrent - Location für standesamtliche Trauungen"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Wedding · Amalfiküste</p>
      <h1 class="font-serif text-display text-white mb-6">Hochzeiten</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Versprechen zwischen Fels und Meer.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Die Welthauptstadt der Destination Weddings</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Es ist kein Zufall, dass Sorrent und die Amalfiküste zu den begehrtesten Destination-Wedding-Zielen der Welt zählen. Hier ist Schönheit nicht nur ein Detail, sondern eine stille Komplizin: Sie findet sich im goldenen Licht, das die Dörfer beim Sonnenuntergang streichelt, in der Architektur der jahrtausendealten Kirchen und im berauschenden Duft der Orangenblüten, der im Frühling die Luft erfüllt. Hier zu heiraten bedeutet, die eigene Liebesgeschichte in einen legendären Rahmen zu setzen, in dem jede Ansicht eigens für ein unvergessliches Hochzeitsalbum gemalt zu sein scheint.
          </p>
        </div>

        <!-- Standesamtliche Trauung -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Der Zauber der Standesamtlichen Trauung: Geschichte und Natur</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Neben religiösen Feierlichkeiten bietet die Region atemberaubend schöne kommunale Locations für standesamtliche Trauungen, bei denen das Ja-Wort in einem Rahmen gesprochen werden kann, der Geschichte und Natur vereint. Viele Gemeindeverwaltungen haben die Türen historischer Villen und botanischer Gärten geöffnet und so die Bürokratie in einen Moment reiner Poesie verwandelt.
          </p>

          <div class="space-y-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">Der Kreuzgang San Francesco — Sorrent</h3>
              <p class="text-slate-600 leading-relaxed mb-4">
                Zweifellos die ikonischste Location für eine standesamtliche Trauung auf der Sorrentiner Halbinsel. Dieser Kreuzgang aus dem 14. Jahrhundert ist ein architektonisches Juwel, in dem verschiedene Stile — von der Spätgotik bis zur Renaissance — in einer Umarmung aus verflochtenen Bögen und Tuffsteinsäulen verschmelzen. Die Atmosphäre ist intim, fast mystisch, belebt von Kletterpflanzen und Blumen, die die mittelalterlichen Mauern schmücken.
              </p>
              <p class="text-slate-600 leading-relaxed">
                Wenige Schritte vom Kreuzgang entfernt bietet die Villa Comunale eine natürliche Terrasse mit einem atemberaubenden Blick auf Capri — perfekt für die ersten Fotos als frisch Vermählte unmittelbar nach der Zeremonie.
              </p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">Terrassen und Museen</h3>
              <p class="text-slate-600 leading-relaxed">
                Neben dem Kreuzgang bietet Sorrent Locations wie das Museo Correale di Terranova oder die Villa Fondi in Piano di Sorrento, wo Gärten auf den Klippen und archäologische Funde Zeuge eines ewigen Versprechens werden.
              </p>
            </div>
          </div>
        </div>

        <!-- Monumentale Kirchen -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Monumentale Kirchen: Altäre zwischen Himmel und Meer</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Für alle, die von einer religiösen Zeremonie träumen, beherbergt die Küste einige der suggestivsten Gotteshäuser der Welt, wo der Glaube auf den Schwindel der Küste trifft.
          </p>

          <div class="rounded-[2rem] overflow-hidden shadow-xl mb-6">
            <img
              src="/images/chiesa-annunziata-vico.webp"
              alt="Kirche der Santissima Annunziata in Vico Equense, auf einer Klippe über dem Golf von Neapel mit dem Vesuv im Hintergrund"
              class="w-full h-72 object-cover"
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          </div>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Kirche der Santissima Annunziata — Vico Equense</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Oft als "schönste Kirche Italiens" bezeichnet, ist dieses gotische Juwel mit seiner rosa Fassade auf einer Klippe über dem Meer erbaut. Hier das Ja-Wort zu geben bedeutet, den Blick über den gesamten Golf von Neapel mit dem Vesuv am Horizont schweifen zu lassen. Es ist die einzige Kirche der Welt, die buchstäblich über den Wellen zu schweben scheint.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Der Dom von Amalfi — Sant'Andrea</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Für alle, die sich einen triumphalen Einzug wünschen. Seine imposante Treppe und der arabisch-normannische Stil bieten zeitlose Erhabenheit im Herzen der Küste.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Santa Maria Assunta — Positano</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Berühmt für ihre gelb-grüne Majolikadom, die in der Sonne glitzert, nur wenige Schritte vom Hauptstrand entfernt. Perfekt für eine glamouröse, ikonische Hochzeit, die den Geist der Dolce Vita atmet.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Empfänge -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Erlebnisse und Empfänge</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Von den historischen Anwesen Ravello — wie der Villa Cimbrone mit ihrer Terrazza dell'Infinito — bis zu versteckten Buchten, die nur per Boot erreichbar sind, für eine exklusive Party am Meer, sind die Möglichkeiten grenzenlos. Viele Paare empfangen ihre Gäste mit einem typischen Sorrentiner Aperitif in den Zitrusgärten und verwandeln das Hochzeitswochenende in eine gastronomische Entdeckungsreise und Erholungsurlaub.
          </p>
        </div>

        <!-- Insider-Tipp -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Insider-Tipp für das Brautpaar</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Wenn Sie die Santissima Annunziata in Vico Equense wählen, planen Sie den Ausgang aus der Kirche bei Sonnenuntergang: Das Licht, das die rosa Fassade trifft, erzeugt einen magischen Glanz — perfekt für filterfreie Fotos. Für den Kreuzgang San Francesco beachten Sie, dass die Akustik außergewöhnlich ist: Eine Harfe oder ein Streichquartett macht die standesamtliche Trauung zu einem unvergesslichen Erlebnis.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Ein praktischer Tipp für die Braut: Die engen Gassen der Küste sind wunderschön, aber tückisch für Stilettos. Packen Sie ein Paar Luxus-Flats oder Keilschuhe für die Bewegung zwischen den Gassen ein, und behalten Sie die hohen Absätze für den Empfang!
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Auf einen Blick
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/de-de/erlebnisse/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Alle Erlebnisse
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Weitere Erlebnisse -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Weitere Erlebnisse</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
