---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { erlebnisse } from '../../../../data/experiences-de';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Erlebnisse', url: '/de-de/erlebnisse/' },
  { name: 'Mozzarella-Erlebnis', url: '/de-de/erlebnisse/mozzarella-erlebnis/' },
];

const facts = [
  { label: 'Dauer', value: '3–4 Stunden' },
  { label: 'Region', value: 'Sorrentiner Halbinsel' },
  { label: 'Sprache', value: 'Italienisch, Englisch' },
  { label: 'Inbegriffen', value: 'Verkostung, Schürze, Rezepte' },
  { label: 'Richtpreis', value: 'ab €65 pro Person' },
  { label: 'Ideal für', value: 'Paare, Familien, Kochbegeisterte' },
];

const otherExperiences = erlebnisse.filter(e => e.id !== 'mozzarella-erlebnis');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Mozzarella-Erlebnis: Die Kunst des Käsers",
  "description": "Ein authentisches Käse-Erlebnis auf der Sorrentiner Halbinsel. Lernen Sie Mozzarella herzustellen und entdecken Sie den legendären Provolone del Monaco g.U.",
  "location": {
    "@type": "Place",
    "name": "Sorrentiner Halbinsel",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Mozzarella-Erlebnis Sorrentiner Halbinsel 2026 | Kunst des Käsers"
  description="Lernen Sie Mozzarella herzustellen und entdecken Sie Provolone del Monaco g.U. mit einem Käsermeister auf der Sorrentiner Halbinsel."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/mozzarella-provolone-hero.jpg"
      alt="Provolone del Monaco g.U., Sorrentiner Halbinsel"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Kulinarik · Sorrentiner Halbinsel</p>
      <h1 class="font-serif text-display text-white mb-6">Mozzarella-Erlebnis</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Von der zähflüssigen Käsemasse zum gereiften Schatz der Monti Lattari.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Die Kunst des Käsers</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Auf der Sorrentiner Halbinsel ist die Käsehandwerkskunst eine Berufung, die seit Jahrhunderten weitergegeben wird. An diesem Erlebnis teilzunehmen bedeutet nicht nur zu verkosten — es bedeutet, die Rohstoffe zu berühren, die auf den unberührten Weiden der Monti Lattari entstehen. Von der unmittelbaren Frische der Mozzarella bis zur Komplexität des Provolone del Monaco enthüllen wir Ihnen die Geheimnisse der kampanischen Käse-Exzellenz.
          </p>
        </div>

        <!-- Redaktionsbild -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/mozzarella-cagliata.jpg"
            alt="Frische Käsemasse in den Händen des Käsermeisters"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Provolone del Monaco g.U.: Die Geschichte eines legendären Namens</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Wenn Mozzarella die "Königin" ist, dann ist Provolone del Monaco zweifellos der unbestrittene "König" unserer Berge. Aber warum dieser ungewöhnliche Name?
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Die Geschichte geht auf das 18. Jahrhundert zurück, als Hirten, die auf den Monti Lattari lebten, im Morgengrauen zum Hafen von Neapel hinabstiegen, um ihre Produkte zu verkaufen. Um sich auf dem langen Seeweg vor der Feuchtigkeit und Kälte der Nacht zu schützen, hüllten sich die Käser in schwere dunkle Sackleinenmäntel, ähnlich dem Habit eines Mönchs. Als sie auf dem Markt von Neapel ankamen, begannen die Leute, sie vertraut "die Mönche" zu nennen, und folglich wurde der köstliche Käse, den sie mitbrachten, von allen als Provolone del Monaco bekannt.
          </p>

          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-4">Ein striktes Lastenheft</h3>
          <p class="text-slate-600 text-lg leading-relaxed">
            Heute ist dieser Käse durch das g.U.-Siegel geschützt. Er wird ausschließlich aus Kuhmilch hergestellt, von der mindestens 20 % von der Agerolese-Rasse stammen müssen, einer seltenen und wertvollen Rasse, die dem Käse einen einzigartigen Geschmack verleiht: anfangs süß und butterig, aber mit einem pikanten, aromatischen Abgang, der sich mit der Reifung intensiviert (die mindestens 6 Monate dauern muss).
          </p>
        </div>

        <!-- Programm -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Was beim Mozzarella-Erlebnis passiert</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Live-Ziehen</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Sie beobachten den Käsermeister, wie er die Milch direkt vor Ihren Augen in Zöpfe und Bällchen verwandelt.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Selbst Hand anlegen</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Sie haben die Möglichkeit, frische Mozzarella mit Ihren eigenen Händen zu "mozzare" (formen und portionieren) und dabei die Wärme und Konsistenz der zähflüssigen Masse zu spüren.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Reifungsstufen-Verkostung</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Eine geführte Verkostung, die beim frischesten Fior di Latte beginnt und beim Provolone del Monaco g.U. endet, begleitet von lokalem Honig und Sorrentiner Walnüssen.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Insider-Tipp</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Achten Sie beim Verkosten des Provolone del Monaco auf die kleinen Löcher (Occhiature): Sie sollten so groß wie ein Pfefferkorn sein. Aber das wahre Geheimnis liegt im Pairing: Probieren Sie ihn mit einem Glas <strong>kaltem perlenden Gragnano</strong>. Die Bläschen reinigen den Gaumen von der Fülle des Käses und unterstreichen die pikante Note der Agerolese.
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Auf einen Blick
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/de-de/erlebnisse/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Alle Erlebnisse
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Weitere Erlebnisse -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Weitere Erlebnisse</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
