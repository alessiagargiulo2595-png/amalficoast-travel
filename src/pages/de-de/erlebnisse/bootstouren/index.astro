---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Erlebnisse', url: '/de-de/erlebnisse/' },
  { name: 'Bootstouren', url: '/de-de/erlebnisse/bootstouren/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet eine Bootstour an der Amalfiküste?",
      "acceptedAnswer": { "@type": "Answer", "text": "Eine Gruppenbootstour an der Amalfiküste (4-6 Stunden) kostet €50-€80 pro Person. Private Bootsmiete (ohne Skipper) ab €200/Tag für kleine Boote; mit Skipper €400-800/Tag. In Capri kosten Ruderbootfahrten zur Blauen Grotte ~€15." }
    },
    {
      "@type": "Question",
      "name": "Von wo starten die Bootstouren?",
      "acceptedAnswer": { "@type": "Answer", "text": "Bootstouren starten hauptsächlich von: Positano (für die Küste und Capri), Amalfi (für die Küste und Grotten), Sorrent (für Capri und die Küste), Marina Grande di Capri (für Faraglioni und Blaue Grotte). Im Sommer 1-2 Tage im Voraus buchen." }
    },
    {
      "@type": "Question",
      "name": "Werden Bootstouren bei schlechtem Wetter abgesagt?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, alle Bootstouren werden bei rauer See (Wellen über 0,8-1m) oder starkem Wind abgesagt. Absagen sind im April, Oktober und bei Tramontana häufig. Immer die Meeresbedingungen am Vortag auf windguru.cz oder windy.com prüfen." }
    }
  ]
};

const tours = [
  { name: 'Faraglioni-Tour, Capri', from: 'Marina Grande, Capri', duration: '1-2 Stunden', price: '~€18-25 p.P.', highlights: 'Faraglioni, Grotta Verde, Durchfahrt unterm Mezzo-Bogen, Schnorcheln', type: 'Gruppe' },
  { name: 'Blaue Grotte (Ruderboot)', from: 'Marina Grande, Capri', duration: '30 Min. (Warten + Grotte)', price: '~€15 + €14 Eintritt', highlights: 'Einzigartiges blaues Licht, Ruderboote, unvergessliches Erlebnis', type: 'Einzeln' },
  { name: 'Küstentour ab Positano', from: 'Positano, Spiaggia Grande', duration: '4-6 Stunden', price: '~€50-80 p.P.', highlights: 'Smaragdgrotte, Praiano, Amalfi vom Meer, Schnorcheln in versteckten Buchten', type: 'Gruppe' },
  { name: 'Küstentour ab Amalfi', from: 'Amalfi, Hafen', duration: '3-5 Stunden', price: '~€40-70 p.P.', highlights: 'Grotta dello Smeraldo, Positano, unzugängliche Buchten, Mittagessen auf See', type: 'Gruppe' },
  { name: 'Privatboot Sorrent → Capri', from: 'Sorrent, Marina Piccola', duration: 'Ganztag', price: '~€400-800 (ganzes Boot)', highlights: 'Individuelle Route, keine Massen, Schnorcheln, Mittagessen an Bord', type: 'Privat' },
];
---

<BaseLayout
  title="Bootstouren Amalfiküste 2026 | Capri, Positano, Blaue Grotte"
  description="Beste Bootstouren an der Amalfiküste: Capri Faraglioni, Blaue Grotte, Touren ab Positano und Amalfi. Preise, Dauer und Tipps für die richtige Tour."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/capri-hero.jpg" alt="Bootstour, Amalfiküste" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Startseite</a>
        <span>/</span>
        <span class="text-white/60">Erlebnisse</span>
        <span>/</span>
        <span class="text-white">Bootstouren</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Erlebnisse</p>
        <h1 class="font-serif text-display text-white mb-4">Bootstouren</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Die Amalfiküste vom Meer aus ist eine andere Welt: von Land aus unzugängliche Grotten, versteckte Buchten, die Faraglioni direkt über dem Kopf. Von günstigen Gruppentouren bis zu privaten Charterbooten.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Beliebteste Touren</h2>
      <div class="space-y-4">
        {tours.map(t => (
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6 hover:border-med-blue/30 transition-colors">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-semibold text-charcoal text-lg">{t.name}</h3>
              <span class={`text-[10px] uppercase tracking-wide px-2 py-1 rounded-full font-medium flex-shrink-0 ${t.type === 'Privat' ? 'bg-med-cream text-med-gold' : t.type === 'Einzeln' ? 'bg-med-blue/5 text-med-blue' : 'bg-slate-50 text-slate-500'}`}>
                {t.type}
              </span>
            </div>
            <div class="grid sm:grid-cols-3 gap-3 text-sm mb-3">
              <div><span class="text-slate-400">Abfahrt</span><br /><span class="font-medium">{t.from}</span></div>
              <div><span class="text-slate-400">Dauer</span><br /><span class="font-medium">{t.duration}</span></div>
              <div><span class="text-slate-400">Preis</span><br /><span class="font-mono font-medium text-med-blue">{t.price}</span></div>
            </div>
            <p class="text-xs text-slate-500">{t.highlights}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Tipps für die richtige Tour</p>
      <ul class="space-y-2">
        {[
          'Für die Blaue Grotte in Capri: vor 10:00 ankommen. Die Nachmittagsschlange kann 2 Stunden dauern.',
          'Gruppentouren ab Positano sind ideal für Alleinreisende: Leute kennenlernen, Küste sehen, weniger ausgeben.',
          'Mit Familie (Kinder): max. 3-4h-Touren wählen, Schnellboote/Schlauchboote vermeiden (mehr Schaukel).',
          'Die Smaragdgrotte ab Amalfi ist auch zu Fuß erreichbar (€5 Eintritt): kein Tour nötig bei eigenem Transport.',
          'Im Juli-August mindestens 1-2 Tage im Voraus online buchen: Plätze sind schnell ausgebucht.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-gold/50 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>
  </div>

  <CorrelationSlider
    heading="Tourziele entdecken"
    items={[
      { name: 'Capri',    href: '/de-de/inseln/capri/',                 tag: 'Faraglioni',    desc: 'Blaue Grotte, Faraglioni-Tour und unzugängliche Buchten.' },
      { name: 'Positano', href: '/de-de/amalfikueste/positano/',        tag: 'Küstentouren',  desc: 'Ausgangspunkt für Küstentouren nach Osten.' },
      { name: 'Amalfi',   href: '/de-de/amalfikueste/amalfi/',          tag: 'Smaragdgrotte', desc: 'Die Smaragdgrotte und Touren nach Positano.' },
      { name: 'Procida',  href: '/de-de/inseln/procida/',               tag: 'Authentisch',   desc: 'Bootsfahrten rund um die kleine Fischerinsel.' },
    ]}
  />

</BaseLayout>
