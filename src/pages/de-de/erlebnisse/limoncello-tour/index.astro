---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { erlebnisse } from '../../../../data/experiences-de';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Erlebnisse', url: '/de-de/erlebnisse/' },
  { name: 'Limoncello-Tour', url: '/de-de/erlebnisse/limoncello-tour/' },
];

const facts = [
  { label: 'Dauer', value: '2–3 Stunden' },
  { label: 'Region', value: 'Sorrentiner Halbinsel' },
  { label: 'Sprache', value: 'Italienisch, Englisch' },
  { label: 'Inbegriffen', value: 'Zitrusgartenbesuch, Workshop, Verkostung' },
  { label: 'Richtpreis', value: 'ab €55 pro Person' },
  { label: 'Ideal für', value: 'Paare, Familien, Genießer' },
];

const otherExperiences = erlebnisse.filter(e => e.id !== 'limoncello-tour');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Limoncello-Tour: Das goldene Getränk und die Femminiello-Legende",
  "description": "Eine sinnliche Reise durch die Düfte der Sorrenter Zitrone g.g.A. Besuch eines historischen Zitrusgartens, Infusions-Workshop und Verkostung von handwerklichem Limoncello.",
  "location": {
    "@type": "Place",
    "name": "Sorrentiner Halbinsel",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Limoncello-Tour Sorrent 2026 | Femminiello g.g.A. und historischer Zitrusgarten"
  description="Besuchen Sie einen historischen Zitrusgarten auf der Sorrentiner Halbinsel, entdecken Sie das Geheimnis der Femminiello g.g.A.-Zitrone und lernen Sie handwerklichen Limoncello herzustellen."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/limoncello-mercato-hero.jpg"
      alt="Femminiello g.g.A.-Zitronen auf dem Markt, Sorrentiner Halbinsel"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Kulinarik · Sorrentiner Halbinsel</p>
      <h1 class="font-serif text-display text-white mb-6">Limoncello-Tour</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Das goldene Getränk und die Legende der Sorrenter Femminiello g.g.A.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Eine Reise durch die Düfte der g.g.A.-Zitrone</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Durch einen Sorrentiner Zitrusgarten zu spazieren ist nicht nur eine Landwirtschaftstour — es ist ein Eintauchen in ein geschütztes Ökosystem, in dem die Zeit stillzustehen scheint. Hier herrscht der Femminiello, die Zitronensorte, die Sorrent weltweit berühmt gemacht hat und heute das prestigeträchtige g.g.A.-Zeichen (geschützte geografische Angabe) trägt.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Geschichte und Name: Ein jahrtausendealtes Erbe</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Der Name "Femminiello" leitet sich von der außergewöhnlichen Fruchtbarkeit dieser Pflanze ab, die mehrmals im Jahr blüht und Früchte mit einer fast "mütterlichen" Beständigkeit produziert. Ihre Wurzeln reichen bis in die Römerzeit zurück — Fresken, die sie darstellen, wurden sogar in den Ausgrabungen von Pompeji gefunden — aber es waren die Jesuiten-Mönche im 17. Jahrhundert, die den Anbau flächendeckend verbreiteten.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Diese Zitrone ist aus zwei grundlegenden Gründen einzigartig:
          </p>

          <div class="space-y-6">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">Die Pergolen</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Die Pflanzen wachsen unter den typischen "Pagliarelle" (Strohgeflechten), die die Früchte vor Kälte und Wind schützen, die Reifung verzögern und ganzjährig frische Zitronen ermöglichen.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">Der Vulkanboden</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Der fruchtbare Boden der Halbinsel, reich an Mineralien aus den alten Vesuvausbrüchen, verleiht dem Femminiello einen sauren aber ausgewogenen Geschmack und eine Schale, die außergewöhnlich reich an ätherischen Ölen ist.</p>
            </div>
          </div>
        </div>

        <!-- Redaktionsbild -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/limoncello-femminiello.jpg"
            alt="Femminiello g.g.A.-Zitronen handgepflückt auf der Sorrentiner Halbinsel"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Was macht den Femminiello so besonders?</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Im Gegensatz zum Sfusato Amalfitano — seinem "Cousin" von der Amalfiküste, der länger und größer ist — hat der Sorrenter Femminiello eine elliptische Form und mittlere Größe. Seine wahre Magie liegt in der Schale: dick, intensiv duftend und reich an Terpenen. Genau diese gelbe Schicht, die "Zeste", ist es, die — in reinem Alkohol infundiert — das unverwechselbare Aroma des echten Limoncello freisetzt.
          </p>
        </div>

        <!-- Programm -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Was bei einer Limoncello-Tour passiert</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Geführter Spaziergang unter den Pergolen</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Ein Rundgang unter den historischen Strohgeflechten mit dem Guide, der die Geschichte der alten Zitronenanbauersfamilien und die Geheimnisse des g.g.A.-Anbaus erzählt.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Besuch des Infusions-Workshops</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Sie entdecken jede Phase der handwerklichen Herstellung: von der Auswahl und dem Abreiben der Schalen über die Infusion in reinem Alkohol bis hin zum Mischen mit Zuckersirup.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Verkostung</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Ein Schluck eiskalter Limoncello, Zitronenmarmelade auf geröstetem Brot und die berühmte kandierte Schale mit dunkler Schokolade.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Insider-Tipp -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Insider-Tipp</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Achten Sie während der Tour auf die Schalenfarbe. Der perfekte Femminiello muss ein leuchtendes Zitronengelb haben. Wenn Sie die Schale leicht mit dem Daumen reiben und der Duft stundenlang an Ihren Fingern haftet, haben Sie das Gold von Sorrent gefunden. Noch ein Geheimnis? Echte Sorrentiner essen auch den weißen Teil (das Albedo): Er ist süß, schwammig und vitaminreich!
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Auf einen Blick
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/de-de/erlebnisse/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Alle Erlebnisse
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Weitere Erlebnisse -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Weitere Erlebnisse</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
