---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { erlebnisse } from '../../../../data/experiences-de';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Erlebnisse', url: '/de-de/erlebnisse/' },
  { name: 'Sterne-Restaurants', url: '/de-de/erlebnisse/sterne-restaurants/' },
];

const facts = [
  { label: 'Führer', value: 'Michelin 2026' },
  { label: 'Region', value: 'Sorrentiner Halbinsel · Amalfiküste' },
  { label: 'Top-Adresse', value: 'Quattro Passi - 3 Michelin-Sterne' },
  { label: 'Reservierung', value: '3–4 Monate im Voraus (Wochenenden)' },
  { label: 'Ideal für', value: 'Foodies, besondere Anlässe, Jahrestage' },
  { label: 'Nicht verpassen', value: 'Besuch des in den Fels gehauenen Weinkellers' },
];

const otherExperiences = erlebnisse.filter(e => e.id !== 'sterne-restaurants');

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Michelin-Sterne-Restaurants 2026 - Sorrent und Amalfiküste",
  "description": "Das Ranking 2026 der besten Michelin-Sterne-Restaurants zwischen Sorrentiner Halbinsel und Amalfiküste: Quattro Passi, Il Buco, Don Alfonso 1890 und mehr.",
  "url": "https://amalficoast-travel.com/de-de/erlebnisse/sterne-restaurants/",
  "numberOfItems": 8,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Quattro Passi - Nerano (3 Michelin-Sterne)" },
    { "@type": "ListItem", "position": 2, "name": "Il Buco - Sorrent" },
    { "@type": "ListItem", "position": 3, "name": "Lorelei - Sorrent" },
    { "@type": "ListItem", "position": 4, "name": "Terrazza Bosquet - Sorrent" },
    { "@type": "ListItem", "position": 5, "name": "Don Alfonso 1890 - Sant'Agata sui Due Golfi" },
    { "@type": "ListItem", "position": 6, "name": "La Caravella - Amalfi" },
    { "@type": "ListItem", "position": 7, "name": "Glicine - Positano" },
    { "@type": "ListItem", "position": 8, "name": "Zass e Li Galli - Positano" },
  ],
};
---

<BaseLayout
  title="Michelin-Sterne-Restaurants Amalfiküste 2026 | Michelin-Führer"
  description="Führer zu den besten Michelin-Sterne-Restaurants 2026 zwischen Sorrent und der Amalfiküste: Quattro Passi (3 Sterne), Il Buco, Don Alfonso 1890 und die Perlen von Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/stellati-hero.jpg"
      alt="Fine-Dining-Gericht in einem Michelin-Sterne-Restaurant an der Amalfiküste"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Fine Dining · Amalfiküste</p>
      <h1 class="font-serif text-display text-white mb-6">Sterne-Restaurants</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Das Firmament des Geschmacks 2026.</p>
    </div>
  </section>

  <!-- Inhalt + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Haupttext -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Eine Pilgerreise ins Herz der gastronomischen Exzellenz</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Wenn es ein Land gibt, in dem die Haute Cuisine zu Hause ist, dann ist es die Region rund um Sorrent und die Amalfiküste. Im Jahr 2026 bestätigt der Michelin-Führer dieses Territorium als das leuchtendste Italiens: Kampanien liegt nicht nur an der Spitze für die Gesamtzahl der Sterne, sondern hält auch einen einzigartigen Rekord für gastronomische Dichte.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Obwohl es eine der flächenmäßig kleinsten Regionen Italiens ist, beherbergt Kampanien etwa <strong>12 % der Sterne-Restaurants auf der gesamten Halbinsel</strong> und übertrifft in der Konzentration pro Quadratkilometer Geschmacksgiganten wie Piemont und Lombardei. In diesem kleinen Landstrich über dem Meer ist kulinarische Exzellenz nicht die Ausnahme, sondern eine echte territoriale Berufung.
          </p>
        </div>

        <!-- Das Ranking 2026 -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Das Ranking 2026: Die Stars</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Die gastronomische Landschaft 2026 sieht die großen Namen bestätigt, die diese Zone zu einem Pilgerziel für Foodies aus aller Welt gemacht haben.
          </p>

          <div class="space-y-6">

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Quattro Passi — Nerano, Massa Lubrense</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Der absolute Gipfel</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                Das legendäre Quattro Passi in Nerano behält seine prestigeträchtigen 3 Michelin-Sterne — das einzige Restaurant in der Region, das den Weltgipfel erreicht. Seine Küche ist eine Hymne auf die Reinheit der Meeresaromen, reinterpretiert mit tadelloser Technik.
              </p>
            </div>

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Die Sterne von Sorrent</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Eine Stadt, drei unverzichtbare Adressen</span>
                </div>
              </div>
              <div class="space-y-4 mt-4">
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Il Buco</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Untergebracht in einer eindrucksvollen ehemaligen Klosterrampe, wo die Geschichte des Gebäudes mit der territorialen Küche in Dialog tritt.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Lorelei</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Avantgardistische Küche auf einer atemberaubenden Terrasse: zwei sensorische Erlebnisse in einem.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Terrazza Bosquet</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Ikonischer Geschmackstempel im Excelsior Vittoria: Luxus, Geschichte und Haute Cuisine unter einem Dach.</p>
                </div>
              </div>
            </div>

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Ikonen und Neuentdeckungen</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Von Sant'Agata bis Positano</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                Man kann nicht sagen, die Küste erlebt zu haben, ohne <strong>Don Alfonso 1890</strong> in Sant'Agata sui Due Golfi zu erwähnen, einen Pionier der Nachhaltigkeit, oder die Perlen von Amalfi und Positano: <strong>La Caravella</strong>, <strong>Glicine</strong>, <strong>Zass</strong> und <strong>Li Galli</strong>.
              </p>
            </div>

          </div>
        </div>

        <!-- Jenseits des Tellers -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Ein Erlebnis jenseits des Tellers</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            In einem Sterne-Restaurant zwischen Sorrent und Amalfi zu speisen ist nicht nur ein Abendessen, sondern eine sensorische Reise. Sie reicht von der Architektur der Gerichte bis zur akribischen Sorgfalt für "Null-Kilometer"-Zutaten aus den Hängegärten, die die Küste dominieren. Hier trifft Luxus auf das Land: Es ist nicht ungewöhnlich, schlichte Zutaten wie Sardellen oder Zitronen in Meisterwerke der hohen Gastronomik verwandelt zu sehen.
          </p>
        </div>

        <!-- Insider-Tipp -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Insider-Tipp</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Viele dieser Spitzenrestaurants haben historische Weinkeller, die direkt in den Kalkstein oder Tuff gehauen wurden. Auch wenn Sie kein Sommelier sind, fragen Sie immer um eine Besichtigung: Es sind echte unterirdische Museen mit seltenen Jahrgängen der "heroischen Weine" von den Terrassen-Weinbergen in Furore und Tramonti.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Ein Geheimtipp der Einheimischen? Für die bekanntesten Restaurants der Küste müssen Wochenendreservierungen mindestens <strong>3–4 Monate im Voraus</strong> gemacht werden: Der Ausblick ist inklusive, aber den Tisch muss man sich verdienen!
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Auf einen Blick
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/de-de/erlebnisse/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Alle Erlebnisse
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Weitere Erlebnisse -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Weitere Erlebnisse</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
