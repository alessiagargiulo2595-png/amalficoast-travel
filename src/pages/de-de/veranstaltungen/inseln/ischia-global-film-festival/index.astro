---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Ischia Global Film & Music Fest', url: '/de-de/veranstaltungen/inseln/ischia-global-film-festival/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Ischia Global Film & Music Festival 2026",
  "startDate": "2026-07-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Lacco Ameno & Ischia Porto",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ischia",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/inseln/ischia-global-film-festival/"
};

const facts = [
  { dt: 'Zeitraum', dd: 'Juli 2026' },
  { dt: 'Orte', dd: 'Lacco Ameno & Ischia Porto' },
  { dt: 'Typ', dd: 'Film- & Musikfestival' },
  { dt: 'Atmosphäre', dd: 'Glamour & mediterrane Sonne' },
  { dt: 'Ab Neapel', dd: 'Fähre, ca. 80 min' },
];
---

<BaseLayout
  title="Ischia Global Film & Music Festival 2026 – Hollywood-Glamour auf der Insel"
  description="Das Ischia Global Film & Music Festival im Juli 2026. Weltpremieren, Preisverleihungen und internationale Stars auf den Plätzen und in den Luxushotels von Ischia."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ischia-hero.jpg"
      alt="Ischia Global Film & Music Festival"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">Juli 2026</span>
        <span class="text-white/70 text-sm">Ischia, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Ischia Global Film & Music Fest</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Hollywood-Glamour unter der mediterranen Sonne der Insel Ischia.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Das Ischia Global Film & Music Festival ist eines der glamourösesten Kulturereignisse des mediterranen Sommers. Internationale Stars aus Film und Musik versammeln sich auf der Insel für Weltpremieren, Preisverleihungen und unvergessliche Abendveranstaltungen unter freiem Himmel.</p>
            <p>Die Kulisse ist einzigartig: Die Piazze von Lacco Ameno, die Terrassen der Luxushotels und die historischen Räumlichkeiten von Ischia Porto verwandeln sich in Festivalschauplätze, an denen Kinokultur und Inselzauber zusammenkommen.</p>
          </div>
        </div>

        <!-- Das Festival -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Das Festival</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Filmvorführungen</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Weltpremieren & Preise</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Das Festival zeigt internationale Produktionen, vergibt Auszeichnungen an Filmschaffende und bietet dem Publikum die Möglichkeit, Stars und Regisseure zu treffen – eine einzigartige Begegnung zwischen Kino und Inselkultur.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Musikprogramm</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Konzerte & Events</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Neben dem Filmprogramm bietet das Festival ein reiches Musikprogramm mit Konzerten internationaler Künstler in den schönsten Locations der Insel – von Open-Air-Bühnen bis zu historischen Villen.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel Molo Beverello</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ca. 80 min nach Ischia Porto</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Tragflügelboot</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel oder Pozzuoli</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ca. 45 min, häufige Verbindungen</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus (auf der Insel)</td>
                  <td class="px-6 py-4 text-slate-600">Ischia Porto → Lacco Ameno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Linie CD/CS, ca. 20 min</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
