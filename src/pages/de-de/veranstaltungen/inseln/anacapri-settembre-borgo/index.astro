---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Anacapri Settembre Borgo', url: '/de-de/veranstaltungen/inseln/anacapri-settembre-borgo/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Anacapri Settembre Borgo 2026",
  "startDate": "2026-09-01",
  "endDate": "2026-09-10",
  "location": {
    "@type": "Place",
    "name": "Historisches Zentrum, Anacapri",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Anacapri",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/inseln/anacapri-settembre-borgo/"
};

const facts = [
  { dt: 'Datum', dd: '1.–10. September 2026' },
  { dt: 'Veranstaltungsort', dd: 'Historisches Zentrum, Anacapri' },
  { dt: 'Typ', dd: 'Volksfest & Stadtviertelwettbewerb' },
  { dt: 'Besonderheit', dd: 'Private Höfe geöffnet' },
  { dt: 'Ab Capri', dd: 'Bus oder Sessellift' },
];
---

<BaseLayout
  title="Anacapri Settembre Borgo 2026 – Das echte Capri im September"
  description="Anacapri Settembre Borgo, 1.–10. September 2026. Volkskundliches Festival mit dem Wettbewerb zwischen den vier Vierteln von Anacapri und privaten Höfen, die Besuchern geöffnet werden."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/capri-hero.jpg"
      alt="Anacapri Settembre Borgo, Capri"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">1.–10. September 2026</span>
        <span class="text-white/70 text-sm">Anacapri, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Anacapri Settembre Borgo</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Der Stadtviertelwettbewerb, offene Höfe und das echte Capri im September.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Das Settembre Borgo ist das authentischste Ereignis auf Capri – ein volkskundliches Festival, das den Wettbewerb zwischen den vier historischen Vierteln von Anacapri in den Mittelpunkt stellt. Jedes Viertel dekoriert seine Gassen, organisiert Veranstaltungen und öffnet private Höfe für Besucher.</p>
            <p>Im September ist Anacapri von der Hochsommertouristik befreit – die Temperaturen sind angenehm, die Preise niedriger und die Atmosphäre ist die einer echten kleinen Gemeinde, die ihr Erbe feiert. Der ideale Zeitpunkt, um das „andere Capri" kennenzulernen.</p>
          </div>
        </div>

        <!-- Das Festival -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Das Festival</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Stadtviertelwettbewerb</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Die vier Viertel</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Die vier historischen Viertel von Anacapri – Capodimonte, Caprile, La Ninfa und Pagliaro – treten in freundschaftlichem Wettbewerb gegeneinander an. Dekorationen, Musik, Essen und Spiele bestimmen den Sieger.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Offene Höfe</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Blick hinter die Fassaden</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Für zehn Tage öffnen Privatleute ihre Höfe und Gärten für Besucher – ein seltener Einblick in das echte Leben hinter den weißen Mauern von Anacapri, fernab der Touristenpfade.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre + Bus</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel, Sorrent oder Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Fähre nach Capri Porto, Bus nach Anacapri</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Sessellift</td>
                  <td class="px-6 py-4 text-slate-600">Ab Capri Stadt</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Monte Solaro-Sessellift bis Anacapri</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
