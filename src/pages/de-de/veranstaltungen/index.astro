---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { events } from '../../../data/events-de';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
];

const amalfikuesteEvents = events.filter(e => e.area === 'amalfikueste');
const inselnEvents = events.filter(e => e.area === 'inseln');
const halbinselEvents = events.filter(e => e.area === 'sorrentinische-halbinsel');

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Veranstaltungen 2026 – Amalfiküste & Sorrentinische Halbinsel",
  "description": "Die besten Feste und Veranstaltungen 2026 an der Amalfiküste und der Sorrentinischen Halbinsel: Ravello Festival, Ferragosto-Feuerwerk, Fischfeste und gastronomische Feiern.",
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/",
  "numberOfItems": events.length,
  "itemListElement": events.map((ev, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": ev.title,
    "url": `https://amalficoast-travel.com${ev.path}`,
  })),
};
---

<BaseLayout
  title="Veranstaltungen 2026 Amalfiküste | Ravello Festival, Feuerwerk & Lokale Feste"
  description="Die besten Veranstaltungen 2026 an der Amalfiküste und der Sorrentinischen Halbinsel: Ravello Festival, Ferragosto-Feuerwerk, das Fischfest in Positano und authentische lokale Feiern."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <img
      src="/images/ravello-hero.jpg"
      alt="Veranstaltungen an der Amalfiküste 2026"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Veranstaltungen 2026</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Kalender 2026</p>
        <h1 class="font-serif text-display text-white mb-4">Veranstaltungen</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Vom Ravello Festival bis zu den Ferragosto-Feuerwerken über dem Meer. Der Veranstaltungskalender 2026 der Amalfiküste und Sorrentinischen Halbinsel.
        </p>
      </div>
    </div>
  </section>

  <!-- Amalfiküste -->
  <section class="bg-med-cream py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Amalfiküste</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Veranstaltungen an der Amalfiküste</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {amalfikuesteEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Inseln -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Inseln</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Veranstaltungen auf den Inseln</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {inselnEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sorrentinische Halbinsel -->
  <section class="bg-med-cream py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Sorrentinische Halbinsel</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Veranstaltungen auf der Sorrentinischen Halbinsel</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {halbinselEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
