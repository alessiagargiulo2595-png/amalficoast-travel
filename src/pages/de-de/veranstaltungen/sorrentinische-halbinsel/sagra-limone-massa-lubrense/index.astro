---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Zitronenfest – Massa Lubrense', url: '/de-de/veranstaltungen/sorrentinische-halbinsel/sagra-limone-massa-lubrense/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Zitronenfest Massa Lubrense 2026",
  "startDate": "2026-07-11",
  "endDate": "2026-07-12",
  "location": {
    "@type": "Place",
    "name": "Historisches Zentrum, Massa Lubrense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Massa Lubrense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/sorrentinische-halbinsel/sagra-limone-massa-lubrense/"
};

const facts = [
  { dt: 'Datum', dd: '11.–12. Juli 2026' },
  { dt: 'Produkt', dd: 'Femminiello-Zitrone IGP' },
  { dt: 'Veranstaltungsort', dd: 'Historisches Zentrum, Massa Lubrense' },
  { dt: 'Anreise', dd: 'EAV-Bus ab Sorrent alle 20 min' },
  { dt: 'Eintritt', dd: 'Kostenlos' },
];
---

<BaseLayout
  title="Zitronenfest Massa Lubrense 2026 – Verkostungen & Märkte"
  description="Das Zitronenfest in Massa Lubrense am 11. und 12. Juli 2026. Verkostungspfade durch die historischen Portale von Massa Lubrense mit Limoncello, Granita und Zitronenpasta."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/massa-lubrense-hero.jpg"
      alt="Zitronenfest, Massa Lubrense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">11.–12. Juli 2026</span>
        <span class="text-white/70 text-sm">Massa Lubrense, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Zitronenfest</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Die IGP-Femminiello-Zitrone als Protagonistin in den historischen Portalen von Massa Lubrense.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Ein kulinarisches Ereignis, das die lokale Zitrone feiert. Es umfasst Verkostungspfade durch die historischen Portale des Dorfes und Kunsthandwerksmärkte. Transport per EAV-Bus ab der Piazza Tasso in Sorrent alle 20 Minuten.</p>
            <p>Die Femminiello-Zitrone der Sorrentinischen Halbinsel ist eines der Symbole der lokalen Landwirtschaft, geschützt durch eine geografische Herkunftsbezeichnung. Das Fest ist eine Gelegenheit, lokale Produzenten kennenzulernen und Limoncello, Granita und Spezialitäten aus Zitrone zu verkosten.</p>
          </div>
        </div>

        <!-- Verkostungspfade -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Verkostungspfade</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Handwerklicher Limoncello</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Vom Baum zur Flasche</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Lokale Produzenten öffnen ihre Werkstätten und zeigen den Herstellungsprozess des traditionellen Limoncello aus biologischer Femminiello-Schale – vom Hain bis zur fertigen Flasche.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Zitronenküche</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Lokale Gastronomie</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Zitronenkuchen, Granita, Zitronenpasta und traditionelle Süßigkeiten beleben die Gastronomieständen entlang des Pfades durch die historischen Portale des Dorfes.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">EAV-Bus</td>
                  <td class="px-6 py-4 text-slate-600">Ab Sorrent Piazza Tasso</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Alle 20 Minuten</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Auto</td>
                  <td class="px-6 py-4 text-slate-600">SS145 Sorrentina</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Parkplätze entlang der Hauptstraße</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
