---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Auberginenfest – Preazzano', url: '/de-de/veranstaltungen/sorrentinische-halbinsel/sagra-melanzana-preazzano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Auberginenfest Preazzano 2026",
  "startDate": "2026-08-09",
  "endDate": "2026-08-10",
  "location": {
    "@type": "Place",
    "name": "Preazzano, Vico Equense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vico Equense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/sorrentinische-halbinsel/sagra-melanzana-preazzano/"
};

const facts = [
  { dt: 'Datum', dd: '9.–10. August 2026' },
  { dt: 'Spezialität', dd: 'Schokoladen-Aubergine' },
  { dt: 'Shuttle', dd: 'Ab Bahnhof Vico Equense' },
  { dt: 'Eintritt', dd: 'Kostenlos' },
  { dt: 'Ort', dd: 'Mittelalterlicher Weiler' },
];
---

<BaseLayout
  title="Auberginenfest Preazzano 2026 – Die Schokoladen-Variation"
  description="Das Auberginenfest in Preazzano am 9. und 10. August 2026. Eines der ältesten Feste der Region: die lokale Aubergine in dutzenden Variationen, darunter die berühmte Schokoladen-Version."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/vico-equense-hero.jpg"
      alt="Auberginenfest, Preazzano, Vico Equense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">9.–10. August 2026</span>
        <span class="text-white/70 text-sm">Preazzano, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Auberginenfest</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Der mittelalterliche Weiler und die unverwechselbare Schokoladen-Auberginen-Spezialität.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Eines der ältesten Feste der Region. Der mittelalterliche Weiler Preazzano beherbergt Gastronomieständen, an denen die Aubergine im Mittelpunkt steht – einschließlich der süßen Schokoladen-Variation. Ein Shuttlebus verbindet den Bahnhof Vico Equense mit dem Festgelände.</p>
            <p>Preazzano, ein kleiner mittelalterlicher Weiler im Herzen der Sorrentinischen Halbinsel, verwandelt sich für zwei Tage in ein Freiluft-Kochstudio. Die lokale Aubergine wird in Dutzenden von Variationen serviert: frittiert, gefüllt, alla parmigiana und die überraschende süße Schokoladenversion.</p>
          </div>
        </div>

        <!-- Die Spezialitäten -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Die Spezialitäten des Festes</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Herzhafte Variationen</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Die traditionelle Aubergine</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Frittiert, gefüllt, alla parmigiana, in Pasta und im kampanischen Ragù: Die Aubergine ist die Protagonistin eines Dutzends traditioneller Rezepte aus der sorrentinischen Küchentradition.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Süße Schokoladenversion</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Die unerwartete Überraschung</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Aubergine in Schokolade ist die überraschende Spezialität, die Besucher aus ganz Kampanien anzieht: frittierte Auberginenscheiben, überzogen mit dunkler Schokolade – eine unerwartete Kombination, die perfekt funktioniert.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Festivalshuttle</td>
                  <td class="px-6 py-4 text-slate-600">Ab Bahnhof Vico Equense</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Verfügbar während der Festtage</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel oder Sorrent</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ausstieg Vico Equense, dann Shuttle</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
