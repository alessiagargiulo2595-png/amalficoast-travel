---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: "Madonna della Libera – Sant'Agnello", url: '/de-de/veranstaltungen/sorrentinische-halbinsel/madonna-della-libera/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Madonna della Libera Sant'Agnello 2026",
  "startDate": "2026-09-13",
  "endDate": "2026-09-13",
  "location": {
    "@type": "Place",
    "name": "Sant'Agnello",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sant'Agnello",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/sorrentinische-halbinsel/madonna-della-libera/"
};

const facts = [
  { dt: 'Datum', dd: '13. September 2026' },
  { dt: 'Ort', dd: "Sant'Agnello" },
  { dt: 'Typ', dd: 'Stadtteilfest' },
  { dt: 'Atmosphäre', dd: 'Traditionell & authentisch' },
  { dt: 'Ab Sorrent', dd: '5 min mit dem Bus' },
];
---

<BaseLayout
  title="Madonna della Libera Sant'Agnello 2026 – Stadtteilfest der Halbinsel"
  description="Das Fest der Madonna della Libera in Sant'Agnello am 13. September 2026. Lokales Stadtteilfest, das den authentischen Geist der Halbinsel-Traditionen bewahrt – fernab der Touristenströme."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Madonna della Libera, Sant'Agnello"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">13. September 2026</span>
        <span class="text-white/70 text-sm">Sant'Agnello, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Madonna della Libera</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Das Stadtteilfest mit dem Flair vergangener Feiern – fernab der Touristenströme.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Ein Stadtteilfest, das den authentischen Geist der Halbinsel-Traditionen bewahrt – mit traditionellen Lichterketten und lokalen Produkten. Eine Gelegenheit, die Sorrentinische Halbinsel abseits der sommerlichen Touristenströme zu erleben.</p>
            <p>Sant'Agnello, nur wenige Minuten von Sorrent entfernt, bewahrt seine eigene, unverwechselbare Gemeinschaftsidentität. Das Fest der Madonna della Libera ist eines jener Ereignisse, das die Einwohner stolz als Erbe ihres Stadtteils verteidigen.</p>
          </div>
        </div>

        <!-- Das Fest -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Das Fest</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Traditionelle Lichterketten</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Die Lichter des Stadtteils</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Die Straßen von Sant'Agnello werden mit traditionellen Lichterketten geschmückt, die die festliche Atmosphäre eines alten süditalienischen Stadtteilfestes heraufbeschwören – intim, warm und durch und durch lokal.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Lokale Produkte</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Der Geschmack der Region</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Stände mit lokalen Produkten, Street Food mit sorrentinischen Spezialitäten und die Geselligkeit der Dorfgemeinschaft machen dieses Fest zu einem authentischen Stück Halbinselleben.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Lokalbus</td>
                  <td class="px-6 py-4 text-slate-600">Ab Sorrent Piazza Tasso</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 min, sehr häufige Verbindungen</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Zu Fuß</td>
                  <td class="px-6 py-4 text-slate-600">Ab Sorrentzentrum</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">20 min angenehmer Spaziergang entlang der Küstenstraße</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
