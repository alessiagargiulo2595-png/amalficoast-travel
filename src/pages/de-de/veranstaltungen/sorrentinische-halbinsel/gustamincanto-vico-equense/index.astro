---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Gustamincanto – Vico Equense', url: '/de-de/veranstaltungen/sorrentinische-halbinsel/gustamincanto-vico-equense/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Gustamincanto Vico Equense 2026",
  "startDate": "2026-09-01",
  "endDate": "2026-09-30",
  "location": {
    "@type": "Place",
    "name": "Historisches Zentrum, Vico Equense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vico Equense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/sorrentinische-halbinsel/gustamincanto-vico-equense/"
};

const facts = [
  { dt: 'Zeitraum', dd: 'September 2026' },
  { dt: 'Veranstaltungsort', dd: 'Historisches Zentrum, Vico Equense' },
  { dt: 'Typ', dd: 'Gastronomisches Festival' },
  { dt: 'Spezialität', dd: 'Provolone del Monaco DOP' },
  { dt: 'Ab Neapel', dd: 'Circumvesuviana, 45 min' },
];
---

<BaseLayout
  title="Gustamincanto Vico Equense 2026 – Gastronomische Exzellenz der Halbinsel"
  description="Das Gustamincanto in Vico Equense im September 2026. Gastronomisches Festival mit Provolone del Monaco DOP und Sterne-Köchen in den mittelalterlichen Gassen von Vico Equense."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/vico-equense-hero.jpg"
      alt="Gustamincanto, Vico Equense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">September 2026</span>
        <span class="text-white/70 text-sm">Vico Equense, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Gustamincanto</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Gastronomische Exzellenz der Sorrentinischen Halbinsel in den mittelalterlichen Gassen von Vico Equense.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Das Gustamincanto ist das gastronomische Spitzenereignis der Sorrentinischen Halbinsel. In den mittelalterlichen Gassen von Vico Equense präsentieren lokale Produzenten und Sterne-Köche die besten Produkte der Region – allen voran der Provolone del Monaco DOP, der emblematische Käse der Halbinsel.</p>
            <p>Das Festival verbindet Verkostungen, Kochvorführungen und Begegnungen mit Produzenten zu einem Erlebnis, das sowohl die kulinarische Tradition als auch die gastronomische Innovation der Campania feiert. Vico Equense selbst ist ein verstecktes Juwel mit Panoramablick auf den Golf von Neapel.</p>
          </div>
        </div>

        <!-- Gastronomie -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Die Produkte</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Provolone del Monaco DOP</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Der Käse der Halbinsel</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Der Provolone del Monaco DOP wird nur auf der Sorrentinischen Halbinsel hergestellt, aus der Milch der lokalen Agerolese-Kühe. Sein unverwechselbarer Geschmack macht ihn zu einem der besten Käse Süditaliens.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Sterne-Küche</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Exzellenz auf dem Teller</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Renommierte Küchenchefs aus der Campania und darüber hinaus präsentieren Kreationen, die die lokalen Produkte in einem modernen kulinarischen Kontext interpretieren – Tradition trifft Innovation.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ca. 45 min, Haltestelle Vico Equense</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Auto</td>
                  <td class="px-6 py-4 text-slate-600">Autostrada A3 Sorrent</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ausfahrt Castellammare di Stabia</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
