---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Sorrento Meeting', url: '/de-de/veranstaltungen/sorrentinische-halbinsel/sorrento-meeting-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Sorrento Meeting 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Kreuzgang San Francesco, Sorrent",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sorrento",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/sorrentinische-halbinsel/sorrento-meeting-cultura/"
};

const facts = [
  { dt: 'Zeitraum', dd: 'Jun–Jul 2026' },
  { dt: 'Veranstaltungsort', dd: 'Kreuzgang San Francesco' },
  { dt: 'Typ', dd: 'Literarische Begegnungsreihe' },
  { dt: 'Zugang', dd: 'Reservierung empfohlen' },
  { dt: 'Ab Neapel', dd: 'Circumvesuviana 70 min' },
];
---

<BaseLayout
  title="Sorrento Meeting 2026 – Literatur & Journalismus im gotisch-arabischen Kreuzgang"
  description="Das Sorrento Meeting von Juni bis Juli 2026. Abendliche Begegnungen mit international renommierten Autoren im gotisch-arabischen Kreuzgang von San Francesco."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Sorrento Meeting, Kreuzgang San Francesco"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">Jun–Jul 2026</span>
        <span class="text-white/70 text-sm">Sorrent, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Sorrento Meeting</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Literatur und internationaler Journalismus im Kreuzgang aus dem 14. Jahrhundert.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Eine literarische und journalistische Begegnungsreihe im Kreuzgang von San Francesco. Abendliche Treffen mit international renommierten Autoren. Der gotisch-arabische Kreuzgang aus dem 14. Jahrhundert bietet einen einzigartigen Rahmen für die Kulturbegegnungen dieser Sommerreihe.</p>
            <p>Die Abendveranstaltungen finden typischerweise bei Sonnenuntergang statt und nutzen das magische Abendlicht im Kreuzgang. Die Teilnehmer können den Abend anschließend in den Restaurants und Panoramaterrassen des Sorrenter Zentrums fortsetzen.</p>
          </div>
        </div>

        <!-- Die Kulturreihe -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Die Kulturreihe</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Autorenbegegnungen</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Internationale Literatur</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Schriftsteller, Journalisten und international renommierte Intellektuelle wechseln sich im Kreuzgang ab, um ihre Werke vorzustellen und in einem offenen, informellen Format mit dem Publikum zu diskutieren.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Der Kreuzgang</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Ein einzigartiger Ort</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Der Kreuzgang von San Francesco mit seinen gotisch-arabischen Bögen aus dem 14. Jahrhundert ist einer der stimmungsvollsten Orte Sorrents und ein aktives Kulturzentrum während des gesamten Sommers.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">70 Minuten, Haltestelle Sorrent</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre</td>
                  <td class="px-6 py-4 text-slate-600">Ab der Küste oder Neapel</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Hafen Sorrent, Inselverbindungen</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Zu Fuß</td>
                  <td class="px-6 py-4 text-slate-600">Ab Sorrentzentrum</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 min ab der Piazza Tasso</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
