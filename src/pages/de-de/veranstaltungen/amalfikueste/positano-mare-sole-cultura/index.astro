---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Positano Kunst & Kultur', url: '/de-de/veranstaltungen/amalfikueste/positano-mare-sole-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Positano Kunst & Kultur 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-31",
  "location": {
    "@type": "Place",
    "name": "Positano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/amalfikueste/positano-mare-sole-cultura/"
};

const facts = [
  { dt: 'Zeitraum', dd: 'August 2026' },
  { dt: 'Veranstaltungsort', dd: 'Positano' },
  { dt: 'Art', dd: 'Kunst- & Kulturfestival' },
  { dt: 'Kulisse', dd: 'Panoramaterrassen' },
  { dt: 'Ab Neapel', dd: 'Fähre 1h oder SITA-Bus' },
];
---

<BaseLayout
  title="Positano Kunst & Kultur 2026 – Kunst, Musik und Literatur an der Küste"
  description="Positano Kunst & Kultur 2026 im August. Sommerprogramm mit Kunst, Musik und Literatur auf Panoramaterrassen und in Kulturräumen von Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Positano Kunst und Kulturfestival"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">August 2026</span>
        <span class="text-white/70 text-sm">Positano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Positano Kunst & Kultur</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Kunst, Musik und Literatur am berühmtesten Strand der Amalfiküste.
      </p>
    </div>
  </section>

  <!-- Inhalt 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Hauptinhalt (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Über die Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Positano hat schon immer Künstler, Schriftsteller und Musiker angezogen — von Picasso und Steinbeck bis zu Nurejew, alle wurden von seiner außergewöhnlichen Schönheit fasziniert. Das Festival Positano Kunst & Kultur setzt diese Tradition jeden August fort und verwandelt die Terrassen, Gärten und Piazze des Dorfes in Freilichtbühnen für zeitgenössische und klassische Kunst.</p>
            <p>Das Programm erstreckt sich über den ganzen August mit Abendkonzerten auf Panoramaterrassen mit Meerblick, Kunstausstellungen in historischen Räumen, Lesungen, Tanzaufführungen und Filmvorführungen unter dem Sternenhimmel. Ein Sommerfestival, das Positanos natürliche Schönheit ergänzt statt mit ihr zu konkurrieren.</p>
          </div>
        </div>

        <!-- Das Programm -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Das Programm</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Musik & Tanz</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Konzerte auf den Terrassen</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Abendkonzerte von klassischer Kammermusik bis zu zeitgenössischen Darbietungen auf den spektakulärsten Terrassen Positanos mit Meer und Faraglioni als Kulisse.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Kunst & Literatur</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Ausstellungen und Lesungen</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Zeitgenössische Kunstausstellungen in historischen Räumen, Autorenlesungen und Freiluftkino feiern die enge Verbindung des Dorfes mit internationalen Künstlern und Schriftstellern.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel oder Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Saisonaler Betrieb, Anleger Positano</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">SITA-Bus</td>
                  <td class="px-6 py-4 text-slate-600">Ab Sorrent oder Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">SS163, Haltestelle Positano Sponda oder Chiesa Nuova</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Bitte das aktualisierte Programm auf den offiziellen Kanälen prüfen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
