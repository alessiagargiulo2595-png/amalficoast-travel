---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Historische Seeregatta', url: '/de-de/veranstaltungen/amalfikueste/regata-storica-amalfi/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Historische Seeregatta Amalfi 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-06-30",
  "location": {
    "@type": "Place",
    "name": "Porto di Amalfi",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Amalfi",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/amalfikueste/regata-storica-amalfi/"
};

const facts = [
  { dt: 'Zeitraum', dd: 'Juni 2026' },
  { dt: 'Veranstaltungsort', dd: 'Porto di Amalfi' },
  { dt: 'Art', dd: 'Historische Regatta & Umzug' },
  { dt: 'Kostüme', dd: 'Mittelalterlich, spektakulär' },
  { dt: 'Ab Neapel', dd: 'Fähre 1h30' },
];
---

<BaseLayout
  title="Historische Seeregatta Amalfi 2026 – Mittelalterlicher Umzug und Ruderrennen"
  description="Die Historische Regatta der Antiken Seerepubliken 2026 in Amalfi. Mittelalterliche Kostümumzüge und das Ruderrennen zwischen Amalfi, Venedig, Genua und Pisa im Hafen."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/amalfi-hero.jpg"
      alt="Historische Seeregatta, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">Juni 2026</span>
        <span class="text-white/70 text-sm">Amalfi, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Historische Seeregatta</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Amalfi, Venedig, Genua und Pisa messen sich auf dem Meer mit mittelalterlichen Kostümumzügen.
      </p>
    </div>
  </section>

  <!-- Inhalt 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Hauptinhalt (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Über die Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Die Regatta der Antiken Seerepubliken ist eines der spektakulärsten historischen Schauspiele Italiens. Vier Städte, die im Mittelalter maritime Mächte waren — Amalfi, Venedig, Genua und Pisa — wetteifern in einem Ruderrennen auf historischen Galeeren, dem ein Umzug von über dreihundert kostümierten Teilnehmern vorausgeht.</p>
            <p>Wenn die Regatta in Amalfi stattfindet, verwandelt sich der Hafen in eine außergewöhnliche mittelalterliche Bühne: die bunten Häuser an den Klippen, der Dom im Hintergrund und die Galeeren mit ihren farbigen Segeln bieten ein unvergessliches Spektakel. Die Kostüme, Rüstungen und Banner der vier Republiken versetzen die Stadt in ihre glanzvolle maritime Vergangenheit zurück.</p>
          </div>
        </div>

        <!-- Das Programm -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Das Programm</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Der Historische Umzug</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Dreihundert kostümierte Teilnehmer</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Der historische Zug windet sich durch die Gassen der Altstadt von Amalfi mit über dreihundert mittelalterlich gekleideten Teilnehmern, die die vier Republiken mit ihren Dogen, Kapitänen und Matrosen vertreten.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Das Ruderrennen</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Historische Galeeren auf dem Meer</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Vier Mannschaften aus je acht Ruderern wetteifern auf historischen Galeeren im Hafen von Amalfi. Die Siegerstadt behält die Trophäe bis zur nächsten Ausgabe in einer der anderen vier Städte.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">1h30, direkt zum Hafen Amalfi</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">SITA-Bus</td>
                  <td class="px-6 py-4 text-slate-600">Ab Sorrent oder Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">SS163, Haltestelle Amalfi centro</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Bitte das aktualisierte Programm auf den offiziellen Kanälen prüfen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
