---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Notte Blu Vietri', url: '/de-de/veranstaltungen/amalfikueste/notte-blu-vietri/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Notte Blu Vietri sul Mare 2026",
  "startDate": "2026-07-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Historisches Zentrum, Vietri sul Mare",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vietri sul Mare",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/amalfikueste/notte-blu-vietri/"
};

const facts = [
  { dt: 'Zeitraum', dd: 'Juli 2026' },
  { dt: 'Veranstaltungsort', dd: 'Historisches Zentrum, Vietri' },
  { dt: 'Typ', dd: 'Kunst, Keramik & Musik' },
  { dt: 'Öffnungszeiten', dd: 'Bis Mitternacht' },
  { dt: 'Ab Salerno', dd: '15 min mit dem Bus' },
];
---

<BaseLayout
  title="Notte Blu Vietri sul Mare 2026 – Kunst, Keramik und Musik"
  description="Die Notte Blu in Vietri sul Mare im Juli 2026. Keramikwerkstätten bis Mitternacht geöffnet, Live-Konzerte und Kunstinstallationen im historischen Stadtkern."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/costiera-hero.jpg"
      alt="Notte Blu, Vietri sul Mare"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">Juli 2026</span>
        <span class="text-white/70 text-sm">Vietri sul Mare, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Notte Blu</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Kunst, Keramik und Musik bis spät in der Nacht im historischen Zentrum von Vietri sul Mare.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>In der Notte Blu öffnen die berühmten Keramikwerkstätten von Vietri sul Mare bis Mitternacht ihre Türen. Die Besucher können den Handwerkern bei der Arbeit zusehen, Keramik kaufen und dabei Live-Konzerte und Kunstinstallationen im historischen Stadtzentrum genießen.</p>
            <p>Vietri sul Mare ist die Keramikhauptstadt der Amalfiküste – seine bunten Majolika-Fliesen schmücken Kirchen, Villen und Cafés von Sorrent bis Salerno. Die Notte Blu ist die beste Gelegenheit, die Werkstätten hinter den Kulissen zu erleben.</p>
          </div>
        </div>

        <!-- Die blaue Nacht -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Die blaue Nacht</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Keramik-Werkstätten</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Offene Ateliers</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Die traditionsreichen Keramikwerkstätten von Vietri öffnen ihre Tore und gewähren Einblick in die uralte Kunst der Majolika-Herstellung – von der Tonscheibe bis zur bemalten Glasur.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Live-Musik & Kunst</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Kultur bis Mitternacht</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Lokale Bands, Kunstinstallationen und Lichtprojektionen verwandeln das historische Zentrum in eine offene Bühne – die ganze Stadt feiert gemeinsam bis in die Nacht.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus</td>
                  <td class="px-6 py-4 text-slate-600">Ab Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ca. 15 min, sehr häufige Verbindungen</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Entlang der Amalfiküste</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Vietri ist das östliche Tor der Küste</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Zug</td>
                  <td class="px-6 py-4 text-slate-600">Ab Salerno Hauptbahnhof</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Haltestelle Vietri sul Mare</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
