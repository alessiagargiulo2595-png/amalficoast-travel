---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Fest des hl. Gennaro – Praiano', url: '/de-de/veranstaltungen/amalfikueste/festa-san-gennaro-praiano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Fest des hl. Gennaro Praiano 2026",
  "startDate": "2026-09-19",
  "endDate": "2026-09-19",
  "location": {
    "@type": "Place",
    "name": "Vettica Maggiore, Praiano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Praiano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/amalfikueste/festa-san-gennaro-praiano/"
};

const facts = [
  { dt: 'Datum', dd: '19. September 2026' },
  { dt: 'Ort', dd: 'Vettica Maggiore, Praiano' },
  { dt: 'Typ', dd: 'Patronatsprozession' },
  { dt: 'Atmosphäre', dd: 'Authentisch, kaum Touristen' },
  { dt: 'Ab Amalfi', dd: 'Bus SITA, 20 min' },
];
---

<BaseLayout
  title="Fest des hl. Gennaro Praiano 2026 – Authentische Prozession mit Capri-Blick"
  description="Das Fest des heiligen Gennaro in Praiano am 19. September 2026. Patronatsprozession im Weiler Vettica Maggiore – wenig Touristen, Panoramablick auf Capri."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/praiano-hero.jpg"
      alt="Fest des hl. Gennaro, Praiano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">19. September 2026</span>
        <span class="text-white/70 text-sm">Praiano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Fest des hl. Gennaro</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Eine authentische Prozession mit Panoramablick auf Capri – fernab der Touristenströme.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Das Patronatsfest des heiligen Gennaro findet im oberen Weiler Vettica Maggiore statt – dem höher gelegenen Teil von Praiano mit atemberaubendem Panoramablick auf Capri und den Golf von Salerno. Anders als die bekannteren Feste der Küste ist dieses Ereignis noch weitgehend von Touristen unentdeckt.</p>
            <p>Die feierliche Prozession durch die engen Gassen des Weilers, der Klang der Blaskapelle und die Gemeinschaft der Dorfbewohner verleihen dem Fest eine Authentizität, die man heute an der Amalfiküste selten noch findet.</p>
          </div>
        </div>

        <!-- Die Prozession -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Die Prozession</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Vettica Maggiore</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Der Weiler über dem Meer</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Vettica Maggiore liegt auf einem Felsen über dem Meer und bietet einen der besten Aussichtspunkte auf Capri. Die Prozession durch seine steilen Gassen ist ein bewegendes Erlebnis.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Dorfleben</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Echtes Campania</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Das Fest spiegelt das echte Leben an der Amalfiküste wider: Die Einwohner feiern ihren Schutzpatron mit Herzlichkeit und Stolz – ohne Tourismusrummel, mit echtem campanesinischem Gemeinschaftsgefühl.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Ab Amalfi oder Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Haltestelle Praiano, dann zu Fuß bergauf</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Taxi/Transfer</td>
                  <td class="px-6 py-4 text-slate-600">Ab jedem Küstenort</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Empfehlenswert für Abendveranstaltungen</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
