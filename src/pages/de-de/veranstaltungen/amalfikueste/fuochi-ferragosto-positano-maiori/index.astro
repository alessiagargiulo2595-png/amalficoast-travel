---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Ferragosto-Feuerwerk', url: '/de-de/veranstaltungen/amalfikueste/fuochi-ferragosto-positano-maiori/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Ferragosto-Feuerwerk 2026 – Positano & Maiori",
  "startDate": "2026-08-15",
  "endDate": "2026-08-15",
  "location": {
    "@type": "Place",
    "name": "Positano & Maiori",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/amalfikueste/fuochi-ferragosto-positano-maiori/"
};

const facts = [
  { dt: 'Datum', dd: '15. August 2026' },
  { dt: 'Orte', dd: 'Positano & Maiori' },
  { dt: 'Anlass', dd: 'Ferragosto / Mariä Himmelfahrt' },
  { dt: 'Beste Sicht', dd: 'Vom Meer aus' },
  { dt: 'Eintritt', dd: 'Kostenlos' },
];
---

<BaseLayout
  title="Ferragosto-Feuerwerk 2026 – Positano & Maiori leuchten über dem Meer"
  description="Das Ferragosto-Feuerwerk am 15. August 2026. Spektakuläre Feuerwerke über dem Meer in Positano (Madonna Assunta) und Maiori (Santa Maria a Mare)."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Ferragosto-Feuerwerk, Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">15. August 2026</span>
        <span class="text-white/70 text-sm">Positano & Maiori, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Ferragosto-Feuerwerk</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Die Küste leuchtet: Positano und Maiori feiern Ferragosto mit Feuerwerken über dem Meer.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Der 15. August ist Ferragosto – Italiens größter Sommerferien-Feiertag, verbunden mit dem Fest Mariä Himmelfahrt. An der Amalfiküste feiern gleich zwei Orte mit spektakulären Feuerwerken über dem Tyrrhenischen Meer: Positano zu Ehren der Madonna Assunta und Maiori zu Ehren der Santa Maria a Mare.</p>
            <p>Das Feuerwerk von Positano ist besonders eindrucksvoll, da die bunten Farbexplosionen zwischen den weißen Häusern des steilen Hangs reflektieren. Von einem Boot oder der Küstenstraße aus betrachtet entfaltet sich ein unvergessliches Schauspiel.</p>
          </div>
        </div>

        <!-- Zwei Feuerwerke -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Zwei Feuerwerke, eine Nacht</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Positano</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Madonna Assunta</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Das Feuerwerk von Positano ist eines der schönsten an der Küste: Die Raketen spiegeln sich im Meer und beleuchten die berühmte Stufensilhouette des Dorfes in allen Farben.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Maiori</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Santa Maria a Mare</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Maiori, mit seinem breiten Sandstrand, bietet hervorragende Sichtverhältnisse für das Feuerwerk zu Ehren der Schutzpatronin Santa Maria a Mare – ideal auch für Familien.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre</td>
                  <td class="px-6 py-4 text-slate-600">Ab Amalfi, Sorrent, Neapel</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Beste Sicht auf das Feuerwerk vom Wasser</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Entlang der SS163</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Sehr stark frequentiert am 15. August</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
