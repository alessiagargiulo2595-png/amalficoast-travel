---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Ravello Festival', url: '/de-de/veranstaltungen/amalfikueste/ravello-festival/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Ravello Festival 2026",
  "startDate": "2026-07-04",
  "endDate": "2026-09-05",
  "location": {
    "@type": "Place",
    "name": "Villa Rufolo, Ravello",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ravello",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/amalfikueste/ravello-festival/"
};

const facts = [
  { dt: 'Zeitraum', dd: '4. Jul – 5. Sep 2026' },
  { dt: 'Veranstaltungsort', dd: 'Villa Rufolo, Ravello' },
  { dt: 'Typ', dd: 'Klassik & zeitgenössische Musik' },
  { dt: 'Tickets', dd: 'Reservierung empfohlen' },
  { dt: 'Ab Amalfi', dd: 'Bus + 5 min zu Fuß' },
];
---

<BaseLayout
  title="Ravello Festival 2026 – Musik zwischen Himmel und Meer"
  description="Das Ravello Festival 2026, 4. Juli bis 5. September. Die 74. Ausgabe des renommiertesten Kulturfestivals an der Amalfiküste auf der legendären Bühne von Villa Rufolo."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ravello-hero.jpg"
      alt="Ravello Festival, Villa Rufolo"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">4. Jul – 5. Sep 2026</span>
        <span class="text-white/70 text-sm">Ravello, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Ravello Festival</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Musik zwischen Himmel und Meer auf der legendären Bühne der Villa Rufolo.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Die 74. Ausgabe des renommiertesten Kulturfestivals an der Amalfiküste. Konzerte auf der legendären Bühne der Villa Rufolo mit Blick auf das Meer – ein einzigartiges Erlebnis, bei dem Musik und Landschaft zu einem Gesamtkunstwerk verschmelzen.</p>
            <p>Das Ravello Festival zählt zu den bedeutendsten Musikfestivals Italiens. Jedes Jahr zieht es Weltklasse-Orchester, Dirigenten und Solisten auf die Terrasse der Villa Rufolo, deren Bühne direkt über dem Tyrrhenischen Meer schwebt.</p>
          </div>
        </div>

        <!-- Das Programm -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Das Programm</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Orchesterkonzerte</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Weltklasse-Orchester</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Renommierte Orchester aus aller Welt gastieren auf der Terrasse der Villa Rufolo. Das Meer bildet die natürliche Bühnenkulisse für unvergessliche Abendkonzerte.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Die Bühne</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Villa Rufolo</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Die mittelalterliche Villa aus dem 13. Jahrhundert mit ihren maurischen Gärten und der Terrasse hoch über dem Meer gilt als eine der schönsten Konzertbühnen der Welt.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Ab Amalfi oder Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Haltestelle Ravello, 5 min zu Fuß zur Villa</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre + Bus</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel oder Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Fähre nach Amalfi, dann Bus nach Ravello</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Taxi/Transfer</td>
                  <td class="px-6 py-4 text-slate-600">Ab jedem Küstenort</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Empfehlenswert für Abendveranstaltungen</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, Tickets frühzeitig zu reservieren. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
