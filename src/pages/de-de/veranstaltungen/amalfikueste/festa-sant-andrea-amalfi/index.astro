---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Fest des hl. Andreas – Amalfi', url: '/de-de/veranstaltungen/amalfikueste/festa-sant-andrea-amalfi/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Fest des hl. Andreas Amalfi 2026",
  "startDate": "2026-06-27",
  "endDate": "2026-06-27",
  "location": {
    "@type": "Place",
    "name": "Dom von Amalfi",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Amalfi",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/amalfikueste/festa-sant-andrea-amalfi/"
};

const facts = [
  { dt: 'Datum', dd: '27. Juni 2026' },
  { dt: 'Veranstaltungsort', dd: 'Dom von Amalfi' },
  { dt: 'Typ', dd: 'Patronatsfest' },
  { dt: 'Höhepunkt', dd: 'Trägerrennen & Feuerwerk' },
  { dt: 'Eintritt', dd: 'Kostenlos' },
];
---

<BaseLayout
  title="Fest des hl. Andreas Amalfi 2026 – Trägerrennen & Feuerwerk"
  description="Das Fest des heiligen Andreas in Amalfi am 27. Juni 2026. Träger tragen die silberne Büste des hl. Andreas die Domtreppen hinauf, gefolgt von einem spektakulären Feuerwerk im Hafen."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/amalfi-hero.jpg"
      alt="Fest des hl. Andreas, Dom von Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">27. Juni 2026</span>
        <span class="text-white/70 text-sm">Amalfi, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Fest des hl. Andreas</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Der Trägerrennen und das Feuerwerk über dem Hafen von Amalfi.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Das Patronatsfest des heiligen Andreas ist eines der bewegendsten Ereignisse des Jahres in Amalfi. Kräftige Träger schultern die schwere silberne Büste des Schutzpatrons und tragen sie in einer feierlichen Prozession die 62 Stufen des Doms hinauf – begleitet von den Rufen der Menge und dem Klang der Kirchenglocken.</p>
            <p>Am Abend erhellt ein spektakuläres Feuerwerk den Hafen von Amalfi und spiegelt sich im ruhigen Wasser des Golfs. Das gesamte Städtchen versammelt sich auf der Piazza del Duomo und entlang des Uferwegs, um das Fest seines Schutzpatrons zu begehen.</p>
          </div>
        </div>

        <!-- Das Fest -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Das Fest</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Der Trägerrennen</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Die silberne Büste</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Die Prozession der Träger ist das Herzstück des Festes: Starke Männer aus Amalfi tragen im Wettlauf die schwere silberne Büste des heiligen Andreas die Domtreppe hinauf – eine Jahrhunderte alte Tradition.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Feuerwerk im Hafen</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Ein Spektakel über dem Meer</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Das abendliche Feuerwerk über dem Hafen von Amalfi ist eines der schönsten Küstenfeuerwerke – zu sehen von der Piazza, von den Terrassen und vom Wasser aus.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre</td>
                  <td class="px-6 py-4 text-slate-600">Ab Neapel, Sorrent, Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Anleger im Zentrum von Amalfi</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Entlang der SS163</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Haltestelle Piazza Flavio Gioia, Amalfi</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Zu Fuß</td>
                  <td class="px-6 py-4 text-slate-600">Vom Hafenbereich</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">3 min zum Dom</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
