---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Veranstaltungen', url: '/de-de/veranstaltungen/' },
  { name: 'Luminaria di San Domenico', url: '/de-de/veranstaltungen/amalfikueste/luminaria-san-domenico-praiano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Luminaria di San Domenico Praiano 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-04",
  "location": {
    "@type": "Place",
    "name": "Piazza San Gennaro, Praiano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Praiano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/de-de/veranstaltungen/amalfikueste/luminaria-san-domenico-praiano/"
};

const facts = [
  { dt: 'Datum', dd: '1.–4. August 2026' },
  { dt: 'Veranstaltungsort', dd: 'Piazza San Gennaro, Praiano' },
  { dt: 'Typ', dd: 'Lichtinstallation & Feuerwerk' },
  { dt: 'Eintritt', dd: 'Kostenlos' },
  { dt: 'Ab Amalfi', dd: 'Bus SITA, 20 min' },
];
---

<BaseLayout
  title="Luminaria di San Domenico Praiano 2026 – Tausende Kerzen im Fischerdorf"
  description="Die Luminaria di San Domenico in Praiano, 1.–4. August 2026. Tausende Kerzen, Feuerkunst und Lichtprojektionen verwandeln das Fischerdorf Praiano in ein Lichtermeer."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/praiano-hero.jpg"
      alt="Luminaria di San Domenico, Praiano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Veranstaltung 2026</span>
        <span class="text-white/70 text-sm">1.–4. August 2026</span>
        <span class="text-white/70 text-sm">Praiano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Luminaria di San Domenico</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Tausende von Kerzen verwandeln Praiano in ein Lichterdorf.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Zur Veranstaltung</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Vier Nächte lang verwandelt sich das Fischerdorf Praiano in ein Meer aus Kerzenlicht. Tausende handgemachter Kerzen werden entlang der Gassen, Treppen und Häuserfronten aufgestellt – eine der stimmungsvollsten Veranstaltungen an der gesamten Amalfiküste.</p>
            <p>Lichtprojektionen, Feuerkunst und Musikdarbietungen begleiten die Kerzenlichtnächte. Praiano bleibt auch im August ein ruhigeres Dorf als die bekannteren Nachbarn – die Luminaria ist der ideale Anlass, es zu entdecken.</p>
          </div>
        </div>

        <!-- Die Nächte des Lichts -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Die Nächte des Lichts</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Tausende Kerzen</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Das Lichtermeer</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Freiwillige aus dem Dorf stellen jedes Jahr tausende Kerzen in handbemalten Papierhüllen auf – entlang der Treppengassen, auf Fensterbänken und an der Küstenmauer. Das Ergebnis ist magisch.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Feuerwerk & Lichtkunst</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Spektakel über dem Meer</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Lichtprojektionen auf den Fassaden der Kirchen, Feuerkunst über dem Meer und traditionelle Musik runden das Fest zu einem vollständigen Spektakel ab.</p>
            </div>
          </div>
        </div>

        <!-- Anreise -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Anreise</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verkehrsmittel</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Verbindung</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Ab Amalfi oder Positano</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ca. 20 min ab Amalfi</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Fähre</td>
                  <td class="px-6 py-4 text-slate-600">Ab Positano oder Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Anleger Praiano Marina di Praia</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Veranstaltungsdetails</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Wir empfehlen, frühzeitig anzureisen. Das aktualisierte Programm finden Sie auf den offiziellen Kanälen.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
