---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Amalfiküste', url: '/de-de/amalfikueste/' },
  { name: 'Amalfi', url: '/de-de/amalfikueste/amalfi/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Amalfi",
  "description": "Amalfi ist die historische Hauptstadt der Amalfiküste, einst eine mächtige mittelalterliche Seerepublik. Berühmt für den Dom von Sant'Andrea, den Kreuzgang des Paradieses und die handgeschöpfte Papierherstellung.",
  "url": "https://amalficoast-travel.com/de-de/amalfikueste/amalfi/",
  "image": "https://amalficoast-travel.com/images/amalfi-hero.jpg",
  "touristType": ["Kultur", "Geschichte", "Meer", "Gastronomie"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84011"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6339,
    "longitude": 14.6027
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie kommt man von Neapel nach Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Von Neapel kann man Amalfi per Fähre vom Molo Beverello erreichen (ca. 90–105 Min., saisonal) oder mit dem SITA-Bus von Sorrent über die SS163 (ca. 90 Min.). Mit dem Auto ist die SS163 spektakulär, aber kurvenreich: im Sommer besser meiden."
      }
    },
    {
      "@type": "Question",
      "name": "Wann ist die beste Reisezeit für Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "April–Juni und September–Oktober sind ideal: mildes Wetter, vertretbare Menschenmassen, angemessene Preise. Juli und August sind die Haupttouristensaison. November–März ist ruhig, aber mit Regenrisiko und eingeschränkten Angeboten."
      }
    },
    {
      "@type": "Question",
      "name": "Was kostet die Fähre von Salerno nach Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Travelmar-Fähre von Salerno nach Amalfi kostet etwa 8–10 € je Richtung. Tickets können online oder am Hafenschalter gekauft werden. Der Dienst läuft ungefähr von April bis Oktober."
      }
    },
    {
      "@type": "Question",
      "name": "Was kann man in Amalfi an einem Tag sehen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An einem Tag kann man den Dom von Sant'Andrea und den Kreuzgang des Paradieses besuchen, das Papiermuseum, das historische Zentrum mit der Piazza del Duomo, und einen Spaziergang ins Valle delle Ferriere unternehmen. Am Abend Abendessen in einem der Uferrestaurants."
      }
    },
    {
      "@type": "Question",
      "name": "Gibt es Parkplätze in Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Parken ist rar und teuer (Parkplätze Luna Rossa und Flavio Gioia: ca. 4–5 €/Stunde). Im Sommer gilt eine ZTL-Verkehrsbeschränkungszone im historischen Zentrum. Es wird empfohlen, mit der Fähre oder dem SITA-Bus anzureisen, um den Stau auf der SS163 zu vermeiden."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Lage', dd: 'Amalfiküste, SA' },
  { dt: 'Einwohner', dd: '~5.000' },
  { dt: 'Von Neapel', dd: '~90 Min. (Fähre)' },
  { dt: 'Von Sorrent', dd: '~90 Min. (SITA-Bus)' },
  { dt: 'ZTL', dd: 'Ja, im Sommer' },
  { dt: 'Strand', dd: 'Kiesel (Stadtzentrum)' },
  { dt: 'Beste Reisezeit', dd: 'Apr–Jun / Sep–Okt' },
  { dt: 'Währung', dd: 'Euro (€)' },
];
---

<BaseLayout
  title="Amalfi 2026: Vollständiger Reiseführer | Amalfiküste"
  description="Alles über Amalfi: Anreise, Dom, Papiermuseum, Fähr- und Busfahrpläne, Sehenswürdigkeiten, Reisezeit. Der vollständige Reiseführer zur historischen Hauptstadt der Amalfiküste."
  lang={lang}
  pageKey="amalfi"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/amalfi-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfiküste</p>
        <h1 class="font-serif text-display text-white mb-4">Amalfi</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Die historische Hauptstadt der Küste: eine mittelalterliche Seerepublik, deren Tradition der Papierherstellung noch heute in ihren Werkstätten lebt, und deren Dom die beeindruckendste Kirche an der tyrrhenischen Küste bleibt.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Kurzinfos</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Anreise</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Amalfi ist mehr als eine Postkarte. Zwischen dem 9. und 13. Jahrhundert war es eine der mächtigsten Seerepubliken im Mittelmeer - auf Augenhöhe mit Venedig, Genua und Pisa. Heute leben 5.000 Einwohner an den Hängen einer dramatischen Schlucht, die vom Torrente Canneto eingeschnitten wurde, zwischen Türmen, Klöstern und einem Dom, der allein die Reise rechtfertigt.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Die Stadt gab der Welt auch die Amalfi-Tafeln - den ältesten Seefahrtskodex der westlichen Welt aus dem 11. Jahrhundert - sowie eine Papierherstellungstradition, die das erste Wasserzeichenpapier Europas hervorbrachte.
          </p>
        </div>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wusstest du?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">IX</p>
              <p class="text-white/60 text-xs italic mt-1">Jahrhundert: Gründung der Seerepublik</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">62</p>
              <p class="text-white/60 text-xs italic mt-1">Stufen der Domtreppe</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">5.000</p>
              <p class="text-white/60 text-xs italic mt-1">Einwohner heute</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Die Amalfi-Tafeln (Tabula Amalfitana), der älteste Seefahrtskodex der westlichen Welt, regelten den Handel im Mittelmeer vom 11. bis zum 16. Jahrhundert.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Sehenswürdigkeiten in Amalfi</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Dom von Sant'Andrea</h3>
                <p class="text-slate-600 leading-relaxed">Die arabisch-normannische Fassade mit ihrem auffälligen schwarz-weißen Mosaik und die 62 Stufen von der Piazza del Duomo hinauf sind das ikonische Bild von Amalfi. Der Kreuzgang des Paradieses (Chiostro del Paradiso), ein arabisch-normannischer Kreuzgang aus dem 13. Jahrhundert, ist im Domticket enthalten. Täglich geöffnet.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Papiermuseum (Museo della Carta)</h3>
                <p class="text-slate-600 leading-relaxed">In einer Papiermühle aus dem 13. Jahrhundert im Valle dei Mulini gelegen, zeichnet dieses Museum die Geschichte der Papierherstellung in Amalfi nach. Live-Vorführungen zeigen, wie Bögen mit traditionellen Techniken von Hand hergestellt werden. Eintritt ~4 €.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Arsenal der Seerepublik</h3>
                <p class="text-slate-600 leading-relaxed">Die einzige erhaltene mittelalterliche Schiffswerft der Republik mit gewölbten Hallen, in denen Galeeren gebaut wurden. Heute beherbergt sie Wechselausstellungen und das Kompassmuseum.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Valle delle Ferriere</h3>
                <p class="text-slate-600 leading-relaxed">Ein geschütztes Naturschutzgebiet oberhalb der Stadt mit einem malerischen Wasserfall und üppiger Vegetation. Der Wanderweg beginnt beim Papiermuseum und dauert etwa 2 Stunden hin und zurück. Freier Zutritt.</p>
              </div>
            </div>
          </div>
        </div>

        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Anreise nach Amalfi</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Amalfi ist gut per Fähre und Bus erreichbar. Mit dem Auto ist die SS163 spektakulär, aber im Sommer überlastet - öffentliche Verkehrsmittel werden dringend empfohlen.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Per Fähre</h3><p class="text-white/50 text-sm leading-relaxed">Travelmar von Salerno (April–Oktober). NLG / Alilauro von Neapel Molo Beverello (saisonal). Die malerischste Option.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">SITA-Bus</h3><p class="text-white/50 text-sm leading-relaxed">Von Sorrent entlang der SS163 (~90 Min., ~2,50 €). Von Salerno direkt (~75 Min.). Ganzjährig.</p></div>
              </div>
            </div>
            <a href="/de-de/ratgeber/faehren/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Vollständiger Transportführer
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Fährfahrpläne - Sommer 2026
          </h3>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Travelmar - Salerno ↔ Amalfi</caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Abfahrt Salerno</th>
                  <th class="text-left px-4 py-3 font-semibold">Ankunft Amalfi</th>
                  <th class="text-left px-4 py-3 font-semibold">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">07:15</td><td class="px-4 py-3 font-mono">08:30</td><td class="px-4 py-3 text-slate-500">Über Cetara, Maiori</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">09:00</td><td class="px-4 py-3 font-mono">10:15</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">11:00</td><td class="px-4 py-3 font-mono">12:15</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">14:15</td><td class="px-4 py-3 font-mono">15:30</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">16:30</td><td class="px-4 py-3 font-mono">17:45</td><td class="px-4 py-3 text-slate-500">—</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Indikative Fahrpläne für 2026. Auf travelmar.it bestätigen.</p>
        </div>

        <!-- Verborgene Ecken -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Verborgene Ecken in Amalfi</h2>
          <p class="text-slate-500 mb-8">Jenseits der Postkarten: vier Winkel, die Durchgangstouristen nie finden.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Valle dei Mulini</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Das Tal oberhalb der Stadt, wo die mittelalterlichen Papiermühlen standen. Ein kurzer, aber malerischer Spaziergang durch üppige Vegetation, weit abseits der touristischen Trampelpfade.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Strand Santa Croce</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Nur per Boot oder über eine schmale Treppe erreichbar, dieser Strand westlich von Amalfi bietet kristallklares Wasser mit deutlich weniger Besuchern als das Stadtzentrum.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Fontana Sant'Andrea</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Der mittelalterliche Brunnen in einer ruhigen Seitengasse hinter dem Dom. Ein magischer, fast vergessener Winkel, wo die Zeit stillzustehen scheint.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Handgeschöpftes Papier kaufen</h3>
              <p class="text-sm text-slate-600 leading-relaxed">In den kleinen Papierhandwerksläden rund ums Papiermuseum kann man echtes, handgemachtes Amalfi-Papier kaufen - das einzige authentische Souvenir aus dem Ort seiner Entstehung.</p>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Insider-Tipp</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Dom frühmorgens besuchen</h3>
              <p class="text-white/70 leading-relaxed">Den Dom vor 9:00 Uhr besuchen, bevor die Tagestouristen ankommen. Die 62 Stufen hinaufsteigen, wenn die Piazza noch leer ist, und das arabisch-normannische Mosaik im Morgenlicht bewundern. Der Eintritt in den Kreuzgang des Paradieses ist im Domticket inbegriffen - nicht auslassen.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Häufig gestellte Fragen zu Amalfi</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Kurzinfos - Amalfi</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i, arr) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < arr.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Insider-Tipps -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Insider-Tipps</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Den Dom frühmorgens besuchen, bevor die Tagestouristen eintreffen - die Treppe ist dann noch leer.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Das Papiermuseum nicht auslassen: eine der originellsten Erfahrungen der gesamten Küste.</span>
            </li>
