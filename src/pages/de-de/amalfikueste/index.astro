---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Amalfiküste', url: '/de-de/amalfikueste/' },
];

const borghi = [
  {
    name: 'Positano',
    href: '/de-de/amalfikueste/positano/',
    desc: 'Das meistfotografierte Dorf der Küste, mit bunten Häusern, die über dem Meer thronen, und dem berühmten Spiaggia Grande.',
    tag: 'Das ikonischste',
  },
  {
    name: 'Amalfi',
    href: '/de-de/amalfikueste/amalfi/',
    desc: 'Historische Hauptstadt der Küste, mit dem Dom von Sant\'Andrea und dem Papiermuseum.',
    tag: 'Historische Hauptstadt',
  },
  {
    name: 'Ravello',
    href: '/de-de/amalfikueste/ravello/',
    desc: 'Auf 350 m über dem Meer, die „Stadt der Musik" mit der Villa Rufolo und der Villa Cimbrone.',
    tag: 'Panoramablick',
  },
  {
    name: 'Praiano',
    href: '/de-de/amalfikueste/praiano/',
    desc: 'Das bestgehütete Geheimnis: weniger Trubel, spektakuläre Sonnenuntergänge über der Bucht von Praia.',
    tag: 'Das authentischste',
  },
  {
    name: 'Maiori',
    href: '/de-de/amalfikueste/maiori/',
    desc: 'Der längste Sandstrand der Küste: ideal für alle, die das Meer ohne Komfortverzicht suchen.',
    tag: 'Sandstrand',
  },
  {
    name: 'Minori',
    href: '/de-de/amalfikueste/minori/',
    desc: 'Dorf der Zitronenhaine, mit Überresten einer römischen Villa aus dem 1. Jh. n. Chr. und ausgezeichneten Konditoreien.',
    tag: 'Authentische Aromen',
  },
];

const destinationSchema = {
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": "Amalfiküste",
  "description": "Die Amalfiküste ist ein 50 km langer Küstenabschnitt in Kampanien, seit 1997 UNESCO-Welterbe, mit bunten Dörfern, Klippen und dem Blau des Tyrrhenischen Meeres.",
  "url": "https://amalficoast-travel.com/de-de/amalfikueste/",
  "touristType": ["Kultur", "Meer", "Natur", "Gastronomie", "Wandern"],
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6333,
    "longitude": 14.6027
  }
};
---

<BaseLayout
  title="Amalfiküste 2026: Vollständiger Reiseführer zu den Dörfern"
  description="Reiseführer zur Amalfiküste: zu besichtigende Dörfer, Strände, Anreise, Reisezeit. Von Positano bis Amalfi – alles, was Sie wissen müssen."
  lang={lang}
  pageKey="costiera-amalfitana"
  breadcrumbs={breadcrumbs}
  schema={[destinationSchema]}
>

  <!-- Hero -->
  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager"  referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/de-de/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Amalfiküste</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">UNESCO-Welterbe</p>
        <h1 class="font-serif text-display text-white mb-4">Amalfiküste</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Fünfzig Kilometer Klippen, bunte Dörfer und türkisfarbenes Wasser. Italiens berühmteste Küste in einem vollständigen, aktuellen Reiseführer für 2026.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-20">

    <!-- Intro -->
    <section class="max-w-text">
      <p class="text-xl leading-relaxed text-charcoal">
        Die Amalfiküste ist einer jener Orte, die jede Erwartung übertreffen. Egal wie viele Fotos Sie schon gesehen haben: die Wirklichkeit - der Duft von Zitronen, das Funkeln der Sonne auf dem Meer, die an den Felsen klebenden Häuser - ist immer intensiver.
      </p>
      <p class="mt-4 text-slate-600 leading-relaxed">
        Seit 1997 UNESCO-Welterbe, erstreckt sie sich über 50 km von der Sorrentinischen Halbinsel bis nach Vietri sul Mare in der Provinz Salerno. Das Herzstück ist die SS163, eine kurvenreiche Straße, die in den Felsen gehauen wurde und 13 Gemeinden verbindet, jede mit ihrer eigenen Geschichte, Landschaft und Aromen.
      </p>
    </section>

    <!-- Borghi Grid -->
    <section>
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-serif text-3xl font-semibold text-slate-900">Dörfer der Küste</h2>
        <p class="text-sm text-slate-400 hidden sm:block">Von West nach Ost entlang der SS163</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {borghi.map(b => (
          <a href={b.href} class="group bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm hover:border-med-blue/30 hover:shadow-xl transition-all duration-300">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-serif text-xl font-semibold text-slate-900 group-hover:text-med-blue transition-colors">{b.name}</h3>
              <span class="text-[10px] uppercase tracking-wide bg-med-blue/5 text-med-blue px-2 py-1 rounded-full font-medium flex-shrink-0 ml-2">{b.tag}</span>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed">{b.desc}</p>
            <p class="text-med-blue text-sm font-medium mt-4 group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
              {b.name} entdecken
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6"/></svg>
            </p>
          </a>
        ))}
      </div>
    </section>

    <!-- Did You Know -->
    <section class="bg-charcoal text-white rounded-[2rem] p-10">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-8">Die Küste in Zahlen</p>
      <div class="grid sm:grid-cols-4 gap-8 text-center">
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">50 km</p>
          <p class="text-white/60 text-sm mt-2">UNESCO-Küstenlinie</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">13</p>
          <p class="text-white/60 text-sm mt-2">Küstengemeinden</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">1997</p>
          <p class="text-white/60 text-sm mt-2">UNESCO-Jahr</p>
        </div>
        <div>
          <p class="font-serif text-5xl font-bold text-med-gold">2 Mio.+</p>
          <p class="text-white/60 text-sm mt-2">Touristen/Jahr</p>
        </div>
      </div>
    </section>

    <!-- Quick Links -->
    <section>
      <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Praktische Reiseführer</h2>
      <div class="grid sm:grid-cols-3 gap-4">
        <a href="/de-de/amalfikueste/come-arrivare/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Anreise</p>
            <p class="text-xs text-slate-500">Fähren, Bus, Auto</p>
          </div>
        </a>
        <a href="/de-de/quando-visitare/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Beste Reisezeit</p>
            <p class="text-xs text-slate-500">Monat für Monat</p>
          </div>
        </a>
        <a href="/de-de/spiagge/" class="flex items-center gap-4 bg-med-cream rounded-2xl p-5 hover:bg-med-blue/5 transition-colors group border border-slate-100">
          <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17c3-3 6-3 9 0s6 3 9 0M3 12c3-3 6-3 9 0s6 3 9 0"/></svg>
          </div>
          <div>
            <p class="font-medium text-charcoal group-hover:text-med-blue text-sm transition-colors">Die Strände</p>
            <p class="text-xs text-slate-500">8 ausgewählte Strände</p>
          </div>
        </a>
      </div>
    </section>

  </div>

</BaseLayout>
