---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Amalfiküste', url: '/de-de/amalfikueste/' },
  { name: 'Maiori', url: '/de-de/amalfikueste/maiori/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Maiori",
  "description": "Maiori besitzt den längsten Sandstrand der Amalfiküste (300 m), eine breite Uferpromenade, einen normannischen Turm und ist der entspannteste Ort der gesamten Küste.",
  "url": "https://amalficoast-travel.com/de-de/amalfikueste/maiori/",
  "image": "https://amalficoast-travel.com/images/maiori-hero.jpg",
  "touristType": ["Strand", "Familien", "Erholung", "Authentizität"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Maiori",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6497,
    "longitude": 14.6408
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie kommt man von Salerno nach Maiori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Per Travelmar-Fähre von Salerno (ca. 50 Min., saisonal April–Oktober) oder per SITA-Bus von Salerno oder Amalfi. Der Bus ist die häufigste Option ganzjährig."
      }
    },
    {
      "@type": "Question",
      "name": "Hat Maiori einen Sandstrand?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja — Maiori hat den längsten Sandstrand der Amalfiküste, ca. 300 Meter, mit sowohl kostenfreien öffentlichen Abschnitten als auch bezahlten Strandclubs. Der Sand hier ist gröber als der Kiesel, der für andere Küstendörfer typisch ist."
      }
    },
    {
      "@type": "Question",
      "name": "Lohnt sich ein Besuch in Maiori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, besonders wenn man eine lokalere, weniger touristische Atmosphäre bevorzugt. Maiori ist bei italienischen Familien für seinen Strand, seine Uferpromenade und seine niedrigeren Preise im Vergleich zu Positano und Amalfi beliebt."
      }
    },
    {
      "@type": "Question",
      "name": "Was kann man in Maiori außer dem Strand besichtigen?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Abtei Santa Maria de Olearia aus dem 11. Jahrhundert ist ein architektonisches Juwel, das in den Fels gemeißelt wurde. Der normannische Turm Torre Normanna bietet Aussichten über die Bucht. Die Gärten des Palazzo Mezzacapo sind eine ruhige grüne Oase mit Panoramaterrasse."
      }
    },
    {
      "@type": "Question",
      "name": "Wann ist das Feuerwerk in Maiori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Am 15. August feiert Maiori das Fest der Santa Maria a Mare mit einer Prozession auf dem Meer und einem Feuerwerk über der Bucht — eines der schönsten Ferragosto-Spektakel der Küste. Es empfiehlt sich, einen Platz an der Promenade rechtzeitig zu sichern."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Lage', dd: 'Amalfiküste, SA' },
  { dt: 'Einwohner', dd: '~5.500' },
  { dt: 'Von Salerno', dd: '~50 Min. (Fähre)' },
  { dt: 'Von Amalfi', dd: '~20 Min. (SITA-Bus)' },
  { dt: 'Strand', dd: 'Sand (300 m)' },
  { dt: 'Ideal für', dd: 'Strand, Familien, Einheimische' },
  { dt: 'Beste Reisezeit', dd: 'Jun–Sep' },
  { dt: 'Währung', dd: 'Euro (€)' },
];
---

<BaseLayout
  title="Maiori 2026: Vollständiger Reiseführer | Amalfiküste"
  description="Reiseführer zu Maiori: der längste Sandstrand der Amalfiküste, die Gärten des Palazzo Mezzacapo, die Abtei Santa Maria de Olearia. Anreise per Fähre von Salerno."
  lang={lang}
  pageKey="maiori"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/maiori-hero.jpg" alt="Maiori, Amalfiküste" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfiküste · Strand & Einheimisches Leben</p>
        <h1 class="font-serif text-display text-white mb-4">Maiori</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Der längste Strand der Amalfiküste: 300 Meter Sand statt der überall sonst zu findenden Kiesel. Maiori ist der entspannteste Ort der Küste — eine echte Uferpromenade, einheimische Restaurants und Preise, die keinen Schrecken verbreiten.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Maiori liegt an der Mündung des Regina-Tales, das von der Küste ins Landesinnere reicht und der Stadt die breiteste Küstenebene — und damit den breitesten Strand — der gesamten Amalfiküste beschert. Es ist eine echte Kleinstadt mit einem Supermarkt, einem Postamt und Bewohnern, die das ganze Jahr über hier leben — was an diesem Küstenabschnitt ungewöhnlich ist.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wusstest du?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">300 m</p>
              <p class="text-white/60 text-xs italic mt-1">der längste Sandstrand der Küste</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">XI</p>
              <p class="text-white/60 text-xs italic mt-1">Jahrhundert: Abtei Santa Maria de Olearia</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">5.500</p>
              <p class="text-white/60 text-xs italic mt-1">ganzjährige Einwohner</p>
            </div>
          </div>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Sehenswürdigkeiten in Maiori</h2>
          <div class="space-y-6">
            {[
              { title: 'Der Strand', text: 'Der Hauptsandstrand mit 300 m Sand — der längste der Amalfiküste. Sowohl kostenfreie öffentliche Abschnitte als auch bezahlte Strandclubs sind vorhanden. Eine Uferpromenade mit Bars und Restaurants verläuft entlang der Küste.' },
              { title: 'Abtei Santa Maria de Olearia', text: 'Eine bemerkenswerte Benediktinerabtei aus dem 11. Jahrhundert, in den Fels über der Küstenstraße gemeißelt, mit drei übereinander angeordneten Kapellen und mittelalterlichen Fresken. Für Besucher geöffnet; saisonale Zeiten beachten.' },
              { title: 'Gärten des Palazzo Mezzacapo', text: 'Ein Garten aus dem 19. Jahrhundert mit seltenen Pflanzen, einer Panoramaterrasse und Ausblicken auf die Bucht. Kostenloser öffentlicher Zutritt.' },
              { title: 'Ferragosto-Feuerwerk (15. August)', text: 'Am 15. August feiert Maiori das Fest der Santa Maria a Mare mit einer Meeresprozession und Feuerwerk über der Bucht — eines der besten Ferragosto-Spektakel der Küste.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Anreise</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Fähre (Saisonal)</p>
              <p class="text-slate-700 font-medium mb-1">Travelmar von Salerno</p>
              <p class="text-slate-500 text-sm">~50 Min., April–Oktober. Die malerischste Option von Salerno aus.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">SITA-Bus</p>
              <p class="text-slate-700 font-medium mb-1">Von Amalfi oder Salerno</p>
              <p class="text-slate-500 text-sm">~20 Min. von Amalfi. Ganzjähriger Betrieb entlang der SS163.</p>
            </div>
          </div>
        </div>

        <!-- Fährfahrplan -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Fährfahrpläne — Sommer 2026
          </h3>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Travelmar — Salerno ↔ Maiori</caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Abfahrt Salerno</th>
                  <th class="text-left px-4 py-3 font-semibold">Ankunft Maiori</th>
                  <th class="text-left px-4 py-3 font-semibold">Hinweise</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">07:15</td><td class="px-4 py-3 font-mono">08:05</td><td class="px-4 py-3 text-slate-500">Über Cetara</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">09:00</td><td class="px-4 py-3 font-mono">09:50</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">11:00</td><td class="px-4 py-3 font-mono">11:50</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">14:15</td><td class="px-4 py-3 font-mono">15:05</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">16:30</td><td class="px-4 py-3 font-mono">17:20</td><td class="px-4 py-3 text-slate-500">—</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Indikative Fahrpläne für 2026. Auf travelmar.it bestätigen.</p>
        </div>

        <!-- Verborgene Ecken -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Verborgene Ecken in Maiori</h2>
          <p class="text-slate-500 mb-8">Jenseits der Postkarten: vier Winkel, die Durchgangstouristen nie finden.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Normannischer Turm (Torre Normanna)</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Der mittelalterliche Wachturm am östlichen Ende des Strandes bietet Aussichten auf die gesamte Bucht von Maiori und die Küste bis nach Capo d'Orso. Selten besucht, aber architektonisch beeindruckend.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Valle del Regina</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Das Tal hinter Maiori führt zu kleinen Dörfern und Terrassengärten mit Zitronen und Kastanien. Ein ruhiger Spaziergang oder eine kurze Wanderung, die das Hinterland der Küste zeigt.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Morgenmarkt</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Anders als in Positano oder Amalfi hat Maiori einen echten wöchentlichen Markt, auf dem Einheimische einkaufen. Frische lokale Produkte, Oliven, Käse und Zitronen zu authentischen Preisen.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Abtei Santa Maria de Olearia</h3>
              <p class="text-sm text-slate-600 leading-relaxed">In den Fels oberhalb der SS163 gemeißelt und nur wenigen bekannt, ist diese Abtei aus dem 11. Jahrhundert eines der verstecktesten architektonischen Juwele der gesamten Küste. Drei übereinanderliegende Kapellen mit mittelalterlichen Fresken.</p>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Insider-Tipp</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Maiori als Stützpunkt für die ganze Küste</h3>
              <p class="text-white/70 leading-relaxed">Maiori ist der perfekte Stützpunkt für die gesamte Amalfiküste: häufige Busverbindungen in beide Richtungen, Fähranschluss nach Salerno, deutlich niedrigere Hotelpreise als in Positano oder Amalfi — und abends kehrt man an einen ruhigen Strand zurück, den man kaum mit anderen teilen muss.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen zu Maiori</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Kurzinfos — Maiori</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Insider-Tipps -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Insider-Tipps</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Maiori als Basis für Tagesausflüge nach Positano und Amalfi nutzen — günstigere Übernachtungspreise.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Frühmorgens an den Strand gehen: vor 9 Uhr hat man den 300-m-Strand nahezu für sich allein.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Die Abtei Santa Maria de Olearia besuchen: eines der am wenigsten bekannten Juwelen der Küste.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Am 15. August für das Feuerwerk über der Bucht bleiben — das Beste der gesamten Küste.</span>
            </li>
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Amalfiküste</p>
          <nav class="space-y-1">
            {[
              { href: '/de-de/amalfikueste/positano/', label: 'Positano' },
              { href: '/de-de/amalfikueste/amalfi/', label: 'Amalfi' },
              { href: '/de-de/amalfikueste/ravello/', label: 'Ravello' },
              { href: '/de-de/amalfikueste/praiano/', label: 'Praiano' },
              { href: '/de-de/amalfikueste/minori/', label: 'Minori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Auch die Küste erkunden"
    items={[
      { name: 'Minori',   href: '/de-de/amalfikueste/minori/',   tag: 'Aromen & Kultur',    desc: 'Römische Villa aus dem 1. Jh., Scialatielli-Pasta und Konditoreien.' },
      { name: 'Amalfi',   href: '/de-de/amalfikueste/amalfi/',   tag: 'Kunst & Geschichte', desc: 'Der Dom, das Papiermuseum und die Seerepublik.' },
      { name: 'Ravello',  href: '/de-de/amalfikueste/ravello/',  tag: 'Musik & Gärten',     desc: 'Villa Rufolo, Villa Cimbrone und das Ravello Festival.' },
      { name: 'Positano', href: '/de-de/amalfikueste/positano/', tag: 'Das Ikonischste',     desc: 'Bunte Häuser über dem Meer und der berühmteste Strand der Küste.' },
    ]}
  />

</BaseLayout>
