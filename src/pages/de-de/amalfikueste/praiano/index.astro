---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Amalfiküste', url: '/de-de/amalfikueste/' },
  { name: 'Praiano', url: '/de-de/amalfikueste/praiano/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Praiano",
  "description": "Praiano ist das bestgehütete Geheimnis der Amalfiküste: spektakuläre Sonnenuntergänge von der Kirche San Gennaro, der ruhige Strand Gavitella, die Marina di Praia und deutlich weniger Touristen als in Positano.",
  "url": "https://amalficoast-travel.com/de-de/amalfikueste/praiano/",
  "image": "https://amalficoast-travel.com/images/praiano-hero.jpg",
  "touristType": ["Natur", "Strand", "Sonnenuntergang", "Authentizität"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6108,
    "longitude": 14.5344
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie kommt man nach Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Praiano liegt an der SS163 zwischen Positano und Amalfi. Der SITA-Bus ist die bequemste Option: von Positano (ca. 15 Min.) oder von Amalfi (ca. 30 Min.). Im Sommer gibt es auch Fähranschlüsse. Mit dem Auto gibt es begrenzte Parkplätze entlang der Hauptstraße."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist das Besondere an Praiano gegenüber Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Praiano hat viel weniger Touristen als Positano, niedrigere Preise und eine authentischere Atmosphäre. Der Sonnenuntergang von der Kirche San Gennaro ist legendär. Der Strand Gavitella ist ruhiger und die Marina di Praia bietet einen echten kleinen Fischereihafen."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Strände gibt es in Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die Hauptstrände sind Gavitella (erreichbar über eine Treppe von der Hauptstraße, Kiesel, mit einem Strandclub) und die Marina di Praia (kleiner Kiesstand in einer Felsenbucht mit einem Restaurant). Beide sind weniger belebt als die Strände in Positano."
      }
    },
    {
      "@type": "Question",
      "name": "Wann ist der beste Sonnenuntergang in Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der spektakulärste Sonnenuntergang der Amalfiküste ist von der Terrasse der Kirche San Gennaro aus zu sehen, die direkt auf dem Kap über dem Meer liegt. Von Mai bis September setzt die Sonne direkt hinter dem Meer unter — ideal ist etwa 30 Minuten vor Sonnenuntergang dort zu sein."
      }
    },
    {
      "@type": "Question",
      "name": "Gibt es in Praiano gute Restaurants?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ja, Praiano hat mehrere ausgezeichnete Restaurants mit frischen Meeresfrüchten zu deutlich niedrigeren Preisen als in Positano. Das Restaurant an der Marina di Praia ist für seine Pasta mit frischem Fisch bekannt. Abends sind die Restaurants entlang der SS163 sehr beliebt bei Einheimischen."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Lage', dd: 'Amalfiküste, SA' },
  { dt: 'Einwohner', dd: '~1.900' },
  { dt: 'Von Positano', dd: '~15 Min. (SITA-Bus)' },
  { dt: 'Von Amalfi', dd: '~30 Min. (SITA-Bus)' },
  { dt: 'Strände', dd: 'Gavitella, Marina di Praia' },
  { dt: 'Highlight', dd: 'Sonnenuntergang San Gennaro' },
  { dt: 'Beste Reisezeit', dd: 'Mai–Okt' },
  { dt: 'Atmosphäre', dd: 'Ruhig, authentisch' },
];
---

<BaseLayout
  title="Praiano 2026: Vollständiger Reiseführer | Amalfiküste"
  description="Alles über Praiano: Sonnenuntergang von San Gennaro, Strand Gavitella, Marina di Praia, Anreise. Das bestgehütete Geheimnis der Amalfiküste mit weniger Touristen und echtem Flair."
  lang={lang}
  pageKey="praiano"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/praiano-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfiküste · Sonnenuntergang & Ruhe</p>
        <h1 class="font-serif text-display text-white mb-4">Praiano</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Das bestgehütete Geheimnis zwischen Positano und Amalfi: spektakuläre Sonnenuntergänge von der Kirche San Gennaro, der stille Strand Gavitella und die Magie einer kleinen Fischerbucht — all das ohne die Menschenmassen der berühmten Nachbarn.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Kurzinfos</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Anreise</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Praiano liegt auf einem Kap zwischen Positano und Amalfi und ist das authentischste der Küstendörfer — bekannt bei jenen, die es kennen, aber von den meisten Touristen übersehen. Hier haben die Einheimischen noch einen Platz für sich, die Preise sind vernünftig und der Sonnenuntergang von der Kirche San Gennaro gehört zu den spektakulärsten Italiens.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wusstest du?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1.900</p>
              <p class="text-white/60 text-xs italic mt-1">Einwohner — das ruhigste Dorf der Küste</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">2</p>
              <p class="text-white/60 text-xs italic mt-1">Strände: Gavitella und Marina di Praia</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">180°</p>
              <p class="text-white/60 text-xs italic mt-1">Panoramablick von San Gennaro</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Praiano war einst bekannt für seine Fischereitradition und die Herstellung von Seidenstoffen. Die Kirche San Gennaro, direkt auf dem Kap, bietet eine der spektakulärsten Aussichten der gesamten Küste.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Sehenswürdigkeiten in Praiano</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Kirche San Gennaro — Sonnenuntergang</h3>
                <p class="text-slate-600 leading-relaxed">Die Terrasse der Kirche San Gennaro liegt direkt auf dem Kap und bietet einen freien 180-Grad-Blick aufs Meer. Der Sonnenuntergang von hier aus gilt als einer der schönsten der Küste. Freier Zutritt zur Terrasse.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Strand Gavitella</h3>
                <p class="text-slate-600 leading-relaxed">Über eine Treppe von der Hauptstraße erreichbar, dieser Kieselstrand ist deutlich ruhiger als die berühmten Strände von Positano. Ein Strandclub bietet Liegen und Getränke an, es gibt auch einen freien Bereich.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Marina di Praia</h3>
                <p class="text-slate-600 leading-relaxed">Eine enge Felsenbucht mit einem kleinen Kieselstrand, einem echten Fischereihafen und einem ausgezeichneten Restaurant direkt am Wasser. Der Tunnel durch den Fels, der zur Bucht führt, ist ein einzigartiges Erlebnis.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Tauchen und Schnorcheln</h3>
                <p class="text-slate-600 leading-relaxed">Die Gewässer vor Praiano gehören zu den klarsten der Küste. Lokale Tauchschulen organisieren Ausflüge zu Unterwasserhöhlen und dem versunkenen Dorf Conca dei Marini. Auch für Anfänger geeignet.</p>
              </div>
            </div>
          </div>
        </div>

        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Anreise nach Praiano</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Praiano liegt direkt an der SS163, der Panoramastraße der Amalfiküste. Der SITA-Bus ist die bequemste Option. Im Sommer gibt es auch Fähranschlüsse.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">SITA-Bus</h3><p class="text-white/50 text-sm leading-relaxed">Von Positano (~15 Min.) oder von Amalfi (~30 Min.). Ganzjährig, häufige Verbindungen im Sommer.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Per Fähre</h3><p class="text-white/50 text-sm leading-relaxed">Saisonal von Positano und Amalfi. Die Marina di Praia hat einen kleinen Steg für Boote.</p></div>
              </div>
            </div>
            <a href="/de-de/ratgeber/faehren/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Vollständiger Transportführer
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Busfahrplan -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
            SITA-Bus — Positano ↔ Praiano ↔ Amalfi
          </h3>
          <p class="text-sm text-slate-500 mb-4">Praiano liegt auf der SITA-Hauptlinie SS163. Häufige Verbindungen in beide Richtungen ganzjährig.</p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Von</th>
                  <th class="text-left px-4 py-3 font-semibold">Nach Praiano</th>
                  <th class="text-left px-4 py-3 font-semibold">Fahrtdauer</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-3 text-slate-600">Positano</td>
                  <td class="px-4 py-3 font-mono">ca. 15 Min.</td>
                  <td class="px-4 py-3 text-slate-500">~2,50 €</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-3 text-slate-600">Amalfi</td>
                  <td class="px-4 py-3 font-mono">ca. 30 Min.</td>
                  <td class="px-4 py-3 text-slate-500">~2,50 €</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-3 text-slate-600">Sorrent</td>
                  <td class="px-4 py-3 font-mono">ca. 60 Min.</td>
                  <td class="px-4 py-3 text-slate-500">~3,50 €</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Fahrpläne und Preise sind indikativ für 2026. Auf sitasudtrasporti.it prüfen.</p>
        </div>

        <!-- Verborgene Ecken -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Verborgene Ecken in Praiano</h2>
          <p class="text-slate-500 mb-8">Jenseits der Postkarten: vier Winkel, die Durchgangstouristen nie finden.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Grotte dello Smeraldo</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Die Smaragdgrotte, nur wenige Kilometer östlich von Praiano, ist mit dem Boot von der Marina di Praia erreichbar. Ein natürliches Meereshöhlenwunder mit smaragdgrünem Wasser — weniger bekannt als die Blaue Grotte von Capri.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Sentiero delle Sirene</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Der Sirenenweg verbindet Praiano mit Positano entlang der Klippen. Ein Wanderweg mit atemberaubenden Meerblicken, kaum besucht und mit keiner App markiert — perfekt für alle, die die echte Wildnis der Küste suchen.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Kirche San Luca</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Im oberen Teil des Dorfes gelegen, weit abseits der touristischen Routen. Die Kirche aus dem 16. Jahrhundert hat ein beeindruckendes Majolika-Portal und ist umgeben von Zitronen- und Olivenbäumen.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Nachtleben an der Marina di Praia</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Im Sommer verwandelt sich die kleine Bucht der Marina di Praia am Abend in einen der romantischsten Orte der Küste. Eine Bar in einem Felsentunnel und Konzerte unter den Sternen machen Praiano zur Geheimadresse der Nachtschwärmer.</p>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Insider-Tipp</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Übernachten in Praiano statt in Positano</h3>
              <p class="text-white/70 leading-relaxed">Wer eine Unterkunft in Praiano statt in Positano bucht, spart 30–50 % bei den Hotelpreisen und hat Positano morgens zu Fuß in 20 Minuten mit dem Minibus erreichbar — aber kehrt jeden Abend in ein ruhigeres, authentischeres Dorf zurück, in dem die Einheimischen noch tatsächlich wohnen.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Häufig gestellte Fragen zu Praiano</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Kurzinfos — Praiano</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Insider-Tipps -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Insider-Tipps</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>In Praiano statt Positano übernachten: deutlich niedrigere Preise, gleiche Küstenmagie.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Sonnenuntergang von San Gennaro aus beobachten: 30 Minuten vor Sonnenuntergang dort sein.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Die Marina di Praia abends besuchen: Konzerte, Fischrestaurant und romantische Stimmung.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
