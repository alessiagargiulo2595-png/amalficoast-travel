---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Amalfiküste', url: '/de-de/amalfikueste/' },
  { name: 'Positano', url: '/de-de/amalfikueste/positano/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Positano",
  "description": "Positano ist das ikonischste Dorf der Amalfiküste, bekannt für seine bunten Häuser über dem Meer, Kieselstrände und das Dolce-Vita-Flair.",
  "url": "https://amalficoast-travel.com/de-de/amalfikueste/positano/",
  "image": "https://amalficoast-travel.com/images/positano-hero.jpg",
  "touristType": ["Kultur", "Natur", "Meer", "Gastronomie"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Positano",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84017"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6281,
    "longitude": 14.4849
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Positano, Amalfiküste",
  "description": "Küstendorf der Amalfiküste in der Provinz Salerno, Kampanien.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6281,
    "longitude": 14.4849
  },
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Amalfiküste"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie kommt man von Neapel nach Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Von Neapel Centrale nimmt man die Circumvesuviana bis Sorrent (ca. 65 Min.), dann den SITA-Bus entlang der SS163 nach Positano (ca. 50 Min.). Alternativ gibt es eine Fähre vom Neapler Molo Beverello (ca. 90 Min. im Sommer, saisonal)."
      }
    },
    {
      "@type": "Question",
      "name": "Wann ist die beste Reisezeit für Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mai–Juni und September–Oktober bieten das beste Gleichgewicht aus mildem Wetter, vertretbaren Menschenmassen und angemessenen Preisen. Juli und August sind sehr heiß und überfüllt. Im Winter ist es ruhig, aber viele Betriebe schließen."
      }
    },
    {
      "@type": "Question",
      "name": "Gibt es Parkplätze in Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Bezahlte Parkplätze sind begrenzt und teuer (bis zu 5 €/Stunde). Im Sommer gilt eine ZTL (Verkehrsbeschränkungszone): nur Anwohner und Hotelgäste mit Genehmigung dürfen zu Stoßzeiten mit dem Auto einfahren. Öffentliche Verkehrsmittel werden dringend empfohlen."
      }
    },
    {
      "@type": "Question",
      "name": "Welche Strände gibt es in Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Der Hauptstrand ist die Spiaggia Grande (Kiesel, mit Strandclubs und einem kostenfreien öffentlichen Abschnitt). Der Fornillo-Strand ist ruhiger und zu Fuß in 10 Minuten erreichbar. Der Arienzo-Strand ist nur per Boot zugänglich."
      }
    },
    {
      "@type": "Question",
      "name": "Was kostet ein Aufenthalt in Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Positano gehört zu Italiens exklusivsten Reisezielen. In der Hochsaison starten B&Bs bei 120–150 €/Nacht, 4-Sterne-Boutique-Hotels ab 250 € und 5-Sterne-Häuser ab 400 €+. Eine Buchung 3–6 Monate im Voraus ist unbedingt erforderlich."
      }
    }
  ]
};
---

<BaseLayout
  title="Positano 2026: Vollständiger Reiseführer | Amalfiküste"
  description="Alles über Positano: Anreise, Strände, Fähr- und Busfahrpläne, Sehenswürdigkeiten, Reisezeit. Der vollständige Reiseführer zum schönsten Dorf der Amalfiküste."
  lang={lang}
  pageKey="positano"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, placeSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/positano-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfiküste</p>
        <h1 class="font-serif text-display text-white mb-4">Positano</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Pastellfarbene Häuser, die zum Tyrrhenischen Meer hinabkaskadieren, Majolikagassen, der Duft von Zitronen und der berühmteste Strand der Küste. Willkommen im Dorf, das Künstler und Reisende von Steinbeck bis Picasso inspirierte.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Kurzinfos
          </a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Anreise
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <!-- Main Content -->
      <div class="space-y-16">

        <!-- Intro -->
        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Positano ist das Symbol der Amalfiküste: ein Amphitheater aus bunten Häusern — weiß, ocker, rosa — die steil zum Meer hinabfallen. Mit weniger als 4.000 Einwohnern konzentriert das Dorf eine Dichte an Schönheit, die nur wenige Orte auf der Welt erreichen.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Der Schriftsteller John Steinbeck beschrieb es 1953 als „einen Ort, der schwer zu erreichen und unmöglich zu vergessen ist." Siebzig Jahre später ist diese Beschreibung noch immer perfekt. Positano ist kein Touristenziel — es ist ein sinnliches Erlebnis, bei dem jede Kurve eine neue Aussicht und jede Trattoria einen echten Geschmack enthüllt.
          </p>
        </div>

        <!-- Wusstest du? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wusstest du?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1.000+</p>
              <p class="text-white/60 text-xs italic mt-1">Treppenstufen im historischen Zentrum</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">14°C</p>
              <p class="text-white/60 text-xs italic mt-1">Durchschnittstemperatur im Januar</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">4 Mio.</p>
              <p class="text-white/60 text-xs italic mt-1">geschätzte Besucher pro Jahr</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Der Name „Positano" leitet sich höchstwahrscheinlich vom lateinischen <em>Positanum</em> ab, nach einer römischen Familie namens Posidio, die hier im 1. Jh. n. Chr. eine Villa besaß.
          </p>
        </div>

        <!-- Sehenswürdigkeiten -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Sehenswürdigkeiten in Positano</h2>
          <div class="space-y-8">

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Kirche Santa Maria Assunta</h3>
                <p class="text-slate-600 leading-relaxed">Die grün-gelbe Majolikakuppel ist das Wahrzeichen des Dorfes. Im Inneren befindet sich die <em>Schwarze Madonna von Positano</em>, eine byzantinische Ikone aus dem 12. Jahrhundert. Freier Eintritt, täglich geöffnet.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Spiaggia Grande</h3>
                <p class="text-slate-600 leading-relaxed">Der Hauptstrand — ein Bogen aus dunklen Kieseln mit Blick auf bunte Boote. Der kostenfreie Abschnitt ist unentgeltlich; Strandclubs bieten Liegen und Sonnenschirme an. Im Sommer füllt er sich früh: vor 9:00 Uhr ankommen.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Fornillo-Strand</h3>
                <p class="text-slate-600 leading-relaxed">Von der Spiaggia Grande über einen malerischen 10-minütigen Pfad zu Fuß erreichbar. Weniger belebt, mit zwei spektakulären Felsnadeln (I Galli) am Horizont.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Via dei Mulini und das Zentrum</h3>
                <p class="text-slate-600 leading-relaxed">Die Hauptstraße des Dorfes, gesäumt von Modeboutiquen (Positano ist Italiens Strand-Modemetropole), Keramikläden und Restaurants. Am besten am Abend erkunden, um den Touristenmassen auszuweichen.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">5</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Götterweg (Sentiero degli Dei)</h3>
                <p class="text-slate-600 leading-relaxed">Die spektakulärste Wanderung der Küste beginnt in Nocelle, oberhalb von Positano, und endet in Agerola. Etwa 7,5 km mit atemberaubenden Aussichten auf den Golf von Salerno. Schwierigkeitsgrad: mittel.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Anreise — Dark Box -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Anreise nach Positano</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Es gibt keinen Bahnhof in Positano. Die wichtigsten Optionen sind die Fähre (saisonal) und der Bus. Im Sommer wird dringend empfohlen, auf das Auto zu verzichten.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Per Schiff</h3><p class="text-white/50 text-sm leading-relaxed">April bis Oktober: von Salerno, Amalfi, Sorrent und Neapel. Die Ankunft vom Meer bietet die ikonischste Aussicht auf das Dorf.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">SITA-Bus</h3><p class="text-white/50 text-sm leading-relaxed">Verbindet Positano mit Sorrent und Amalfi entlang der SS163. Günstig (~2,50 €), ganzjährig verfügbar.</p></div>
              </div>
            </div>
            <a href="/de-de/ratgeber/faehren/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Vollständiger Transportführer
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Fähr- und Busfahrpläne -->
        <div>
          <div class="mb-10">
            <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
              Fährfahrpläne — Sommer 2026
            </h3>
            <p class="text-sm text-slate-500 mb-4">Dienste laufen ungefähr von April bis Oktober. Aktuelle Fahrpläne stets auf den offiziellen Websites der Reedereien prüfen.</p>

            <div class="overflow-x-auto rounded-2xl border border-slate-200">
              <table class="w-full text-sm">
                <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                  Travelmar — Salerno ↔ Positano (über Amalfi)
                </caption>
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Abfahrt Salerno</th>
                    <th class="text-left px-4 py-3 font-semibold">Ankunft Positano</th>
                    <th class="text-left px-4 py-3 font-semibold">Hinweise</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">07:15</td>
                    <td class="px-4 py-3 font-mono">08:55</td>
                    <td class="px-4 py-3 text-slate-500">Über Cetara, Maiori, Amalfi</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">09:00</td>
                    <td class="px-4 py-3 font-mono">10:40</td>
                    <td class="px-4 py-3 text-slate-500">—</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">11:00</td>
                    <td class="px-4 py-3 font-mono">12:40</td>
                    <td class="px-4 py-3 text-slate-500">—</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">14:15</td>
                    <td class="px-4 py-3 font-mono">15:55</td>
                    <td class="px-4 py-3 text-slate-500">—</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">16:30</td>
                    <td class="px-4 py-3 font-mono">18:10</td>
                    <td class="px-4 py-3 text-slate-500">—</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="overflow-x-auto rounded-2xl border border-slate-200 mt-6">
              <table class="w-full text-sm">
                <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                  Alilauro — Neapel (Beverello) ↔ Positano
                </caption>
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Abfahrt Neapel</th>
                    <th class="text-left px-4 py-3 font-semibold">Ankunft Positano</th>
                    <th class="text-left px-4 py-3 font-semibold">Dauer</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">09:00</td>
                    <td class="px-4 py-3 font-mono">10:30</td>
                    <td class="px-4 py-3 text-slate-500">~90 Min.</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">11:00</td>
                    <td class="px-4 py-3 font-mono">12:30</td>
                    <td class="px-4 py-3 text-slate-500">~90 Min.</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">14:00</td>
                    <td class="px-4 py-3 font-mono">15:30</td>
                    <td class="px-4 py-3 text-slate-500">~90 Min.</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-400 mt-2">* Fahrpläne sind indikativ für die Saison 2026. Auf travelmar.it und alilauro.it bestätigen.</p>
          </div>

          <div>
            <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
              SITA-Bus — Sorrent ↔ Positano (SS163)
            </h3>
            <p class="text-sm text-slate-500 mb-4">Der SITA-Bus ist die günstigste Option (~2,50 €). Abfahrt von Sorrent Piazza Tasso. Häufige Verbindungen ganzjährig.</p>

            <div class="overflow-x-auto rounded-2xl border border-slate-200">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Abfahrt Sorrent</th>
                    <th class="text-left px-4 py-3 font-semibold">Ankunft Positano</th>
                    <th class="text-left px-4 py-3 font-semibold">Häufigkeit</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">06:30</td>
                    <td class="px-4 py-3 font-mono">07:20</td>
                    <td class="px-4 py-3 text-slate-500">Nur werktags</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">08:00</td>
                    <td class="px-4 py-3 font-mono">08:50</td>
                    <td class="px-4 py-3 text-slate-500">Täglich</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">09:30</td>
                    <td class="px-4 py-3 font-mono">10:20</td>
                    <td class="px-4 py-3 text-slate-500">Täglich</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">11:00</td>
                    <td class="px-4 py-3 font-mono">11:50</td>
                    <td class="px-4 py-3 text-slate-500">Täglich</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">13:00</td>
                    <td class="px-4 py-3 font-mono">13:50</td>
                    <td class="px-4 py-3 text-slate-500">Täglich</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">15:30</td>
                    <td class="px-4 py-3 font-mono">16:20</td>
                    <td class="px-4 py-3 text-slate-500">Täglich</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">17:30</td>
                    <td class="px-4 py-3 font-mono">18:20</td>
                    <td class="px-4 py-3 text-slate-500">Täglich</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-400 mt-2">* Indikative Fahrpläne. Im Sommer werden Extraverbindungen hinzugefügt. Auf sitasudtrasporti.it prüfen.</p>
          </div>
        </div>

        <!-- Verborgene Ecken -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Verborgene Ecken in Positano</h2>
          <p class="text-slate-500 mb-8">Jenseits der Postkarten: vier Winkel, die Durchgangstouristen nie finden.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Arienzo-Strand</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Ein Strand, der nur per Schiff oder über 300 Stufen erreichbar ist. In der Hochsaison ist er deutlich weniger belebt als die Spiaggia Grande. Bootsvermietung im Hafen verfügbar.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Nocelle und der Götterweg</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Das Weiler Nocelle (418 m ü. M.) oberhalb von Positano ist mit einem Shuttlebus erreichbar. Panoramablick auf das Dorf und das Meer — ganz ohne Menschenmassen.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Torre Trasita</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Einer der mittelalterlichen Sarazenentürme des Dorfes, heute als privates Ferienhaus vermietet. Von außen entlang der Hauptstraße sicht- und fotografierbar.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Authentisches Frühstück auf lokale Art</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Die Bars an der Uferpromenade meiden (Touristenpreise) und die Bars in den oberen Straßen des Dorfes aufsuchen, die von Einheimischen besucht werden — für ein echtes Frühstück zu normalen Preisen.</p>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Insider-Tipp</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Authentisches Frühstück in Positano</h3>
              <p class="text-white/70 leading-relaxed">Die Bars an der Uferpromenade meiden (Touristenpreise). In die oberen Straßen gehen und die Bars suchen, die die Einheimischen nutzen. Ein Zitronencreme-Hörnchen mit einem Shakerato-Espresso probieren und dabei zusehen, wie das Dorf aufwacht — dasselbe Erlebnis zum halben Preis.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
