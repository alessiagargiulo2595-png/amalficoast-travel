---
import BlogPostLayout from '../../../../layouts/BlogPostLayout.astro';

const lang = 'de-de';
const post = {
  title: 'Zitronen-Köstlichkeit',
  subtitle: 'Geschichte und Geheimnisse der beliebtesten Kuppel der Küste',
  category: 'KULINARIK',
  date: '22. April 2026',
  readTime: '7 min',
  image: '/images/delizia-limone-hero.jpg',
  imageAlt: 'Delizia al Limone - das Wahrzeichen-Dessert der Amalfiküste',
  path: '/de-de/blog/zitronen-koestlichkeit/',
};

const metaTitle = 'Zitronen-Köstlichkeit: Geschichte, Rezept und wo man sie isst | Amalfiküste 2026';
const metaDescription = "Die Geschichte der Delizia al Limone, erfunden von Carmine Marzuillo im Jahr 1978, die Geheimnisse des Originalrezepts mit g.g.A.-Zitronen und die besten Adressen an der Amalfiküste.";

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Blog', url: '/de-de/blog/' },
  { name: 'Zitronen-Köstlichkeit', url: '/de-de/blog/zitronen-koestlichkeit/' },
];

const quickInfo = [
  { label: 'Erfinder', value: 'Carmine Marzuillo (1978)' },
  { label: 'Hauptzutat', value: 'g.g.A.-Zitrone (Sfusato oder Femminiello)' },
  { label: 'Zubereitung', value: '45 Min. + 2 Stunden Ruhe' },
  { label: 'Backzeit', value: '20 Minuten' },
  { label: 'Portionen', value: '8 Kuppeln' },
  { label: 'Schwierigkeit', value: 'Mittel (Präzision bei der Creme)' },
  { label: 'Getränkebegleitung', value: 'Eiskalter Limoncello oder Tramonti-Passito' },
  { label: 'Beste Adressen', value: 'Sal De Riso (Minori) · Pansa (Amalfi)' },
];

const faq = [
  {
    q: 'Was ist der Unterschied zwischen einer Delizia al Limone und einem normalen Zitronen-Biskuit?',
    a: 'Die Struktur der Delizia ist viel komplexer: Sie erfordert eine doppelte Creme (Konditorcreme und Zitronen-Chantilly) sowie eine äußere Glasur, die sie feucht und weich hält, anders als ein klassischer Kuchen.',
  },
  {
    q: 'Kann ich normale Supermarkt-Zitronen verwenden?',
    a: "Das ist möglich, aber das Ergebnis wird nicht dasselbe sein. Das Geheimnis der Delizia liegt in den ätherischen Ölen der Schale der g.g.A.-Zitronen aus Sorrent oder Amalfi, die unbehandelt sind und ein unendlich beständigeres Aroma haben.",
  },
  {
    q: 'Gibt es eine glutenfreie Version der Delizia?',
    a: 'Viele handwerkliche Konditoreien an der Küste bieten jetzt glutenfreie Versionen mit Reismehl oder Stärke an, wobei die Magie der Zitronencreme erhalten bleibt.',
  },
  {
    q: 'Wer hat die Delizia al Limone erfunden?',
    a: "Der Sorrentiner Konditormeister Carmine Marzuillo, der sie 1978 erstmals bei einem Gastronomiewettbewerb in Formia vorstellte. Binnen weniger Jahre wurde sie zum Wahrzeichen-Dessert der gesamten Amalfiküste.",
  },
  {
    q: 'Wo isst man die beste Delizia al Limone an der Küste?',
    a: "Die bekanntesten Orte sind: Pasticceria Sal De Riso in Minori (wahrscheinlich die berühmteste der Welt), Pasticceria Pansa neben dem Amalfi-Dom und Antico Francischiello in Massa Lubrense, dem Geburtsort des Originalrezepts.",
  },
];

const sidebarLinks = [
  { label: 'Cetara-Sardellen', href: '/de-de/blog/cetara-sardellen/' },
  { label: 'Amalfi-Weine', href: '/de-de/blog/amalfi-weine/' },
  { label: 'Bootstouren', href: '/de-de/erlebnisse/bootstouren/' },,
  { label: 'Die Strände', href: '/de-de/strande/' },
  { label: 'Reisezeit', href: '/de-de/reisezeit/' },
  { label: 'Anreise', href: '/de-de/anreise/' },
];

const authorRole = 'Gastronomie-Kritikerin & Lokale Expertin · Amalfiküste';
---

<BlogPostLayout
  lang={lang}
  post={post}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  breadcrumbs={breadcrumbs}
  quickInfo={quickInfo}
  faq={faq}
  sidebarLinks={sidebarLinks}
  authorRole={authorRole}
>

  <!-- Einleitung -->
  <div>
    <p class="text-slate-600 text-xl leading-relaxed mb-6 font-light">
      Wenn die Amalfiküste einen Geschmack hätte, wäre es zweifellos der der Delizia al Limone. Diese weiche Biskuitkuppel, getränkt in duftendem Sirup und bedeckt mit einer Wolke aus Zitronencreme, ist weit mehr als ein Dessert: Sie ist die Essenz der Sonne von Sorrent und Amalfi, eingefangen in einem einzigen Bissen.
    </p>
  </div>

  <!-- Geschichte -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Die Geschichte: Die Erfindung eines Meisters</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Im Gegensatz zu vielen traditionellen kampanischen Desserts, deren Wurzeln Jahrhunderte zurückreichen, hat die Delizia al Limone ein genaues Geburtsdatum: <strong>1978</strong>.
    </p>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Ihr Schöpfer ist der Sorrentiner Konditormeister <strong>Carmine Marzuillo</strong>, der sie 1978 erstmals bei einem Gastronomiewettbewerb in Formia vorstellte. Die Idee war einfach, aber revolutionär: den Sfusato Amalfitano und den Femminiello Sorrentino zu verwenden, um ein Dessert zu kreieren, das leicht, frisch und intensiv aromatisch ist. Der Erfolg war sofort, und innerhalb weniger Jahre verbreitete sich die Delizia von den Werkstätten Sorrents auf Tische in aller Welt.
    </p>

    <blockquote class="border-l-4 border-med-gold pl-6 my-8">
      <p class="text-slate-700 text-xl font-serif italic leading-relaxed">
        "Eine perfekte Balance zwischen der Säure der Zitrusfrucht und der Süße der Creme: Die Delizia ist der Kuss der Sonne auf dem Tisch."
      </p>
    </blockquote>
  </div>

  <!-- Wo essen -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Wo man die beste Delizia al Limone isst</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Obwohl sie heute in jeder Konditorei der Region zu finden ist, gibt es "heilige" Orte, an denen die Verkostung zu einem mystischen Erlebnis wird.
    </p>

    <div class="space-y-4">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Pasticceria Sal De Riso — Minori</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Wahrscheinlich die berühmteste der Welt. Salvatore De Risos Version wird für die Balance der Tränkung und die Qualität der Zutaten gefeiert. Unverzichtbar.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Pasticceria Pansa — Amalfi</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Direkt neben dem Dom gelegen. Hier wird die Delizia von Geschichte umgeben gegessen, mit einem Rezept, das die klassischen Grundsätze streng befolgt.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Antico Francischiello — Massa Lubrense</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Der Ort, an dem die Familie Marzuillo dieses Dessert zur Legende gemacht hat. Hier wurde das Originalrezept geboren.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Das Rezept -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Das Rezept: Wie man es zu Hause zubereitet</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Eine echte Delizia erfordert Geduld und vor allem g.g.A.-Zitronen hoher Qualität.
    </p>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm mb-6">
      <h3 class="font-serif text-xl font-bold text-slate-900 mb-6">Zutaten (für 8 Kuppeln)</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div>
          <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.2em] mb-3">Biskuit</p>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>4 frische Eier</li>
            <li>120 g Zucker</li>
            <li>120 g Mehl Typ 405</li>
          </ul>
        </div>
        <div>
          <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.2em] mb-3">Zitronencreme</p>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>500 ml Vollmilch</li>
            <li>4 Eigelb</li>
            <li>150 g Zucker</li>
            <li>50 g Maisstärke</li>
            <li>Schale von 2 g.g.A.-Zitronen</li>
            <li>300 ml Sahne</li>
          </ul>
        </div>
        <div>
          <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.2em] mb-3">Tränksirup</p>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>100 ml Limoncello</li>
            <li>50 ml Wasser</li>
            <li>30 g Zucker</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-8 h-8 rounded-full bg-slate-900 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">1</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Der Biskuit</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Eier mit Zucker lange aufschlagen bis die Masse locker und schaumig ist. Das gesiebte Mehl vorsichtig mit Hebegriffen unterheben. In halbkugelförmigen Formen bei 180°C 18-20 Minuten backen.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-8 h-8 rounded-full bg-slate-900 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">2</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Die Zitronencreme</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Milch mit Zitronenschale erhitzen. Eigelb mit Zucker und Stärke verquirlen, heiße Milch einrühren und kochen bis die Masse eindickt. Vollständig abkühlen lassen, dann mit Schlagsahne unterheben.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-8 h-8 rounded-full bg-slate-900 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">3</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Das Geheimnis des Meisters: Die Montage</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Die Delizia wird "verkehrt herum" zusammengesetzt: Kuppel füllen, mit Limoncello-Sirup tränken, vollständig mit verdünnter Creme bedecken und mindestens 2 Stunden kühlen. Die Ruhezeit ist wesentlich.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Tipps -->
  <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
    <div class="flex items-center gap-4 mb-6">
      <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      <h3 class="text-xl font-bold text-slate-900">Expertentipps</h3>
    </div>
    <div class="space-y-6">
      <div>
        <p class="font-bold text-slate-900 mb-1">Die Temperatur</p>
        <p class="text-slate-600 text-sm leading-relaxed">Niemals direkt aus dem Kühlschrank essen. 10-15 Minuten vor dem Servieren herausnehmen: Die Creme soll seidig sein und der Biskuit im Mund zergehen.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Die Farbe</p>
        <p class="text-slate-600 text-sm leading-relaxed">Vorsicht bei Delizie mit zu kräftigem Gelb. Eine echte handwerkliche Zitronencreme hat ein zartes Strohgelb. Leuchtendes Gelb ist oft ein Zeichen für künstliche Farbstoffe.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Begleitung</p>
        <p class="text-slate-600 text-sm leading-relaxed">Mit einem Glas eiskaltem Limoncello servieren oder, für Abenteuerlustige, mit einem Glas süßem Passito-Weißwein aus dem Tramonti-Gebiet.</p>
      </div>
    </div>
  </div>

</BlogPostLayout>
