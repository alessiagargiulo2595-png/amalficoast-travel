---
import BlogPostLayout from '../../../../layouts/BlogPostLayout.astro';

const lang = 'de-de';
const post = {
  title: 'Cetara-Sardellen',
  subtitle: 'Das Silbergold der Amalfiküste',
  category: 'KULINARIK',
  date: '22. April 2026',
  readTime: '7 min',
  image: '/images/alici-cetara-hero.jpg',
  imageAlt: 'Cetara-Sardellen und Colatura g.U. - Amalfiküste',
  path: '/de-de/blog/cetara-sardellen/',
};

const metaTitle = 'Cetara-Sardellen: Colatura g.U. und Spaghetti alla Colatura | Reiseführer 2026';
const metaDescription = 'Die Geschichte der g.U.-Colatura di Alici von Cetara, Erbin des römischen Garum: Nachtfischerei mit Lampare, Reifung in Eichenfässern, Originalrezept der Spaghetti alla Colatura.';

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Blog', url: '/de-de/blog/' },
  { name: 'Cetara-Sardellen', url: '/de-de/blog/cetara-sardellen/' },
];

const quickInfo = [
  { label: 'Produkt', value: 'Gesalzene Sardellen · Colatura g.U.' },
  { label: 'Ort', value: 'Cetara (SA)' },
  { label: 'Fangsaison', value: 'März – August' },
  { label: 'g.U.-Reifung', value: 'Mind. 9 Monate im Eichenfass' },
  { label: 'Kultgericht', value: 'Spaghetti alla Colatura' },
  { label: 'Wichtiger Tipp', value: 'Niemals das Nudelwasser salzen' },
  { label: 'Kauftipp', value: 'Handwerkliche Läden in der Hauptstraße' },
  { label: 'Zertifizierung', value: 'g.U. – Geschützte Ursprungsbezeichnung' },
];

const faq = [
  {
    q: 'Wie lange müssen die Sardellen reifen, um Colatura herzustellen?',
    a: 'Die g.U.-Spezifikation schreibt eine Mindestreifezeit von 9 Monaten vor, aber die besten Reserven können in Eichenfässern mehrere Jahre reifen und dabei komplexere und dunklere Noten entwickeln.',
  },
  {
    q: 'Ist Colatura sehr salzig?',
    a: 'Ja, sie ist extrem würzig. Aus diesem Grund sollte beim Kochen niemals Salz in das Nudelwasser oder andere Gerichte gegeben werden.',
  },
  {
    q: 'Sind Cetara-Sardellen gesund?',
    a: 'Absolut. Als Blaufisch sind sie reich an Omega-3, hochwertigen Proteinen und Mineralstoffen. Das Einsalzen bewahrt die Nährstoffe ohne chemische Konservierungsstoffe.',
  },
  {
    q: 'Wo kauft man die originale g.U.-Colatura?',
    a: "In der Hauptstraße von Cetara gibt es handwerkliche Werkstätten und historische Läden, wo man die Originalfässer kaufen kann. Achten Sie immer auf das g.U.-Zeichen: Viele Imitationen verwenden Fisch aus anderen Meeren.",
  },
  {
    q: 'Was bedeutet die „Kopf-an-Schwanz"-Technik?',
    a: 'Es ist die traditionelle Methode, Sardellen im Fass anzuordnen: Jede Schicht wird durch Umkehrung der Fischorientierung abgewechselt, um die Kompaktheit zu maximieren und eine gleichmäßige Salzung zu gewährleisten.',
  },
];

const sidebarLinks = [
  { label: 'Bootstouren', href: '/de-de/erlebnisse/bootstouren/' },
  { label: 'Amalfi entdecken', href: '/de-de/amalfikueste/amalfi/' },
  { label: 'SITA-Bus', href: '/de-de/ratgeber/sita-bus/' },
];

const authorRole = 'Kulinarik & Reise-Spezialist · Amalfiküste';

const keyTakeaways = [
  "Die g.U.-Colatura di Alici di Cetara ist die direkte Erbin des römischen Garum, von mittelalterlichen Mönchen wiederentdeckt und heute als Weltkulturgut anerkannt.",
  'Die Sardellen werden nachts mit Lampare zwischen März und August gefangen und noch am selben Tag per Hand verarbeitet.',
  'Die Reifung in Eichenfässern dauert laut g.U.-Spezifikation mindestens 9 Monate; die besten Reserven reifen mehrere Jahre.',
  'Spaghetti alla Colatura werden immer roh gewürzt und ohne Salz im Wasser: Die Colatura ist bereits von Natur aus sehr würzig.',
  'Ein einziger Tropfen Colatura reicht, um Pasta, gekochtes Gemüse und Hülsenfrüchtesuppen zu würzen — niemals erhitzen.',
];
---

<BlogPostLayout
  lang={lang}
  post={post}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  breadcrumbs={breadcrumbs}
  quickInfo={quickInfo}
  faq={faq}
  sidebarLinks={sidebarLinks}
  authorRole={authorRole}
>

  <!-- Key Takeaways -->
  <div class="bg-slate-900 text-white p-8 rounded-[2rem]">
    <div class="flex items-center gap-3 mb-6">
      <svg class="w-5 h-5 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <h2 class="font-serif text-lg font-bold text-med-gold uppercase tracking-[0.15em]">Key Takeaways</h2>
    </div>
    <ul class="space-y-4">
      {keyTakeaways.map((point) => (
        <li class="flex items-start gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-med-gold flex-shrink-0 mt-2"></span>
          <span class="text-white/80 text-sm leading-relaxed">{point}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Einleitung -->
  <div>
    <p class="text-slate-600 text-xl leading-relaxed mb-6 font-light">
      Wenn es ein Dorf gibt, dem es gelungen ist, den Geschmack des Meeres in ein Glas zu füllen, dann ist es Cetara. Hinter dem Felskap Capo d'Orso erscheint dieses kleine Fischerdorf wie eine Krippe aus weißen Häusern, die sich um einen sarazenischen Turm scharen. Aber Cetaras wahrer Schatz ist nicht von der Straße aus sichtbar: Er verbirgt sich in den Netzen seiner Fischerboote und in den alten Holzfässern, die das Geheimnis seiner berühmten Sardellen hüten.
    </p>
  </div>

  <!-- Alte Tradition -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Eine uralte Tradition: Von der Lampara zum Fass</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Die Sardellenfi scherei in Cetara hat jahrtausendealte Wurzeln. Noch heute fahren in mondlosen Nächten zwischen März und August die „Lampare" hinaus. Die Technik ist fast unverändert geblieben: Das Licht lockt den Blaufisch an die Oberfläche und die Netze umschließen ihn.
    </p>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Aber die wahre Magie geschieht an Land. Frisch gefangen, werden die Sardellen per Hand geköpft und ausgenommen, dann schichtweise — mit der klassischen „Kopf-an-Schwanz"-Technik — in kleinen Eichenfässern namens <strong>Terzigni</strong> angeordnet. Hier beginnt unter dem Gewicht einer Holzpresse und bedeckt mit Meersalz ihre Reifung.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
        <h4 class="font-bold text-slate-900 mb-2">Die „Kopf-an-Schwanz"-Technik</h4>
        <p class="text-slate-600 text-sm leading-relaxed">Jede Schicht wird durch Umkehrung der Fischorientierung abgewechselt, um die Kompaktheit zu maximieren und eine gleichmäßige Salzung während der Reifung zu gewährleisten.</p>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
        <h4 class="font-bold text-slate-900 mb-2">Das Eichenholz-Terzigno</h4>
        <p class="text-slate-600 text-sm leading-relaxed">Das kleine Eichenfass ist nicht nur ein Behälter: Das Holz atmet, reguliert die Feuchtigkeit und trägt zur aromatischen Entwicklung während der langen Salzreifung bei.</p>
      </div>
    </div>
  </div>

  <!-- Die Colatura -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Die Colatura: Das flüssige Wesen des Meeres</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Das edelste Produkt dieses Verfahrens ist die <strong>g.U.-Colatura di Alici di Cetara</strong>. Es ist eine bernsteinfarbene, klare Flüssigkeit, das Ergebnis der langsamen Fermentation gesalzener Sardellen.
    </p>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Der Legende nach ist die Colatura die Erbin des <strong>römischen Garum</strong>, der von Kaisern so geliebten Fischsauce. In Cetara wurde diese Tradition von mittelalterlichen Mönchen wiederbelebt und ist heute ein weltweites Gütezeichen geworden. Ein einziger Tropfen dieses Destillats kann ein einfaches Gericht in ein Gourmet-Erlebnis verwandeln.
    </p>

    <blockquote class="border-l-4 border-med-gold pl-6 my-8">
      <p class="text-slate-700 text-xl font-serif italic leading-relaxed">
        "Cetaras Colatura ist kein Gewürz — sie ist die Seele des Mittelmeers, Tropfen für Tropfen destilliert."
      </p>
    </blockquote>
  </div>

  <!-- Wie genießen -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Wie man sie genießt: Das Kultgericht</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Wenn Sie Cetara besuchen, gibt es ein Ritual, das Sie nicht verpassen dürfen: <strong>Spaghetti alla Colatura</strong>. Das Gericht der Schlichtheit, die zu Luxus wird.
    </p>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
      <h3 class="font-serif text-xl font-bold text-slate-900 mb-5">Das Originalrezept</h3>
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <div class="w-6 h-6 rounded-full bg-med-gold/15 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">1</div>
          <p class="text-slate-600 text-sm leading-relaxed"><strong>Kein Salz ins Wasser</strong> — die Colatura ist bereits von Natur aus sehr würzig.</p>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-6 h-6 rounded-full bg-med-gold/15 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">2</div>
          <p class="text-slate-600 text-sm leading-relaxed"><strong>Rohes Anrichten</strong> — natives Olivenöl extra, gehackter Knoblauch, Chili, Petersilie und ein großzügiger Esslöffel Colatura.</p>
        </div>
        <div class="flex items-start gap-3">
          <div class="w-6 h-6 rounded-full bg-med-gold/15 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">3</div>
          <p class="text-slate-600 text-sm leading-relaxed"><strong>Colatura niemals erhitzen</strong> — Hitze verändert das aromatische Bouquet, das sich über Monate der Reifung entwickelt hat.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Tipps -->
  <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
    <div class="flex items-center gap-4 mb-6">
      <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      <h3 class="text-xl font-bold text-slate-900">Expertentipps</h3>
    </div>
    <div class="space-y-6">
      <div>
        <p class="font-bold text-slate-900 mb-1">Auf das g.U.-Zeichen achten</p>
        <p class="text-slate-600 text-sm leading-relaxed">Achten Sie darauf, dass das g.U.-Zeichen auf der Verpackung ist. Viele Imitationen verwenden Fisch aus anderen Meeren, aber nur Sardellen aus dem Golf von Salerno haben jene perfekte Balance aus Fett und Geschmack.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Das Küchengeheimnis</p>
        <p class="text-slate-600 text-sm leading-relaxed">Colatura eignet sich auch hervorragend zum Würzen von gekochtem Gemüse oder zum Verleihen eines „Umami"-Geschmacks bei Hülsenfrüchtesuppen. Aber immer roh verwenden, um das Aromabouquet zu erhalten.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Aufbewahrung</p>
        <p class="text-slate-600 text-sm leading-relaxed">Gesalzene Sardellen in Gläsern immer mit ihrer Flüssigkeit oder etwas Öl bedeckt halten. Nach dem Öffnen im Kühlschrank aufbewahren und innerhalb weniger Wochen verbrauchen.</p>
      </div>
    </div>
  </div>

</BlogPostLayout>
