---
import BlogPostLayout from '../../../../layouts/BlogPostLayout.astro';

const lang = 'de-de';
const post = {
  title: 'Amalfi-Weine',
  subtitle: 'Eine Reise durch die heroischen Weinberge von Tramonti und Scala',
  category: 'KULINARIK',
  date: '22. April 2026',
  readTime: '8 min',
  image: '/images/vini-costa-amalfi-hero.jpg',
  imageAlt: 'Heroische Weinberge der Amalfiküste - Tramonti und Scala',
  path: '/de-de/blog/amalfi-weine/',
};

const metaTitle = "Amalfiküste DOC-Weine: Tintore, Tramonti und heroischer Weinbau | Ratgeber 2026";
const metaDescription = "Die DOC Costa d'Amalfi zwischen Tramonti und Scala: 200 Jahre alte Reben vor der Reblauskatastrophe, autochthone Rebsorten (Tintore, Fenile, Ripoli), heroischer Weinbau und Degustationsführer.";

const breadcrumbs = [
  { name: 'Startseite', url: '/de-de/' },
  { name: 'Blog', url: '/de-de/blog/' },
  { name: 'Amalfi-Weine', url: '/de-de/blog/amalfi-weine/' },
];

const quickInfo = [
  { label: 'DOC', value: "Costa d'Amalfi (Tramonti, Ravello, Furore)" },
  { label: 'Star-Rebsorte', value: 'Tintore di Tramonti' },
  { label: 'Autochthone Weißweine', value: 'Fenile · Ripoli · Ginestra' },
  { label: 'Rotweine', value: 'Tintore · Piedirosso · Aglianico' },
  { label: 'Weinlese', value: 'Ende Oktober / Anfang November' },
  { label: 'Weinbegleitung', value: 'Provolone del Monaco g.U.' },
  { label: 'Älteste Reben', value: 'Über 200 Jahre (vor der Reblaus)' },
  { label: 'Methode', value: 'Ausschließlich Handlese' },
];

const faq = [
  {
    q: 'Was bedeutet "heroischer Weinbau"?',
    a: 'Darunter versteht man Weinbau, bei dem die Hangneigung über 30 % beträgt oder die Weinberge auf Terrassen oder in großer Höhe angelegt sind. An der Amalfiküste muss alle Arbeit — vom Schneiden bis zur Ernte — von Hand erledigt werden, da Maschinen die Terrassen nicht erreichen können.',
  },
  {
    q: 'Was ist der Unterschied zwischen Küsten- und Bergweinen an der Amalfiküste?',
    a: "Weine aus Küstenlagen (Furore, Positano) sind tendenziell salziger und sonnengeprägt. Jene aus Tramonti und Scala weisen eine ausgeprägtere Frische und Säure auf, mit tieferen Mineralnoten dank der Bergnähe und der starken Tag-Nacht-Temperaturschwankungen.",
  },
  {
    q: 'Kann man Weine direkt beim Weingut kaufen?',
    a: "Absolut. Es ist sogar der beste Weg, kleine Kleinstmengenproduktionen (oft nur wenige Tausend Flaschen) zu entdecken, die nie in den Handel kommen. Viele Weingüter in Tramonti nehmen Besuche nach Voranmeldung an.",
  },
  {
    q: 'Was ist der Tintore di Tramonti?',
    a: 'Es ist eine einzigartige autochthone Rebsorte, die auf der ganzen Welt nur hier vorkommt. Die Reben können 150–200 Jahre alt sein. Dank des vulkanischen und sandigen Bodens hat sie die Reblaus überlebt und produziert einen Wein von undurchdringlichem, fast violettem Rot mit Beerenaromen und mächtigem Tannin.',
  },
  {
    q: "Wann findet die Weinlese in der DOC Costa d'Amalfi statt?",
    a: "Die Weinlese findet zwischen Ende Oktober und Anfang November statt — eine der spätesten in ganz Italien. Die kühleren Temperaturen in der Höhe und die lang anhaltenden Temperaturschwankungen lassen die Trauben langsam reifen und entwickeln aromatische Komplexität.",
  },
  {
    q: 'Welches sind die autochthonen Weißweinsorten der DOC?',
    a: 'Die wichtigsten autochthonen Weißweinsorten sind Fenile, Ripoli und Ginestra — Namen, die selbst in der kampanischen Weinszene äußerst selten sind. Sie ergeben Weine mit Aromen von Ginsterblüten, Kräutern und einer ausgeprägten Meersalzigkeit, sehr verschieden von den gängigeren süditalienischen Weißweinen.',
  },
];

const sidebarLinks = [
  { label: 'Die Strände', href: '/de-de/strande/' },
  { label: 'Reisezeit', href: '/de-de/reisezeit/' },
  { label: 'Anreise', href: '/de-de/anreise/' },
];

const authorRole = 'Wein- & Gebietsexpertin · Amalfiküste';

const relatedArticles = [
  {
    title: 'Cetara-Sardellen',
    category: 'KULINARIK',
    date: '22. April 2026',
    image: '/images/alici-cetara-hero.jpg',
    imageAlt: 'Cetara-Sardellen und Colatura g.U. - Amalfiküste',
    path: '/de-de/blog/cetara-sardellen/'
  },
  {
    title: 'Zitronen-Köstlichkeit',
    category: 'KULINARIK',
    date: '22. April 2026',
    image: '/images/delizia-limone-hero.jpg',
    imageAlt: 'Delizia al Limone: Sizilianisches Zitronendessert der Amalfiküste',
    path: '/de-de/blog/zitronen-koestlichkeit/'
  }
];
---

<BlogPostLayout
  lang={lang}
  post={post}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  breadcrumbs={breadcrumbs}
  quickInfo={quickInfo}
  faq={faq}
  sidebarLinks={sidebarLinks}
  authorRole={authorRole}
  relatedArticles={relatedArticles}
>

  <!-- Einleitung -->
  <div>
    <p class="text-slate-600 text-xl leading-relaxed mb-6 font-light">
      Wenn man an die Amalfiküste denkt, erscheint sofort das Blau des Meeres. Aber blickt man zu den Monti Lattari hinauf, entdeckt man eine andere Küste: grün, zerklüftet und geprägt von Weinreihen, die der Schwerkraft trotzen. Hier, zwischen Tramonti und Scala, entsteht der sogenannte <strong>heroische Weinbau</strong> — wo Wein nicht nur ein Getränk ist, sondern die Geschichte eines jahrtausendealten Kampfes zwischen Mensch und Fels.
    </p>
  </div>

  <!-- Tramonti -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Tramonti: Die Grüne Lunge und die Vor-Reblaus-Giganten</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Tramonti ist das Land der jahrhundertealten Weinberge. Hier verändert sich die Landschaft dramatisch: Die Luft wird frisch, und der Meereseinfluss trifft auf Bergwinde. Die wahre Besonderheit von Tramonti ist das Vorhandensein von <strong>Tintore</strong>-Reben, einer weltweit einzigartigen autochthonen Rebsorte, mit massiven Stöcken, die 150 oder 200 Jahre alt geworden sind.
    </p>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Diese Pflanzen haben die Reblaus dank des vulkanischen und sandigen Bodens überlebt. Diese knorrigen "Giganten" zu sehen, die mit dem traditionellen <strong>raggiera tramontina</strong>-System kultiviert werden — einer alten Erziehungsmethode, die ein Laubdach schafft — ist ein Erlebnis, das jeden Weinliebhaber bewegt.
    </p>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
      <div class="flex items-start gap-4">
        <span class="text-med-gold font-bold text-2xl leading-none mt-1">●</span>
        <div>
          <h3 class="font-serif text-xl font-bold text-slate-900 mb-3">Der Tintore</h3>
          <p class="text-slate-600 leading-relaxed">Ein Wein von undurchdringlichem, fast violettem Rot, mit Wildbeerennoten und einem mächtigen Tannin, das die Kraft der Vulkanerde evoziert. In nur wenigen Tausend Flaschen pro Jahr produziert, ist er einer der begehrtesten Rotweine Süditaliens.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Scala -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Scala: Eleganz unter den Wolken</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Scala ist das älteste Dorf der Küste, und seine Weinberge spiegeln diese Noblesse wider. Weniger ausgedehnt als die von Tramonti, sind die Reihen von Scala oft in kleinen Terrassen zwischen den Ruinen alter Kirchen und Adelspaläste eingebettet.
    </p>
    <p class="text-slate-600 text-lg leading-relaxed">
      Die Produktion konzentriert sich hier auf Weißweine von extremer Eleganz und Rotweine von großer Finesse, die von einem bemerkenswerten Temperaturunterschied zwischen der Tageswärme und den kühlen Nächten der Monti Lattari profitieren.
    </p>
  </div>

  <!-- Autochthone Rebsorten -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Die autochthonen Rebsorten der DOC Costa d'Amalfi</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Vergessen Sie die klassischen internationalen Sorten. Hier regieren Namen, die nach Geschichte duften.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
        <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.2em] mb-3">Weißwein-Rebsorten</p>
        <ul class="space-y-2 text-slate-600 text-sm">
          <li><strong>Fenile</strong> — weiße Blüten und Mandelaromen</li>
          <li><strong>Ripoli</strong> — Frische und Meersalzigkeit</li>
          <li><strong>Ginestra</strong> — Kräuter und gelbe Blüten</li>
        </ul>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
        <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.2em] mb-3">Rotwein-Rebsorten</p>
        <ul class="space-y-2 text-slate-600 text-sm">
          <li><strong>Tintore</strong> — Kraft und Langlebigkeit</li>
          <li><strong>Piedirosso</strong> (Per 'e Palummo) — vulkanische Eleganz</li>
          <li><strong>Aglianico</strong> — Struktur und Mineralität</li>
        </ul>
      </div>
    </div>

    <blockquote class="border-l-4 border-med-gold pl-6">
      <p class="text-slate-700 text-xl font-serif italic leading-relaxed">
        "Einen Wein aus Tramonti oder Scala zu trinken bedeutet, die Geschichte eines Territoriums zu schlürfen, das nie Kompromisse mit der Moderne eingegangen ist."
      </p>
    </blockquote>
  </div>

  <!-- Degustationsführer -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Degustationsführer: Wohin Gehen</h2>
    <div class="overflow-hidden rounded-[2rem] border border-slate-100 shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-slate-900 text-white">
          <tr>
            <th class="text-left p-5 font-serif font-bold text-med-gold">Gebiet</th>
            <th class="text-left p-5 font-serif font-bold text-med-gold">Empfohlenes Erlebnis</th>
          </tr>
        </thead>
        <tbody class="bg-white">
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Tramonti</td>
            <td class="p-5 text-slate-600">Besuch historischer Weingüter zum Bewundern der Vor-Reblaus-Reben. Viele bieten nach Voranmeldung Verkostungen mit lokalen Käse- und Wurstsorten an.</td>
          </tr>
          <tr>
            <td class="p-5 font-bold text-slate-900">Scala</td>
            <td class="p-5 text-slate-600">Wanderungen durch Weinberge mit Blick auf Ravello, mit Zwischenstopps bei kleinen Familienbetrieben. Ein einzigartiges Wein-und-Landschaft-Erlebnis in Italien.</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Expertentipps -->
  <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
    <div class="flex items-center gap-4 mb-6">
      <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      <h3 class="text-xl font-bold text-slate-900">Expertentipps</h3>
    </div>
    <div class="space-y-6">
      <div>
        <p class="font-bold text-slate-900 mb-1">Die perfekte Kombination</p>
        <p class="text-slate-600 text-sm leading-relaxed">Kombinieren Sie einen Tramonti-Rotwein (vielleicht eine Tintore-Riserva) mit Provolone del Monaco g.U. Die Schärfe des Käses und die Struktur des Weins schaffen ein legendäres Gleichgewicht, das die Einheimischen seit Jahrhunderten kennen.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Das Weingut als Museum</p>
        <p class="text-slate-600 text-sm leading-relaxed">Einige Weingüter in Tramonti lassen Sie buchstäblich unter jahrhundertealten Reben spazieren. Es ist eine Pflanzkathedrale: Bringen Sie Ihre Kamera mit, denn das durch die Blätter fallende Licht ist magisch, besonders am Morgen.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Nicht nur Weißwein</p>
        <p class="text-slate-600 text-sm leading-relaxed">Obwohl die Küste Fischland ist, sind die Rotweine aus diesen Hügeln unglaublich zu traditionellen Berggerichten wie Ziege oder Schwarzschwein. Fragen Sie den Produzenten nach seiner Empfehlung.</p>
      </div>
    </div>
  </div>

</BlogPostLayout>
