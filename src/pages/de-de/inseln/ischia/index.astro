---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Inseln', url: '/de-de/inseln/' },
  { name: 'Ischia', url: '/de-de/inseln/ischia/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie kommt man von Neapel nach Ischia?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ab Neapel Molo Beverello fahren den ganzen Tag über Fähren (Caremar, Medmar, ~75 Min.) und Tragflächenboote (~50 Min.). Ab Pozzuoli dauern Caremar-Fähren ~35 Minuten und sind die günstigste Option. Im Sommer die Rückfahrkarte im Voraus buchen, besonders sonntags." }
    },
    {
      "@type": "Question",
      "name": "Sind die Thermalbäder auf Ischia kostenlos?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die meisten Thermalparks verlangen Eintritt (15–35 € pro Person für einen ganzen Tag). Die bekanntesten sind Negombo, Poseidon und Terme di Citara. Es gibt auch kostenlose natürliche Thermalquellen, wie den Thermalstrand bei Sant'Angelo, wo das Meer durch Vulkanaktivität erwärmt wird." }
    },
    {
      "@type": "Question",
      "name": "Lohnt sich der Besuch des Aragonesischen Schlosses auf Ischia?",
      "acceptedAnswer": { "@type": "Answer", "text": "Unbedingt. Das Aragonesische Schloss ist eine der besterhaltenen mittelalterlichen Burgen Italiens, erbaut auf einem Felseneiland und mit der Insel durch eine Steinbrücke verbunden. Drinnen: eine Kathedrale, ein unheimlicher Klosterfriedhof, Gärten und eine Terrasse mit außergewöhnlichem Panorama. Eintritt ~12 €." }
    },
    {
      "@type": "Question",
      "name": "Ist Ischia besser als Capri?",
      "acceptedAnswer": { "@type": "Answer", "text": "Das hängt von den eigenen Vorlieben ab. Capri ist glamouröser, exklusiver und teurer. Ischia ist größer, grüner, mit natürlichen Thermen, Schwarzsandstränden und einer weniger elitären Atmosphäre. Für Familien und Naturliebhaber ist Ischia oft die bessere Wahl. Für Glamour und Aussichten gewinnt Capri." }
    },
    {
      "@type": "Question",
      "name": "Wie viele Tage braucht man für Ischia?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ischia ist groß (46 km²) und verdient mindestens 2–3 Tage. An einem Tag kann man Ischia Ponte, das Aragonesische Schloss und einen Thermalpark besuchen. Mit 2 Tagen kommen Sant'Angelo, der Maronti-Strand und die Wanderung zum Monte Epomeo hinzu." }
    }
  ]
};

const fastFacts = [
  { dt: 'Lage',         dd: 'Golf von Neapel, NA' },
  { dt: 'Fläche',       dd: '46,3 km²' },
  { dt: 'Einwohner',    dd: '~62.000' },
  { dt: 'Vulkan',       dd: 'Epomeo (789 m)' },
  { dt: 'Ab Neapel',    dd: '50–75 Min.' },
  { dt: 'Ab Pozzuoli',  dd: '~35 Min. (Fähre)' },
  { dt: 'Strände',      dd: 'Dunkler Vulkansand' },
  { dt: 'Thermen',      dd: 'Natürlich & Thermalparks' },
  { dt: 'Währung',      dd: 'Euro (€)' },
];

const tips = [
  'Thermalpark im Voraus buchen: Negombo und Poseidon sind in Juli und August schnell ausgebucht.',
  'Roller oder Kleinwagen mieten, um die Insel zu erkunden: Linienbusse gibt es, sind aber im Sommer langsam und überfüllt.',
  "Sant'Angelo abends besuchen: dieses autofreie Dorf ist bei Sonnenuntergang am schönsten.",
  'Monte Epomeo früh morgens besteigen (Start bis 7 Uhr): der Gipfelblick ist jeden Schritt wert und man vermeidet die Hitze.',
];
---

<BaseLayout
  title="Ischia 2026: Reiseführer | Thermalparks, Schloss & Strände"
  description="Vollständiger Reiseführer für Ischia: Aragonesisches Schloss, Thermalparks, Maronti-Strand, Monte Epomeo. Anreise ab Neapel und Pozzuoli, Fährfahrpläne, Sehenswürdigkeiten."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/ischia-hero.jpg" alt="Ischia, Golf von Neapel" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Vulkaninsel · Golf von Neapel · Natürliche Thermalparks</p>
        <h1 class="font-serif text-display text-white mb-4">Ischia</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Die grüne Insel des Golfs: vulkanischen Ursprungs, reich an Thermalquellen, geschichtsgesättigt. Ischia bietet ein anderes Erlebnis als Capri — wilder, authentischer, mit Schwarzsandstränden, einer mittelalterlichen Burg auf dem Meer und der Stille des Monte Epomeo auf 789 Metern.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#kurzinfos" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Kurzinfos
          </a>
          <a href="#anreise" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Anreise
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <!-- Intro -->
        <div>
          <p class="text-xl leading-relaxed text-charcoal">
            Ischia ist die größte der drei Inseln im Golf von Neapel — und für viele Reisende die lohnendste für einen längeren Aufenthalt. Anders als Capri, das sich an einem Tag erschöpft, belohnt Ischia jene, die bleiben: jeden Morgen ein anderer Thermalpark, ein ausgiebiges Mittagessen in einem Fischerdorf, eine Wanderung auf einen Vulkangipfel mit Blick bis zum Vesuv.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Die Insel hat sechs Gemeinden, jede mit eigenem Charakter: das lebhafte Ischia Porto, das mittelalterliche Ischia Ponte, das entspannte Sant'Angelo, das ruhige Lacco Ameno. Ein gemieteter Roller oder Kleinwagen ist der beste Weg, sie alle zu erkunden.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wusstest du?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">100+</p>
              <p class="text-white/60 text-xs italic mt-1">natürliche Thermalquellen auf der Insel</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">789 m</p>
              <p class="text-white/60 text-xs italic mt-1">Höhe des Monte Epomeo, des Vulkangipfels</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">474 v. Chr.</p>
              <p class="text-white/60 text-xs italic mt-1">erste griechische Kolonie auf der Insel (Pithecusa)</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Der Name „Ischia" könnte vom lateinischen „Iscla" (Insel) oder vom griechischen Wort für den Vulkantuff stammen, aus dem ein Großteil der Insel besteht. Ischia war der Standort der ersten griechischen Kolonie im westlichen Mittelmeer.
          </p>
        </div>

        <!-- What to See -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Was es auf Ischia zu sehen gibt</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Aragonesisches Schloss (Castello Aragonese)',
                text: 'Eine der besterhaltenen mittelalterlichen Burgen Süditaliens, auf einem Felseneiland erbaut und mit Ischia Ponte durch eine Steinbrücke verbunden. Drinnen: eine Kathedrale, ein unheimlicher Klosterfriedhof, Gärten und eine Panoramaterrasse. Eintritt ~12 €. Einplanen: 2–3 Stunden.',
              },
              {
                n: 2,
                title: 'Thermalparks',
                text: "Ischias Thermalparks sind sein größter Schatz. Negombo (Lacco Ameno) ist der schönste, in einem botanischen Garten am Meer gelegen. Poseidon (Forio) ist der größte mit 22 Becken. Terme di Citara (Forio) ist das günstigste. Im Sommer mindestens einen Tag im Voraus online buchen.",
              },
              {
                n: 3,
                title: 'Monte Epomeo',
                text: 'Der Vulkangipfel auf 789 m bietet einen 360°-Blick über den gesamten Golf von Neapel, den Vesuv und an klaren Tagen die Amalfiküste. Die Wanderung ab Fontana dauert etwa 1,5 Stunden hin. Das letzte Stück ist steil, aber auf einem gepflegten Saumpfad. Oben wartet ein kleines Café.',
              },
              {
                n: 4,
                title: "Sant'Angelo",
                text: "Ein autofreies Fischerdorf an der Südküste mit bunten Häusern auf einer schmalen Landzunge, die durch einen Sandstrand mit der Insel verbunden ist. Das stimmungsvollste Dorf Ischias — am Wasser zu Mittag essen, die Boutiquen erkunden und von den Felsen unterhalb der Landzunge schwimmen.",
              },
              {
                n: 5,
                title: 'Maronti-Strand',
                text: "Ischias längster Strand (fast 2 km) mit dunklem Vulkansand und warmem Thermalwasser, das an manchen Stellen aus dem Boden sprudelt. Das östliche Ende bei Sant'Angelo ist nur per Wassertaxi erreichbar (die paar Euro wert). Im Sommer sehr beliebt — früh ankommen.",
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to Get Here -->
        <div id="anreise" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Anreise nach Ischia</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Ischia ist per Fähre und Tragflächenboot ab Neapel (Beverello und Mergellina) und ab Pozzuoli erreichbar. Die Pozzuoli-Option ist oft schneller, günstiger und weniger überfüllt.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Ab Neapel</h3><p class="text-white/50 text-sm leading-relaxed">Fähre ~75 Min. (Caremar, Medmar) oder Tragflächenboot ~50 Min. Ab Molo Beverello und Mergellina. Häufige tägliche Verbindungen, ganzjährig.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Ab Pozzuoli</h3><p class="text-white/50 text-sm leading-relaxed">Caremar-Fähre ~35 Min. Die wirtschaftlichste Option — kürzere Überfahrt, günstigere Tickets und häufige Abfahrten. Empfohlen für Tagesausflügler.</p></div>
              </div>
            </div>
            <a href="/de-de/ratgeber/faehren/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Vollständiger Fährführer
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Ferry Schedules -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4">Fährfahrpläne — Sommer 2026</h3>
          <p class="text-sm text-slate-500 mb-4">Ganzjährig ab Neapel und Pozzuoli. Im Sommer mehr Verbindungen. Bitte auf caremar.it und medmar.it bestätigen.</p>

          <div class="overflow-x-auto rounded-2xl border border-slate-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Fähre — Neapel Beverello → Ischia Porto
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Abfahrt Neapel</th>
                  <th class="text-left px-4 py-3 font-semibold">Ankunft Ischia</th>
                  <th class="text-left px-4 py-3 font-semibold">Unternehmen</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['06:00', '07:15', 'Caremar'],
                  ['08:00', '09:15', 'Medmar'],
                  ['10:00', '11:15', 'Caremar'],
                  ['12:00', '13:15', 'Medmar'],
                  ['14:30', '15:45', 'Caremar'],
                  ['17:00', '18:15', 'Medmar'],
                  ['19:30', '20:45', 'Caremar'],
                ].map(([dep, arr, co]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{co}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Fähre — Pozzuoli → Ischia Porto (Caremar, ~35 Min.)
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Abfahrt Pozzuoli</th>
                  <th class="text-left px-4 py-3 font-semibold">Ankunft Ischia</th>
                  <th class="text-left px-4 py-3 font-semibold">Dauer</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['05:30', '06:05', '~35 Min.'],
                  ['08:00', '08:35', '~35 Min.'],
                  ['10:30', '11:05', '~35 Min.'],
                  ['13:00', '13:35', '~35 Min.'],
                  ['15:30', '16:05', '~35 Min.'],
                  ['18:00', '18:35', '~35 Min.'],
                  ['20:30', '21:05', '~35 Min.'],
                ].map(([dep, arr, dur]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{dur}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Richtwerte für Sommer 2026. Bitte auf caremar.it und medmar.it bestätigen.</p>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Versteckte Ecken Ischias</h2>
          <p class="text-slate-500 mb-8">Abseits der großen Badeorte versteckt Ischia außergewöhnliche Orte.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'La Mortella Gardens', text: "1956 vom Komponisten William Walton und seiner Frau Susana angelegt, beherbergt dieser außergewöhnliche botanische Garten in Forio über 1.000 Arten seltener und exotischer Pflanzen. Einer der schönsten Privatgärten Italiens. Eintritt ~14 €. April bis November geöffnet." },
              { title: 'Spiaggia dei Pescatori (Ischia Ponte)', text: 'Ein kleiner Strand direkt neben dem Aragonesischen Schloss, hauptsächlich von Einheimischen genutzt. Fast keine Touristen. Der Blick auf das Schloss vom Wasser bei Sonnenuntergang ist spektakulär. Kostenlos, klein und oft von Reiseführern übersehen.' },
              { title: "Kostenloser Thermalstrand bei Sant'Angelo", text: "In der Nähe von Sant'Angelo erwärmen vulkanische Thermalquellen das Meerwasser an einem bestimmten Strandabschnitt. Man kann kostenlos ein natürliches Thermalbad genießen — nur ein Handtuch mitbringen und Stoßzeiten meiden (vor 9 oder nach 17 Uhr)." },
              { title: 'Lacco Ameno und Villa Arbusto', text: 'Die eleganteste Gemeinde Ischias, mit dem berühmten Fungo (pilzförmiger Felsen) im Meer und dem Museum Villa Arbusto, das die archäologische Sammlung Pithecusa beherbergt — Funde aus der frühesten griechischen Kolonie im westlichen Mittelmeer.' },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Insider-Tipp</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Die Pozzuoli-Fähre nehmen</h3>
              <p class="text-white/70 leading-relaxed">Die meisten Touristen nehmen die Fähre von Neapel Beverello. Die Einheimischen nutzen Pozzuoli: die Überfahrt ist 35 Minuten kürzer, das Ticket kostet weniger und es gibt genug Sitzplätze. Ab Neapel nimmt man die U-Bahn Linie 2 bis Pozzuoli und ist in 20 Minuten am Hafen.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Häufig gestellte Fragen zu Ischia</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <div id="kurzinfos" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Kurzinfos — Ischia</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
