---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Inseln', url: '/de-de/inseln/' },
];

const islands = [
  {
    name: 'Capri',
    href: '/de-de/inseln/capri/',
    desc: 'Die Blaue Grotte, die Faraglioni-Felsen und die glamouröse Piazzetta: die bekannteste Insel im Golf von Neapel.',
    tag: 'Die ikonischste',
    facts: ['40 Min. ab Neapel', 'Keine Privatautos', 'Blaue Grotte'],
  },
  {
    name: 'Ischia',
    href: '/de-de/inseln/ischia/',
    desc: 'Die grüne Insel des Golfs: natürliche Thermalbäder, das Aragonesische Schloss, Vulkanstrände und der Monte Epomeo (789 m).',
    tag: 'Thermen & Natur',
    facts: ['50 Min. ab Neapel', '100+ Thermalquellen', 'Aragonesisches Schloss'],
  },
  {
    name: 'Procida',
    href: '/de-de/inseln/procida/',
    desc: 'Die kleinste und authentischste: bunte Häuser an der Marina Corricella, Italiens Kulturhauptstadt 2022.',
    tag: 'Die authentischste',
    facts: ['15 Min. ab Pozzuoli', 'Kulturhauptstadt 2022', 'Die Postboten-Insel'],
  },
];

const destinationSchema = {
  "@context": "https://schema.org",
  "@type": "TouristDestination",
  "name": "Inseln im Golf von Neapel",
  "description": "Capri, Ischia und Procida: die drei Inseln im Golf von Neapel, erreichbar per Fähre von Neapel, Pozzuoli und Sorrent.",
  "url": "https://amalficoast-travel.com/de-de/inseln/",
  "touristType": ["Meer", "Kultur", "Thermen", "Natur"],
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.5500,
    "longitude": 14.1000
  }
};
---

<BaseLayout
  title="Inseln im Golf von Neapel 2026: Capri, Ischia & Procida"
  description="Reiseführer zu den Inseln im Golf von Neapel: Capri, Ischia und Procida. Anreise, Sehenswürdigkeiten, beste Reisezeit. Alles für die Planung Ihres Inselausflugs."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[destinationSchema]}
>

  <!-- Hero -->
  <section class="relative bg-charcoal py-24 md:py-32 overflow-hidden">
    <img src="/images/isole-hero.jpg" alt="Inseln im Golf von Neapel" class="absolute inset-0 w-full h-full object-cover opacity-40" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-charcoal/90 via-charcoal/75 to-charcoal/60"></div>
    <div class="relative z-10 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/50 text-xs mb-8">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white/80">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-4">Golf von Neapel</p>
      <h1 class="font-serif text-display text-white mb-6 max-w-3xl">Die Inseln im Golf von Neapel</h1>
      <p class="text-xl text-white/70 leading-relaxed max-w-2xl">
        Drei Inseln, drei völlig verschiedene Charaktere. Capri für Glamour und ikonische Aussichten. Ischia für Vulkanthermen und wilde Natur. Procida für Authentizität und das Italien, das Touristen selten finden. Alle in weniger als einer Stunde per Fähre oder Tragflächenboot erreichbar.
      </p>
    </div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-med-gold/5 rounded-full blur-3xl pointer-events-none"></div>
  </section>

  <!-- Island Cards -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid md:grid-cols-3 gap-8">
      {islands.map(({ name, href, desc, tag, facts }) => (
        <a href={href} class="group block bg-white rounded-[3rem] border border-slate-100 p-8 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">{tag}</p>
          <h2 class="font-serif text-3xl font-bold text-charcoal mb-3 group-hover:text-med-blue transition-colors">{name}</h2>
          <p class="text-slate-600 leading-relaxed text-sm mb-6">{desc}</p>
          <ul class="space-y-2 mb-6">
            {facts.map(fact => (
              <li class="flex items-center gap-2 text-xs text-slate-500">
                <span class="w-1.5 h-1.5 rounded-full bg-med-gold flex-shrink-0"></span>
                {fact}
              </li>
            ))}
          </ul>
          <span class="inline-flex items-center gap-1.5 text-med-blue text-xs font-bold uppercase tracking-[0.2em] group-hover:gap-2.5 transition-all">
            {name} entdecken
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Comparison -->
  <section class="bg-slate-50 py-20">
    <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Welche Insel passt zu Ihnen?</h2>
      <p class="text-slate-500 mb-10 max-w-2xl leading-relaxed">Jede Insel hat eine eigene Persönlichkeit. Ein schneller Vergleich zur Entscheidungshilfe.</p>

      <div class="overflow-x-auto rounded-2xl border border-slate-200 bg-white">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="text-left px-6 py-4 font-semibold text-charcoal">Merkmal</th>
              <th class="text-left px-6 py-4 font-semibold text-charcoal">Capri</th>
              <th class="text-left px-6 py-4 font-semibold text-charcoal">Ischia</th>
              <th class="text-left px-6 py-4 font-semibold text-charcoal">Procida</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {[
              ['Fläche', '10,4 km²', '46,3 km²', '4,1 km²'],
              ['Besucherandrang', 'Im Sommer sehr hoch', 'Moderat', 'Gering bis moderat'],
              ['Preisniveau', '€€€€', '€€–€€€', '€–€€'],
              ['Am besten für', 'Glamour, Aussichten, Tagesausflug', '2–3 Tage, Thermen', 'Authentizität, Tagesausflug'],
              ['Strände', 'Felsen & Kiesel', 'Dunkler Vulkansand', 'Dunkel- & Hellsand'],
              ['Autofahren?', 'Nein (nur Einwohner)', 'Ja', 'Roller & Kleinautos'],
              ['Ab Neapel', '~40 Min. Tragflächenboot', '~50 Min. Tragflächenboot', '~35 Min. Tragflächenboot'],
              ['Nächster Hafen', 'Sorrent (25 Min.)', 'Pozzuoli (35 Min.)', 'Pozzuoli (15 Min.)'],
            ].map(([feature, capri, ischia, procida]) => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-6 py-3 font-medium text-charcoal">{feature}</td>
                <td class="px-6 py-3 text-slate-600">{capri}</td>
                <td class="px-6 py-3 text-slate-600">{ischia}</td>
                <td class="px-6 py-3 text-slate-600">{procida}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Getting There -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
      <div class="relative z-10">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-4">Anreise zu den Inseln</p>
        <h2 class="font-serif text-3xl font-bold text-white mb-6 tracking-tight">Alle Inseln per Fähre oder Tragflächenboot</h2>
        <p class="text-white/60 mb-10 leading-relaxed max-w-2xl">Keine Brücken, keine Flughäfen. Der einzige Weg zu den Golfinseln führt übers Meer - was an sich schon Teil des Erlebnisses ist. Hauptabfahrtsorte sind Neapel Molo Beverello und Pozzuoli. Von Sorrent gelangt man nur nach Capri.</p>
        <div class="grid sm:grid-cols-3 gap-6 mb-10">
          {[
            { from: 'Neapel → Capri', time: '~40 Min.', note: 'Tragflächenboot, ganzjährig' },
            { from: 'Neapel → Ischia', time: '~50 Min.', note: 'Tragflächenboot, ganzjährig' },
            { from: 'Pozzuoli → Procida', time: '~15 Min.', note: 'Fähre, ganzjährig' },
          ].map(({ from, time, note }) => (
            <div class="bg-white/5 rounded-2xl p-5 border border-white/10">
              <p class="text-white/50 text-xs mb-1">{from}</p>
              <p class="font-serif text-2xl font-bold text-med-gold">{time}</p>
              <p class="text-white/40 text-xs mt-1">{note}</p>
            </div>
          ))}
        </div>
        <a href="/de-de/ratgeber/faehren/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
          Vollständiger Fährführer mit Fahrplänen
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
    </div>
  </section>

</BaseLayout>
