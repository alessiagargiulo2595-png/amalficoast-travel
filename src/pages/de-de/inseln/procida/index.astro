---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'de-de';

const breadcrumbs = [
  { name: 'Home', url: '/de-de/' },
  { name: 'Inseln', url: '/de-de/inseln/' },
  { name: 'Procida', url: '/de-de/inseln/procida/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Wie kommt man von Neapel nach Procida?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ab Neapel Molo Beverello fahren Tragflächenboote nach Procida (~35 Min., SNAV/Caremar). Ab Pozzuoli dauern Caremar-Fähren ~15 Minuten und sind die günstigste und häufigste Verbindung. Im Sommer gibt es sehr viele tägliche Überfahrten." }
    },
    {
      "@type": "Question",
      "name": "Warum ist Procida berühmt geworden?",
      "acceptedAnswer": { "@type": "Answer", "text": "Procida wurde schon immer von Künstlern geliebt: Elsa Morante hat hier ihren Roman 'Arturo's Insel' (1957) angesiedelt, Massimo Troisi drehte 'Der Postmann' (Il Postino, 1994) auf der Insel. Internationale Bekanntheit erlangte sie 2022, als sie zur Italiens Kulturhauptstadt ernannt wurde." }
    },
    {
      "@type": "Question",
      "name": "Ist Marina Corricella einen Besuch wert?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, Marina Corricella ist eines der schönsten und meistfotografierten Fischerdörfer Italiens: mehrfarbige Häuser in Gelb, Orange, Rosa und Blau direkt am Meer, ohne Straße für Autos. Zu Fuß in 15 Minuten von Marina Grande erreichbar. Der Sonnenuntergang von hier ist unvergesslich." }
    },
    {
      "@type": "Question",
      "name": "Eignet sich Procida für einen Tagesausflug?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ja, Procida ist klein (4,1 km²) und lässt sich bequem an einem Tag erkunden. An einem Tag kann man Marina Grande, Marina Corricella, Terra Murata, Spiaggia del Pozzo Vecchio und La Chiaiolella besuchen. Mit Fähren ab Pozzuoli kann man morgens fahren und abends zurückkehren." }
    },
    {
      "@type": "Question",
      "name": "Was ist der schönste Strand auf Procida?",
      "acceptedAnswer": { "@type": "Answer", "text": "Die Spiaggia del Pozzo Vecchio (als 'Arturo's Insel-Strand' nach dem Film bekannt) ist die bekannteste und stimmungsvollste. La Chiaiolella ist die größte und am besten ausgestattete. Spiaggia di Ciraccio ist ruhiger. Alle Strände Procidas haben sehr klares Wasser dank der offenen Lage der Insel." }
    }
  ]
};

const fastFacts = [
  { dt: 'Lage',              dd: 'Golf von Neapel, NA' },
  { dt: 'Fläche',            dd: '4,1 km²' },
  { dt: 'Einwohner',         dd: '~10.000' },
  { dt: 'Kulturhauptstadt',  dd: '2022' },
  { dt: 'Ab Neapel',         dd: '~35 Min. (Tragflächenboot)' },
  { dt: 'Ab Pozzuoli',       dd: '~15 Min. (Fähre)' },
  { dt: 'Strände',           dd: 'Dunkel- und Hellsand' },
  { dt: 'Beste Zeit',        dd: 'Mai–Jun / Sep–Okt' },
  { dt: 'Währung',           dd: 'Euro (€)' },
];

const tips = [
  'Die Fähre ab Pozzuoli nehmen: günstiger, schneller und weniger überfüllt als ab Neapel.',
  'Fahrrad oder Roller mieten: Procida ist klein, aber im Sommer überall zu Fuß zu gehen ist anstrengend.',
  'Marina Corricella bei Sonnenuntergang besuchen: das Lichtspiel auf den bunten Häusern ist außergewöhnlich.',
  "Die Kaisergranaten probieren (scampi): Procida ist berühmt für seine Garnelen - jedes Meeresfrüchterestaurant hat sie frisch.",
];
---

<BaseLayout
  title="Procida 2026: Reiseführer | Marina Corricella & Die Postboten-Insel"
  description="Vollständiger Reiseführer für Procida: Marina Corricella, Terra Murata, Spiaggia del Pozzo Vecchio. Anreise ab Neapel und Pozzuoli, Fährfahrpläne, Sehenswürdigkeiten."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/procida-hero.jpg" alt="Procida, Golf von Neapel" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Insel · Golf von Neapel · Italiens Kulturhauptstadt 2022</p>
        <h1 class="font-serif text-display text-white mb-4">Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Die kleinste, authentischste und - viele würden sagen - schönste Insel im Golf von Neapel. Procida hat keine Luxushotels, keine Designerboutiquen, keine berühmten Höhlen. Was sie hat, ist etwas Selteneres: eine echte Fischergemeinschaft, eine Pastellpalette, die unmöglich aussieht, und ein Lebenstempo, das sich seit Jahrhunderten nicht verändert hat.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#kurzinfos" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Kurzinfos
          </a>
          <a href="#anreise" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Anreise
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <!-- Intro -->
        <div>
          <p class="text-xl leading-relaxed text-charcoal">
            Wenn Capri die Prominenten-Insel ist und Ischia die Wellness-Insel, dann ist Procida die Seelen-Insel. Mit nur 4 km² ist sie Italiens kleinste bewohnte Insel - und eine der bewegendsten. Die Schriftstellerin Elsa Morante wählte sie als Schauplatz ihres Meisterwerks <em>Arturo's Insel</em> (1957). Massimo Troisi drehte hier seine letzte Rolle in <em>Der Postmann</em> (1994). 2022 wurde sie zur Italiens Kulturhauptstadt ernannt.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Was Procida besonders macht, ist genau das, was fehlt: keine Massentourismusinfrastruktur, keine Tagesausflüglermassen von Kreuzfahrtschiffen, keine internationalen Hotelketten. Die Insel funktioniert nach ihren eigenen Regeln - Kaisergranaten-Fischerboote fahren bei Morgengrauen aus, Kinder spielen in den Gassen von Terra Murata, und die Bars schließen, wenn der letzte Fischer nach Hause geht.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Wusstest du?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">4,1 km²</p>
              <p class="text-white/60 text-xs italic mt-1">Italiens kleinste bewohnte Insel</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1994</p>
              <p class="text-white/60 text-xs italic mt-1">Il Postino hier gedreht, Oscar für beste Musik</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">2022</p>
              <p class="text-white/60 text-xs italic mt-1">Italiens Kulturhauptstadt</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Procidas Kaisergranaten (scampi di Procida) gelten als die besten in ganz Italien. Einheimische Fischer fahren noch jeden Morgen mit ihren Booten aus - Restaurants, die "gamberi di paranza" direkt vom Morgenfang servieren, suchen.
          </p>
        </div>

        <!-- What to See -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Was es auf Procida zu sehen gibt</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Marina Corricella',
                text: "Das schönste Fischerdorf des Mittelmeers: Häuser in Gelb, Orange, Rosa, Blau und Weiß auf einem Hügel gestapelt, alle zum Meer gewandt, ohne Straße für Fahrzeuge. Zu Fuß in 15 Minuten von Marina Grande erreichbar. Boote, Fischernetze, Katzen. Für den Sonnenuntergang bleiben.",
              },
              {
                n: 2,
                title: 'Terra Murata',
                text: "Das mittelalterliche befestigte Dorf auf dem höchsten Punkt der Insel (91 m), mit der Abtei San Michele Arcangelo und Panoramablick über den gesamten Golf von Neapel. Die alten Häuser innerhalb der Mauern sind teils verlassen, teils bewohnt - ein einzigartig atmosphärischer Ort. Kostenlos zu besuchen.",
              },
              {
                n: 3,
                title: 'Spiaggia del Pozzo Vecchio',
                text: "Als 'Arturo's Insel-Strand' bekannt, nach dem Elsa-Morante-Roman und dem Film. Eine kleine, fotogene Bucht mit dunklem Sand, klarem Wasser und einer natürlichen Höhle. Weniger überfüllt als La Chiaiolella. Zu Fuß von Marina Grande in 20 Minuten erreichbar.",
              },
              {
                n: 4,
                title: 'La Chiaiolella',
                text: "Procidas größter und am besten ausgestatteter Strand am westlichen Ende der Insel. Halbmondförmig, mit hellem Sand und warmem, flachem Wasser, ideal für Familien. Bootsverleih vorhanden. Das Dorf Chiaiolella in der Nähe hat ausgezeichnete Restaurants und eine lebhafte Abendatmosphäre.",
              },
              {
                n: 5,
                title: 'Abtei San Michele Arcangelo',
                text: "Das spirituelle Herz der Insel, im 11. Jahrhundert gegründet und mehrmals umgebaut. Beherbergt eine Gemäldesammlung lokaler Künstler, eine bemalte Decke aus dem 17. Jahrhundert und Katakomben. Der Blick von der Terrasse über Terra Murata und das Meer darunter ist außergewöhnlich. Eintritt ~3 €.",
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to Get Here -->
        <div id="anreise" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Anreise nach Procida</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Procida ist die dem Festland nächstgelegene Insel. Die schnellste Option ist die Fähre ab Pozzuoli (15 Min.). Ab Neapel Beverello dauern Tragflächenboote rund 35 Minuten.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Ab Pozzuoli</h3><p class="text-white/50 text-sm leading-relaxed">Caremar-Fähre ~15 Min. Die günstigste und bequemste Option - U-Bahn Linie 2 ab Neapel bis Pozzuoli Solfatara, dann 10 Min. zum Hafen zu Fuß.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Ab Neapel</h3><p class="text-white/50 text-sm leading-relaxed">Tragflächenboot ~35 Min. (SNAV, Caremar) ab Molo Beverello. Mehrere tägliche Abfahrten. Etwas teurer als Pozzuoli, aber bequemer vom Stadtzentrum aus.</p></div>
              </div>
            </div>
            <a href="/de-de/ratgeber/faehren/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Vollständiger Fährführer
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Ferry Schedules -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4">Fährfahrpläne - Sommer 2026</h3>
          <p class="text-sm text-slate-500 mb-4">Ganzjährig ab Pozzuoli und Neapel. Im Sommer sehr häufige Abfahrten. Bitte auf caremar.it bestätigen.</p>

          <div class="overflow-x-auto rounded-2xl border border-slate-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Fähre - Pozzuoli → Marina Grande, Procida (Caremar, ~15 Min.)
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Abfahrt Pozzuoli</th>
                  <th class="text-left px-4 py-3 font-semibold">Ankunft Procida</th>
                  <th class="text-left px-4 py-3 font-semibold">Dauer</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['06:00', '06:15', '~15 Min.'],
                  ['07:30', '07:45', '~15 Min.'],
                  ['09:00', '09:15', '~15 Min.'],
                  ['11:00', '11:15', '~15 Min.'],
                  ['13:30', '13:45', '~15 Min.'],
                  ['16:00', '16:15', '~15 Min.'],
                  ['18:30', '18:45', '~15 Min.'],
                  ['20:00', '20:15', '~15 Min.'],
                ].map(([dep, arr, dur]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{dur}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Tragflächenboot - Neapel Beverello → Marina Grande, Procida (~35 Min.)
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Abfahrt Neapel</th>
                  <th class="text-left px-4 py-3 font-semibold">Ankunft Procida</th>
                  <th class="text-left px-4 py-3 font-semibold">Unternehmen</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['07:00', '07:35', 'SNAV'],
                  ['09:15', '09:50', 'Caremar'],
                  ['12:00', '12:35', 'SNAV'],
                  ['15:00', '15:35', 'Caremar'],
                  ['18:00', '18:35', 'SNAV'],
                ].map(([dep, arr, co]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{co}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Richtwerte für Sommer 2026. Bitte auf caremar.it und snav.it bestätigen.</p>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Procida abseits der Pfade</h2>
          <p class="text-slate-500 mb-8">Eine so authentische Insel hat keine Seltenheit an versteckten Momenten.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Morgens am Fischmarkt', text: 'Um 7 Uhr an der Marina Grande laden Fischer ihren Nachtfang aus. Der Fischmarkt läuft etwa eine Stunde. Kaisergranaten, Tintenfische und frischen Fisch direkt vom Boot kaufen beobachten - ein Einblick in das echte Inselleben.' },
              { title: 'Via Vittorio Emanuele bei Einbruch der Dämmerung', text: 'Die Hauptstraße der Insel wird um 19 Uhr zur Flaniermeile. Einheimische kommen heraus, Kinder spielen, die Bars füllen sich. Keine Touristen, keine Selfie-Sticks. Einen Spritz in einer lokalen Bar nehmen und der Gemeinschaft bei ihrer authentischsten Stunde zusehen.' },
              { title: 'Spiaggia di Ciraccio', text: 'Der ruhigste Strand der Insel an der nordwestlichen Küste. Dunklerer Sand, weniger Menschen selbst in der Hochsaison, schönes Wasser. Per Roller oder zu Fuß in 30 Minuten von Marina Grande erreichbar. Perfekt für ein Morgenbad vor dem Ansturm.' },
              { title: "Palazzo d'Avalos", text: 'Der ehemalige Königspalast, der im 18. Jahrhundert zum Gefängnis wurde und erst 1988 schloss. Das Gebäude auf der Landzunge ist noch teilweise verfallen, aber das Äußere mit den Meeresblicken ist tief atmosphärisch. Sanierungsarbeiten laufen - prüfen, ob geführte Touren wieder stattfinden.' },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Insider-Tipp</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Die Kaisergranaten bestellen</h3>
              <p class="text-white/70 leading-relaxed">Procidas scampi (Kaisergranaten) sind im gesamten Golf von Neapel berühmt. "Gamberi di Procida" oder "scampi alla griglia" bestellen - jedes Restaurant auf der Insel hat sie. Die süßesten, frischesten Schalentiere der gesamten Küste, zu etwa einem Drittel des Capri-Preises.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Häufig gestellte Fragen zu Procida</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <div id="kurzinfos" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Kurzinfos - Procida</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

