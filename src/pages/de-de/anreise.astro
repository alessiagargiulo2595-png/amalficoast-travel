---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocalePath } from '../../i18n/translations';

const lang = 'de-de';
const t = getTranslations(lang);
---

<BaseLayout
  title={t.meta.getting_here_title}
  description={t.meta.getting_here_description}
  lang={lang}
  pageKey="getting-here"
>
  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/come-arrivare-hero.jpg" alt="Hafen von Sorrent, Amalfiküste" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <p class="text-med-gold text-sm uppercase tracking-[0.3em] mb-3 font-medium">Praktischer Ratgeber</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Anreise zur Amalfiküste</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto font-light">Zug, Flugzeug, Fähre oder Auto: alle Möglichkeiten, um die Küste aus Italien und dem Ausland zu erreichen.</p>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-lg text-slate-600 leading-relaxed">
      Die Amalfiküste hat weder einen eigenen Flughafen noch einen Bahnhof an ihrer Hauptstrecke. Der bequemste Weg, sie zu erreichen, führt über Neapel (internationaler Flughafen und Hochgeschwindigkeitsbahnhof) oder Salerno (per Zug aus ganz Italien erreichbar). Von dort gibt es Fähren, Busse und private Transfers.
    </p>
  </section>

  <!-- Transport methods -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">

      <!-- Ab Neapel -->
      <div class="bg-white rounded-[2rem] shadow-sm border border-slate-100 p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 bg-med-gold rounded-2xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold font-serif text-slate-900">Ab Neapel</h2>
            <p class="text-med-gold text-sm">Flughafen Capodichino · Hauptbahnhof Neapel</p>
          </div>
        </div>
        <p class="text-slate-600 leading-relaxed mb-6">
          Neapel ist das wichtigste Einfallstor zur Amalfiküste. Der internationale Flughafen Neapel-Capodichino (NAP) hat Direktflüge aus allen wichtigen europäischen Städten, darunter viele Billigflüge aus Rom, Mailand, London, Paris, Frankfurt und Madrid. Von Neapel gibt es drei Möglichkeiten, die Küste zu erreichen:
        </p>
        <div class="space-y-4">
          <div class="bg-med-gold/5 rounded-2xl p-5">
            <h3 class="font-semibold text-slate-900 mb-2">Direktfähre (Sommer)</h3>
            <p class="text-slate-600 text-sm">Von April bis Oktober fahren Schnellfähren vom Neapler Molo Beverello direkt nach Positano und Amalfi in etwa 1h30. Komfortabel, malerisch und staufrei. In der Hochsaison im Voraus buchen.</p>
          </div>
          <div class="bg-med-gold/5 rounded-2xl p-5">
            <h3 class="font-semibold text-slate-900 mb-2">SITA Bus über Sorrent</h3>
            <p class="text-slate-600 text-sm">Circumvesuviana von Neapel nach Sorrent (ca. 1h), dann SITA Bus entlang der Küste. Günstig aber langsam (2h30–3h gesamt). Gute Option, wenn Sie das Autofahren vermeiden möchten.</p>
          </div>
          <div class="bg-med-gold/5 rounded-2xl p-5">
            <h3 class="font-semibold text-slate-900 mb-2">Privattransfer</h3>
            <p class="text-slate-600 text-sm">Taxi oder NCC vom Flughafen Neapel: ca. 90–120 Euro bis Positano/Amalfi (1h–1h30 ohne Stau). Praktisch für Familien oder mit viel Gepäck.</p>
          </div>
        </div>
      </div>

      <!-- Ab Salerno -->
      <div class="bg-white rounded-[2rem] shadow-sm border border-slate-100 p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 bg-med-gold rounded-2xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold font-serif text-slate-900">Ab Salerno</h2>
            <p class="text-med-gold text-sm">Östliches Eingangstor zur Amalfiküste</p>
          </div>
        </div>
        <p class="text-slate-600 leading-relaxed mb-6">
          Salerno ist ein oft unterschätzter, aber sehr bequemer Ausgangspunkt. Der Bahnhof Salerno wird von Hochgeschwindigkeitszügen bedient (1h40 ab Rom, 2h30 ab Mailand) und von vielen Regionalzügen. Ab Salerno fährt der SITA Bus zur Küste häufig und braucht 45 Minuten bis Amalfi. Im Sommer gibt es auch Fähren.
        </p>
        <div class="bg-med-gold/5 rounded-2xl p-5">
          <h3 class="font-semibold text-slate-900 mb-2">Fähre ab Salerno (Sommer)</h3>
          <p class="text-slate-600 text-sm">Fähren von Salerno nach Amalfi und Positano von April bis Oktober. Etwa 45 Minuten bis Amalfi, mit wunderschönen Küstenansichten. Günstiger als Fähren ab Neapel.</p>
        </div>
      </div>

      <!-- Ab Sorrent -->
      <div class="bg-white rounded-[2rem] shadow-sm border border-slate-100 p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 bg-med-gold rounded-2xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 18c.5 0 1-.5 1-1s-.5-1-1-1-1 .5-1 1 .5 1 1 1zm10 0c.5 0 1-.5 1-1s-.5-1-1-1-1 .5-1 1 .5 1 1 1zm-5-11l4 4h2V6h-6v5zm0 0l-4-4h-2v5h6V7z"/></svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold font-serif text-slate-900">Ab Sorrent</h2>
            <p class="text-med-gold text-sm">Per Fähre oder Panoramastraße</p>
          </div>
        </div>
        <p class="text-slate-600 leading-relaxed">
          Sorrent ist ein beliebter Ausgangspunkt für Ausflüge sowohl zur Sorrentiner Halbinsel als auch zur Amalfiküste. Fähren von Sorrent erreichen Positano in 25 Minuten: das ist der malerischste und schnellste Weg, die Küste zu betreten. Alternativ folgt der SITA Bus der SP145 und SS163 für etwa 1h30 bis Amalfi.
        </p>
      </div>

      <!-- Mit dem Auto -->
      <div class="bg-white rounded-[2rem] shadow-sm border border-slate-100 p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 bg-med-gold rounded-2xl flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 14h8m-7-7h6V6h-6v1zm0 0H6l.5 6h11l.5-6h-2V4h-2v3H8V4H6v3z"/></svg>
          </div>
          <div>
            <h2 class="text-2xl font-bold font-serif text-slate-900">Mit dem Auto</h2>
            <p class="text-med-gold text-sm font-medium">⚠️ Im Juli und August nicht empfohlen</p>
          </div>
        </div>
        <p class="text-slate-600 leading-relaxed mb-6">
          Die SS163, die Küstenstraße durch die Amalfiküste, ist eine der spektakulärsten Straßen Europas, aber auch eine der engsten. In der Hochsaison kann der Verkehr lähmend sein, mit stundenlangen Staus. Wenn Sie mit dem Auto fahren, beachten Sie diese Tipps:
        </p>
        <ul class="space-y-3">
          <li class="flex gap-3 text-sm text-slate-600">
            <svg class="w-5 h-5 text-med-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Abfahrt vor 8 Uhr morgens oder nach 19 Uhr, um den schlimmsten Stau zu vermeiden
          </li>
          <li class="flex gap-3 text-sm text-slate-600">
            <svg class="w-5 h-5 text-med-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            In Sorrent oder Salerno parken und öffentliche Verkehrsmittel oder Fähren entlang der Küste nutzen
          </li>
          <li class="flex gap-3 text-sm text-slate-600">
            <svg class="w-5 h-5 text-med-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Parkplätze in Amalfi und Positano kosten 3–5 Euro/Stunde und sind in der Hochsaison oft ausgebucht
          </li>
          <li class="flex gap-3 text-sm text-slate-600">
            <svg class="w-5 h-5 text-med-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Im Frühling (April–Mai) und Herbst (September–Oktober) ist das Autofahren angenehm und problemlos
          </li>
        </ul>
      </div>

    </div>
  </section>

  <!-- Entfernungen & Reisezeiten -->
  <section class="bg-slate-100 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-serif text-slate-900 mb-8 text-center">Entfernungen & Reisezeiten</h2>
      <div class="overflow-x-auto">
        <table class="w-full bg-white rounded-2xl shadow-sm overflow-hidden">
          <thead class="bg-slate-700 text-white">
            <tr>
              <th class="px-6 py-4 text-left text-sm font-semibold">Von</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Nach</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Verkehrsmittel</th>
              <th class="px-6 py-4 text-left text-sm font-semibold">Zeit</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-4 text-sm">Neapel (Flughafen)</td>
              <td class="px-6 py-4 text-sm font-medium">Positano</td>
              <td class="px-6 py-4 text-sm">Fähre (Sommer)</td>
              <td class="px-6 py-4 text-sm text-med-gold font-medium">1h 30min</td>
            </tr>
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-4 text-sm">Neapel Hauptbahnhof</td>
              <td class="px-6 py-4 text-sm font-medium">Amalfi</td>
              <td class="px-6 py-4 text-sm">Zug + SITA Bus</td>
              <td class="px-6 py-4 text-sm text-med-gold font-medium">2h 30min</td>
            </tr>
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-4 text-sm">Salerno</td>
              <td class="px-6 py-4 text-sm font-medium">Amalfi</td>
              <td class="px-6 py-4 text-sm">SITA Bus</td>
              <td class="px-6 py-4 text-sm text-med-gold font-medium">45 min</td>
            </tr>
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-4 text-sm">Sorrent</td>
              <td class="px-6 py-4 text-sm font-medium">Positano</td>
              <td class="px-6 py-4 text-sm">Fähre</td>
              <td class="px-6 py-4 text-sm text-med-gold font-medium">25 min</td>
            </tr>
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-4 text-sm">Rom Termini</td>
              <td class="px-6 py-4 text-sm font-medium">Salerno</td>
              <td class="px-6 py-4 text-sm">Hochgeschwindigkeitszug</td>
              <td class="px-6 py-4 text-sm text-med-gold font-medium">1h 40min</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Jetzt Ihre Reiseroute planen</h2>
      <a href={getLocalePath(lang, 'itineraries')}
        class="inline-block bg-med-gold text-white font-semibold px-8 py-3 rounded-full hover:bg-med-gold transition-colors">
        Empfohlene Reiserouten ansehen
      </a>
    </div>
  </section>
</BaseLayout>
