---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Îles', url: '/fr-fr/iles/' },
  { name: 'Capri', url: '/fr-fr/iles/capri/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment aller de Naples à Capri ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Depuis Naples Molo Beverello, on peut rejoindre Capri en ferry (~50 min, Caremar/SNAV) ou en hydroglisseur (~40 min, NLG/Alilauro). Depuis Sorrente, l'hydroglisseur ne prend que 20–25 minutes. Achetez les billets en ligne ou au guichet. En été, réservez le trajet retour bien à l'avance." }
    },
    {
      "@type": "Question",
      "name": "Peut-on amener sa voiture à Capri ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Non. Capri applique une interdiction quasi totale des voitures privées : seuls les résidents peuvent amener leurs véhicules. Les touristes se déplacent à pied, en bus local, en taxi découvert ou en funiculaire. C'est l'une des raisons pour lesquelles l'île est si agréable à visiter." }
    },
    {
      "@type": "Question",
      "name": "Combien coûte l'entrée à la Grotte Bleue ?",
      "acceptedAnswer": { "@type": "Answer", "text": "L'entrée à la Grotte Bleue coûte environ 14 € par personne (inclut la promenade en barque à rames à l'intérieur). Le bateau depuis Marina Grande coûte en plus (~15 € aller-retour). En haute saison, les files d'attente peuvent durer 1 à 2 heures. Il est fortement recommandé d'y aller tôt le matin." }
    },
    {
      "@type": "Question",
      "name": "Capri ou Anacapri - lequel est mieux ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Capri (le bourg principal) est plus glamour, avec la Piazzetta et les boutiques de luxe. Anacapri, en haut de l'île, est plus calme et authentique, avec la Villa San Michele et le télésiège vers le Monte Solaro. Pour une journée complète, visitez les deux ; pour une demi-journée, choisissez selon votre style." }
    },
    {
      "@type": "Question",
      "name": "Quelle est la meilleure période pour visiter Capri ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Mai, juin et septembre sont idéaux : météo parfaite, mer chaude et foules gérables. Juillet et août sont très chauds et surpeuplés (plus de 10 000 visiteurs par jour). Avril et octobre sont calmes mais certains services sont réduits." }
    }
  ]
};

const fastFacts = [
  { dt: 'Situation',      dd: 'Golfe de Naples, NA' },
  { dt: 'Superficie',     dd: '10,4 km²' },
  { dt: 'Population',     dd: '~14 000 habitants' },
  { dt: 'Voitures privées', dd: 'Interdites aux touristes' },
  { dt: 'Depuis Naples',  dd: '40–50 min (hydro/ferry)' },
  { dt: 'Depuis Sorrente', dd: '20–25 min (hydroglisseur)' },
  { dt: 'Plages',         dd: 'Rochers et galets' },
  { dt: 'Meilleure période', dd: 'Mai–Jun / Sep' },
  { dt: 'Monnaie',        dd: 'Euro (€)' },
];

const tips = [
  "Prendre le premier hydroglisseur du matin (7h–8h) : on arrive avant les foules et la Grotte Bleue est sans file d'attente.",
  "Éviter le taxi depuis le port : prendre le funiculaire vers Capri ou le bus vers Anacapri - dix fois moins cher.",
  "La Piazzetta est chère mais un apéritif y est presque obligatoire : s'installer, profiter du spectacle.",
  "Les Jardins d'Auguste (entrée ~1 €) offrent la vue carte postale sur les Faraglioni - gratuit avant 10h.",
];
---

<BaseLayout
  title="Capri 2026 : Guide Complet | Grotte Bleue, Faraglioni & Piazzetta"
  description="Guide complet de Capri : Grotte Bleue, Faraglioni, Piazzetta, Villa San Michele, Monte Solaro. Comment y aller depuis Naples et Sorrente, horaires des ferries, que voir."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/capri-hero.jpg" alt="Capri, golfe de Naples" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Île · Golfe de Naples · Pas de voitures privées</p>
        <h1 class="font-serif text-display text-white mb-4">Capri</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Une île calcaire qui surgit de la Méditerranée avec une force visuelle sans égale. La Grotte Bleue qui illumine l'eau en bleu électrique, les Faraglioni qui s'élancent vers le ciel, la Piazzetta où le monde a rendez-vous depuis un siècle. Capri ne déçoit jamais.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#infos-pratiques" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Infos pratiques
          </a>
          <a href="#comment-venir" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Comment y aller
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <!-- Intro -->
        <div>
          <p class="text-xl leading-relaxed text-charcoal">
            Capri est probablement l'île la plus célèbre d'Italie. Empereurs romains, intellectuels du XXe siècle, stars hollywoodiennes - tous ont succombé à son charme. Ce n'est pas une destination bon marché, ni une destination calme en été - mais une expérience qui reste gravée.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            L'île est divisée en deux communes : Capri (en bas, plus glamour) et Anacapri (en haut, plus calme). Marina Grande est le port principal. De là, le funiculaire ou un taxi vous conduit au centre en quelques minutes. Sans voitures, on se déplace à pied, en bus ou en taxi découvert - ce qui contribue énormément au charme de l'endroit.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Le saviez-vous ?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">27 av. J.-C.</p>
              <p class="text-white/60 text-xs italic mt-1">Auguste acheta Capri à Naples</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">12</p>
              <p class="text-white/60 text-xs italic mt-1">villas impériales romaines sur l'île</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">10 000+</p>
              <p class="text-white/60 text-xs italic mt-1">visiteurs par jour en août</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            La Grotte Bleue était déjà connue des Romains sous le nom de « bain de Tibère ». Elle fut redécouverte par des artistes européens en 1826 et est depuis l'une des attractions les plus visitées d'Italie.
          </p>
        </div>

        <!-- What to See -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Que voir à Capri</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Grotte Bleue (Grotta Azzurra)',
                text: "La grotte marine la plus célèbre de Méditerranée : la lumière solaire filtre par une ouverture sous-marine et illumine l'eau d'un bleu électrique irréel. On entre allongé dans de minuscules barques à rames. Entrée ~14 €. Accessible en bateau depuis Marina Grande ou à pied (puis en barque). Fermée par mauvaise mer.",
              },
              {
                n: 2,
                title: 'Les Faraglioni',
                text: "Les trois grands rochers qui s'élèvent de la mer à l'est de l'île sont le symbole absolu de Capri. À admirer depuis les Jardins d'Auguste, le belvédère de Punta Tragara, ou de près lors d'une excursion en bateau. Le bateau passe sous l'arche naturelle du Faraglione central - un moment inoubliable.",
              },
              {
                n: 3,
                title: 'La Piazzetta (Piazza Umberto I)',
                text: "Le salon du monde : quatre terrasses de café, le clocher, les marches de l'église Santo Stefano. Un apéritif ici est cher (~8–12 €) mais s'asseoir à la Piazzetta est un rite incontournable. Elle s'anime encore plus le soir.",
              },
              {
                n: 4,
                title: 'Villa San Michele (Anacapri)',
                text: "Construite à la fin du XIXe siècle par le médecin suédois Axel Munthe sur les ruines d'une villa de Tibère, c'est l'un des jardins les plus romantiques d'Italie. La vue sur la côte et le golfe de Naples depuis le belvédère est extraordinaire. Entrée ~8 €. Ouvert toute l'année.",
              },
              {
                n: 5,
                title: 'Monte Solaro (Anacapri)',
                text: "Le point culminant de l'île (589 m), accessible en télésiège depuis Anacapri (~15 min, ~12 € aller-retour). Panorama à 360° sur Capri, Ischia, Procida, la côte et le Vésuve. Au sommet : silence absolu, un café et le sanctuaire de la Madonna del Soccorso. À ne pas manquer.",
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to Get Here -->
        <div id="comment-venir" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Comment aller à Capri</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Capri n'a ni pont ni aéroport. Le seul moyen d'y arriver est par mer - ferry ou hydroglisseur depuis Naples, Sorrente, Positano et Amalfi (ces deux derniers en saison).</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Depuis Naples</h3><p class="text-white/50 text-sm leading-relaxed">Hydroglisseur ~40 min (NLG, Alilauro) ou ferry ~50 min (Caremar, SNAV) depuis Molo Beverello. Plusieurs départs quotidiens, toute l'année.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Depuis Sorrente</h3><p class="text-white/50 text-sm leading-relaxed">Hydroglisseur uniquement ~20–25 min. L'option la plus rapide et la plus pratique si vous êtes déjà sur la péninsule sorrentine.</p></div>
              </div>
            </div>
            <a href="/fr-fr/guide/ferries/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Guide complet des ferries
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Ferry Schedules -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4">Horaires des hydroglisseurs - Été 2026</h3>
          <p class="text-sm text-slate-500 mb-4">Services toute l'année depuis Naples ; liaisons fréquentes depuis Sorrente en été. Vérifier sur les sites officiels des compagnies.</p>

          <div class="overflow-x-auto rounded-2xl border border-slate-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Hydroglisseurs - Naples Beverello → Marina Grande, Capri
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Départ Naples</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivée Capri</th>
                  <th class="text-left px-4 py-3 font-semibold">Compagnie</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['07:15', '07:55', 'NLG'],
                  ['08:00', '08:40', 'Alilauro'],
                  ['09:15', '09:55', 'NLG'],
                  ['10:30', '11:10', 'SNAV'],
                  ['12:00', '12:40', 'NLG'],
                  ['14:30', '15:10', 'Alilauro'],
                  ['16:00', '16:40', 'NLG'],
                ].map(([dep, arr, co]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{co}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Hydroglisseurs - Sorrente → Marina Grande, Capri
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Départ Sorrente</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivée Capri</th>
                  <th class="text-left px-4 py-3 font-semibold">Durée</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['08:00', '08:25', '~25 min'],
                  ['09:30', '09:55', '~25 min'],
                  ['11:00', '11:25', '~25 min'],
                  ['13:30', '13:55', '~25 min'],
                  ['15:30', '15:55', '~25 min'],
                  ['17:30', '17:55', '~25 min'],
                ].map(([dep, arr, dur]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{dur}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Horaires indicatifs pour l'été 2026. Vérifier sur nlg.it, alilauro.it, snav.it.</p>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Les coins cachés de Capri</h2>
          <p class="text-slate-500 mb-8">Au-delà des cartes postales : quatre endroits que le touriste de passage ne trouve jamais.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Arco Naturale', text: "Une arche calcaire à 185 m au-dessus de la mer, accessible à pied depuis le centre de Capri en 40 minutes. Presque pas de files d'attente, vues spectaculaires sur la mer est. Le chemin passe devant la Villa Malaparte (photographiable de l'extérieur)." },
              { title: 'Belvédère Punta Cannone', text: "Un belvédère peu connu derrière la Certosa di San Giacomo avec une vue directe sur les Faraglioni. Gratuit, sans file d'attente, accessible à pied en 10 minutes depuis la Piazzetta. La photo des Faraglioni de là surpasse celle des Jardins d'Auguste." },
              { title: 'Grotta di Matromania', text: "Une grotte antique consacrée aux nymphes, plus tard transformée en nymphée romain. Accessible à pied depuis l'Arco Naturale en 15 minutes. Presque pas de touristes. À proximité se trouve la Villa Malaparte, l'iconique maison rouge sur la falaise." },
              { title: 'Bagni di Tiberio', text: "Les vestiges de la villa maritime de Tibère sur la côte nord de Capri, accessibles en bateau depuis Marina Grande ou à pied en 20 minutes. Entrée gratuite. Dans la baie voisine, on peut nager dans une eau d'une clarté exceptionnelle." },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Conseil local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Comment éviter les foules à Capri</h3>
              <p class="text-white/70 leading-relaxed">Prendre le tout premier hydroglisseur du matin (7h–7h30). À 8h30, vous êtes déjà à la Grotte Bleue sans file d'attente. Au moment où les excursionnistes débarquent à 10h, vous aurez déjà vu le meilleur de l'île avant de monter à Anacapri déjeuner tranquillement.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Questions fréquentes sur Capri</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <div id="infos-pratiques" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Infos pratiques - Capri</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Conseils locaux</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
