---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Îles', url: '/fr-fr/iles/' },
  { name: 'Ischia', url: '/fr-fr/iles/ischia/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment aller de Naples à Ischia ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Depuis Naples Molo Beverello, des ferries (Caremar, Medmar, ~75 min) et des hydroglisseurs (~50 min) partent tout au long de la journée. Depuis Pozzuoli, les ferries Caremar prennent ~35 min et sont l'option la moins chère. En été, réservez votre billet retour à l'avance, surtout le dimanche." }
    },
    {
      "@type": "Question",
      "name": "Les parcs thermaux d'Ischia sont-ils gratuits ?",
      "acceptedAnswer": { "@type": "Answer", "text": "La plupart des parcs thermaux sont payants (15–35 € par personne pour une journée complète). Les plus célèbres sont Negombo, Poseidon et les Terme di Citara. Il existe aussi des sources thermales naturelles gratuites, comme la plage thermale de Sant'Angelo où la mer est réchauffée par l'activité volcanique." }
    },
    {
      "@type": "Question",
      "name": "Le Château Aragonais d'Ischia vaut-il le détour ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolument. Le Château Aragonais est l'un des châteaux médiévaux les mieux conservés d'Italie, construit sur un îlot rocheux relié à Ischia Ponte par un pont de pierre. À l'intérieur : une cathédrale, un cimetière monastique, des jardins et une terrasse panoramique extraordinaire. Entrée ~12 €." }
    },
    {
      "@type": "Question",
      "name": "Ischia est-elle mieux que Capri ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Cela dépend de vos préférences. Capri est plus glamour, exclusive et chère. Ischia est plus grande, plus verte, avec des thermes naturels, des plages de sable noir et une atmosphère moins élitiste. Pour les familles et les amoureux de la nature et de la détente, Ischia est souvent le meilleur choix. Pour le glamour et les panoramas iconiques, Capri l'emporte." }
    },
    {
      "@type": "Question",
      "name": "Combien de jours faut-il pour visiter Ischia ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ischia est grande (46 km²) et mérite au moins 2–3 jours. En un jour, on peut voir Ischia Ponte, le Château Aragonais et un parc thermal. Avec 2 jours, ajoutez Sant'Angelo, la plage de Maronti et la randonnée au Monte Epomeo." }
    }
  ]
};

const fastFacts = [
  { dt: 'Situation',      dd: 'Golfe de Naples, NA' },
  { dt: 'Superficie',     dd: '46,3 km²' },
  { dt: 'Population',     dd: '~62 000 habitants' },
  { dt: 'Volcan',         dd: 'Epomeo (789 m)' },
  { dt: 'Depuis Naples',  dd: '50–75 min' },
  { dt: 'Depuis Pozzuoli', dd: '~35 min (ferry)' },
  { dt: 'Plages',         dd: 'Sable volcanique noir' },
  { dt: 'Thermes',        dd: 'Naturels & parcs thermaux' },
  { dt: 'Monnaie',        dd: 'Euro (€)' },
];

const tips = [
  "Réserver le parc thermal à l'avance : Negombo et Poseidon affichent complet rapidement en juillet-août.",
  "Louer un scooter ou une petite voiture : les bus locaux existent mais sont lents et bondés en été.",
  "Visiter Sant'Angelo en soirée : ce village sans voiture est le plus magique au coucher du soleil.",
  "Gravir le Monte Epomeo tôt le matin (départ avant 7h) : la vue au sommet vaut chaque pas et on évite la chaleur.",
];
---

<BaseLayout
  title="Ischia 2026 : Guide Complet | Thermes, Château & Plages"
  description="Guide complet d'Ischia : Château Aragonais, parcs thermaux, plage de Maronti, Monte Epomeo. Comment y aller depuis Naples et Pozzuoli, horaires des ferries, que voir."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/ischia-hero.jpg" alt="Ischia, golfe de Naples" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Île volcanique · Golfe de Naples · Parcs thermaux naturels</p>
        <h1 class="font-serif text-display text-white mb-4">Ischia</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          L'île verte du golfe : d'origine volcanique, riche en sources thermales, dense en histoire. Ischia offre une expérience différente de Capri — plus sauvage, plus authentique, avec des plages de sable noir, un château médiéval perché sur la mer et le silence du Monte Epomeo à 789 mètres.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#infos-pratiques" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Infos pratiques
          </a>
          <a href="#comment-venir" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Comment y aller
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <!-- Intro -->
        <div>
          <p class="text-xl leading-relaxed text-charcoal">
            Ischia est la plus grande des trois îles du golfe de Naples — et, pour de nombreux voyageurs, la plus enrichissante pour un séjour prolongé. Contrairement à Capri, qui s'épuise en une journée, Ischia récompense ceux qui restent : un parc thermal différent chaque matin, un long déjeuner dans un village de pêcheurs, une randonnée jusqu'à un sommet volcanique avec vue sur le Vésuve.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            L'île compte six communes, chacune avec son caractère propre : l'animée Ischia Porto, la médiévale Ischia Ponte, la détendue Sant'Angelo, la calme Lacco Ameno. Louer un scooter ou une petite voiture est la meilleure façon de toutes les explorer.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Le saviez-vous ?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">100+</p>
              <p class="text-white/60 text-xs italic mt-1">sources thermales naturelles sur l'île</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">789 m</p>
              <p class="text-white/60 text-xs italic mt-1">altitude du Monte Epomeo, sommet volcanique</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">474 av. J.-C.</p>
              <p class="text-white/60 text-xs italic mt-1">première colonie grecque sur l'île (Pithecusa)</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Ischia fut le site de la première colonie grecque en Méditerranée occidentale. Le nom « Ischia » proviendrait du latin « Iscla » (île) ou du mot grec désignant le tuf volcanique qui compose une grande partie de l'île.
          </p>
        </div>

        <!-- What to See -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Que voir à Ischia</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Château Aragonais (Castello Aragonese)',
                text: "L'un des châteaux médiévaux les mieux conservés du sud de l'Italie, construit sur un îlot rocheux relié à Ischia Ponte par un pont de pierre. À l'intérieur : une cathédrale, un cimetière monastique, des jardins et une terrasse panoramique spectaculaire. Entrée ~12 €. Prévoir 2–3 heures.",
              },
              {
                n: 2,
                title: 'Parcs thermaux',
                text: "Les parcs thermaux d'Ischia sont son plus grand trésor. Negombo (Lacco Ameno) est le plus beau, dans un jardin botanique face à la mer. Poseidon (Forio) est le plus grand avec 22 bassins. Les Terme di Citara (Forio) sont les plus abordables. Réserver en ligne au moins un jour à l'avance en été.",
              },
              {
                n: 3,
                title: 'Monte Epomeo',
                text: "Le sommet volcanique à 789 m offre un panorama à 360° sur tout le golfe de Naples, le Vésuve et, par temps clair, la Côte Amalfitaine. La randonnée depuis Fontana dure environ 1h30 à l'aller. La dernière partie est raide mais sur un chemin muletier bien entretenu. Un petit café attend au sommet.",
              },
              {
                n: 4,
                title: "Sant'Angelo",
                text: "Un village de pêcheurs sans voiture sur la côte sud, avec des maisons colorées sur une étroite presqu'île reliée à l'île par une plage de sable. Le village le plus atmosphérique d'Ischia — déjeuner au bord de l'eau, explorer les boutiques, nager depuis les rochers sous la presqu'île.",
              },
              {
                n: 5,
                title: 'Plage de Maronti',
                text: "La plus longue plage d'Ischia (près de 2 km) avec du sable volcanique sombre et de l'eau thermale chaude qui jaillit du sol par endroits. L'extrémité est près de Sant'Angelo n'est accessible qu'en taxi nautique (quelques euros bien dépensés). Très fréquentée en été — arriver tôt.",
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-slate-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to Get Here -->
        <div id="comment-venir" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Comment aller à Ischia</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Ischia est accessible en ferry et hydroglisseur depuis Naples (Beverello et Mergellina) et depuis Pozzuoli. L'option Pozzuoli est souvent plus rapide, moins chère et moins fréquentée.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Depuis Naples</h3><p class="text-white/50 text-sm leading-relaxed">Ferry ~75 min (Caremar, Medmar) ou hydroglisseur ~50 min. Depuis Molo Beverello et Mergellina. Liaisons quotidiennes fréquentes, toute l'année.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Depuis Pozzuoli</h3><p class="text-white/50 text-sm leading-relaxed">Ferry Caremar ~35 min. L'option la plus économique — traversée plus courte, tarifs moins élevés et départs fréquents. Recommandé pour les excursionnistes à la journée.</p></div>
              </div>
            </div>
            <a href="/fr-fr/guide/ferries/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Guide complet des ferries
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Ferry Schedules -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4">Horaires des ferries — Été 2026</h3>
          <p class="text-sm text-slate-500 mb-4">Services toute l'année depuis Naples et Pozzuoli. En été les départs sont très fréquents. Vérifier sur caremar.it et medmar.it.</p>

          <div class="overflow-x-auto rounded-2xl border border-slate-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Ferry — Naples Beverello → Ischia Porto
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Départ Naples</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivée Ischia</th>
                  <th class="text-left px-4 py-3 font-semibold">Compagnie</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['06:00', '07:15', 'Caremar'],
                  ['08:00', '09:15', 'Medmar'],
                  ['10:00', '11:15', 'Caremar'],
                  ['12:00', '13:15', 'Medmar'],
                  ['14:30', '15:45', 'Caremar'],
                  ['17:00', '18:15', 'Medmar'],
                  ['19:30', '20:45', 'Caremar'],
                ].map(([dep, arr, co]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{co}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Ferry — Pozzuoli → Ischia Porto (Caremar, ~35 min)
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Départ Pozzuoli</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivée Ischia</th>
                  <th class="text-left px-4 py-3 font-semibold">Durée</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                {[
                  ['05:30', '06:05', '~35 min'],
                  ['08:00', '08:35', '~35 min'],
                  ['10:30', '11:05', '~35 min'],
                  ['13:00', '13:35', '~35 min'],
                  ['15:30', '16:05', '~35 min'],
                  ['18:00', '18:35', '~35 min'],
                  ['20:30', '21:05', '~35 min'],
                ].map(([dep, arr, dur]) => (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{dep}</td>
                    <td class="px-4 py-3 font-mono">{arr}</td>
                    <td class="px-4 py-3 text-slate-500">{dur}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Horaires indicatifs pour l'été 2026. Vérifier sur caremar.it et medmar.it.</p>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Les coins méconnus d'Ischia</h2>
          <p class="text-slate-500 mb-8">Loin des grandes stations balnéaires, Ischia cache des endroits extraordinaires.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Jardins La Mortella', text: "Créés en 1956 par le compositeur William Walton et son épouse Susana, cet extraordinaire jardin botanique de Forio abrite plus de 1 000 espèces de plantes rares et exotiques. L'un des plus beaux jardins privés d'Italie. Entrée ~14 €. Ouvert du mardi au dimanche, d'avril à novembre." },
              { title: 'Spiaggia dei Pescatori (Ischia Ponte)', text: "Une petite plage juste à côté du Château Aragonais, fréquentée surtout par les locaux. Presque pas de touristes. La vue sur le château depuis l'eau au coucher du soleil est spectaculaire. Gratuit, petit et souvent ignoré des guides." },
              { title: "Plage thermale gratuite de Sant'Angelo", text: "Près du village de Sant'Angelo, des sources hydrothermales volcaniques réchauffent l'eau de mer sur un tronçon de plage précis. On peut profiter d'un bain thermal naturel gratuitement — apporter une serviette et éviter les heures de pointe (avant 9h ou après 17h)." },
              { title: 'Lacco Ameno et Villa Arbusto', text: "La commune la plus élégante d'Ischia, avec le célèbre Fungo (rocher en forme de champignon) dans la mer et le musée Villa Arbusto, qui abrite la collection archéologique Pithecusa — trouvailles de la première colonie grecque en Méditerranée occidentale." },
            ].map(({ title, text }) => (
              <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Local Tip -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Conseil local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Prendre le ferry depuis Pozzuoli</h3>
              <p class="text-white/70 leading-relaxed">La plupart des touristes prennent le ferry depuis Naples Beverello. Les locaux utilisent Pozzuoli : la traversée est 35 minutes plus courte, le billet coûte moins cher et il y a toujours des places. Depuis Naples, prendre la ligne 2 du métro jusqu'à Pozzuoli : on est au port en 20 minutes.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Questions fréquentes sur Ischia</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">

        <div id="infos-pratiques" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Infos pratiques — Ischia</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Conseils locaux</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
