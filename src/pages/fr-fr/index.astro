---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocalePath } from '../../i18n/translations';
import { homeContent } from '../../i18n/content';

const lang = 'fr-fr';
const t = getTranslations(lang);
const content = homeContent[lang];
---

<BaseLayout
  title={t.meta.home_title}
  description={t.meta.home_description}
  lang={lang}
  pageKey="home"
>
  <section class="relative bg-gradient-to-br from-sea-700 via-sea-600 to-teal-500 text-white overflow-hidden">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36 text-center">
      <p class="text-sea-100 text-sm font-medium uppercase tracking-widest mb-4">Patrimoine mondial de l'UNESCO</p>
      <h1 class="text-4xl md:text-6xl font-bold font-serif leading-tight mb-6">{t.hero.title}</h1>
      <p class="text-lg md:text-xl text-sea-100 max-w-3xl mx-auto leading-relaxed mb-10">{t.hero.subtitle}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={getLocalePath(lang, 'destinations')} class="inline-block bg-white text-sea-700 font-semibold px-8 py-3 rounded-full hover:bg-sea-50 transition-colors shadow-lg">{t.hero.cta}</a>
        <a href={getLocalePath(lang, 'itineraries')} class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-full hover:bg-white/10 transition-colors">{t.hero.cta_secondary}</a>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="white"/></svg>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
    <p class="text-lg text-gray-600 leading-relaxed">{content.intro}</p>
  </section>

  <section class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold font-serif text-gray-900 text-center mb-3">{t.sections.featured_towns}</h2>
      <p class="text-center text-gray-500 mb-12">Des villages de pêcheurs aux retraites perchées — découvrez chaque facette de la côte</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {content.towns.map(town => (
          <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 hover:shadow-md transition-shadow">
            <div class="w-10 h-10 bg-sea-100 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-sea-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-1">{town.name}</h3>
            <p class="text-sea-600 text-sm font-medium mb-3">{town.tagline}</p>
            <p class="text-gray-600 text-sm leading-relaxed">{town.description}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={getLocalePath(lang, 'destinations')} class="inline-block bg-sea-600 text-white font-semibold px-8 py-3 rounded-full hover:bg-sea-700 transition-colors">{t.sections.explore_more}</a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold font-serif text-gray-900 text-center mb-12">{t.sections.why_visit}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {content.why_visit.map((item, i) => (
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 bg-amalfi-lemon rounded-xl flex items-center justify-center text-amalfi-terracotta font-bold text-lg">{i + 1}</div>
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-gray-600 leading-relaxed">{item.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-sea-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold font-serif text-gray-900 text-center mb-12">{t.sections.top_beaches}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {content.beaches.map(beach => (
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-sea-100">
            <div class="text-2xl mb-3">🏖️</div>
            <h3 class="font-bold text-gray-900 mb-1">{beach.name}</h3>
            <p class="text-sea-600 text-xs font-medium mb-2">{beach.location} · {beach.type}</p>
            <p class="text-gray-600 text-sm">{beach.description}</p>
            <p class="mt-2 text-xs text-gray-400">Idéal pour : {beach.bestFor}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href={getLocalePath(lang, 'beaches')} class="inline-block bg-sea-600 text-white font-semibold px-8 py-3 rounded-full hover:bg-sea-700 transition-colors">{t.sections.read_more}</a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold font-serif text-gray-900 mb-4">{t.sections.plan_your_trip}</h2>
      <p class="text-gray-600 mb-8">Tout ce qu'il vous faut pour planifier le voyage parfait sur la Côte Amalfitaine.</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href={getLocalePath(lang, 'getting-here')} class="block p-6 bg-white border-2 border-sea-100 rounded-2xl hover:border-sea-400 transition-colors text-left">
          <div class="text-2xl mb-2">✈️</div>
          <h3 class="font-bold text-gray-900">{t.nav.getting_here}</h3>
          <p class="text-sm text-gray-500 mt-1">Trains, ferries & transferts</p>
        </a>
        <a href={getLocalePath(lang, 'itineraries')} class="block p-6 bg-white border-2 border-sea-100 rounded-2xl hover:border-sea-400 transition-colors text-left">
          <div class="text-2xl mb-2">🗺️</div>
          <h3 class="font-bold text-gray-900">{t.nav.itineraries}</h3>
          <p class="text-sm text-gray-500 mt-1">1 jour, 3 jours, 1 semaine</p>
        </a>
        <a href={getLocalePath(lang, 'when-to-visit')} class="block p-6 bg-white border-2 border-sea-100 rounded-2xl hover:border-sea-400 transition-colors text-left">
          <div class="text-2xl mb-2">📅</div>
          <h3 class="font-bold text-gray-900">{t.nav.when_to_visit}</h3>
          <p class="text-sm text-gray-500 mt-1">Guide mois par mois</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
