---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": "Côte Amalfitaine",
    "alternateName": "Costiera Amalfitana",
    "description": "Patrimoine mondial de l'UNESCO, 50 km de falaises sur la mer Tyrrhénienne en Campanie, Italie.",
    "url": "https://amalficoast-travel.com/fr-fr/",
    "geo": { "@type": "GeoCoordinates", "latitude": "40.634", "longitude": "14.602" },
    "containedInPlace": { "@type": "Country", "name": "Italy" }
  }
];

const silos = [
  {
    title: 'Côte Amalfitaine',
    subtitle: '50 km de falaises UNESCO',
    href: '/fr-fr/cote-amalfitaine/',
    borghi: ['Positano', 'Amalfi', 'Ravello', 'Praiano', 'Maiori', 'Minori'],
    img: '/images/costiera-hero.jpg',
  },
  {
    title: 'Péninsule Sorrentine',
    subtitle: 'La porte du sud de l\'Italie',
    href: '/fr-fr/destinations/',
    borghi: ['Sorrento', 'Vico Equense', 'Massa Lubrense', "Sant'Agnello"],
    img: '/images/sorrento-hero.jpg',
  },
  {
    title: 'Îles du Golfe',
    subtitle: 'Capri, Ischia, Procida',
    href: '/fr-fr/iles/',
    borghi: ['Capri', 'Ischia', 'Procida'],
    img: '/images/capri-hero.jpg',
  },
];

const borghi = [
  {
    name: 'Positano',
    subtitle: 'La carte postale vivante',
    description: 'Célèbre pour ses maisons aux couleurs pastel qui défient la gravité, ses boutiques de luxe et ses plages iconiques.',
    img: '/images/positano-hero.jpg',
    href: '/fr-fr/cote-amalfitaine/positano/',
    tags: ['Iconique', 'Mode', 'Spiaggia Grande'],
  },
  {
    name: 'Amalfi',
    subtitle: 'L\'ancienne République Maritime',
    description: 'Le cœur historique de la côte, dominé par la majestueuse cathédrale Sant\'Andrea et les anciennes papeteries.',
    img: '/images/amalfi-hero.jpg',
    href: '/fr-fr/cote-amalfitaine/amalfi/',
    tags: ['Histoire', 'Cathédrale', 'Piazza'],
  },
  {
    name: 'Ravello',
    subtitle: 'La cité de la musique',
    description: 'Suspendue entre ciel et mer, elle offre les panoramas les plus spectaculaires depuis ses villas historiques et ses jardins enchantés.',
    img: '/images/ravello-hero.jpg',
    href: '/fr-fr/cote-amalfitaine/ravello/',
    tags: ['Musique', 'Villa Cimbrone', 'Panoramas'],
  },
  {
    name: 'Praiano',
    subtitle: 'Le village des couchers de soleil',
    description: 'Une oasis de tranquillité avec des vues à couper le souffle et une scène artistique locale vivante entre mer et montagnes.',
    img: '/images/praiano-hero.jpg',
    href: '/fr-fr/cote-amalfitaine/praiano/',
    tags: ['Couchers de soleil', 'Détente', 'Marina di Praia'],
  },
  {
    name: 'Maiori',
    subtitle: 'La plus longue plage',
    description: 'Le front de mer le plus étendu de la Côte - authentique, moins fréquenté, avec les vestiges d\'une villa romaine.',
    img: '/images/maiori-hero.jpg',
    href: '/fr-fr/cote-amalfitaine/maiori/',
    tags: ['Plage', 'Détente', 'Authenticité'],
  },
  {
    name: 'Minori',
    subtitle: 'L\'âme gastronomique',
    description: 'Réputée pour le limoncello, les pâtes fraîches et les vestiges d\'une villa romaine face à la mer.',
    img: '/images/minori-hero.jpg',
    href: '/fr-fr/cote-amalfitaine/minori/',
    tags: ['Gastronomie', 'Villa Romaine', 'Citrons'],
  },
];

const topBeaches = [
  { name: 'Spiaggia Grande', location: 'Positano' },
  { name: 'Marina di Praia', location: 'Praiano' },
  { name: 'Plage de Maiori', location: 'Maiori' },
  { name: 'Plage de Minori', location: 'Minori' },
];

const editorial = [
  { label: 'Guide', title: 'Quand visiter la Côte Amalfitaine', subtitle: 'Mois par mois : météo, affluence et prix', href: '/fr-fr/quand-visiter/' },
  { label: 'Itinéraires', title: 'De 1 jour à 1 semaine', subtitle: 'Les meilleures routes prêtes à suivre', href: '/fr-fr/itineraires/' },
  { label: 'Plages', title: 'Les 8 plus belles plages', subtitle: 'De Positano à Cetara', href: '/fr-fr/plages/' },
  { label: 'Transport', title: 'Comment y aller et se déplacer', subtitle: 'Ferries, bus SITA, voiture', href: '/fr-fr/comment-venir/' },
];
---

<BaseLayout
  title="Guide de la Côte Amalfitaine 2026 - Positano, Amalfi, Ravello"
  description="Guide de voyage complet sur la Côte Amalfitaine. Villages, plages, ferries, itinéraires et conseils pratiques. Patrimoine mondial UNESCO en Campanie, Italie."
  lang={lang}
  schema={schema}
>

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center justify-center bg-charcoal overflow-hidden">
    <img src="/images/hero-hp.jpg" alt="Côte Amalfitaine vue du ciel" referrerpolicy="no-referrer" class="absolute inset-0 w-full h-full object-cover object-center" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/30 to-black/65"></div>

    <div class="relative text-center px-6 max-w-4xl mx-auto">
      <p class="text-med-gold text-xs font-medium uppercase tracking-[0.3em] mb-6">Patrimoine mondial UNESCO · Campanie, Italie</p>
      <h1 class="font-serif text-white leading-tight mb-6" style="font-size: clamp(2.8rem, 7vw, 5.5rem); letter-spacing: -0.02em;">
        La Côte<br/>
        <em class="not-italic text-med-gold">Amalfitaine</em>
      </h1>
      <p class="text-blue-100 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10 font-light">
        Cinquante kilomètres de falaises plongeant dans la mer Tyrrhénienne. Villages perchés, citrons géants,
        ferries colorés et une Italie qui ne cesse de surprendre.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/fr-fr/cote-amalfitaine/positano/"
           class="inline-block bg-med-blue text-white font-semibold px-8 py-3.5 rounded-full hover:scale-105 hover:shadow-[0_8px_30px_rgba(0,91,150,0.5)] transition-all duration-300 text-sm">
          Commencer par Positano
        </a>
        <a href="/fr-fr/itineraires/"
           class="inline-block border-2 border-white/50 text-white font-medium px-8 py-3.5 rounded-full hover:bg-white/10 hover:border-white transition-all duration-300 text-sm">
          Choisir son itinéraire
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
      <span class="text-[10px] uppercase tracking-[0.3em]">Découvrir</span>
      <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- INTRO EDITORIALE -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium mb-4">Pourquoi ce lieu est unique</p>
        <h2 class="font-serif text-3xl md:text-4xl text-slate-900 tracking-tight leading-tight mb-6">
          Pas seulement une destination.<br/>Une expérience qui change votre regard sur la mer.
        </h2>
        <p class="text-slate-500 text-lg leading-relaxed font-light">
          La Côte Amalfitaine est l'un des littoraux les plus photographiés au monde - et pourtant, elle ne manque jamais de surprendre ceux qui la découvrent en personne. Le parfum des citrons, le bruit des ferries du matin, les ruelles trop étroites pour les voitures, les déjeuners qui s'étirent jusqu'au coucher du soleil. Ce guide ne vous dira pas seulement où aller - il vous aidera à comprendre comment la vivre vraiment.
        </p>
      </div>
    </div>
  </section>

  <!-- BORGHI INCANTATI -->
  <section id="villages" class="py-24 bg-med-cream">
    <div class="max-w-7xl mx-auto px-6">

      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div class="max-w-2xl">
          <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-3">Explorer la Côte</p>
          <h2 class="font-serif text-4xl md:text-5xl font-bold text-slate-900 tracking-tight mb-4">Les Villages Enchantés</h2>
          <p class="text-slate-500 text-lg font-light">Découvrez les joyaux du littoral, chacun avec son âme propre et ses traditions séculaires.</p>
        </div>
        <a href="/fr-fr/cote-amalfitaine/" class="group flex items-center gap-2 text-med-blue font-semibold hover:text-med-gold transition-colors flex-shrink-0">
          Toutes les destinations
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {borghi.map((b, i) => (
          <a href={b.href} class="group cursor-pointer fade-in-card" style={`animation-delay: ${i * 0.1}s`}>
            <div class="relative aspect-[4/5] overflow-hidden rounded-[3rem] mb-6 shadow-[0_20px_50px_rgba(0,0,0,0.3)]">
              <img
                src={b.img}
                alt={b.name}
                referrerpolicy="no-referrer"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />
              <div class="absolute bottom-8 left-8 right-8">
                <span class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2 block">{b.subtitle}</span>
                <h3 class="font-serif text-3xl font-bold text-white tracking-tight">{b.name}</h3>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed font-light mb-4">{b.description}</p>
            <div class="flex flex-wrap gap-2">
              {b.tags.map(tag => (
                <span class="text-[10px] uppercase tracking-wider font-bold text-med-blue bg-med-blue/5 px-3 py-1 rounded-full">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>

      <div class="mt-32">
        <div class="text-center mb-12">
          <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-3">Eaux cristallines</p>
          <h2 class="font-serif text-4xl font-bold text-slate-900 tracking-tight mb-4">Les Plus Belles Plages</h2>
          <div class="w-20 h-1 bg-med-gold mx-auto rounded-full"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {topBeaches.map((beach) => (
            <div class="bg-med-cream p-8 rounded-[2rem] shadow-sm border border-slate-100 text-center hover:shadow-xl transition-all duration-500 hover:scale-105">
              <h4 class="font-serif font-bold text-slate-900 mb-1">{beach.name}</h4>
              <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{beach.location}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- 3 SILOS -->
  <section class="bg-charcoal py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium mb-3">Explorer par région</p>
        <h2 class="font-serif text-3xl md:text-4xl text-white tracking-tight">Trois territoires, des histoires sans fin</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {silos.map(silo => (
          <a href={silo.href} class="group relative aspect-[4/5] overflow-hidden rounded-[3rem] shadow-[0_20px_50px_rgba(0,0,0,0.3)] block hover:scale-[1.02] transition-transform duration-500">
            <img
              src={silo.img}
              alt={silo.title}
              referrerpolicy="no-referrer"
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />
            <div class="absolute bottom-8 left-8 right-8">
              <span class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2 block">{silo.subtitle}</span>
              <h3 class="font-serif text-3xl font-bold text-white tracking-tight mb-3">{silo.title}</h3>
              <div class="flex flex-wrap gap-2">
                {silo.borghi.slice(0, 3).map(b => (
                  <span class="text-[10px] text-white/70 bg-white/10 px-2 py-0.5 rounded-full">{b}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- GRID EDITORIALE -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium mb-3">Guides pratiques</p>
          <h2 class="font-serif text-3xl md:text-4xl text-slate-900 tracking-tight">Tout ce qu'il vous faut</h2>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href={editorial[0].href} class="group lg:col-span-2 lg:row-span-2 bg-med-cream rounded-[2rem] p-10 shadow-sm border border-slate-100 hover:shadow-xl transition-all duration-500 flex flex-col justify-between min-h-72">
          <div>
            <span class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-bold">{editorial[0].label}</span>
            <h3 class="font-serif text-3xl md:text-4xl text-slate-900 tracking-tight mt-3 mb-3 group-hover:text-med-blue transition-colors leading-tight">{editorial[0].title}</h3>
            <p class="text-slate-400 font-light">{editorial[0].subtitle}</p>
          </div>
          <span class="text-sm font-medium text-med-blue flex items-center gap-1 mt-8">
            Lire le guide
            <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        {editorial.slice(1).map(item => (
          <a href={item.href} class="group bg-med-cream rounded-[2rem] p-8 shadow-sm border border-slate-100 hover:shadow-xl transition-all duration-500 hover:scale-[1.02]">
            <span class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-bold">{item.label}</span>
            <h3 class="font-serif text-xl text-slate-900 tracking-tight mt-2 mb-2 group-hover:text-med-blue transition-colors">{item.title}</h3>
            <p class="text-slate-400 text-sm mb-6 font-light">{item.subtitle}</p>
            <span class="text-sm font-medium text-med-blue flex items-center gap-1">
              Lire
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DID YOU KNOW -->
  <section class="bg-charcoal py-24">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium text-center mb-12">Le saviez-vous</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503-10.498 4.875 2.812M6.497 9.252 1.622 12.064m19.88 0-4.875 2.812M1.622 12.064l4.875 2.812m0 0 4.498 2.598a.75.75 0 0 0 .75 0l4.498-2.598m-9.746 0V17.25"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">50 km</div>
          <p class="text-white/70 font-medium mb-2">de littoral</p>
          <p class="text-white/50 text-sm leading-relaxed font-light">De Positano à Vietri sul Mare, inscrit au patrimoine mondial de l'UNESCO en 1997.</p>
        </div>
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">IXe s.</div>
          <p class="text-white/70 font-medium mb-2">naissance d'Amalfi</p>
          <p class="text-white/50 text-sm leading-relaxed font-light">Première puissance maritime d'Europe, avec des routes commerciales jusqu'à Constantinople.</p>
        </div>
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">350 m</div>
          <p class="text-white/70 font-medium mb-2">l'altitude de Ravello</p>
          <p class="text-white/50 text-sm leading-relaxed font-light">Wagner y écrivit Parsifal. Gore Vidal vécut à Ravello pendant trente ans.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- POSITANO SPOTLIGHT -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium mb-4">Commencer ici</p>
          <h2 class="font-serif text-4xl md:text-5xl text-slate-900 leading-tight tracking-tight mb-6">
            Positano.<br/><em class="not-italic text-slate-400">La carte postale vivante.</em>
          </h2>
          <p class="text-slate-500 leading-relaxed mb-6 font-light">
            Aucun endroit sur la côte n'est plus photographié que Positano, et pourtant aucune photo ne parvient vraiment à en capturer l'essence. Les maisons aux couleurs pastel, la Spiaggia Grande, les boutiques de sandales artisanales, le parfum du citron partout. Le guide complet vous dit comment y arriver, où se garer (si vous insistez), quand partent les ferries et où manger sans se ruiner.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <span class="text-xs px-3 py-1.5 bg-med-blue/5 text-med-blue rounded-full font-medium">ZTL active</span>
            <span class="text-xs px-3 py-1.5 bg-med-blue/5 text-med-blue rounded-full font-medium">Ferries depuis Naples</span>
            <span class="text-xs px-3 py-1.5 bg-med-blue/5 text-med-blue rounded-full font-medium">Sentier des Dieux</span>
          </div>
          <a href="/fr-fr/cote-amalfitaine/positano/"
             class="inline-block bg-med-blue text-white font-semibold px-8 py-3.5 rounded-full hover:scale-105 hover:shadow-[0_8px_30px_rgba(0,91,150,0.5)] transition-all duration-300 text-sm">
            Guide complet de Positano
          </a>
        </div>
        <div class="bg-med-cream rounded-[2rem] p-8 shadow-sm border border-slate-100 hover:shadow-xl transition-all duration-500">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Infos clés · Positano</p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: 'Altitude', value: '0–350 m' },
              { label: 'Population', value: '≈ 3 900' },
              { label: 'ZTL', value: 'Oui (été)' },
              { label: 'Accès', value: 'Ferry · Bus' },
              { label: 'Province', value: 'Salerne (SA)' },
              { label: 'Meilleure période', value: 'Mai · Sep' },
            ].map(f => (
              <div class="bg-white rounded-2xl p-4 border border-slate-100">
                <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 mb-1">{f.label}</p>
                <p class="font-semibold text-slate-900 text-sm">{f.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-in-card').forEach(el => observer.observe(el));
</script>

</BaseLayout>
