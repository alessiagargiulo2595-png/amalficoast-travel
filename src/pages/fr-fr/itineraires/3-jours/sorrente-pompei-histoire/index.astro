---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Itinéraires', url: '/fr-fr/itineraires/' },
  { name: 'Sorrente, Pompéi & Histoire - 3 jours', url: '/fr-fr/itineraires/3-jours/sorrente-pompei-histoire/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien de temps faut-il pour visiter Pompéi ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pour une visite approfondie, il faut au moins 3–4 heures. Une visite essentielle (Forum, Via dell'Abbondanza, Casa del Fauno, amphithéâtre) peut se faire en 2–2,5 heures. Arriver à l'ouverture (09h00) pour éviter la chaleur de l'après-midi et les files. Billet ~€18–20, gratuit pour les moins de 18 ans." }
    },
    {
      "@type": "Question",
      "name": "Vaut-il la peine de visiter Herculanum en plus de Pompéi ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, Herculanum est souvent préféré par les visiteurs expérimentés : plus petit que Pompéi (2h suffisent) mais mieux conservé car enseveli sous la boue plutôt que sous les cendres. Un billet combiné Pompéi + Herculanum existe. Avec 3 jours : visiter Herculanum l'après-midi du jour 2 et Pompéi le matin du jour 3." }
    }
  ]
};

const days = [
  {
    day: 'Jour 1',
    title: 'Sorrente',
    items: [
      'Arrivée à Sorrente en Circumvesuviana depuis Naples (70 min, ~€3,90).',
      'Vieille ville : Piazza Tasso, Cathédrale, Vallone dei Mulini (gorge volcanique au centre-ville).',
      'Museo Correale : artefacts romains et vues de Sorrente du XVIIIe siècle.',
      'Marina Grande : le port des pêcheurs, dîner avec vue.',
    ],
  },
  {
    day: 'Jour 2',
    title: 'Herculanum et Vésuve',
    items: [
      'Circumvesuviana vers Herculanum Scavi (20 min depuis Naples, 50 min depuis Sorrente).',
      'Site archéologique d\'Herculanum : conservation extraordinaire, 2–3 heures.',
      'Après-midi : bus/navette vers le Vésuve (cratère à 1 281 m, ~€12 + guide obligatoire). Vues sur le Golfe de Naples.',
      'Retour à Sorrente en Circumvesuviana.',
    ],
  },
  {
    day: 'Jour 3',
    title: 'Pompéi',
    items: [
      'Circumvesuviana vers Pompei Scavi – Villa dei Misteri (35 min depuis Naples, 45 min depuis Sorrente).',
      'Fouilles de Pompéi : Forum, Thermes, amphithéâtre, maisons patriciennes. Au moins 3h.',
      'Déjeuner dans la Pompéi moderne, puis visite du Musée du Trésor de San Gennaro (optionnel).',
      'Retour vers Naples ou Sorrente l\'après-midi.',
    ],
  },
];
---

<BaseLayout
  title="Sorrente, Pompéi et Herculanum en 3 Jours 2026 | Itinéraire Historique"
  description="Itinéraire de 3 jours alliant histoire et mer : Sorrente, Herculanum, Vésuve et Pompéi. Horaires Circumvesuviana, prix des billets et conseils pratiques."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/sorrento-hero.jpg" alt="Sorrente et Pompéi" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <a href="/fr-fr/itineraires/" class="hover:text-white transition-colors">Itinéraires</a>
        <span>/</span>
        <span class="text-white">Sorrente, Pompéi & Histoire</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinéraire · 3 jours</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrente, Pompéi & Histoire</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Trois jours d'archéologie et de Golfe de Naples : Sorrente comme base, Herculanum et le Vésuve le deuxième jour, Pompéi le troisième. Tout en train, sans voiture.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Durée</p>
          <p class="font-semibold text-charcoal">3 jours / 2 nuits</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base recommandée</p>
          <p class="font-semibold text-charcoal">Sorrente</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport clé</p>
          <p class="font-semibold text-charcoal">Circumvesuviana</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programme jour par jour</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Conseils pratiques</p>
      <ul class="space-y-2">
        {[
          'Pompéi et Herculanum : arriver à l\'ouverture (09h00). La chaleur de l\'après-midi et les files rendent la visite difficile.',
          'Billet combiné Pompéi + Herculanum : intéressant si vous visitez les deux le même jour ou les jours suivants.',
          'La Circumvesuviana est fréquente mais lente : Sorrente vers Pompei Scavi ~45 min, depuis Naples ~35 min.',
          'Vésuve : la navette part d\'Herculanum et Pompéi (vérifier les horaires saisonniers). Un guide est obligatoire.',
          'Sorrente le soir est magnifique : apéritif à la Marina Grande, dîner sur le corso principal.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
