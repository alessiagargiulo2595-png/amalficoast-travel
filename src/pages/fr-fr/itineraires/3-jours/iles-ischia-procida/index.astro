---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Itinéraires', url: '/fr-fr/itineraires/' },
  { name: 'Îles : Ischia & Procida — 3 jours', url: '/fr-fr/itineraires/3-jours/iles-ischia-procida/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Laquelle est la meilleure pour un week-end, Ischia ou Procida ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Tout dépend de ce que vous cherchez : Ischia est grande (46 km²), avec des thermes, des plages variées, des châteaux et une vie nocturne — il faut au moins 2 jours. Procida est petite (4 km²), authentique, avec des couleurs pastel iconiques, des pêcheurs et peu de foule. Avec 3 jours, vous pouvez passer 2 nuits à Ischia et faire une excursion à Procida." }
    },
    {
      "@type": "Question",
      "name": "Comment aller à Ischia et Procida depuis Naples ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Depuis Naples Beverello : hydrofoil vers Ischia Porto (~50 min, €20–24) ou ferry (~75 min, €12–14). Pour Procida : hydrofoil depuis Naples (~35 min, €15–18). Depuis Pozzuoli : ferry Medmar/Caremar pour Ischia et Procida, moins cher (~€10–13). Réserver en ligne en été." }
    }
  ]
};

const days = [
  {
    day: 'Jour 1',
    title: 'Arrivée à Ischia',
    items: [
      'Ferry ou hydrofoil depuis Naples Beverello vers Ischia Porto (50–75 min).',
      'Check-in. Après-midi : Ischia Ponte et le Château Aragonais (entrée ~€24, 2h).',
      'Plage de Maronti (la plus longue de l\'île, sable noir volcanique) ou apéritif à Forio.',
      'Dîner à Lacco Ameno ou Ischia Porto : cuisine ischitaine, lapin à l\'ischitaine.',
    ],
  },
  {
    day: 'Jour 2',
    title: 'Thermes et Plages',
    items: [
      'Matin : jardins thermaux (Poseidon ou Negombo, ~€35–40 entrée). Bassins thermaux, saunas.',
      'Après-midi : Plage de Citara (Forio), une des plus belles de l\'île.',
      'Coucher de soleil depuis le belvédère de Sant\'Angelo, le village le plus pittoresque d\'Ischia.',
      'Dîner à Sant\'Angelo ou retour à Ischia Porto.',
    ],
  },
  {
    day: 'Jour 3',
    title: 'Excursion à Procida',
    items: [
      'Hydrofoil d\'Ischia à Procida (20 min, ~€9). Premier service 08h00.',
      'Marina Corricella : le port des pêcheurs, maisons colorées en pastel, bar sur la jetée.',
      'Terra Murata : le village médiéval le plus haut de l\'île, vue sur le Golfe.',
      'Plage de Pozzo Vecchio (la plage du Facteur) pour une baignade à midi.',
      'Retour à Naples en hydrofoil depuis Procida (35 min).',
    ],
  },
];
---

<BaseLayout
  title="Ischia et Procida en 3 Jours 2026 | Îles du Golfe de Naples"
  description="Itinéraire de 3 jours entre Ischia et Procida : thermes, plages volcaniques, Marina Corricella et Château Aragonais. Comment y aller, où dormir et que voir."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/isole-hero.jpg" alt="Ischia et Procida, Golfe de Naples" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <a href="/fr-fr/itineraires/" class="hover:text-white transition-colors">Itinéraires</a>
        <span>/</span>
        <span class="text-white">Îles : Ischia & Procida</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinéraire · 3 jours</p>
        <h1 class="font-serif text-display text-white mb-4">Îles : Ischia & Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Deux îles, deux caractères opposés : Ischia grande et thermale, Procida petite et authentique. Un week-end parfait dans le Golfe de Naples, loin de la foule de la Côte Amalfitaine.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Durée</p>
          <p class="font-semibold text-charcoal">3 jours / 2 nuits</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base</p>
          <p class="font-semibold text-charcoal">Ischia Porto ou Forio</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport</p>
          <p class="font-semibold text-charcoal">Hydrofoils + bus insulaire</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programme jour par jour</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Conseils pratiques</p>
      <ul class="space-y-2">
        {[
          'Sur Ischia le bus circulaire (CS/CD) circule toute la journée : ticket simple ~€1,50, pass journée ~€6.',
          'Réserver les jardins thermaux en ligne : Poseidon et Negombo sont complets en été.',
          'Procida en journée : prendre le premier hydrofoil (08h00) pour avoir le temps avant la foule.',
          'Ischia hors saison (octobre–novembre) : thermes ouverts, peu de touristes, prix bas.',
          'L\'hydrofoil ne circule pas par mer agitée : vérifier la météo avant de réserver.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
