---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Itinéraires', url: '/fr-fr/itineraires/' },
  { name: 'Côte Amalfitaine classique — 3 jours', url: '/fr-fr/itineraires/3-jours/cote-amalfitaine-classique/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Où dormir pour visiter la Côte Amalfitaine en 3 jours ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Les meilleures bases sont Amalfi (position centrale, bon choix d'hôtels et B&B, bien desservie par bus et ferries) ou Positano (plus romantique mais plus chère). Sorrente est idéale pour ceux qui veulent une ville plus pratique avec plus de services et des prix plus bas, avec des excursions à la journée vers la Côte." }
    },
    {
      "@type": "Question",
      "name": "3 jours sur la Côte : mieux en haute ou basse saison ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Mai–juin et septembre–octobre sont les meilleurs mois : climat parfait, moins de foule qu'en juillet–août, prix plus bas. En juillet–août les bus sont bondés, les parkings pleins et les plages surpeuplées. En hiver de nombreux établissements ferment mais les villages sont calmes et authentiques." }
    }
  ]
};

const days = [
  {
    day: 'Jour 1',
    title: 'Arrivée et Positano',
    items: [
      'Arrivée à Sorrente ou Amalfi. Check-in.',
      "Après-midi à Positano : Spiaggia Grande, via Cristoforo Colombo, église Santa Maria Assunta.",
      'Apéritif avec vue depuis le belvédère au-dessus du village.',
      'Dîner à Positano ou retour en bus à Amalfi.',
    ],
  },
  {
    day: 'Jour 2',
    title: 'Amalfi et Ravello',
    items: [
      'Matin : Cathédrale d\'Amalfi, Cloître du Paradis, Musée du Papier (papier amalfitain, XIIIe s.).',
      'Bus SITA pour Ravello (25 min). Villa Rufolo, Villa Cimbrone, panoramas sur la Côte.',
      'Déjeuner à Ravello, puis retour à Amalfi l\'après-midi.',
      'Dîner sur le port d\'Amalfi : poisson du jour, mozzarella de bufflonne.',
    ],
  },
  {
    day: 'Jour 3',
    title: 'Praiano et Grotte Émeraude',
    items: [
      'Matin : bus SITA vers Positano, arrêt à Praiano (promenade tranquille, plage Gavitella).',
      'Grotte Émeraude près de Conca dei Marini : entrée ~€5, lumière verte spectaculaire.',
      'Après-midi libre à Amalfi ou excursion en bateau (tour de la côte depuis Amalfi, ~€40–70 p.p.).',
      'Départ en fin d\'après-midi vers Naples/Salerne.',
    ],
  },
];
---

<BaseLayout
  title="Côte Amalfitaine en 3 Jours 2026 | Itinéraire Classique Complet"
  description="Itinéraire classique de 3 jours sur la Côte Amalfitaine : Positano, Amalfi, Ravello et Grotte Émeraude. Où dormir, que voir et comment se déplacer."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Côte Amalfitaine classique" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <a href="/fr-fr/itineraires/" class="hover:text-white transition-colors">Itinéraires</a>
        <span>/</span>
        <span class="text-white">Côte Amalfitaine classique — 3 jours</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinéraire · 3 jours</p>
        <h1 class="font-serif text-display text-white mb-4">Côte Amalfitaine Classique</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Trois jours pour voir le meilleur de la Côte : Positano, Amalfi, Ravello et la Grotte Émeraude. Le parcours classique, optimisé pour les transports en commun.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Durée</p>
          <p class="font-semibold text-charcoal">3 jours / 2 nuits</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base recommandée</p>
          <p class="font-semibold text-charcoal">Amalfi ou Positano</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport</p>
          <p class="font-semibold text-charcoal">Bus SITA + ferries</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programme jour par jour</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Conseils pour 3 jours sur la Côte</p>
      <ul class="space-y-2">
        {[
          'Base à Amalfi : position centrale, moins chère que Positano, excellentes liaisons bus et ferry.',
          'Acheter les tickets SITA en lot (tabac-bureau) à l\'arrivée : gain de temps chaque matin.',
          'Ravello n\'a pas de plages mais offre le plus beau belvédère de la Côte : prévoir au moins une demi-journée.',
          'Tour en bateau le jour 3 est optionnel mais transforme la journée : réserver la veille.',
          'En été : se déplacer avant 9h pour éviter les bus bondés et les files d\'attente.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
