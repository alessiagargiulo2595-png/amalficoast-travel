---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Itinéraires', url: '/fr-fr/itineraires/' },
  { name: 'Grand Tour — 7 jours', url: '/fr-fr/itineraires/7-jours/grand-tour-cote-peninsule/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment organiser 7 jours entre la Côte Amalfitaine et la Péninsule Sorrentine ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le parcours classique : 2 nuits à Naples (jours 1–2), puis Sorrente ou Amalfi comme base pour la Côte (jours 3–5), avec excursion à Capri (jour 4 ou 5), puis les îles en fin de séjour (jours 6–7). Bus SITA, Circumvesuviana et hydrofoils permettent de tout faire sans voiture." }
    },
    {
      "@type": "Question",
      "name": "Combien de nuits à Naples avant la Côte ?",
      "acceptedAnswer": { "@type": "Answer", "text": "1 à 2 nuits suffisent pour Naples : Spaccanapoli, Musée Archéologique National, pizza authentique, Certosa di San Martino. Avec 2 nuits on peut inclure Herculanum ou Pompéi en excursion à la journée. Naples est le point d'arrivée et de départ naturel pour toute la région." }
    }
  ]
};

const days = [
  { day: 'Jour 1', title: 'Naples', items: ['Arrivée à Naples. Spaccanapoli, centre historique UNESCO.', 'Musée Archéologique National : collections de Pompéi, mosaïques, bronzes.', 'Pizza authentique dans le quartier historique : Da Michele, Sorbillo ou Brandi.'] },
  { day: 'Jour 2', title: 'Pompéi ou Herculanum', items: ['Excursion en Circumvesuviana : fouilles d\'Herculanum (matin, 2–3h) + Vésuve (après-midi).', 'Alternative : Pompéi toute la journée (3–4h sur le site).', 'Retour à Naples pour le dîner.'] },
  { day: 'Jour 3', title: 'Sorrente et arrivée sur la Côte', items: ['Circumvesuviana Naples→Sorrente (70 min). Check-in Sorrente ou Amalfi.', 'Après-midi : centre de Sorrente, Vallone dei Mulini, Marina Grande.', 'Bus SITA vers Positano (optionnel, 50 min) : premier aperçu de la Côte.'] },
  { day: 'Jour 4', title: 'Capri', items: ['Hydrofoil de Sorrente à Capri (20–25 min). Premier départ 07h30.', 'Grotte Bleue tôt le matin. Anacapri et Monte Solaro en télésiège.', 'Faraglioni l\'après-midi. Apéritif sur la Piazzetta. Retour en soirée.'] },
  { day: 'Jour 5', title: 'Amalfi et Ravello', items: ['Bus SITA Sorrente→Amalfi (90 min) ou ferry Sorrente→Amalfi.', 'Cathédrale, Cloître du Paradis, Musée du Papier.', 'Bus pour Ravello (25 min) : Villa Rufolo, Villa Cimbrone. Dîner à Amalfi.'] },
  { day: 'Jour 6', title: 'Positano et tour en bateau', items: ['Bus SITA vers Positano (45 min depuis Amalfi). Matin libre sur la plage.', 'Tour en bateau depuis Positano (Grotte Émeraude, criques, ~€50–80, 4h).', 'Retour à Amalfi ou Positano. Dîner au bord du port.'] },
  { day: 'Jour 7', title: 'Ischia ou Procida et départ', items: ['Ferry Amalfi/Naples→Ischia ou Procida (excursion demi-journée).', 'Procida : Marina Corricella, Terra Murata, plage du Pozzo Vecchio.', 'Retour à Naples pour le départ.'] },
];
---

<BaseLayout
  title="Grand Tour Côte Amalfitaine 7 Jours 2026 | Naples, Capri, Positano, Amalfi"
  description="Itinéraire complet de 7 jours : Naples, Côte Amalfitaine, Capri et îles du Golfe. Pompéi, Sorrente, Positano, Amalfi, Ravello — le Grand Tour du sud de l'Italie."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Grand Tour Côte Amalfitaine" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <a href="/fr-fr/itineraires/" class="hover:text-white transition-colors">Itinéraires</a>
        <span>/</span>
        <span class="text-white">Grand Tour — 7 jours</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinéraire · 7 jours</p>
        <h1 class="font-serif text-display text-white mb-4">Grand Tour : Côte & Péninsule</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Une semaine pour tout voir : Naples, Pompéi, Sorrente, Capri, Positano, Amalfi, Ravello et une île. Le Grand Tour du Golfe de Naples — sans voiture, en transports en commun.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Durée</p>
          <p class="font-semibold text-charcoal">7 jours / 6 nuits</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Bases</p>
          <p class="font-semibold text-charcoal">Naples + Amalfi/Sorrente</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Transport</p>
          <p class="font-semibold text-charcoal">Train + bus + ferries</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Budget transport</p>
          <p class="font-semibold text-charcoal">~€80–120</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programme jour par jour</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Conseils pour le Grand Tour</p>
      <ul class="space-y-2">
        {[
          'Campania Express : billet journalier sur la Circumvesuviana (valable Naples–Sorrente–Pompéi–Herculanum) ~€10.',
          'Réserver Capri et la Grotte Bleue 1–2 jours à l\'avance en juillet–août.',
          'Changer de base en milieu de séjour : 2 nuits Naples + 3 nuits Amalfi/Sorrente + 1 nuit île (optionnel).',
          'Le tour en bateau est flexible : le reprogrammer selon les conditions de mer.',
          'Prévoir de bonnes chaussures pour les pavés de Naples et les escaliers de Positano.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
