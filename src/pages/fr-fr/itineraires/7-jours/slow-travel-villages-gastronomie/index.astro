---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Itinéraires', url: '/fr-fr/itineraires/' },
  { name: 'Slow Travel — 7 jours', url: '/fr-fr/itineraires/7-jours/slow-travel-villages-gastronomie/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qu'est-ce que le slow travel sur la Côte Amalfitaine ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le slow travel sur la Côte signifie rester plusieurs jours dans le même village plutôt que de bouger chaque jour, manger dans des restaurants locaux (pas touristiques), parcourir des sentiers peu connus, fréquenter le marché, acheter des produits locaux (citrons, anchois, vin rouge de Ravello). C'est le contraire de l'itinéraire all-inclusive." }
    },
    {
      "@type": "Question",
      "name": "Quels sont les villages les moins touristiques de la Côte Amalfitaine ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Les villages les moins fréquentés sont : Praiano (entre Positano et Amalfi, sans ZTL, plage calme), Cetara (célèbre pour la colatura d'anchois, authentique), Furore (le village qui n'existe pas, construit dans la gorge), Conca dei Marini (300 habitants, près de la Grotte Émeraude). Tous accessibles en bus SITA sur la SS163." }
    }
  ]
};

const days = [
  { day: 'Jour 1', title: 'Arrivée à Praiano', items: ['Praiano : le village central sans ZTL. Moins de touristes que Positano, prix plus bas.', 'Plage Gavitella : petite, belle, accessible à pied.', 'Dîner dans une trattoria du port : poisson du jour.'] },
  { day: 'Jour 2', title: 'Sentier des Dieux', items: ['Bus SITA vers Amalfi, puis Agerola (départ du sentier).', 'Sentier des Dieux (Agerola→Nocelle, 8 km, 3–4h, exigeant).', 'Retour à Praiano via Positano en bus SITA.'] },
  { day: 'Jour 3', title: 'Amalfi et Furore', items: ['Bus SITA vers Amalfi. Matin : marché du jeudi (produits locaux, mozzarella, citrons).', 'Furore : le Fiordo di Furore, arrêt à la demande sur le bus SITA. Le village dans la gorge.', 'Musée du Papier d\'Amalfi : papier artisanal fabriqué depuis le XIIIe siècle.'] },
  { day: 'Jour 4', title: 'Ravello et Scala', items: ['Bus pour Ravello (25 min). Matin calme sans foule à 9h00.', 'Sentier Ravello→Scala : 4 km à travers oliviers et vignes, vues sur le golfe. Déjeuner à Scala.', 'Après-midi : apéritif avec vue, dégustation de vin rouge de Ravello.'] },
  { day: 'Jour 5', title: 'Cetara et Vietri', items: ['Bus SITA vers l\'est jusqu\'à Cetara (célèbre pour sa colatura d\'anchois DOP). Marché aux poissons.', 'Visite du Musée de la colatura et achat direct chez les producteurs.', 'Vietri sul Mare : céramiques, Musée de la Céramique. Promenade au bord de mer.'] },
  { day: 'Jour 6', title: 'Valle delle Ferriere', items: ['Matin : randonnée Valle delle Ferriere depuis Amalfi (7 km aller-retour, 3h, facile–modéré). Cascades et fougères tropicales.', 'Après-midi : baignade dans les criques isolées près d\'Amalfi ou tour en kayak.', 'Dîner de poisson frais à Amalfi.'] },
  { day: 'Jour 7', title: 'Marché et départ', items: ['Matin libre au marché local. Acheter des produits typiques : limoncello artisanal, anchois, céramiques.', 'Long déjeuner dans une trattoria. Au revoir.', 'Bus SITA vers Salerne (60 min) ou Sorrente (90 min) pour trains ou aéroport.'] },
];
---

<BaseLayout
  title="Slow Travel Côte Amalfitaine 7 Jours 2026 | Villages, Gastronomie et Sentiers"
  description="Itinéraire slow travel de 7 jours sur la Côte Amalfitaine : Praiano, Furore, Cetara, Valle delle Ferriere et Sentier des Dieux. Villages authentiques, marchés locaux et gastronomie."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Slow travel Côte Amalfitaine" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <a href="/fr-fr/itineraires/" class="hover:text-white transition-colors">Itinéraires</a>
        <span>/</span>
        <span class="text-white">Slow Travel — 7 jours</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinéraire · 7 jours</p>
        <h1 class="font-serif text-display text-white mb-4">Slow Travel : Villages & Gastronomie</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Une semaine lente parmi les villages authentiques, les marchés locaux et les sentiers peu connus. Praiano comme base, Furore, Cetara, Valle delle Ferriere. La Côte Amalfitaine sans précipitation, sans visites guidées.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Durée</p>
          <p class="font-semibold text-charcoal">7 jours / 6 nuits</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base</p>
          <p class="font-semibold text-charcoal">Praiano ou Amalfi</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Meilleure saison</p>
          <p class="font-semibold text-charcoal">Mai–Juin / Sep–Oct</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Rythme</p>
          <p class="font-semibold text-charcoal">Lent</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programme jour par jour</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Produits à ne pas manquer</p>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <p class="font-semibold mb-1">Citron sfusato amalfitano IGP</p>
          <p class="text-white/70">Les énormes citrons de la Côte : arôme unique, peau épaisse. À acheter directement chez les producteurs d'Amalfi ou Minori.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Colatura d'anchois de Cetara DOP</p>
          <p class="text-white/70">Garum moderne : un liquide ambré d'anchois fermentés. Cetara produit la meilleure version DOP d'Italie.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Vin de Ravello</p>
          <p class="text-white/70">Les vignes en altitude produisent un rouge léger et parfumé. Dégustation dans les caves de Ravello.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Céramiques de Vietri sul Mare</p>
          <p class="text-white/70">La capitale italienne de la céramique : carreaux, assiettes et œuvres peints à la main. Choisir les ateliers artisanaux locaux.</p>
        </div>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
