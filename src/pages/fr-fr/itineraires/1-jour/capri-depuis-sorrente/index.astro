---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Home', url: '/fr-fr/' },
  { name: 'Itinéraires', url: '/fr-fr/itineraires/' },
  { name: 'Capri depuis Sorrente', url: '/fr-fr/itineraires/1-jour/capri-depuis-sorrente/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Combien de temps prend l'hydroglisseur de Sorrente à Capri ?",
      "acceptedAnswer": { "@type": "Answer", "text": "L'hydroglisseur de Sorrente (Marina Piccola) à Capri (Marina Grande) prend environ 20-25 minutes. Les principales compagnies sont NLG et Alilauro. En été, les traversées partent toutes les 30-60 min de 7h00 à 20h00. Le billet A/R coûte ~18-22€." }
    },
    {
      "@type": "Question",
      "name": "Est-il possible de voir la Grotte Bleue en une journée depuis Sorrente ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, mais cela nécessite une organisation précise. Prenez le premier hydroglisseur depuis Sorrente (7h30-8h00), arrivez à Capri et allez directement à la Grotte Bleue avant la foule (idéalement avant 10h00). Explorez ensuite Capri et Anacapri dans l'après-midi. Retour à Sorrente avec le dernier hydroglisseur (vers 18h30-19h00)." }
    },
    {
      "@type": "Question",
      "name": "Capri vs Anacapri : laquelle visiter en une journée ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Les deux méritent une visite, mais avec une seule journée, choisissez selon vos envies : Capri ville est plus chic, pleine de boutiques et avec les Faraglioni. Anacapri est plus tranquille, avec la Villa San Michele et la télécabine pour le Monte Solaro (589 m). Une bonne journée inclut la Grotte Bleue le matin, le déjeuner à Anacapri, l'après-midi à Capri et les Faraglioni." }
    }
  ]
};

const schedule = [
  { time: '07:30', place: 'Sorrente, Marina Piccola', action: 'Hydroglisseur NLG/Alilauro pour Capri (20-25 min, ~9-11€)', transport: 'ferry' },
  { time: '08:00', place: 'Capri, Marina Grande', action: 'Bus pour la Grotte Bleue (20 min, ~2€). Arrivez avant 10h pour éviter les files.', transport: 'bus' },
  { time: '08:30', place: 'Grotte Bleue', action: 'Barque à rames dans la grotte (15€ + entrée 14€). Attente variable.', transport: 'ferry' },
  { time: '10:00', place: 'Anacapri', action: 'Bus de Capri pour Anacapri (15 min). Villa San Michele (~7€). Télécabine Monte Solaro (589 m, ~13€ A/R).', transport: 'bus' },
  { time: '12:30', place: 'Anacapri', action: 'Déjeuner en trattoria locale (moins cher que le centre de Capri)', transport: 'visit' },
  { time: '14:00', place: 'Centre de Capri', action: 'Bus pour Capri. La Piazzetta, Via Camerelle, Jardins d\'Auguste, vue sur les Faraglioni.', transport: 'bus' },
  { time: '16:00', place: 'Marina Grande', action: 'Tour en barque autour des Faraglioni (~18-25€ p.p., 1-2h)', transport: 'ferry' },
  { time: '18:00', place: 'Capri → Sorrente', action: 'Hydroglisseur de retour pour Sorrente (20-25 min)', transport: 'ferry' },
];

const tips = [
  'Grotte Bleue : avant 10h00 presque sans file. Après 11h l\'attente peut durer 1 à 2 heures.',
  'En juillet-août, réservez l\'hydroglisseur en ligne la veille : les premières traversées se remplissent vite.',
  'Capri est chère : déjeuner à Anacapri coûte 30 à 40 % moins cher qu\'à la Piazzetta.',
  'La télécabine pour le Monte Solaro depuis Anacapri est incontournable : 589 m, vue à 360° sur la Côte et Naples.',
  'L\'hydroglisseur ne part pas par mer agitée : vérifiez la météo marine et ayez un plan B.',
];

const transportBadge: Record<string, { label: string; cls: string }> = {
  train: { label: 'TRAIN', cls: 'bg-orange-100 text-orange-700' },
  ferry: { label: 'FERRY', cls: 'bg-blue-100 text-blue-700' },
  bus:   { label: 'BUS', cls: 'bg-green-100 text-green-700' },
  walk:  { label: 'À PIED', cls: 'bg-gray-100 text-slate-500' },
  visit: { label: '', cls: '' },
};
---

<BaseLayout
  title="Capri depuis Sorrente en 1 Jour 2026 | Grotte Bleue, Faraglioni, Anacapri"
  description="Itinéraire d'1 jour à Capri au départ de Sorrente : Grotte Bleue, Anacapri, Monte Solaro et Faraglioni. Hydroglisseurs, horaires et conseils pour éviter les files."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/capri-hero.jpg" alt="Capri depuis Sorrente" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/fr-fr/itineraires/" class="hover:text-white transition-colors">Itinéraires</a>
        <span>/</span>
        <span class="text-white">Capri depuis Sorrente - 1 jour</span>
      </nav>
      <div class="max-w-2xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinéraire · 1 jour</p>
        <h1 class="font-serif text-display text-white mb-4">Capri depuis Sorrente</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          25 minutes d'hydroglisseur et vous voilà sur l'île la plus célèbre d'Italie. Grotte Bleue tôt le matin, Monte Solaro à Anacapri, Faraglioni dans l'après-midi : la journée parfaite à Capri.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-4xl mx-auto">
      <div class="grid grid-cols-3 gap-6">
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Durée</p><p class="font-bold text-charcoal text-lg">1 Jour</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Coût transport</p><p class="font-bold text-charcoal text-lg">~40–60€</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Difficulté</p><p class="font-bold text-charcoal text-lg">Facile</p></div>
        </div>
      </div>
    </section>

    <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">
      <section class="lg:col-span-8">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Programme Heure par Heure</h2>
        <div class="relative">
          <div class="space-y-12 border-l-2 border-slate-200 pl-8 ml-3">
            {schedule.map((s) => {
              const badge = transportBadge[s.transport] ?? transportBadge.visit;
              return (
                <div class="relative">
                  <div class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-med-blue ring-4 ring-white shadow-sm"></div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-med-blue font-bold text-sm">{s.time}</span>
                    {badge.label && <span class={`text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded ${badge.cls}`}>{badge.label}</span>}
                  </div>
                  <p class="font-semibold text-charcoal text-base leading-snug">{s.place}</p>
                  <p class="text-slate-600 text-sm mt-1 leading-relaxed">{s.action}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <aside class="lg:col-span-4 mt-12 lg:mt-0">
        <div class="lg:sticky lg:top-24 space-y-6">
          <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2a7 7 0 0 1 7 7c0 3-1.7 5.2-4 6.4V17a1 1 0 0 1-1 1H10a1 1 0 0 1-1-1v-1.6C6.7 14.2 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M10 21h4M12 17v4"/></svg>
              Conseils Pratiques
            </p>
            <ul class="space-y-3">
              {tips.map(tip => (
                <li class="flex gap-2.5 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
              Carte Rapide
            </p>
            <a href="https://maps.google.com/maps?q=Capri,Italy" target="_blank" rel="noopener" class="flex items-center justify-between bg-slate-50 hover:bg-med-blue/5 rounded-xl px-4 py-3 text-sm text-med-blue font-medium transition-colors group">
              Ouvrir l'itinéraire dans Google Maps
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </aside>
    </div>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions Fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
