---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Côte Amalfitaine', url: '/fr-fr/plages#cote-amalfitaine' },
  { name: 'Spiaggia Grande Positano', url: '/fr-fr/plages/cote-amalfitaine/spiaggia-grande-positano' },
];

const facts = [
  { label: 'Revêtement', value: 'Sable et galets' },
  { label: 'Accès', value: 'Facile (plat)' },
  { label: 'Ombre', value: 'À partir de 17h30' },
  { label: 'Équipements', value: 'Établissements de luxe, restaurants, embarcadère' },
  { label: 'Idéal pour', value: 'Atmosphère, glamour, VIP-watching' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia Grande di Positano",
  "description": "La plage principale de Positano, cœur de la vie mondaine et des établissements de bains de luxe de la Côte Amalfitaine.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6273",
    "longitude": "14.4849"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Positano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Restaurants", "value": "Oui" },
    { "@type": "LocationFeatureSpecification", "name": "Établissement de bains", "value": "Oui" }
  ]
};
---

<BaseLayout
  title="Spiaggia Grande Positano 2026 : Établissements et Tarifs"
  description="Vivez le cœur de Positano. Tarifs 2026 des transats, restaurants et comment rejoindre la Spiaggia Grande par la mer."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-grande-positano.jpg"
      alt="Spiaggia Grande di Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Positano · Côte Amalfitaine</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia Grande</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Le cœur glamour de la Côte Amalfitaine.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Le Glamour de la Côte</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La Spiaggia Grande est le centre de la vie mondaine de Positano. Avec la ville verticale en toile de fond - maisons aux couleurs pastel qui grimpent jusqu'à l'église Santa Maria Assunta - le cadre est unique au monde. En 2026, les établissements de bains exigent des réservations plusieurs semaines à l'avance en haute saison.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            C'est aussi le point de départ de tous les taxi-boats vers les criques isolées de la côte. Si vous voulez le mélange parfait de confort, cocktails signature et atmosphère exclusive, c'est votre plage. La partie publique gratuite, à l'est, se remplit rapidement après 9h.
          </p>
        </div>

        <!-- Tarifs -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="6" width="20" height="12" rx="2"/><circle cx="12" cy="12" r="2"/><path d="M6 12h.01M18 12h.01"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Tarifs 2026</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Un transat plus parasol dans les établissements de la Spiaggia Grande coûte en moyenne <strong>35–60 € par personne</strong>. Les restaurants en bord de mer (La Buca di Bacco, La Scalinatella) incluent le service parasol avec le déjeuner.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Le <strong>stationnement</strong> au centre de Positano est fortement déconseillé : arrivez en ferry depuis Amalfi ou Sorrente, ou en bus SITA - descendez à l'arrêt Sponda.
          </p>
        </div>

        <!-- Comment y aller -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Aller</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Par la mer ⭐ Recommandé</p>
              <p class="text-slate-700 font-medium mb-1">Ferry depuis Amalfi ou Sorrente</p>
              <p class="text-slate-500 text-sm">Débarquement direct sur la plage. Profitez du panorama depuis l'eau.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus SITA</p>
              <p class="text-slate-700 font-medium mb-1">Arrêt Sponda</p>
              <p class="text-slate-500 text-sm">Escalier escarpé jusqu'à la plage (environ 10 min à pied).</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Infos Clés
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez d'autres plages de la Côte Amalfitaine</h2>
      <a
        href="/fr-fr/plages"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet des plages
      </a>
    </div>
  </section>

</BaseLayout>
