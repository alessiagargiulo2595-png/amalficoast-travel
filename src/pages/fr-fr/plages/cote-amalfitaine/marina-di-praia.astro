---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Côte Amalfitaine', url: '/fr-fr/plages#cote-amalfitaine' },
  { name: 'Marina di Praia', url: '/fr-fr/plages/cote-amalfitaine/marina-di-praia' },
];

const facts = [
  { label: 'Composition', value: 'Galets et rochers' },
  { label: 'Accès', value: 'En bateau ou sentier de randonnée' },
  { label: 'Ombre', value: 'Minimale (exposée)' },
  { label: 'Atmosphère', value: 'Sauvage, isolée' },
  { label: 'Idéale pour', value: 'Aventuriers, randonnée' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina di Praia",
  "description": "Une plage sauvage et cachée accessible uniquement en bateau ou à pied. Falaises dramatiques et eaux cristallines pour le snorkeling.",
  "image": "https://amalficoast-travel.com/images/marina-di-praia.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5967",
    "longitude": "14.4883"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina di Praia 2026: Guide de la Plage Secrète"
  description="Marina di Praia est une plage sauvage et cachée entre Positano et Praiano. Guide d'accès en bateau, sentier de randonnée et conseils."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-di-praia.jpg"
      alt="Marina di Praia, Côte Amalfitaine"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Côte Amalfitaine · Joyaux Cachés</p>
      <h1 class="font-serif text-display text-white mb-6">Marina di Praia</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La plage sauvage entre Positano et Praiano, préservée du tourisme de masse.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Le Secret Sauvage de la Côte Amalfitaine</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina di Praia est une petite plage dramatique nichée sous des falaises abruptes entre Positano et Praiano. Aucune route ne mène ici—l'accès se fait uniquement par la mer ou un sentier de randonnée exigeant. Cet isolement en a fait l'une des dernières plages vraiment intactes de la côte.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            La plage est principalement composée de galets et de petites pierres, avec quelques taches de sable. L'eau cristalline et l'excellent snorkeling en font une destination pour les nageurs aventureux. Les falaises au-dessus sont vertigineuses et dramatiques, offrant des vues inoubliables.
          </p>
        </div>

        <!-- Comment y accéder -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Accéder</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">En Bateau ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Depuis Positano ou Praiano</p>
              <p class="text-slate-500 text-sm">Taxi d'eau ou bateau de location. Option la plus fiable. €20-30 aller-retour.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Sentier de Randonnée</p>
              <p class="text-slate-700 font-medium mb-1">45 minutes depuis Praiano</p>
              <p class="text-slate-500 text-sm">Descente abrupte. Bonnes chaussures essentielles. Non pour tous.</p>
            </div>
          </div>
        </div>

        <!-- Pourquoi c'est spécial -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Pourquoi C'est Spécial</h3>
          <div class="space-y-4 text-slate-600">
            <p class="leading-relaxed">
              <strong>Intacte:</strong> Pas de clubs de plage, pas de foules, pas de commercialisation. Juste la nature et la mer.
            </p>
            <p class="leading-relaxed">
              <strong>Snorkeling:</strong> L'eau est si claire que vous pouvez voir 15+ mètres en profondeur. Poissons colorés et formations rocheuses intéressantes.
            </p>
            <p class="leading-relaxed">
              <strong>Photographie:</strong> Le drame des falaises combiné à l'eau turquoise crée des images époustouflantes.
            </p>
          </div>
        </div>
      </div>

      <!-- Sidebar Faits Rapides -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Faits Rapides
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez plus de plages de la Côte Amalfitaine</h2>
      <a
        href="/fr-fr/plages"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet des plages
      </a>
    </div>
  </section>

</BaseLayout>
