---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Côte Amalfitaine', url: '/fr-fr/plages#cote-amalfitaine' },
  { name: 'Fiordo di Furore', url: '/fr-fr/plages/cote-amalfitaine/fiordo-di-furore' },
];

const facts = [
  { label: 'Revêtement', value: 'Galets' },
  { label: 'Accès', value: 'Escaliers (~200 marches)' },
  { label: 'Ombre', value: 'À partir de 14h30 ⚠️' },
  { label: 'Équipements', value: 'Plage publique gratuite' },
  { label: 'Idéal pour', value: 'Photographie, couples' },
];

const logistica = [
  { transport: 'Bus SITA', arret: 'Furore Fiordo', notes: 'Ligne Amalfi–Positano' },
  { transport: 'Scooter', arret: 'Ponte Furore', notes: 'Stationnement limité en bord de route' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Fiordo di Furore",
  "description": "Une plage iconique nichée dans un fjord naturel avec des eaux cristallines et un pont monumental de 30 mètres de haut.",
  "image": "https://amalficoast-travel.com/images/fiordo-furore.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6122",
    "longitude": "14.5534"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Furore",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "publicAccess": "true"
};
---

<BaseLayout
  title="Fiordo di Furore 2026 : Guide, Accès et Heures d'Ensoleillement"
  description="Comment visiter le Fiordo di Furore en 2026. Quand le soleil atteint la plage, comment y aller en bus et conseils pour la photo parfaite."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/fiordo-furore-hero.jpg"
      alt="Fiordo di Furore, Côte Amalfitaine"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Côte Amalfitaine</p>
      <h1 class="font-serif text-display text-white mb-6">Fiordo di Furore</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Un chef-d'œuvre de la nature taillé dans la roche.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Une Icône de la Côte Amalfitaine</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Le Fiordo di Furore est l'une des images les plus iconiques d'Italie. Ce n'est pas une plage traditionnelle, mais une profonde fissure naturelle où la mer s'infiltre sous un pont monumental de 30 mètres. En 2026, l'accès est réglementé pour protéger le site : la plage est petite et l'eau est généralement plus fraîche que sur la côte ouverte.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Un paradis pour les photographes - mais attention à la lumière : le soleil n'illumine le fond du fjord qu'en milieu de journée. Arrivez entre 11h et 13h pour les meilleures photos. Sauter du pont est une tradition locale mais est interdit aux touristes : profitez de la vue d'en haut avant de descendre les 200 marches jusqu'à la plage.
          </p>
        </div>

        <!-- Alerte Ombre -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Alerte Ombre</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Le soleil n'atteint la plage qu'entre <strong>11h et 14h30</strong>. Avant et après cette fenêtre, le fjord est entièrement à l'ombre. Planifiez votre visite en conséquence si vous souhaitez du soleil pour nager. Pour des photos parfaites de l'eau turquoise illuminée, visez environ 11h30.
          </p>
        </div>

        <!-- Comment y aller -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Aller</h2>
          <div class="overflow-hidden rounded-[2rem] border border-slate-100 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-charcoal text-white">
                  <th class="text-left p-4 font-medium">Transport</th>
                  <th class="text-left p-4 font-medium">Arrêt</th>
                  <th class="text-left p-4 font-medium">Notes</th>
                </tr>
              </thead>
              <tbody>
                {logistica.map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                    <td class="p-4 font-medium text-slate-900">{row.transport}</td>
                    <td class="p-4 text-slate-600">{row.arret}</td>
                    <td class="p-4 text-slate-500">{row.notes}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Infos Clés
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez d'autres plages de la Côte Amalfitaine</h2>
      <a
        href="/fr-fr/plages"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet des plages
      </a>
    </div>
  </section>

</BaseLayout>
