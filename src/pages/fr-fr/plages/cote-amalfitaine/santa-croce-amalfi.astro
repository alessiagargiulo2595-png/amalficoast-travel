---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Côte Amalfitaine', url: '/fr-fr/plages#cote-amalfitaine' },
  { name: 'Santa Croce', url: '/fr-fr/plages/cote-amalfitaine/santa-croce-amalfi' },
];

const facts = [
  { label: 'Revêtement', value: 'Galets blancs' },
  { label: 'Accès', value: 'Par mer uniquement (Taxi Boat)' },
  { label: 'Ombre', value: 'À partir de 16h00' },
  { label: 'Équipements', value: '2 restaurants avec lido' },
  { label: 'Idéal pour', value: 'Escapade romantique, poissons frais' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia di Santa Croce",
  "description": "Plage exclusive accessible uniquement par la mer depuis Amalfi, célèbre pour ses eaux cristallines et ses restaurants historiques.",
  "isAccessibleForFree": "false",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Plage Santa Croce Amalfi : Comment y Accéder par la Mer"
  description="Santa Croce est l'escapade parfaite depuis Amalfi. Accessible uniquement en bateau, avec des eaux cristallines et des restaurants historiques offrant une navette gratuite."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/santa-croce-amalfi.jpg"
      alt="Plage de Santa Croce, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfi · Par mer uniquement</p>
      <h1 class="font-serif text-display text-white mb-6">Santa Croce</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Une escapade secrète à quelques minutes du chaos d'Amalfi.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">L'Escapade Parfaite depuis Amalfi</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Santa Croce est l'antidote à la foule de juillet et août à Amalfi. Accessible uniquement par quelques minutes de bateau depuis l'embarcadère principal, elle offre une eau d'une transparence extraordinaire sur des fonds rocheux. La plage de galets blancs est lovée entre de hautes falaises qui la protègent du vent.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Les deux restaurants historiques - Da Gemma et La Caravella - gèrent des lidos privés sur la plage et proposent des navettes gratuites depuis l'embarcadère d'Amalfi pour leurs clients. C'est l'idéal pour ceux qui veulent une journée de mer « sauvage » avec le confort d'un excellent repas de poisson frais.
          </p>
        </div>

        <!-- Conseil local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Conseil Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Réservez le déjeuner au restaurant à l'avance : ils offrent la <strong>navette gratuite</strong> depuis l'embarcadère pour leurs clients. C'est la façon la moins chère - et la plus pittoresque - d'arriver à Santa Croce.
          </p>
        </div>

        <!-- Comment y aller -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Aller</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat ⭐ Seul accès</p>
              <p class="text-slate-700 font-medium mb-1">Depuis l'embarcadère d'Amalfi</p>
              <p class="text-slate-500 text-sm">Environ 5 minutes de traversée. Coût : 5–8 € par personne (aller-retour).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Navette du Restaurant</p>
              <p class="text-slate-700 font-medium mb-1">Gratuite pour les clients</p>
              <p class="text-slate-500 text-sm">Réservez le déjeuner et la traversée est incluse dans le service.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Infos Clés
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez d'autres plages de la Côte Amalfitaine</h2>
      <a
        href="/fr-fr/plages"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet des plages
      </a>
    </div>
  </section>

</BaseLayout>
