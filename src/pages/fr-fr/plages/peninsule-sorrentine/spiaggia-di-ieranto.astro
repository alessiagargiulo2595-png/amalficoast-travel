---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Péninsule Sorrentine', url: '/fr-fr/plages#peninsule-sorrentine' },
  { name: 'Ieranto', url: '/fr-fr/plages/peninsule-sorrentine/spiaggia-di-ieranto' },
];

const facts = [
  { label: 'Composition', value: 'Sable et galets' },
  { label: 'Accès', value: 'Sentier de randonnée uniquement' },
  { label: 'Difficulté', value: 'Randonnée modérée (30 min)' },
  { label: 'Atmosphère', value: 'Sauvage, intacte' },
  { label: 'Idéale pour', value: 'Randonneurs, snorkeling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia di Ieranto",
  "description": "Une plage cachée accessible uniquement par sentier de randonnée. Eaux cristallines, falaises sauvages et réserve naturelle protégée.",
  "image": "https://amalficoast-travel.com/images/ieranto-hero.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5700",
    "longitude": "14.3683"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia di Ieranto 2026: Plage Cachée & Guide de Randonnée"
  description="Ieranto est une plage pristine dans une réserve marine protégée. Accessible uniquement par sentier de randonnée depuis Praiano. Guide de la randonnée et ce à quoi s'attendre."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ieranto-hero.jpg"
      alt="Spiaggia di Ieranto, Péninsule Sorrentine"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Péninsule Sorrentine · Réserve Protégée</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia di Ieranto</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Une plage pristine cachée dans une réserve marine protégée, accessible uniquement à pied.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Une Plage Perdue dans le Temps</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Spiaggia di Ieranto se trouve dans une réserve marine protégée, l'une des premières créées en Italie. Son isolement et sa protection l'ont préservée comme un paradis naturel. Une randonnée de 30 minutes depuis Praiano, l'effort est récompensé par du sable pristine, des eaux turquoise et un paysage intact.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            La plage a une petite source d'eau douce, historiquement utilisée par les bergers. Les eaux cristallines en font une destination de snorkeling exceptionnelle. Une partie de vos frais d'entrée soutient la conservation marine.
          </p>
        </div>

        <!-- Le Sentier de Randonnée -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Le Sentier de Randonnée</h2>
          <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
            <div class="space-y-4 text-slate-600">
              <p class="leading-relaxed">
                <strong>Durée:</strong> 30 minutes à la descente, 40 minutes à la montée (avec l'exposition au soleil au retour)
              </p>
              <p class="leading-relaxed">
                <strong>Difficulté:</strong> Modérée. Sentier bien entretenu avec des sections d'escaliers et des zones exposées. Bonnes chaussures essentielles.
              </p>
              <p class="leading-relaxed">
                <strong>Point de départ:</strong> Via Spiaggia del Gavitello à Praiano (parking disponible)
              </p>
              <p class="leading-relaxed">
                <strong>Ce qu'il faut apporter:</strong> Eau, crème solaire, chaussures de randonnée confortables. Il n'y a pas d'installations à la plage.
              </p>
            </div>
          </div>
        </div>

        <!-- Réserve Marine -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Réserve Marine Protégée</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            Ieranto fait partie de l'Aire Marine Protégée Limonium, créée pour préserver cet écosystème exceptionnel. La baignade et le snorkeling sont autorisés, mais la pêche et l'ancrage sont interdits. L'entrée est de 2,50 €/personne.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Respectez la réserve : ne touchez pas aux coraux, ne prenez pas de souvenirs et utilisez uniquement une crème solaire respectueuse des récifs.
          </p>
        </div>
      </div>

      <!-- Sidebar Faits Rapides -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Faits Rapides
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez plus de plages de la Péninsule Sorrentine</h2>
      <a
        href="/fr-fr/plages"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet des plages
      </a>
    </div>
  </section>

</BaseLayout>
