---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Péninsule Sorrentine', url: '/fr-fr/plages#peninsule-sorrentine' },
  { name: 'Regina Giovanna', url: '/fr-fr/plages/peninsule-sorrentine/regina-giovanna' },
];

const facts = [
  { label: 'Revêtement', value: 'Rocheux' },
  { label: 'Accès', value: 'Sentier 20 min (modéré)' },
  { label: 'Ombre', value: 'À partir de 18h00' },
  { label: 'Équipements', value: 'Aucun — plage sauvage' },
  { label: 'Idéal pour', value: 'Archéologie, randonnée, snorkeling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Bagni della Regina Giovanna",
  "description": "Une piscine naturelle et un site archéologique romain près de Sorrente. Un joyau caché parmi les oliviers, à 20 minutes à pied du centre-ville.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6450",
    "longitude": "14.3540"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sorrente",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Regina Giovanna Sorrente : La Piscine Naturelle (2026)"
  description="Comment rejoindre les Bagni della Regina Giovanna près de Sorrente. Piscine naturelle parmi des ruines romaines, sentier dans les oliviers et eaux émeraude. Guide 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/regina-giovanna-sorrento.jpg"
      alt="Bagni della Regina Giovanna, Sorrente"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrente · Péninsule Sorrentine</p>
      <h1 class="font-serif text-display text-white mb-6">Regina Giovanna</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La piscine naturelle cachée parmi les ruines romaines.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Archéologie et Baignade</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Les Bagni della Regina Giovanna sont un site archéologique à ciel ouvert où l'on peut plonger dans une eau bleu émeraude. Une piscine naturelle encadrée par les vestiges d'une villa romaine du Ier siècle — probablement celle de Publius Vedius Pollio — communique avec la mer ouverte par une arche de roche. En 2026, c'est toujours un endroit sauvage : pas d'établissements.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Le sentier qui mène aux bains traverse des oliveraies millénaires avec des vues spectaculaires sur le golfe de Naples et l'île de Capri. Portez des chaussures de randonnée légères et apportez assez d'eau — il n'y a ni bar ni magasin à proximité.
          </p>
        </div>

        <!-- Plage sauvage -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Plage Sauvage</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Aucun équipement, pas de bar, pas d'établissement. Apportez <strong>eau, nourriture et chaussures aquatiques</strong>. C'est un endroit authentiquement local, fréquenté surtout par les Sorrentins qui connaissent le lieu.
          </p>
        </div>

        <!-- Comment y aller -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Aller</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus EAV ⭐ Recommandé</p>
              <p class="text-slate-700 font-medium mb-1">Ligne « Capo di Sorrento »</p>
              <p class="text-slate-500 text-sm">Depuis Piazza Tasso. Puis 15–20 min à pied dans les oliviers.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">À pied depuis le centre</p>
              <p class="text-slate-700 font-medium mb-1">Environ 40 minutes</p>
              <p class="text-slate-500 text-sm">Panoramique mais exigeant. Suivre Via del Capo vers Punta del Capo.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Infos Clés
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explorez la Péninsule Sorrentine</h2>
      <a
        href="/fr-fr/peninsule-sorrentine/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide de la Péninsule Sorrentine
      </a>
    </div>
  </section>

</BaseLayout>
