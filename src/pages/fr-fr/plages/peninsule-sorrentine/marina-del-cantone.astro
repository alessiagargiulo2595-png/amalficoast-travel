---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Péninsule Sorrentine', url: '/fr-fr/plages#peninsule-sorrentine' },
  { name: 'Marina del Cantone', url: '/fr-fr/plages/peninsule-sorrentine/marina-del-cantone' },
];

const facts = [
  { label: 'Revêtement', value: 'Grands galets' },
  { label: 'Accès', value: 'Très facile (plat)' },
  { label: 'Ombre', value: 'À partir de 18h30' },
  { label: 'Équipements', value: 'Établissements, restaurants étoilés' },
  { label: 'Idéal pour', value: 'Familles, gastronomie, snorkeling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina del Cantone",
  "description": "Une large plage de galets à Nerano, célèbre pour sa gastronomie — berceau des Spaghetti alla Nerano — et ses eaux cristallines dans la réserve marine de Punta Campanella.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Nerano",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina del Cantone Nerano : Plage et Restaurants 2026"
  description="La plage la plus savoureuse d'Italie : Marina del Cantone à Nerano unit des eaux cristallines protégées et les authentiques Spaghetti alla Nerano. Guide 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-del-cantone.jpg"
      alt="Marina del Cantone, Nerano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Nerano · Péninsule Sorrentine</p>
      <h1 class="font-serif text-display text-white mb-6">Marina del Cantone</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La capitale gastronomique face à la mer la plus pure de Campanie.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Mer et Grande Cuisine</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Nerano est la capitale gastronomique de la Péninsule Sorrentine. La plage de Marina del Cantone est large, propre et ensoleillée jusqu'en fin de soirée. L'eau est parmi les plus cristallines de Campanie, protégée par la réserve marine de Punta Campanella : le snorkeling est excellent, avec des prairies de posidonie et une riche faune marine.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Mais la renommée mondiale de Nerano est culinaire. C'est ici qu'est né le <strong>Spaghetti alla Nerano</strong> — courgettes frites, provolone del Monaco, basilic — et chaque restaurant du bord de mer sert la version originale. Parfait pour les familles et pour ceux qui souhaitent combiner une belle journée de plage avec une gastronomie d'exception.
          </p>
        </div>

        <!-- Conseil gastronomique -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Conseil Gastronomique</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            <strong>Lo Cantone</strong> et <strong>Maria Grazia</strong> sont les temples du Spaghetti alla Nerano. Réservez votre table le matin — en été les places partent vite. Un déjeuner en bord de mer ici est une expérience gastronomique complète.
          </p>
        </div>

        <!-- Comment y aller -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Aller</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus EAV</p>
              <p class="text-slate-700 font-medium mb-1">Depuis Sorrente via Massa Lubrense</p>
              <p class="text-slate-500 text-sm">Descendre à Nerano. Puis 10 min à pied jusqu'à la plage.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Par la mer</p>
              <p class="text-slate-700 font-medium mb-1">Taxi boat depuis Sorrente</p>
              <p class="text-slate-500 text-sm">Débarquement direct sur la plage. Pittoresque et très pratique.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Infos Clés
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Explorez la Péninsule Sorrentine</h2>
      <a
        href="/fr-fr/peninsule-sorrentine/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide de la Péninsule Sorrentine
      </a>
    </div>
  </section>

</BaseLayout>
