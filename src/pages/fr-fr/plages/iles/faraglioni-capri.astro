---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Îles de la Baie', url: '/fr-fr/plages#iles' },
  { name: 'Faraglioni di Capri', url: '/fr-fr/plages/iles/faraglioni-capri' },
];

const facts = [
  { label: 'Type', value: 'Formations rocheuses (pas de plage)' },
  { label: 'Accès', value: 'En bateau uniquement' },
  { label: 'Vedette de', value: 'Films italiens & légende' },
  { label: 'Atmosphère', value: 'Iconique, dramatique' },
  { label: 'Idéal pour', value: 'Photographie, baignade' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Faraglioni di Capri",
  "description": "Trois formations rocheuses iconiques s'élevant à 109 mètres de la mer. Un symbole de Capri et vedette de films italiens célèbres. Accessible en bateau pour la baignade et la plongée.",
  "image": "https://amalficoast-travel.com/images/faraglioni-capri.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5447",
    "longitude": "14.2277"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Faraglioni di Capri 2026: Rochers Iconiques & Guide de Baignade"
  description="Les Faraglioni sont trois énormes formations rocheuses au large de Capri. Une icône italienne, vedette de films. Guide de visite en bateau et ce à quoi s'attendre."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/faraglioni-capri.jpg"
      alt="Faraglioni di Capri, Îles de la Baie"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Îles de la Baie · Icône Italienne</p>
      <h1 class="font-serif text-display text-white mb-6">Faraglioni di Capri</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Trois formations rocheuses légendaires qui fascinent les visiteurs depuis des siècles.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Légende en Pierre</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Les Faraglioni di Capri sont trois formations rocheuses colossales s'élevant à 109 mètres (357 pieds) de la mer Tyrrhénienne. Ils sont parmi les repères naturels les plus photographiés d'Italie, des symboles instantanément reconnaissables de Capri et de la côte de Campanie. Chaque formation porte un nom : Faraglione Grande (la plus grande), Faraglione di Mezzo (du milieu) et Faraglione di Fuori (extérieur).
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Ces rochers dramatiques ont inspiré d'innombrables artistes, cinéastes et écrivains. Ils apparaissent dans le film italien classique "Le Talent de M. Ripley" et figurent en bonne place dans la photographie de voyage mondiale. La légende locale dit que passer sous l'arche naturelle de la roche du milieu apporte la bonne fortune—et des centaines de bateaux le font quotidiennement.
          </p>
        </div>

        <!-- Histoires & Histoire -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Histoires & Legende</h2>
          <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
            <div class="space-y-6 text-slate-600">
              <div>
                <p class="font-semibold text-slate-900 mb-2">Le Lézard Bleu</p>
                <p class="leading-relaxed">
                  La légende locale parle du lézard bleu endémique (Podarcis sicula coerulea) qui vit sur les rochers. Autrefois communs, ces créatures sont devenues rares, désormais protégées dans une réserve marine.
                </p>
              </div>
              <div>
                <p class="font-semibold text-slate-900 mb-2">Au Cinéma & Art</p>
                <p class="leading-relaxed">
                  Les Faraglioni ont figuré dans de nombreux films italiens et servent de symbole visuel de la dolce vita. Les artistes les ont peints pendant des siècles, capturant la lumière et le drame de ces formations à différentes heures du jour.
                </p>
              </div>
              <div>
                <p class="font-semibold text-slate-900 mb-2">Merveille Géologique</p>
                <p class="leading-relaxed">
                  Ces formations calcaires sont les vestiges de falaises anciennes érodées par les vagues et le vent. L'arche naturelle dans la roche du milieu crée un passage utilisé par les bateaux—une expérience palpitante et une opportunité photo.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Comment Visiter -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment Visiter</h3>
          <p class="text-slate-600 leading-relaxed mb-4">
            Les Faraglioni ne peuvent être visités que par bateau. De nombreuses excursions partent quotidiennement de Capri, Positano et d'autres villes côtières. Les excursions durent généralement 2-3 heures et incluent du temps pour la baignade et le snorkeling autour des rochers.
          </p>
          <p class="text-slate-600 leading-relaxed">
            <strong>Meilleure période de visite:</strong> Mai à septembre, quand la mer est la plus calme. Les excursions en bateau du matin offrent la meilleure lumière pour la photographie. La baignade est autorisée, et l'eau est exceptionnellement claire, rendant le snorkeling exceptionnel.
          </p>
        </div>
      </div>

      <!-- Sidebar Faits Rapides -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Faits Rapides
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez plus des Îles de la Baie</h2>
      <a
        href="/fr-fr/plages"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet des plages
      </a>
    </div>
  </section>

</BaseLayout>
