---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Îles du Golfe', url: '/fr-fr/plages#iles' },
  { name: 'Cala del Pozzo Vecchio', url: '/fr-fr/plages/iles/cala-del-pozzo-vecchio' },
];

const facts = [
  { label: 'Revêtement', value: 'Sable noir volcanique' },
  { label: 'Ambiance', value: 'Poétique et paisible' },
  { label: 'Accès', value: '10 min à pied depuis l\'arrêt de bus' },
  { label: 'Ombre', value: 'À partir de 17h30' },
  { label: 'Idéal pour', value: 'Cinéphiles, poésie, détente authentique' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala del Pozzo Vecchio",
  "description": "La plage de Procida rendue immortelle par le film Il Postino de Massimo Troisi. Sable noir volcanique et eaux émeraude.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Procida",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Plage du Facteur Procida 2026 : Cala del Pozzo Vecchio"
  description="La plage rendue immortelle par le film Il Postino. Sable noir volcanique, eau émeraude et le côté le plus authentique de Procida. Guide 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-pozzo-vecchio-procida.jpg"
      alt="Cala del Pozzo Vecchio, Procida — la plage du Facteur"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Procida · Îles du Golfe</p>
      <h1 class="font-serif text-display text-white mb-6">Cala del Pozzo Vecchio</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La plage rendue immortelle par Massimo Troisi.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Le Cinéma Fait Plage</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La plage rendue immortelle par Massimo Troisi dans <em>Il Postino</em> (1994). Un croissant de sable noir volcanique et d'eau couleur émeraude qui semble sorti tout droit du film. Dès que vous y entrez, vous comprenez immédiatement pourquoi Troisi et le réalisateur Michael Radford l'ont choisie comme décor principal.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            C'est le côté le plus authentique et le moins touristique des îles campaniennes. Procida n'a jamais connu le tourisme de masse de Capri ou d'Ischia, et cette plage en conserve l'âme : peu de visiteurs, beaucoup de poésie, une eau impeccablement propre. Parfaite pour la détente totale et ceux qui aiment les atmosphères cinématographiques.
          </p>
        </div>

        <!-- Il Postino -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="2.18" ry="2.18"/><line x1="7" y1="2" x2="7" y2="22"/><line x1="17" y1="2" x2="17" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="2" y1="7" x2="7" y2="7"/><line x1="2" y1="17" x2="7" y2="17"/><line x1="17" y1="17" x2="22" y2="17"/><line x1="17" y1="7" x2="22" y2="7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Il Postino (1994)</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Le film de Michael Radford avec Massimo Troisi et Philippe Noiret a remporté l'Oscar du meilleur film étranger. Cette plage est le cœur du film. De nombreux visiteurs viennent ici pour revivre les scènes iconiques — le facteur qui marche sur le rivage, la poésie de la mer.
          </p>
          <p class="text-slate-600 leading-relaxed italic">
            « Il mondo è bello e tu sei un po' curioso » — Il Postino, 1994
          </p>
        </div>

        <!-- Comment y aller -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Aller</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Ligne C1 ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Depuis le port de Procida</p>
              <p class="text-slate-500 text-sm">Arrêt Pozzo Vecchio. Puis 10 min à pied en descente vers la plage.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">À pied</p>
              <p class="text-slate-700 font-medium mb-1">Depuis le centre de Procida</p>
              <p class="text-slate-500 text-sm">20–25 minutes. Pittoresque et agréable dans les ruelles de l'île.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Infos Clés
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez tout sur Procida</h2>
      <a
        href="/fr-fr/iles/procida/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet de Procida
      </a>
    </div>
  </section>

</BaseLayout>
