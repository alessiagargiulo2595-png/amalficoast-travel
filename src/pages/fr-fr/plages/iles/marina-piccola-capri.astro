---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Îles du Golfe', url: '/fr-fr/plages#iles' },
  { name: 'Marina Piccola Capri', url: '/fr-fr/plages/iles/marina-piccola-capri' },
];

const facts = [
  { label: 'Revêtement', value: 'Galets et rochers' },
  { label: 'Accès', value: 'Bus ou escaliers (Via Mulo)' },
  { label: 'Ombre', value: 'À partir de 16h00 ⚠️' },
  { label: 'Vue', value: 'Faraglioni (la meilleure de l\'île)' },
  { label: 'Idéal pour', value: 'Établissements exclusifs, photographie, snorkeling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina Piccola Capri",
  "description": "La plage la plus célèbre de Capri, offrant la vue la plus proche et la plus dramatique sur les Faraglioni. Établissements exclusifs et eaux abritées.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5456",
    "longitude": "14.2344"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina Piccola Capri 2026 : Guide de la Plage des Faraglioni"
  description="Marina Piccola est la baie la plus célèbre de Capri. Guide 2026 avec tarifs des établissements, comment y aller et la meilleure vue sur les Faraglioni."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-piccola-capri.jpg"
      alt="Marina Piccola, Capri, avec les Faraglioni en arrière-plan"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Capri · Îles du Golfe</p>
      <h1 class="font-serif text-display text-white mb-6">Marina Piccola</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Les Faraglioni semblent à portée de main.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">La Légende de Capri</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina Piccola est la baie abritée où se trouvent les établissements de bains les plus célèbres de Capri. D'ici, les Faraglioni — les trois roches iconiques émergeant de la mer — semblent à portée de main : c'est la vue la plus dramatique et la plus photographiée de l'île.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            En 2026, l'espace de plage publique est minimal, il est donc vivement recommandé de réserver dans un établissement comme <strong>La Canzone del Mare</strong> (le plus historique, fondé en 1932 par Gracie Fields). Les eaux sont abritées et idéales pour le snorkeling.
          </p>
        </div>

        <!-- Alerte Ombre -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Alerte Ombre</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Marina Piccola passe à l'ombre <strong>à partir d'environ 16h</strong>, en raison des montagnes qui l'entourent. Si vous voulez du soleil l'après-midi, envisagez la plage de Marina Grande ou les établissements de l'autre côté de l'île. La matinée et le début d'après-midi sont les meilleurs moments.
          </p>
        </div>

        <!-- Comment y aller -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Aller</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus orange ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Depuis le centre de Capri</p>
              <p class="text-slate-500 text-sm">Ligne directe Marina Piccola. Économique et fréquent.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">À pied via Via Mulo</p>
              <p class="text-slate-700 font-medium mb-1">15 minutes de descente</p>
              <p class="text-slate-500 text-sm">Panoramique. Vous profitez du paysage de l'île tout au long du chemin.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Infos Clés
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez tout sur Capri</h2>
      <a
        href="/fr-fr/iles/capri/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet de Capri
      </a>
    </div>
  </section>

</BaseLayout>
