---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Plages', url: '/fr-fr/plages' },
  { name: 'Îles du Golfe', url: '/fr-fr/plages#iles' },
  { name: 'Spiaggia dei Maronti', url: '/fr-fr/plages/iles/spiaggia-maronti' },
];

const facts = [
  { label: 'Revêtement', value: 'Sable volcanique' },
  { label: 'Longueur', value: '3 km (la plus longue de l\'île)' },
  { label: 'Spécial', value: 'Fumerolles naturelles chaudes' },
  { label: 'Ombre', value: 'À partir de 19h00' },
  { label: 'Idéal pour', value: 'Thermalisme naturel, familles, détente' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia dei Maronti",
  "description": "La plage volcanique d'Ischia, la plus longue de l'île (3 km), célèbre pour ses fumerolles naturelles chaudes et ses sources thermales souterraines.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Barano d'Ischia",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia dei Maronti Ischia 2026 : Fumerolles et Sable Chaud"
  description="Les Maronti sont la plage la plus longue d'Ischia (3 km) avec des fumerolles thermales naturelles. Guide 2026 : comment y aller, à quoi s'attendre, conseils pratiques."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-maronti-ischia.jpg"
      alt="Spiaggia dei Maronti, Ischia"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Ischia · Îles du Golfe</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia dei Maronti</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Trois kilomètres de sable chaud chauffé par le volcan.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Bien-être Thermal Naturel</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Les Maronti offrent une expérience unique en Italie. La plage est immense - trois kilomètres de sable volcanique sombre - et le sable lui-même est réchauffé par la chaleur volcanique du sous-sol via les <strong>fumerolles</strong> : des jets de vapeur chaude qui émergent du sable, atteignant par endroits des températures supérieures à 60 °C.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Parfaite pour les marcheurs et ceux qui veulent fuir l'agitation des ports. La vaste étendue garantit que même en août on trouve toujours un coin tranquille. L'eau est calme et idéale pour les familles avec de jeunes enfants.
          </p>
        </div>

        <!-- Fumerolles -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3z"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Les Fumerolles</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Les fumerolles se trouvent dans la partie centrale de la plage (zone Fumarole Beach). Vous pouvez enfouir les pieds dans le sable chaud pour un effet thermal naturel gratuit. <strong>Ne vous approchez pas trop des jets de vapeur</strong> : les températures peuvent être très élevées. Les enfants doivent être surveillés dans cette zone.
          </p>
        </div>

        <!-- Comment y aller -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Comment y Aller</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Ligne 5</p>
              <p class="text-slate-700 font-medium mb-1">Depuis Ischia Porto</p>
              <p class="text-slate-500 text-sm">Descendre à Barano. Puis sentier en descente vers la plage (15 min).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Depuis Sant'Angelo</p>
              <p class="text-slate-500 text-sm">5 minutes en bateau. Pittoresque et pratique. Débarquement direct sur la plage.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Infos Clés
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/fr-fr/plages"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Toutes les plages
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Découvrez tout sur Ischia</h2>
      <a
        href="/fr-fr/iles/ischia/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guide complet d'Ischia
      </a>
    </div>
  </section>

</BaseLayout>
