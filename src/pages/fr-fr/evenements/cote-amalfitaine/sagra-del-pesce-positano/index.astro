---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Fête du Poisson – Positano', url: '/fr-fr/evenements/cote-amalfitaine/sagra-del-pesce-positano/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Fête du Poisson Positano 2026",
  "startDate": "2026-09-26",
  "endDate": "2026-09-26",
  "location": {
    "@type": "Place",
    "name": "Plage Fornillo, Positano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/cote-amalfitaine/sagra-del-pesce-positano/"
};

const facts = [
  { dt: 'Date', dd: '26 septembre 2026' },
  { dt: 'Spécialité', dd: 'Frittura di paranza' },
  { dt: 'Lieu', dd: 'Plage Fornillo' },
  { dt: 'Navette', dd: 'Gratuite depuis le port principal' },
  { dt: 'Entrée', dd: 'Gratuite' },
];
---

<BaseLayout
  title="Fête du Poisson Positano 2026 – Frittura di Paranza sur la Plage Fornillo"
  description="La Fête du Poisson à Positano le 26 septembre 2026. Plat de poisson local sur la plage Fornillo avec navette maritime gratuite depuis l'embarcadère principal."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Fête du Poisson, Plage Fornillo, Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">26 sep 2026</span>
        <span class="text-white/70 text-sm">Positano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Fête du Poisson</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        La Frittura di paranza annonce la fin de l'été sur la plage Fornillo.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>La Fête du Poisson de Positano célèbre la tradition de la pêche locale sur la plage Fornillo, la plus paisible de la ville. La Frittura di paranza — friture de petits poissons locaux — est la grande spécialité de la soirée, dégustée les pieds dans le sable avec vue sur la mer.</p>
            <p>Une navette maritime gratuite relie l'embarcadère principal à la plage Fornillo tout au long de la soirée, permettant d'éviter le chemin escarpé. L'événement marque symboliquement la fin de l'été à Positano et attire aussi bien les résidents que les derniers visiteurs de la saison.</p>
          </div>
        </div>

        <!-- Les spécialités -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Les Spécialités de la Fête</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Plat principal</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Frittura di paranza</h4>
              <p class="text-slate-600 text-sm leading-relaxed">La friture de petits poissons de la Méditerranée — anchois, gobies, rougets — pêchés dans les eaux de la Côte Amalfitaine et frits à la perfection sur la plage.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Ambiance</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Soirée sur la plage</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Tables dressées sur la plage Fornillo, musique live et vin local. La navette maritime gratuite fonctionne jusqu'à la fin de la soirée.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Navette maritime</td>
                  <td class="px-6 py-4 text-slate-600">Depuis l'embarcadère principal</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Gratuite pendant la durée de la fête</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Amalfi ou Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Arrêt Positano, puis descendre à pied</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
