---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Nouvel An Byzantin', url: '/fr-fr/evenements/cote-amalfitaine/capodanno-bizantino/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Nouvel An Byzantin Amalfi 2026",
  "startDate": "2026-09-01",
  "endDate": "2026-09-30",
  "location": {
    "@type": "Place",
    "name": "Centre historique, Amalfi",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Amalfi",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/cote-amalfitaine/capodanno-bizantino/"
};

const facts = [
  { dt: 'Période', dd: 'Septembre 2026' },
  { dt: 'Lieu', dd: 'Centre historique, Amalfi' },
  { dt: 'Type', dd: 'Reconstitution historique' },
  { dt: 'Costumes', dd: 'Byzantins, médiévaux' },
  { dt: 'Depuis Naples', dd: 'Ferry 1h30' },
];
---

<BaseLayout
  title="Nouvel An Byzantin Amalfi 2026 – Patrimoine Médiéval Oriental"
  description="Le Nouvel An Byzantin à Amalfi en septembre 2026. Reconstitution historique du Nouvel An selon le calendrier byzantin, avec défilés en costumes, musique médiévale et spectacles dans le centre historique."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/amalfi-hero.jpg"
      alt="Nouvel An Byzantin, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">Septembre 2026</span>
        <span class="text-white/70 text-sm">Amalfi, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Nouvel An Byzantin</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Amalfi revit son extraordinaire patrimoine médiéval oriental.
      </p>
    </div>
  </section>

  <!-- Contenu 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Contenu Principal (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À Propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Peu de visiteurs savent que l'Amalfi médiévale utilisait le calendrier byzantin, dans lequel la nouvelle année commençait en septembre. La République d'Amalfi était l'une des puissances commerciales méditerranéennes les plus connectées à l'Empire byzantin, et ce patrimoine culturel unique se célèbre chaque septembre avec une reconstitution historique sans égal sur la côte italienne.</p>
            <p>Les rues du centre historique s'emplissent de personnages en costume représentant marchands, nobles et clercs byzantins, accompagnés de musique médiévale jouée sur des instruments d'époque. La procession parcourt le casco antiguo vers la cathédrale, culminant avec des cérémonies et des spectacles qui ramènent la vie au passé oriental extraordinaire de la ville.</p>
          </div>
        </div>

        <!-- Le Programme -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Le Programme</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">La Procession</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Costumes byzantins par les rues historiques</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Les participants en costume byzantin représentent les marchands, le doge et les marins de l'Amalfi médiévale, défilant par les rues historiques au son de la musique médiévale.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Spectacles Médiévaux</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Musique, théâtre et artisanat</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Spectacles de musique médiévale sur instruments d'époque, scènes théâtrales de la vie de la République et démonstrations d'artisanat et de métiers byzantins animent les places et ruelles.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y Aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Naples</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">1h30, direct au port d'Amalfi</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Sorrente ou Salerne</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">SS163, arrêt Amalfi centre</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
