---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Régata Historique Marítima', url: '/fr-fr/evenements/cote-amalfitaine/regata-storica-amalfi/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Régata Historique Amalfitaine 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-06-30",
  "location": {
    "@type": "Place",
    "name": "Port d'Amalfi",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Amalfi",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/cote-amalfitaine/regata-storica-amalfi/"
};

const facts = [
  { dt: 'Période', dd: 'Juin 2026' },
  { dt: 'Lieu', dd: 'Port d\'Amalfi' },
  { dt: 'Type', dd: 'Régata historique et défilé' },
  { dt: 'Costumes', dd: 'Médiévaux, spectaculaires' },
  { dt: 'Depuis Naples', dd: 'Ferry 1h30' },
];
---

<BaseLayout
  title="Régata Historique Amalfitaine 2026 – Défilé Médiéval et Course de Rames"
  description="La Régata Historique des Anciennes Républiques Maritimes 2026 à Amalfi. Défilés en costumes médiévaux et course de rames entre Amalfi, Venise, Gênes et Pisa dans le port."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/amalfi-hero.jpg"
      alt="Régata Historique Marítima, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">Juin 2026</span>
        <span class="text-white/70 text-sm">Amalfi, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Régata Historique Marítima</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Amalfi, Venise, Gênes et Pisa rivalisent en mer avec des défilés de costumes médiévaux.
      </p>
    </div>
  </section>

  <!-- Contenu 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Contenu Principal (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À Propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>La Régata des Anciennes Républiques Maritimes est l'un des spectacles historiques les plus impressionnants d'Italie. Quatre villes qui furent des puissances maritimes médiévales — Amalfi, Venise, Gênes et Pise — rivalisent dans une course de rames à bord de galères historiques, précédée par un défilé de plus de trois cents participants en costume d'époque.</p>
            <p>Quand la régata se déroule à Amalfi, le port se transforme en scène médiévale extraordinaire : les maisons colorées sur les falaises, la cathédrale au fond et les galères avec leurs voiles de couleur offrent un spectacle inoubliable. Les costumes, armures et étendards des quatre républiques transportent la ville dans son glorieux passé maritime.</p>
          </div>
        </div>

        <!-- Le Programme -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Le Programme</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Le Défilé Historique</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Trois cents participants en costume</h4>
              <p class="text-slate-600 text-sm leading-relaxed">La procession historique parcourt les rues du casco antiguo d'Amalfi avec plus de trois cents participants en costume médiéval représentant les quatre républiques, leurs doges, capitaines et mariniers.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">La Course de Rames</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Galères historiques en mer</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Quatre équipages de huit rameurs rivalisent dans des galères historiques dans le port d'Amalfi. La ville gagnante conserve le trophée jusqu'à la prochaine édition dans l'une des quatre autres villes.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y Aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Naples</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">1h30, direct au port d'Amalfi</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Sorrente ou Salerne</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">SS163, arrêt Amalfi centre</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
