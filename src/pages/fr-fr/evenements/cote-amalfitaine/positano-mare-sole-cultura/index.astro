---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Positano Art et Culture', url: '/fr-fr/evenements/cote-amalfitaine/positano-mare-sole-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Positano Art et Culture 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-31",
  "location": {
    "@type": "Place",
    "name": "Positano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/cote-amalfitaine/positano-mare-sole-cultura/"
};

const facts = [
  { dt: 'Période', dd: 'Août 2026' },
  { dt: 'Lieu', dd: 'Positano' },
  { dt: 'Type', dd: 'Festival d\'art et culture' },
  { dt: 'Cadre', dd: 'Terrasses panoramiques' },
  { dt: 'Depuis Naples', dd: 'Ferry 1h ou bus SITA' },
];
---

<BaseLayout
  title="Positano Art et Culture 2026 – Art, Musique et Littérature sur la Côte"
  description="Positano Art et Culture 2026 en août. Programme estival d'art, musique et littérature avec événements sur les terrasses panoramiques et espaces culturels de Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Positano Art et Culture"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">Août 2026</span>
        <span class="text-white/70 text-sm">Positano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Positano Art et Culture</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Art, musique et littérature sur les plus belles terrasses de la Côte de Amalfi.
      </p>
    </div>
  </section>

  <!-- Contenu 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Contenu Principal (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À Propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Positano a toujours attiré artistes, écrivains et musiciens : de Picasso et Steinbeck à Noureev, tous ont été fascinés par sa beauté extraordinaire. Le festival Positano Art et Culture continue cette tradition chaque août, transformant les terrasses, jardins et places du village en scènes en plein air pour l'art contemporain et classique.</p>
            <p>Le programme s'étend sur tout le mois d'août avec des concerts nocturnes sur les terrasses panoramiques face à la mer, des expositions d'art dans les espaces historiques, des lectures littéraires, des spectacles de danse et des projections de cinéma sous les étoiles. Un festival estival qui complète, plutôt que ne concurrence, la beauté naturelle de Positano.</p>
          </div>
        </div>

        <!-- Le Programme -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Le Programme</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Musique et Danse</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Concerts sur les terrasses</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Concerts nocturnes allant de la musique de chambre classique aux performances contemporaines, célébrés sur les terrasses les plus spectaculaires de Positano avec la mer et les Faraglioni en arrière-plan.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Art et Littérature</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Expositions et lectures</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Expositions d'art contemporain dans les espaces historiques, lectures d'auteurs et cinéma en plein air célèbrent la longue relation du village avec artistes et écrivains internationaux.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y Aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Naples ou Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Service saisonnier, embarcadère de Positano</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Sorrente ou Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">SS163, arrêt Positano Sponda ou Chiesa Nuova</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
