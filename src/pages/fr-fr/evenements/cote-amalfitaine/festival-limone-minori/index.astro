---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Festival du Citron – Minori', url: '/fr-fr/evenements/cote-amalfitaine/festival-limone-minori/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Festival du Citron Minori 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-31",
  "location": {
    "@type": "Place",
    "name": "Centre historique, Minori",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Minori",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/cote-amalfitaine/festival-limone-minori/"
};

const facts = [
  { dt: 'Période', dd: 'Août 2026' },
  { dt: 'Lieu', dd: 'Centre historique, Minori' },
  { dt: 'Produit', dd: 'Citron IGP Côte de Amalfi' },
  { dt: 'Spécialité', dd: 'Delizia al limone' },
  { dt: 'Accès', dd: 'Bus SITA ou ferry' },
];
---

<BaseLayout
  title="Festival du Citron Minori 2026 – Citron IGP de la Côte de Amalfi"
  description="Le Festival du Citron à Minori en août 2026. Dégustations, ateliers et marchés dédiés au citron IGP de la Côte de Amalfi dans le village médiéval de Minori."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/costiera-hero.jpg"
      alt="Festival du Citron, Minori"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">Août 2026</span>
        <span class="text-white/70 text-sm">Minori, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Festival du Citron – Minori</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Le citron IGP de la Côte de Amalfi en vedette dans le village médiéval de Minori.
      </p>
    </div>
  </section>

  <!-- Contenu 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Contenu Principal (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À Propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Le Festival du Citron de Minori célèbre le produit qui plus que tout autre identifie la Côte de Amalfi : le citron sfusato IGP, cultivé en terrasses accrochées aux falaises avec des techniques transmises pendant des siècles. Minori, village médiéval avec la plage la plus abritée de la côte, est le cadre idéal pour cette fête de la saveur.</p>
            <p>Le festival offre des dégustations guidées de produits au citron — de la delizia al limone (le dessert qui rendit célèbre Minori), le limoncello artisanal, jusqu'à la pâte fraîche sauce citron — des ateliers avec les producteurs locaux et un marché de citronniers en terrasse où acheter directement aux agriculteurs.</p>
          </div>
        </div>

        <!-- Spécialités -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Spécialités du Festival</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Douceurs au Citron</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">La Delizia al Limone</h4>
              <p class="text-slate-600 text-sm leading-relaxed">La delizia al limone est le dessert qui rendit célèbre Minori dans toute l'Italie : un dôme de biscuit rempli et couvert de crème au citron, créé dans les pâtisseries du village dans les années 70 et aujourd'hui symbole de la côte.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Le Citron Sfusato</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">L'or de la Côte de Amalfi</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Le citron sfusato amalfitain IGP se distingue par son écorce épaisse très parfumée, idéale pour le limoncello artisanal. Les citronniers en terrasse sont un paysage culturel en candidature au patrimoine UNESCO.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y Aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Naples ou Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Service saisonnier, embarcadère de Minori</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">SS163 depuis Amalfi ou Salerne</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Arrêt Minori centre, 10 min depuis Amalfi</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
