---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Ischia Global Film & Music Fest', url: '/fr-fr/evenements/iles/ischia-global-film-festival/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Ischia Global Film & Music Festival 2026",
  "startDate": "2026-07-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Lacco Ameno & Ischia Porto",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ischia",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/iles/ischia-global-film-festival/"
};

const facts = [
  { dt: 'Période', dd: 'Juillet 2026' },
  { dt: 'Lieux', dd: 'Lacco Ameno & Ischia Porto' },
  { dt: 'Type', dd: 'Cinéma & musique internationale' },
  { dt: 'Accès', dd: 'Événements ouverts au public' },
  { dt: 'Depuis Naples', dd: 'Ferry 1h15' },
];
---

<BaseLayout
  title="Ischia Global Film & Music Festival 2026 – Glamour d'Hollywood en Méditerranée"
  description="L'Ischia Global Film & Music Festival en juillet 2026. Premières mondiales, cérémonies de remise de prix et stars internationales sur les places et dans les hôtels de luxe d'Ischia."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ischia-hero.jpg"
      alt="Ischia Global Film Festival"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">Juillet 2026</span>
        <span class="text-white/70 text-sm">Ischia, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Ischia Global Film & Music Fest</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Le glamour d'Hollywood sous le soleil méditerranéen.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>L'Ischia Global Film & Music Festival est l'un des événements cinématographiques les plus glamour d'Italie. Des stars internationales du cinéma et de la musique se retrouvent sur l'île thermale pour des premières mondiales, des remises de prix et des soirées inoubliables dans les hôtels historiques de Lacco Ameno.</p>
            <p>Contrairement à d'autres festivals, une partie des projections et des rencontres sont accessibles au grand public sur les places de l'île. C'est l'occasion de croiser des célébrités dans un cadre méditerranéen unique, avec les vignobles et les sources thermales d'Ischia en arrière-plan.</p>
          </div>
        </div>

        <!-- Le programme -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Le Programme</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Cinéma</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Premières & prix</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Projections en avant-première, cérémonies de remise de prix et rencontres avec des réalisateurs et acteurs internationaux. Certaines projections se tiennent sur les places sous les étoiles.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Musique</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Concerts & soirées</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Des concerts de musique internationale et des soirées dans les jardins des grands hôtels de Lacco Ameno. L'atmosphère mêle glamour hollywoodien et dolce vita italienne.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Naples Beverello</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">1h15, arrivée à Ischia Porto</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Hydrofoil</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Naples ou Pozzuoli</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">45 min, plus rapide et plus cher</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
