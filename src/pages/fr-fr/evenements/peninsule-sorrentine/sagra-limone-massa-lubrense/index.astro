---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Fête du Citron – Massa Lubrense', url: '/fr-fr/evenements/peninsule-sorrentine/sagra-limone-massa-lubrense/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Fête du Citron Massa Lubrense 2026",
  "startDate": "2026-07-11",
  "endDate": "2026-07-12",
  "location": {
    "@type": "Place",
    "name": "Centre historique, Massa Lubrense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Massa Lubrense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/peninsule-sorrentine/sagra-limone-massa-lubrense/"
};

const facts = [
  { dt: 'Dates', dd: '11–12 juillet 2026' },
  { dt: 'Produit', dd: 'Citron Femminiello IGP' },
  { dt: 'Lieu', dd: 'Centre historique, Massa Lubrense' },
  { dt: 'Accès', dd: 'Bus EAV depuis Sorrento toutes les 20 min' },
  { dt: 'Entrée', dd: 'Gratuite' },
];
---

<BaseLayout
  title="Fête du Citron Massa Lubrense 2026 – Dégustations et Marchés"
  description="La Fête du Citron à Massa Lubrense les 11 et 12 juillet 2026. Parcours de dégustation à travers les portails historiques du village avec limoncello, granita et pâtes au citron."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/massa-lubrense-hero.jpg"
      alt="Fête du Citron, Massa Lubrense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">11–12 juil 2026</span>
        <span class="text-white/70 text-sm">Massa Lubrense, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Fête du Citron</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Le citron Femminiello IGP en vedette dans le village historique.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Un événement gastronomique dédié à célébrer le citron local. Il comprend des parcours de dégustation à travers les portails historiques du village et des marchés artisanaux. Transport en bus EAV depuis la Piazza Tasso de Sorrento toutes les 20 minutes.</p>
            <p>Le citron Femminiello de la Péninsule Sorrentine est l'un des symboles de l'agriculture locale, protégé par une indication géographique. La fête est l'occasion de rencontrer les producteurs locaux et de déguster limoncello, granita et spécialités préparées au citron dans les ruelles du village.</p>
          </div>
        </div>

        <!-- Parcours de dégustation -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Parcours de Dégustation</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Limoncello artisanal</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Du verger à la bouteille</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Les producteurs locaux ouvrent leurs ateliers pour montrer le processus d'élaboration du limoncello traditionnel avec l'écorce du Femminiello biologique.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Cuisine au citron</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Gastronomie locale</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Tartes au citron, granita, pâtes au citron et douceurs traditionnelles animent les étals gastronomiques tout au long du parcours dans les portails historiques du village.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus EAV</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Sorrento Piazza Tasso</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Toutes les 20 minutes</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Voiture</td>
                  <td class="px-6 py-4 text-slate-600">SS145 Sorrentina</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Parking le long de la route principale</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
