---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: "Madonna della Libera – Sant'Agnello", url: '/fr-fr/evenements/peninsule-sorrentine/madonna-della-libera/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Madonna della Libera Sant'Agnello 2026",
  "startDate": "2026-09-13",
  "endDate": "2026-09-13",
  "location": {
    "@type": "Place",
    "name": "Sant'Agnello",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sant'Agnello",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/peninsule-sorrentine/madonna-della-libera/"
};

const facts = [
  { dt: 'Date', dd: '13 septembre 2026' },
  { dt: 'Lieu', dd: "Sant'Agnello" },
  { dt: 'Type', dd: 'Fête de quartier' },
  { dt: 'Ambiance', dd: 'Traditionnelle et authentique' },
  { dt: 'Depuis Sorrento', dd: '5 min en bus' },
];
---

<BaseLayout
  title="Madonna della Libera Sant'Agnello 2026 – Fête de Quartier de la Péninsule"
  description="La fête de la Madonna della Libera à Sant'Agnello le 13 septembre 2026. Fête de quartier locale qui préserve l'esprit authentique des traditions de la Péninsule – loin des flux touristiques."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Madonna della Libera, Sant'Agnello"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">13 sep 2026</span>
        <span class="text-white/70 text-sm">Sant'Agnello, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Madonna della Libera</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        La fête de quartier avec le charme des célébrations d'autrefois.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Une fête de quartier qui préserve le goût des célébrations d'antan, avec des illuminations traditionnelles et des produits locaux. Une occasion de vivre la Péninsule Sorrentine loin des flux touristiques de l'été.</p>
            <p>Sant'Agnello, à quelques minutes de Sorrento, maintient sa propre identité communautaire. La fête de la Madonna della Libera est l'un de ces événements que les habitants défendent avec fierté comme patrimoine de leur quartier — intime, chaleureux et profondément ancré dans la tradition du Sud de l'Italie.</p>
          </div>
        </div>

        <!-- La célébration -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">La Célébration</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Illuminations traditionnelles</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Les lumières du quartier</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Les rues de Sant'Agnello se parent d'illuminations traditionnelles qui évoquent l'atmosphère festive des anciennes fêtes de quartier du Sud de l'Italie — intime, chaleureuse et profondément locale.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Produits locaux</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Le goût du territoire</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Étals de produits locaux, street food aux spécialités sorrentines et la convivialité de la communauté font de cette fête un authentique témoignage de la vie sur la Péninsule.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus local</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Sorrento Piazza Tasso</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minutes, très fréquent</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">À pied</td>
                  <td class="px-6 py-4 text-slate-600">Depuis le centre de Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">20 min de promenade le long de la route côtière</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
