---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Gustamincanto – Vico Equense', url: '/fr-fr/evenements/peninsule-sorrentine/gustamincanto-vico-equense/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Gustamincanto Vico Equense 2026",
  "startDate": "2026-09-01",
  "endDate": "2026-09-30",
  "location": {
    "@type": "Place",
    "name": "Centre historique, Vico Equense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vico Equense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/peninsule-sorrentine/gustamincanto-vico-equense/"
};

const facts = [
  { dt: 'Période', dd: 'Septembre 2026' },
  { dt: 'Lieu', dd: 'Centre historique, Vico Equense' },
  { dt: 'Spécialité', dd: 'Provolone del Monaco DOP' },
  { dt: 'Chefs', dd: 'Étoilés présents' },
  { dt: 'Depuis Naples', dd: 'Circumvesuviana 50 min' },
];
---

<BaseLayout
  title="Gustamincanto Vico Equense 2026 – Excellence Gastronomique de la Péninsule Sorrentine"
  description="Le Gustamincanto à Vico Equense en septembre 2026. Festival gastronomique avec le Provolone del Monaco DOP et des chefs étoilés dans les ruelles médiévales de Vico Equense."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/vico-equense-hero.jpg"
      alt="Gustamincanto, Vico Equense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">Septembre 2026</span>
        <span class="text-white/70 text-sm">Vico Equense, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Gustamincanto</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Excellence gastronomique de la Péninsule Sorrentine dans les ruelles médiévales.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Gustamincanto est le festival gastronomique de référence de la Péninsule Sorrentine, dédié aux produits d'excellence locaux. Le Provolone del Monaco DOP — le fromage affiné dans les grottes de la côte — est la star indiscutable de l'événement, accompagné de tous les autres fleurons de la gastronomie locale.</p>
            <p>Des chefs étoilés de la région présentent leurs réinterprétations des recettes traditionnelles dans les ruelles médiévales de Vico Equense, tandis que les producteurs locaux ouvrent leurs ateliers pour des dégustations et des rencontres directes.</p>
          </div>
        </div>

        <!-- Le festival -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Le Festival Gastronomique</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Le Provolone del Monaco</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Le roi des fromages locaux</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Le Provolone del Monaco DOP est un fromage à pâte filée affiné dans les caves fraîches de la Péninsule Sorrentine. Son nom viendrait des vendeurs qui se couvraient d'un manteau pour le transporter à Naples.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Chefs étoilés</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Haute cuisine locale</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Des chefs de restaurants étoilés de la Péninsule proposent des menus spéciaux et des démonstrations culinaires autour des produits du territoire sorrentinien.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Naples Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">50 min, arrêt Vico Equense</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Voiture</td>
                  <td class="px-6 py-4 text-slate-600">Autoroute A3</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Sortie Castellammare, puis SP145</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
