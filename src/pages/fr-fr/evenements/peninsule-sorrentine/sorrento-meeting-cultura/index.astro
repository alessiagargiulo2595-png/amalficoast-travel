---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Événements', url: '/fr-fr/evenements/' },
  { name: 'Sorrento Meeting', url: '/fr-fr/evenements/peninsule-sorrentine/sorrento-meeting-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Sorrento Meeting 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Cloître de San Francesco, Sorrente",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sorrento",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/fr-fr/evenements/peninsule-sorrentine/sorrento-meeting-cultura/"
};

const facts = [
  { dt: 'Période', dd: 'Juin–Juil 2026' },
  { dt: 'Lieu', dd: 'Cloître de San Francesco' },
  { dt: 'Type', dd: 'Cycle littéraire' },
  { dt: 'Accès', dd: 'Réservation recommandée' },
  { dt: 'Depuis Naples', dd: 'Circumvesuviana 70 min' },
];
---

<BaseLayout
  title="Sorrento Meeting 2026 – Littérature et Journalisme dans le Cloître Gothique-Arabe"
  description="Le Sorrento Meeting de juin à juillet 2026. Rencontres en soirée avec des auteurs de renommée internationale dans le cloître gothique-arabe du XIVe siècle de San Francesco."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Sorrento Meeting, Cloître de San Francesco"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Événement 2026</span>
        <span class="text-white/70 text-sm">Juin–Juil 2026</span>
        <span class="text-white/70 text-sm">Sorrente, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Sorrento Meeting</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-alpha leading-relaxed">
        Littérature et journalisme international dans le cloître du XIVe siècle.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">À propos de l'Événement</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Une série de rencontres littéraires et journalistiques dans le Cloître de San Francesco. Des soirées avec des auteurs de renommée internationale. Le cloître gothique-arabe du XIVe siècle offre un cadre unique pour les rencontres culturelles de ce cycle estival.</p>
            <p>Les rencontres ont généralement lieu au coucher du soleil, profitant de la lumière magique du soir dans le cloître. Les participants peuvent poursuivre la soirée dans les restaurants et les terrasses panoramiques du centre de Sorrente.</p>
          </div>
        </div>

        <!-- Le cycle culturel -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Le Cycle Culturel</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Rencontres avec les auteurs</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Littérature internationale</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Des écrivains, journalistes et intellectuels de renommée internationale se succèdent dans le cloître pour présenter leurs œuvres et dialoguer avec le public dans un format ouvert et informel.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Le Cloître</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Un cadre unique</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Le Cloître de San Francesco, avec ses arcs gothiques-arabes du XIVe siècle, est l'un des lieux les plus évocateurs de Sorrente et un centre culturel actif tout au long de l'été.</p>
            </div>
          </div>
        </div>

        <!-- Comment y aller -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Comment y aller</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Transport</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Service</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Depuis Naples Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">70 minutes, arrêt Sorrento</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Depuis la côte ou Naples</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Port de Sorrente, connexions avec les îles</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">À pied</td>
                  <td class="px-6 py-4 text-slate-600">Depuis le centre de Sorrente</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minutes depuis la Piazza Tasso</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Détails de l'Événement</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Nous recommandons d'arriver à l'avance. Consultez le programme mis à jour sur les canaux officiels.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
