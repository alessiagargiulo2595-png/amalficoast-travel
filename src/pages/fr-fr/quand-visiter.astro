---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocalePath } from '../../i18n/translations';

const lang = 'fr-fr';
const t = getTranslations(lang);

const months = [
  { name: 'Janvier', weather: '8–14°C', sea: 'Froide', crowds: 'Déserte', notes: 'La côte est presque déserte. Beaucoup d\'hôtels et restaurants fermés. Idéal pour ceux qui aiment le silence absolu et la photographie sans personnes dans le cadre.' },
  { name: 'Février', weather: '9–15°C', sea: 'Froide', crowds: 'Déserte', notes: 'Similaire à janvier. Quelques ouvertures pour le Carnaval. Mimosas en fleurs sur les collines.' },
  { name: 'Mars', weather: '11–17°C', sea: 'Fraîche', crowds: 'Basse', notes: 'La côte se réveille. Citrons et agrumes en maturation. Quelques visiteurs mais encore calme. Excellent pour la randonnée.' },
  { name: 'Avril', weather: '13–20°C', sea: 'Fraîche', crowds: 'Modérée', notes: 'Période idéale : température agréable, paysages d\'un vert luxuriant, relativement peu de touristes. Les ferries reprennent. Pâques amène quelque affluence.' },
  { name: 'Mai', weather: '16–24°C', sea: 'Tempérée', crowds: 'Modérée–Élevée', notes: 'L\'un des meilleurs mois de l\'année. Tout ouvert, mer déjà baignable pour les courageux, fleurs partout. Réserver l\'hébergement à l\'avance.' },
  { name: 'Juin', weather: '20–28°C', sea: 'Chaude', crowds: 'Élevée', notes: 'Première semaine encore gérable, puis début de haute saison. Mer magnifique, soirées longues et lumineuses. Prix élevés.' },
  { name: 'Juillet', weather: '23–32°C', sea: 'Chaude', crowds: 'Très élevée', notes: 'Mois le plus fréquenté. Trafic intense sur la SS163, plages bondées, prix maximum. À éviter si vous n\'aimez pas les foules, sinon la mer est sublime.' },
  { name: 'Août', weather: '23–32°C', sea: 'Chaude', crowds: 'Très élevée', notes: 'Comme juillet, encore pire. Ferragosto amène l\'exode estival italien. Si vous venez, réservez tout des mois à l\'avance. Magie du soir incomparable cependant.' },
  { name: 'Septembre', weather: '20–27°C', sea: 'Chaude', crowds: 'Modérée–Élevée', notes: 'Septembre est le mois secret des connaisseurs : mer encore chaude, foule en baisse à partir de la mi-mois, prix qui descendent. Probablement le meilleur mois.' },
  { name: 'Octobre', weather: '16–22°C', sea: 'Tempérée', crowds: 'Basse', notes: 'La côte retrouve son rythme. Couleurs automnales sur les collines, citrons mûrs. Excellent pour la randonnée et la photographie.' },
  { name: 'Novembre', weather: '12–17°C', sea: 'Fraîche', crowds: 'Déserte', notes: 'Beaucoup d\'établissements ferment. Possibilité de pluie. Pour ceux qui veulent le silence absolu, des prix minimaux et une Italie authentique.' },
  { name: 'Décembre', weather: '9–14°C', sea: 'Froide', crowds: 'Très basse', notes: 'Quelques ouvertures pour les fêtes de Noël. Crèches vivantes à Praiano et dans les grottes. Atmosphère unique mais services limités.' },
];

const crowdColor: Record<string, string> = {
  'Déserte':          'bg-med-gold/10 text-med-gold',
  'Basse':            'bg-med-gold/10 text-med-gold',
  'Très basse':       'bg-med-gold/10 text-med-gold',
  'Modérée':          'bg-med-blue/10 text-med-blue',
  'Modérée–Élevée':   'bg-med-blue/15 text-med-blue',
  'Élevée':           'bg-slate-200 text-slate-700',
  'Très élevée':      'bg-slate-800 text-white',
};
---

<BaseLayout
  title={t.meta.when_to_visit_title}
  description={t.meta.when_to_visit_description}
  lang={lang}
  pageKey="when-to-visit"
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/quando-visitare-hero.jpg" alt="Villa Cimbrone, Ravello" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <p class="text-med-gold text-sm uppercase tracking-[0.3em] mb-3 font-medium">Guide saisonnier</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Quand visiter la Côte Amalfitaine</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto font-light">Chaque mois a ses avantages et inconvénients. Guide complet mois par mois sur le climat, l'affluence et les prix.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-lg text-slate-600 leading-relaxed">
      La question la plus fréquente de ceux qui planifient un voyage sur la Côte Amalfitaine est : quand y aller ? La réponse honnête est qu'il n'existe pas de moment parfait absolu - tout dépend de ce que vous recherchez. En juillet et août la mer est magnifique mais la côte est surpeuplée ; au printemps et en automne le paysage est superbe et la foule minimale, mais certains services sont réduits. Ce guide mois par mois vous aidera à choisir la bonne période pour vous.
    </p>
  </section>

  <!-- Top recommendation -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8 text-center">
        <div class="w-12 h-12 rounded-2xl bg-med-gold/15 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-2">Meilleure période</p>
        <p class="font-serif text-2xl font-bold text-white mb-2">Mai · Septembre</p>
        <p class="text-white/50 text-sm">Température idéale, mer baignable, affluence gérable</p>
      </div>

      <div class="bg-white border border-slate-100 rounded-[3rem] p-8 text-center shadow-sm">
        <div class="w-12 h-12 rounded-2xl bg-med-blue/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-medium mb-2">Bonne alternative</p>
        <p class="font-serif text-2xl font-bold text-slate-900 mb-2">Avril · Octobre</p>
        <p class="text-slate-500 text-sm">Moins chaud, prix plus bas, beaux paysages</p>
      </div>

      <div class="bg-white border border-slate-100 rounded-[3rem] p-8 text-center shadow-sm">
        <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-medium mb-2">À éviter (si possible)</p>
        <p class="font-serif text-2xl font-bold text-slate-900 mb-2">Juillet · Août</p>
        <p class="text-slate-500 text-sm">Surpeuplé, coûteux, trafic intense</p>
      </div>

    </div>
  </section>

  <!-- Month-by-month table -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-serif text-slate-900 mb-8">Guide mois par mois</h2>
      <div class="space-y-4">
        {months.map(month => (
          <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 p-6 sm:p-8">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h3 class="font-bold text-slate-900 text-lg w-24">{month.name}</h3>
              <span class="text-sm text-slate-500 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/></svg>
                {month.weather}
              </span>
              <span class="text-sm text-slate-500 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-med-blue flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3.744 12 2.25l5.25 1.494m-10.5 0 5.25 1.494M6.75 3.744 2.25 9l4.5 5.256 5.25-1.494M17.25 3.744 21.75 9l-4.5 5.256-5.25-1.494M12 15.75 6.75 14.25m5.25 1.5 5.25-1.5"/></svg>
                Mer : {month.sea}
              </span>
              <span class={`text-xs font-semibold px-3 py-1 rounded-full ${crowdColor[month.crowds]}`}>
                Affluence : {month.crowds}
              </span>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">{month.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Events -->
  <section class="bg-slate-900 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Calendrier</p>
      <h2 class="text-2xl font-bold font-serif text-white mb-10">Événements à ne pas manquer</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Festival de Ravello</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Juillet – Septembre</p>
          <p class="text-white/60 text-sm leading-relaxed">Concerts de musique classique sur la terrasse donnant sur la mer de la Villa Rufolo. L'un des événements culturels les plus émouvants d'Italie. Réservez les billets à l'avance.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Régate des Anciennes Républiques Maritimes</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Juin (tous les 4 ans à Amalfi)</p>
          <p class="text-white/60 text-sm leading-relaxed">La régate opposant Amalfi, Venise, Gênes et Pise. Quand c'est au tour d'Amalfi d'accueillir, la ville revêt ses costumes médiévaux.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Luminara di Sant'Andrea</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">27 juin et 30 novembre</p>
          <p class="text-white/60 text-sm leading-relaxed">La fête du saint patron d'Amalfi illumine la Cathédrale et la place avec des milliers de bougies. Un spectacle nocturne extraordinaire, très ancré dans la communauté locale.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Fête du Citron (Sagra del Limone)</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Août (divers villages)</p>
          <p class="text-white/60 text-sm leading-relaxed">Dégustations de limoncello, desserts au citron, marchés artisanaux. Le citron sfusato amalfitano est un produit IGP : profitez-en pour en ramener chez vous.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Vous avez choisi quand venir ?</h2>
      <p class="text-slate-600 mb-6">Découvrez comment organiser au mieux vos jours sur la côte.</p>
      <a href={getLocalePath(lang, 'itineraries')}
        class="inline-block bg-med-blue text-white font-semibold px-8 py-3 rounded-full hover:shadow-lg transition-shadow">
        Voir les itinéraires
      </a>
    </div>
  </section>

</BaseLayout>
