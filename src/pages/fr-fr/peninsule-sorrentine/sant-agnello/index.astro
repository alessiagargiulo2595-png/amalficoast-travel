---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Péninsule Sorrentine', url: '/fr-fr/peninsule-sorrentine/' },
  { name: "Sant'Agnello", url: '/fr-fr/peninsule-sorrentine/sant-agnello/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Que voir à Sant'Agnello ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sant'Agnello est une ville résidentielle. Les principaux points d'intérêt sont le Parco dei Principi (hôtel avec jardins de Gio Ponti), la Villa Crawford et la promenade des Colli di San Pietro." }
    },
    {
      "@type": "Question",
      "name": "Comment aller à Sant'Agnello ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Circumvesuviana depuis Naples : arrêt Sant'Agnello (60 min), un arrêt avant Sorrente. En bus : EAV depuis Sorrente (~5 min). À pied : ~20 min par le Corso Italia." }
    }
  ]
};

const fastFacts = [
  { dt: 'Emplacement', dd: 'Péninsule Sorrentine, NA' },
  { dt: 'Habitants', dd: '~9.000' },
  { dt: 'Depuis Naples', dd: '~60 min (Circumvesuviana)' },
  { dt: 'Depuis Sorrente', dd: '~5 min (bus/à pied)' },
  { dt: 'Ambiance', dd: 'Résidentielle, calme' },
  { dt: 'Meilleure période', dd: 'Avr-Oct' },
];
---

<BaseLayout
  title="Sant'Agnello 2026 : Alternative Tranquille à Sorrente - Guide Complet"
  description="Guide de Sant'Agnello : l'alternative calme et moins chère à Sorrente. Parco dei Principi, Villa Crawford et la promenade des Colli di San Pietro."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[50vh] flex items-end bg-charcoal overflow-hidden text-white">
    <img src="/images/sorrento-hero.jpg" alt="Sant'Agnello, Italie" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
    <div class="relative z-10 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Péninsule Sorrentine · Tranquillité & Luxe</p>
        <h1 class="font-serif text-display mb-4">Sant'Agnello</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          À seulement 5 minutes de Sorrente mais avec la tranquillité d'un village résidentiel. Le choix idéal pour ceux qui veulent séjourner sur la péninsule sans payer les prix du centre de Sorrente.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 text-charcoal">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed">
          Sant'Agnello n'a pas de monuments de carte postale, mais elle a quelque chose de rare : la paix. De belles villas historiques, des hôtels de charme et des prix 20-30% moins élevés que Sorrente.
        </p>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Le saviez-vous ?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">5 min</p><p class="text-white/60 text-xs italic mt-1">de Sorrente en bus ou à pied</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">-30%</p><p class="text-white/60 text-xs italic mt-1">prix hôtel par rapport à Sorrente</p></div>
            <div class="text-center"><p class="font-serif text-5xl font-bold text-med-gold">9.000</p><p class="text-white/60 text-xs italic mt-1">habitants</p></div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Le Parco dei Principi de Sant'Agnello, avec des jardins dessinés par Gio Ponti dans les années 1960, est considéré comme l'un des meilleurs exemples d'architecture rationaliste appliquée à l'hôtellerie méditerranéenne.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-2xl font-semibold mb-6">Que voir à Sant'Agnello</h2>
          <div class="space-y-6">
            {[
              { title: 'Parco dei Principi', text: "L'hôtel et les jardins dessinés par Gio Ponti dans les années 1960 : un chef-d'œuvre du design rationaliste avec piscine sur la falaise. Même si vous n'y séjournez pas, les jardins publics méritent une visite. Accès via via Rivo." },
              { title: 'Promenade des Colli di San Pietro', text: "Un sentier panoramique reliant Sant'Agnello à Piano di Sorrento le long de la falaise, avec des vues sur le Golfe de Naples. Longueur : ~3 km. Libre et sans trafic. À faire à l'aube ou au coucher du soleil." },
              { title: 'Villa Crawford', text: "Résidence de l'écrivain américain Francis Marion Crawford (1854-1909), qui vécut ici 30 ans à écrire des romans historiques. Visible de l'extérieur seulement ; propriété privée. Les jardins sont parmi les plus beaux de la péninsule." },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
          <p class="font-semibold text-charcoal mb-2">Pourquoi choisir Sant'Agnello comme base ?</p>
          <p class="text-sm text-slate-600 leading-relaxed">Si votre budget est limité mais que vous souhaitez séjourner sur la péninsule, Sant'Agnello propose des hôtels avec les mêmes vues que Sorrente à des prix inférieurs. La Circumvesuviana s'arrête ici, tout comme les bus EAV pour Sorrente (5 min) et Massa Lubrense. Pas besoin de louer une voiture.</p>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold mb-6">Questions fréquentes</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Infos Rapides - Sant'Agnello</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Péninsule Sorrentine</p>
          <nav class="space-y-1">
            {[
              { href: '/fr-fr/peninsule-sorrentine/sorrente/', label: 'Sorrente' },
              { href: '/fr-fr/peninsule-sorrentine/vico-equense/', label: 'Vico Equense' },
              { href: '/fr-fr/peninsule-sorrentine/massa-lubrense/', label: 'Massa Lubrense' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Explorer la Péninsule"
    items={[
      { name: 'Sorrente',       href: '/fr-fr/peninsule-sorrentine/sorrente/',       tag: 'Base idéale',    desc: 'Piazza Tasso, limoncello et hydrofoils vers Capri.' },
      { name: 'Capri',          href: '/fr-fr/iles/capri/',                            tag: 'Incontournable', desc: 'Grotte Bleue et Faraglioni - 25 min en hydrofoil.' },
      { name: 'Massa Lubrense', href: '/fr-fr/peninsule-sorrentine/massa-lubrense/', tag: 'Nature',         desc: 'Punta Campanella et la plus belle plage de la péninsule.' },
      { name: 'Positano',       href: '/fr-fr/cote-amalfitaine/positano/',             tag: 'Mode & Vues',    desc: 'Les maisons colorées sur la falaise de la Côte Amalfitaine.' },
    ]}
  />

</BaseLayout>
