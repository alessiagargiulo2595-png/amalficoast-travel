---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Guide pratique', url: '/fr-fr/guide/' },
  { name: 'Parking & ZTL', url: '/fr-fr/guide/parking-ztl/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Peut-on aller en voiture à Positano ?",
      "acceptedAnswer": { "@type": "Answer", "text": "En été, Positano est fermé à la circulation de 9h00 à 18h00 (ZTL). Seuls les résidents et les clients des hôtels peuvent entrer en voiture. Meilleur conseil : garez-vous à Sorrente ou Praiano et venez en bus SITA ou en ferry." }
    },
    {
      "@type": "Question",
      "name": "Où se garer pour visiter la Côte Amalfitaine ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Meilleures options : 1) Laisser la voiture à Salerne ou Vietri sul Mare et prendre le bus/ferry. 2) Garer à Sorrente (Garage Achille Lauro, ~€2/h) et prendre le bus SITA ou l'hydroglisseur. 3) Utiliser les parkings d'Amalfi (Luna Rossa, Flavio Gioia, ~€4–5/h)." }
    },
    {
      "@type": "Question",
      "name": "Combien coûte le parking à Amalfi ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Les principaux parkings d'Amalfi (Luna Rossa et Flavio Gioia) coûtent ~€4–5/heure ou ~€25–30/jour. Presque toujours complets en juillet et août. Il est conseillé d'arriver avant 9h00 ou d'utiliser les transports en commun." }
    }
  ]
};

const ztlData = [
  { location: 'Positano', ztl: 'Oui', period: 'Juin–Sep (9h–18h)', note: 'Accès réservé aux résidents et clients des hôtels. Bus SITA ou ferry recommandés.' },
  { location: 'Amalfi', ztl: 'Oui', period: 'Toute l\'année (centre)', note: 'ZTL permanente dans le centre historique. Parkings payants sur le front de mer (~€4/h).' },
  { location: 'Ravello', ztl: 'Oui', period: 'Été (10h–19h)', note: 'Seulement bus SITA depuis Amalfi (25 min, ~€1,50) ou voiture avec autorisation hôtel.' },
  { location: 'Sorrente', ztl: 'Oui', period: 'Été (centre)', note: 'Garages couverts disponibles. Piazza Lauro ~€2/h.' },
  { location: 'Praiano', ztl: 'Non', period: '—', note: 'Parkings gratuits et payants le long de la SS163. Excellent point d\'étape.' },
  { location: 'Maiori', ztl: 'Non', period: '—', note: 'Parkings disponibles sur le front de mer. Plus facile que les villages à l\'ouest.' },
  { location: 'Minori', ztl: 'Non', period: '—', note: 'Parkings sur le front de mer, gratuits ou peu coûteux.' },
];
---

<BaseLayout
  title="Parking & ZTL Côte Amalfitaine 2026 | Où Laisser sa Voiture"
  description="Guide complet des parkings et zones ZTL sur la Côte Amalfitaine : Positano, Amalfi, Ravello, Sorrente. Où se garer et comment rejoindre les villages sans stress."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/parcheggi-hero.jpg" alt="Sorrente, Péninsule Sorrentine" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Guide pratique</span>
        <span>/</span>
        <span class="text-white">Parking & ZTL</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Guide pratique</p>
        <h1 class="font-serif text-display text-white mb-4">Parking & Zones ZTL</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          La Côte Amalfitaine en été est un cauchemar pour les conducteurs : ZTL partout, routes étroites et parkings chers. Conseil principal : laissez la voiture et utilisez les transports en commun.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="bg-red-50 border border-red-200 rounded-[2rem] p-6 mb-8">
        <p class="font-semibold text-red-800 mb-2">⚠️ Attention aux ZTL</p>
        <p class="text-sm text-red-700">Les zones ZTL de la Côte Amalfitaine sont surveillées par des caméras. Entrer sans autorisation entraîne une amende de €80–160 envoyée directement à la société de location ou à votre adresse personnelle.</p>
      </div>
      <p class="text-xl leading-relaxed text-charcoal">
        La meilleure stratégie est le "parking stratégique" : garez la voiture à un point accessible (Salerne, Vietri, Sorrente ou Praiano) et utilisez de là les bus, ferries ou hydroglisseurs.
      </p>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">ZTL et parking pour chaque village</h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-med-blue/5 text-charcoal">
              <th class="text-left px-4 py-3 font-semibold">Village</th>
              <th class="text-left px-4 py-3 font-semibold">ZTL</th>
              <th class="text-left px-4 py-3 font-semibold">Période</th>
              <th class="text-left px-4 py-3 font-semibold">Conseil</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {ztlData.map(r => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-semibold text-charcoal">{r.location}</td>
                <td class="px-4 py-3">
                  {r.ztl === 'Oui'
                    ? <span class="text-[10px] bg-red-50 text-red-600 px-2 py-0.5 rounded-full font-medium">Oui</span>
                    : <span class="text-[10px] bg-med-blue/5 text-med-blue px-2 py-0.5 rounded-full font-medium">Non</span>
                  }
                </td>
                <td class="px-4 py-3 text-slate-500">{r.period}</td>
                <td class="px-4 py-3 text-slate-600 text-xs">{r.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
