---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Guide pratique', url: '/fr-fr/guide/' },
  { name: 'Ferries & Hydroglisseurs', url: '/fr-fr/guide/ferries/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quelle est la différence entre ferry et hydroglisseur sur la Côte Amalfitaine ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le ferry (traghetto) est plus lent (50–90 min Naples–Capri) mais moins cher et plus stable. L'hydroglisseur (aliscafo) est plus rapide (40–50 min) mais plus coûteux et ne circule pas par mer agitée. En été, préférez l'hydroglisseur pour gagner du temps ; en hiver ou mauvais temps, le ferry est plus fiable." }
    },
    {
      "@type": "Question",
      "name": "Peut-on réserver les ferries en ligne ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, presque toutes les compagnies permettent la réservation en ligne : nlg.it, alilauro.it, snav.it, travelmar.it, caremar.it. En été (juillet–août), il est recommandé de réserver au moins 1–2 jours à l'avance." }
    },
    {
      "@type": "Question",
      "name": "Combien coûte le ferry de Naples à Capri ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ferry Naples–Capri (Caremar/SNAV) : ~€13–15 aller simple. Hydroglisseur (NLG/Alilauro) : ~€20–23 aller simple. Depuis Sorrente : ~€18–22 aller-retour en hydroglisseur." }
    },
    {
      "@type": "Question",
      "name": "Les ferries circulent-ils en hiver ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oui, mais avec une fréquence réduite. Naples–Capri : au moins 4–5 traversées par jour toute l'année. Les liaisons saisonnières (Positano, Amalfi, Salerne) fonctionnent d'avril à octobre." }
    }
  ]
};

const routes = [
  { from: 'Naples Beverello', to: 'Capri', time: '40–50 min (hydroglisseur) / 75 min (ferry)', price: '€20–23 / €13–15', companies: 'NLG, Alilauro, SNAV, Caremar', seasonal: false },
  { from: 'Naples Beverello', to: 'Ischia (Casamicciola/Porto)', time: '50 min (hydroglisseur) / 75 min (ferry)', price: '€20–24 / €12–14', companies: 'Alilauro, SNAV, Caremar, Medmar', seasonal: false },
  { from: 'Naples Beverello', to: 'Procida', time: '35 min (hydroglisseur)', price: '€15–18', companies: 'Alilauro, SNAV', seasonal: false },
  { from: 'Sorrente', to: 'Capri', time: '20–25 min (hydroglisseur)', price: '€18–22', companies: 'NLG, Alilauro', seasonal: false },
  { from: 'Pozzuoli', to: 'Ischia / Procida', time: '35 min / 15 min (ferry)', price: '€10–13 / €7–9', companies: 'Medmar, Caremar', seasonal: false },
  { from: 'Salerne', to: 'Amalfi / Positano / Capri', time: '45 min / 65 min / 100 min', price: '€8–12 / €12–16 / €18–22', companies: 'Travelmar, NLG', seasonal: true },
  { from: 'Naples Beverello', to: 'Positano / Amalfi', time: '75 min / 90 min', price: '€15–20 / €18–22', companies: 'NLG, Alilauro', seasonal: true },
];
---

<BaseLayout
  title="Ferries & Hydroglisseurs Côte Amalfitaine 2026 | Horaires et Tarifs"
  description="Guide complet des ferries et hydroglisseurs sur la Côte Amalfitaine : Naples–Capri, Naples–Ischia, Sorrente–Capri, Salerne–Amalfi–Positano. Compagnies, horaires et tarifs."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/traghetti-hero.jpg" alt="Ferry sur la Côte Amalfitaine" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Guide pratique</span>
        <span>/</span>
        <span class="text-white">Ferries & Hydroglisseurs</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Guide pratique</p>
        <h1 class="font-serif text-display text-white mb-4">Ferries & Hydroglisseurs</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Toutes les liaisons maritimes en Campanie : Naples, Sorrente, Salerne, Positano, Amalfi, Capri, Ischia et Procida. Compagnies, horaires indicatifs et tarifs mis à jour pour la saison 2026.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Toutes les liaisons principales</h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-med-blue/5 text-charcoal">
              <th class="text-left px-4 py-3 font-semibold">De</th>
              <th class="text-left px-4 py-3 font-semibold">À</th>
              <th class="text-left px-4 py-3 font-semibold">Durée</th>
              <th class="text-left px-4 py-3 font-semibold">Tarif (aller simple)</th>
              <th class="text-left px-4 py-3 font-semibold">Compagnies</th>
              <th class="text-left px-4 py-3 font-semibold">Saisonnier</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {routes.map(r => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-medium text-charcoal">{r.from}</td>
                <td class="px-4 py-3">{r.to}</td>
                <td class="px-4 py-3 text-slate-600">{r.time}</td>
                <td class="px-4 py-3 font-mono text-sm">{r.price}</td>
                <td class="px-4 py-3 text-slate-500 text-xs">{r.companies}</td>
                <td class="px-4 py-3">
                  {r.seasonal
                    ? <span class="text-[10px] bg-med-cream text-med-gold px-2 py-0.5 rounded-full font-medium">Avr–Oct</span>
                    : <span class="text-[10px] bg-med-blue/5 text-med-blue px-2 py-0.5 rounded-full font-medium">Toute l'année</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-slate-400 mt-2">* Tarifs et durées indicatifs. Vérifiez toujours auprès des compagnies : nlg.it, alilauro.it, snav.it, caremar.it, medmar.it, travelmar.it</p>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Conseils pratiques</p>
      <ul class="space-y-2">
        {[
          'En juillet et août, réservez les billets la veille : les premiers départs (7h00–8h30) se remplissent vite.',
          'Les hydroglisseurs ne circulent pas par mer agitée (Beaufort 4–5) : vérifiez toujours les prévisions météo marines.',
          'Le port d\'embarquement à Naples pour presque toutes les liaisons est le Molo Beverello (Piazza Municipio). Medmar part de Pozzuoli.',
          'Avec de jeunes enfants, le ferry est plus stable que l\'hydroglisseur.',
          'Les billets de retour peuvent s\'acheter sur l\'île — inutile de les acheter à l\'aller.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
