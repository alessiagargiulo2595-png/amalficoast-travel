---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Côte Amalfitaine', url: '/fr-fr/cote-amalfitaine/' },
  { name: 'Praiano', url: '/fr-fr/cote-amalfitaine/praiano/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Praiano",
  "description": "Praiano est le secret le mieux gardé de la Côte Amalfitaine : moins touristique que Positano, avec des couchers de soleil spectaculaires depuis San Gennaro, la plage Gavitella et la Marina di Praia.",
  "url": "https://amalficoast-travel.com/fr-fr/cote-amalfitaine/praiano/",
  "image": "https://amalficoast-travel.com/images/praiano-hero.jpg",
  "touristType": ["Nature", "Mer", "Coucher de soleil", "Authenticité"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "Salerne",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6108,
    "longitude": 14.5368
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment se rendre à Praiano depuis Positano ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depuis Positano, prenez le bus SITA en direction d'Amalfi — Praiano est à environ 15–20 minutes. En été, des ferries relient également Positano à la Marina di Praia de Praiano. La route côtière offre des vues spectaculaires."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est la meilleure plage de Praiano ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La plage Gavitella est la plus connue : accessible par un long escalier depuis la route principale, avec des eaux très claires et moins fréquentée que les plages de Positano. La Marina di Praia est un port pittoresque avec un restaurant et des possibilités de plongée."
      }
    },
    {
      "@type": "Question",
      "name": "Pourquoi Praiano est-elle moins touristique que Positano ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Praiano compte environ 2 000 habitants répartis sur les flancs de la montagne entre San Gennaro et Marina di Praia. L'absence d'hôtels de luxe très médiatisés et une infrastructure plus modeste ont préservé son caractère authentique. C'est un avantage pour les voyageurs qui cherchent la vraie vie locale."
      }
    },
    {
      "@type": "Question",
      "name": "Quel est le meilleur endroit pour voir le coucher de soleil à Praiano ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La terrasse de l'église San Gennaro, dans la partie haute du village, offre l'un des plus beaux couchers de soleil de toute la côte. Arrivez 30 minutes avant le coucher du soleil pour trouver une bonne place. L'entrée est libre."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il des hébergements à Praiano ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, Praiano propose des B&B, des appartements en location et quelques hôtels boutique à des prix sensiblement inférieurs à Positano. C'est une excellente base pour explorer la côte en bus ou en ferry tout en profitant d'un cadre plus tranquille."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Localisation', dd: 'Côte Amalfitaine, SA' },
  { dt: 'Population', dd: '~2 000 habitants' },
  { dt: 'Depuis Positano', dd: '~15 min (bus SITA)' },
  { dt: 'Depuis Amalfi', dd: '~30 min (bus SITA)' },
  { dt: 'Plage', dd: 'Gavitella, Marina di Praia' },
  { dt: 'Atout majeur', dd: 'Coucher de soleil San Gennaro' },
  { dt: 'Meilleure période', dd: 'Mai–Oct' },
  { dt: 'Monnaie', dd: 'Euro (€)' },
];
---

<BaseLayout
  title="Praiano 2026 : Guide Complet | Côte Amalfitaine"
  description="Guide de Praiano : plage Gavitella, coucher de soleil depuis San Gennaro, Marina di Praia, comment y arriver. Le village authentique de la Côte Amalfitaine, moins touristique que Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/praiano-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Côte Amalfitaine · Coucher de soleil & Authenticité</p>
        <h1 class="font-serif text-display text-white mb-4">Praiano</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Le secret le mieux gardé entre Positano et Amalfi. Praiano offre des couchers de soleil à couper le souffle depuis San Gennaro, une plage aux eaux cristallines et une atmosphère authentiquement locale — sans la foule ni les prix exorbitants de ses célèbres voisins.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Infos pratiques</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Comment y arriver</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Praiano est l'antithèse de Positano. Pas de boutiques de mode hors de prix, pas de célébrités photographiées par des paparazzis, pas de files d'attente pour la plage. À la place : des maisons blanches accrochées à la falaise, le son des cloches de l'église San Gennaro, des pêcheurs qui rentrent le soir avec leur prise et l'un des plus beaux couchers de soleil de tout le littoral méditerranéen.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Praiano est divisée en deux parties : San Gennaro, le noyau principal sur les hauteurs, et la Marina di Praia, un minuscule port au niveau de la mer encaissé entre deux falaises. Les deux valent le détour, et l'escalier qui les relie est lui-même un parcours panoramique.
          </p>
        </div>

        <!-- Le saviez-vous ? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Le saviez-vous ?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">2 000</p>
              <p class="text-white/60 text-xs italic mt-1">habitants, dont beaucoup vivent ici toute l'année</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">270°</p>
              <p class="text-white/60 text-xs italic mt-1">panorama depuis la terrasse de San Gennaro</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">XVI</p>
              <p class="text-white/60 text-xs italic mt-1">siècle : date de l'église San Gennaro</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            La tour sarrasine de Praiano, visible depuis la route côtière, faisait partie d'un réseau de tours de surveillance construites le long de la côte pour détecter les incursions de pirates barbaresques.
          </p>
        </div>

        <!-- Que voir -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Que voir à Praiano</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Coucher de soleil depuis San Gennaro</h3>
                <p class="text-slate-600 leading-relaxed">La terrasse de l'église San Gennaro offre une vue panoramique à 270° sur la mer et les falaises au crépuscule. Gratuit, accessible à tous, et l'un des couchers de soleil les plus spectaculaires de toute la Côte Amalfitaine.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Plage Gavitella</h3>
                <p class="text-slate-600 leading-relaxed">La plage principale de Praiano, accessible par un escalier depuis la route SS163. Eaux très claires, moins fréquentée que les plages voisines. Un club de plage propose des transats et la restauration.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Marina di Praia</h3>
                <p class="text-slate-600 leading-relaxed">Un minuscule port encaissé entre deux falaises avec quelques bateaux de pêche et un restaurant réputé. Point de départ pour des excursions en bateau vers la Grotte de l'Émeraude et le Fiordo di Furore.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Luminaria di San Domenico</h3>
                <p class="text-slate-600 leading-relaxed">En août, Praiano célèbre la Luminaria di San Domenico : des centaines de bougies illuminent les façades et les escaliers du village la nuit, créant une atmosphère féerique. L'un des événements les plus photogéniques de la côte.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Comment y arriver -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Comment se rendre à Praiano</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Praiano est bien desservie par le bus SITA tout au long de l'année. En été, des ferries saisonniers s'arrêtent à la Marina di Praia.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Bus SITA</h3><p class="text-white/50 text-sm leading-relaxed">Toute l'année sur la SS163. ~15 min depuis Positano, ~30 min depuis Amalfi. ~2,50 €.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Ferry (saisonnier)</h3><p class="text-white/50 text-sm leading-relaxed">Arrêt à la Marina di Praia d'avril à octobre. Connexion avec Positano, Amalfi et Salerne.</p></div>
              </div>
            </div>
            <a href="/fr-fr/guide/ferries/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Guide complet des transports
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Horaires bus -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
            Bus SITA — Sorrento ↔ Amalfi (arrêt Praiano)
          </h3>
          <p class="text-sm text-slate-500 mb-4">Le bus SITA dessert Praiano sur la ligne Sorrento–Amalfi via la SS163. Les arrêts sont sur la route principale (signalés).</p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Départ Positano</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivée Praiano</th>
                  <th class="text-left px-4 py-3 font-semibold">Fréquence</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-3 font-mono">08:15</td>
                  <td class="px-4 py-3 font-mono">08:30</td>
                  <td class="px-4 py-3 text-slate-500">Tous les jours</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-3 font-mono">10:05</td>
                  <td class="px-4 py-3 font-mono">10:20</td>
                  <td class="px-4 py-3 text-slate-500">Tous les jours</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-3 font-mono">12:05</td>
                  <td class="px-4 py-3 font-mono">12:20</td>
                  <td class="px-4 py-3 text-slate-500">Tous les jours</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-3 font-mono">14:05</td>
                  <td class="px-4 py-3 font-mono">14:20</td>
                  <td class="px-4 py-3 text-slate-500">Tous les jours</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-4 py-3 font-mono">16:35</td>
                  <td class="px-4 py-3 font-mono">16:50</td>
                  <td class="px-4 py-3 text-slate-500">Tous les jours</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Horaires indicatifs. Consultez sitasudtrasporti.it pour les horaires actualisés.</p>
        </div>

        <!-- Coins cachés -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Coins cachés de Praiano</h2>
          <p class="text-slate-500 mb-8">Un village à explorer sans carte : quatre découvertes pour les vrais curieux.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Grotte de l'Émeraude depuis Praiano</h3>
              <p class="text-sm text-slate-600 leading-relaxed">La plupart des touristes visitent la Grotte de l'Émeraude depuis Amalfi. Depuis la Marina di Praia de Praiano, des bateliers proposent des excursions moins chères et moins bondées vers cette merveille naturelle.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Sentier des Vierges</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Un sentier de randonnée reliant Praiano à Vettica Maggiore avec des vues imprenables sur la côte et des chapelles votive disséminées dans la végétation. Peu fréquenté même en haute saison.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Restaurant du port (Marina di Praia)</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Le petit restaurant au bord de l'eau de la Marina di Praia propose du poisson ultra-frais dans un décor de cartes postales. Réservez à l'avance en été — les tables sont rares et très demandées.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Piscine naturelle de la Tour Sarrasine</h3>
              <p class="text-sm text-slate-600 leading-relaxed">En contrebas de la tour sarrasine, une piscine naturelle dans la roche offre un bain en mer en dehors des plages aménagées. Accessible à pied depuis la route principale en quelques minutes.</p>
            </div>
          </div>
        </div>

        <!-- Conseil local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Conseil local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Dormez à Praiano, explorez depuis Praiano</h3>
              <p class="text-white/70 leading-relaxed">Praiano est la base idéale pour explorer la côte : moins chère que Positano ou Amalfi, bien reliée par bus et ferry, et nettement plus tranquille. Le soir, quand tous les visiteurs sont repartis, les ruelles sont à vous seul.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Questions fréquentes sur Praiano</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Infos pratiques — Praiano</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Conseils d'initiés -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Conseils d'initiés</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Arrivez à San Gennaro 30 min avant le coucher du soleil pour trouver la meilleure place sur la terrasse.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
