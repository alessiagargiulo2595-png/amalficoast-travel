---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Côte Amalfitaine', url: '/fr-fr/cote-amalfitaine/' },
  { name: 'Marina di Praia', url: '/fr-fr/cote-amalfitaine/marina-di-praia/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Marina di Praia",
  "description": "Marina di Praia est la plage sauvage et secrète de Praiano, accessible uniquement par 70 à 80 marches creusées dans la roche. Aucun service, 100 % authenticité, et les meilleurs couchers de soleil de la côte.",
  "url": "https://amalficoast-travel.com/fr-fr/cote-amalfitaine/marina-di-praia/",
  "image": "https://amalficoast-travel.com/images/praia-hero.jpg",
  "touristType": ["Nature sauvage", "Mer", "Authenticité", "Baignade"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "Salerne",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6053,
    "longitude": 14.5393
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Où est Marina di Praia exactement ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Marina di Praia est un minuscule port naturel encaissé entre deux falaises dans la partie basse de Praiano, à environ 15–20 minutes de marche à pied depuis le centre du village. Elle est accessible par 70 à 80 marches creusées directement dans la roche."
      }
    },
    {
      "@type": "Question",
      "name": "Comment accéder à Marina di Praia ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depuis le centre de Praiano, descendez l'escalier qui mène vers la mer. Les marches sont bien indiquées mais abruptes : elles font partie du charme du lieu. La descente prend environ 15 minutes, la remontée environ 20 minutes (c'est plus dur en montée). Pas de route jusqu'en bas, uniquement l'escalier."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il des services à Marina di Praia ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non. Aucun restaurant, aucun bar, aucun club de plage. C'est justement ce qui en fait son charme : authenticité absolue. Un petit restaurant rustique se trouve en haut, mais à Marina di Praia elle-même, il n'y a rien d'autre que la roche, la mer et le silence."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est la meilleure période pour visiter Marina di Praia ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mai à septembre pour la baignade, lorsque l'eau est chaude. Juin et septembre sont idéaux : l'eau est chaude, mais les foules de juillet-août ne sont pas encore arrivées. Les couchers de soleil sont spectaculaires toute l'année, mais les jours sans nuages (fréquents en mai et septembre) sont les meilleurs."
      }
    },
    {
      "@type": "Question",
      "name": "Est-ce que Marina di Praia est dangereuse ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Marina di Praia est loin du danger : c'est un endroit très sûr. Les seuls défis sont les marches escarpées (attention si vous avez des enfants ou des problèmes de mobilité) et le fait qu'il n'y a pas d'urgence médicale proche. L'eau est aussi calme qu'une piscine la plupart du temps en raison de sa position encaissée."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Localisation', dd: 'Praiano, Côte Amalfitaine' },
  { dt: 'Accès', dd: '70-80 marches creusées' },
  { dt: 'Depuis Positano', dd: '~25 min (à pied)' },
  { dt: 'Depuis Amalfi', dd: '~45 min (à pied)' },
  { dt: 'Services', dd: 'Aucun - 100 % sauvage' },
  { dt: 'Atout majeur', dd: 'Couchers de soleil & authenticité' },
  { dt: 'Meilleure période', dd: 'Mai–Sept' },
  { dt: 'Monnaie', dd: 'Euro (€)' },
];
---

<BaseLayout
  title="Marina di Praia 2026 : La Plage Sauvage de Praiano | Côte Amalfitaine"
  description="Marina di Praia : la plage secrète et sauvage de la Côte Amalfitaine. Accessible par 70 marches creusées dans la roche, 100 % authentique, zéro service. Couchers de soleil spectaculaires."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/praia-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Côte Amalfitaine · Authenticité Sauvage</p>
        <h1 class="font-serif text-display text-white mb-4">Marina di Praia</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La plage secrète de Praiano, accessible uniquement par 70 à 80 marches creusées dans la roche. Pas de services, pas de touristes, pas de bruit. Juste la roche, la mer turquoise et les meilleurs couchers de soleil de toute la côte.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Infos pratiques</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Comment y aller</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Marina di Praia n'est pas une destination touristique : c'est un endroit secret, réservé aux locaux et aux voyageurs qui font l'effort de descendre 80 marches pour y accéder. C'est l'une des rares plages de la Côte Amalfitaine complètement exempte d'infrastructure, de vendeurs de glaces ou de « photoshop ».
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Ce minuscule port encaissé entre deux falaises est le territoire des pêcheurs et des voyageurs aventureux qui apprécient l'authenticité avant tout. L'escalier qui la relie à Praiano est lui-même une aventure : marches étroites, parfois exposées, mais avec des vues qui vous coupent le souffle à chaque tournant.
          </p>
        </div>

        <!-- Le saviez-vous ? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Le saviez-vous ?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">70-80</p>
              <p class="text-white/60 text-xs italic mt-1">marches creusées dans la roche, pas d'ascenseur</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">0</p>
              <p class="text-white/60 text-xs italic mt-1">services : aucun restaurant, bar ou commerce</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">100 %</p>
              <p class="text-white/60 text-xs italic mt-1">authenticité : le seul endroit sans artifice</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Marina di Praia est l'un des rares endroits de la Côte Amalfitaine où aucun développement touristique n'a survécu. C'est volontaire : les locaux préfèrent la garder secrète.
          </p>
        </div>

        <!-- Que faire -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Activités à Marina di Praia</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Baignade dans le silence</h3>
                <p class="text-slate-600 leading-relaxed">L'eau à Marina di Praia est cristalline et calme, encaissée entre deux falaises qui la protègent du vent. Pas de vagues, pas de touristes, juste vous et la mer. Les enfants adorent parce que c'est sûr ; les adultes adorent parce que c'est silencieux.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Couchers de soleil spectaculaires</h3>
                <p class="text-slate-600 leading-relaxed">Les falaises qui entourent Marina di Praia créent un cadre parfait pour les couchers de soleil : le soleil disparaît lentement entre les roches, teintant le ciel de rouge et d'orange. Arrivez une heure avant le coucher du soleil et amenez un livre.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Exploration des roches</h3>
                <p class="text-slate-600 leading-relaxed">Les falaises qui encadrent Marina di Praia sont parsemées de petites grottes et de crevasses. Avec un masque et un tuba, explorez la vie sous-marine : poissons colorés, poulpes, étoiles de mer. Le monde sous-marin est intact parce que les touristes ne viennent presque jamais ici.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Pique-nique minimaliste</h3>
                <p class="text-slate-600 leading-relaxed">Apportez du pain, du fromage, des fruits et une bouteille de vin blanc frais. Asseyez-vous sur les roches plates, regardez les pêcheurs rentrer avec leur prise du jour, et mangez en silence. C'est le pique-nique idéal : pas d'interruption, pas de vendeurs, pas de bruit.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Comment y arriver -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Comment se rendre à Marina di Praia</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Marina di Praia est accessible uniquement à pied : il n'y a pas de route, pas de ferry direct. L'accès se fait en deux étapes : d'abord se rendre à Praiano (en bus ou en voiture), puis descendre les 80 marches.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Bus SITA</h3><p class="text-white/50 text-sm leading-relaxed">Praiano est sur la SS163. ~15 min depuis Positano, ~30 min depuis Amalfi. Une fois à Praiano, cherchez l'escalier qui descend vers la mer (bien indiqué). ~2,50 €.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Voiture</h3><p class="text-white/50 text-sm leading-relaxed">Garez-vous à Praiano (petits parkings sur la SS163). Ensuite, l'accès est uniquement pédestre par l'escalier. Pratique pour avoir une voiture si vous voulez explorer la côte.</p></div>
              </div>
            </div>
            <a href="/fr-fr/comment-venir/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Guide complet des transports
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Conseil local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Conseil local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Apportez tout avec vous</h3>
              <p class="text-white/70 leading-relaxed">Marina di Praia n'a aucun service. Apportez de l'eau en bouteille (la descente est difficile), une serviette, de la crème solaire et, si vous prévoyez de rester longtemps, nourriture et boissons. Il n'y a pas de toilettes non plus : planifiez en conséquence.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Questions fréquentes sur Marina di Praia</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Infos pratiques - Marina di Praia</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Conseils d'initiés -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Conseils d'initiés</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Descendez tôt le matin (avant 9h) pour avoir l'endroit presque entièrement pour vous.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Les escaliers sont escarpés et étroits : chaussures de sport obligatoires, talons interdits.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Apportez 2 litres d'eau minimum : la descente est difficile et il fait très chaud en été.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Visitez en mai, juin ou septembre : juillet-août sont trop chauds et le soleil cogne fort.</span>
            </li>
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Explorer la côte</p>
          <nav class="space-y-1">
            {[
              { href: '/fr-fr/cote-amalfitaine/praiano/', label: 'Praiano' },
              { href: '/fr-fr/cote-amalfitaine/positano/', label: 'Positano' },
              { href: '/fr-fr/cote-amalfitaine/amalfi/', label: 'Amalfi' },
              { href: '/fr-fr/cote-amalfitaine/ravello/', label: 'Ravello' },
              { href: '/fr-fr/cote-amalfitaine/maiori/', label: 'Maiori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Découvrez aussi la côte"
    items={[
      { name: 'Praiano',  href: '/fr-fr/cote-amalfitaine/praiano/',  tag: 'Authentique',       desc: 'Le secret bien gardé entre Positano et Amalfi avec des couchers de soleil spectaculaires.' },
      { name: 'Positano',  href: '/fr-fr/cote-amalfitaine/positano/',  tag: 'Iconique',         desc: 'Maisons colorées sur la mer et la plage la plus célèbre de la côte.' },
      { name: 'Amalfi',    href: '/fr-fr/cote-amalfitaine/amalfi/',    tag: 'Art & Histoire',   desc: 'La Cathédrale, le Cloître du Paradis et les ruelles de la république maritime.' },
      { name: 'Ravello',   href: '/fr-fr/cote-amalfitaine/ravello/',   tag: 'Panoramique',      desc: 'À 365m au-dessus de la mer avec des villas historiques et des vues à couper le souffle.' },
    ]}
  />

</BaseLayout>
