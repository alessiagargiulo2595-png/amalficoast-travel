---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Côte Amalfitaine', url: '/fr-fr/cote-amalfitaine/' },
  { name: 'Ravello', url: '/fr-fr/cote-amalfitaine/ravello/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Ravello",
  "description": "Ravello est un village médiéval perché à 350 m au-dessus de la mer, célèbre pour la Villa Rufolo, la Villa Cimbrone et le Festival de Ravello. La « ville de la musique » offre les vues les plus spectaculaires de toute la Côte Amalfitaine.",
  "url": "https://amalficoast-travel.com/fr-fr/cote-amalfitaine/ravello/",
  "image": "https://amalficoast-travel.com/images/ravello-hero.jpg",
  "touristType": ["Culture", "Musique", "Vues", "Jardins"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ravello",
    "addressRegion": "Salerne",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6492,
    "longitude": 14.6122
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment se rendre à Ravello depuis Amalfi ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depuis Amalfi, prenez le bus SITA jusqu'à Ravello (environ 25 min, ~1,30 €). Les bus partent de la place du port d'Amalfi. En voiture, la route est étroite et sinueuse — le bus est un meilleur choix. Il n'y a pas d'accès direct en ferry."
      }
    },
    {
      "@type": "Question",
      "name": "Quand a lieu le Festival de Ravello ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le Festival de Ravello se déroule chaque année de juin à septembre, avec des concerts dans le cadre spectaculaire de la Villa Rufolo. C'est l'un des festivals de musique classique les plus prestigieux d'Italie. Les billets doivent être achetés à l'avance sur ravellofestival.com."
      }
    },
    {
      "@type": "Question",
      "name": "Combien coûte l'entrée à la Villa Cimbrone ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "L'entrée aux jardins de la Villa Cimbrone coûte environ 7 € par adulte. Les jardins sont ouverts toute l'année de 9h00 jusqu'au coucher du soleil. La Terrasse de l'Infini (Belvedere dell'Infinito) est le belvédère le plus photographié de la côte."
      }
    },
    {
      "@type": "Question",
      "name": "Ravello vaut-il la visite sans assister au Festival ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolument. La Villa Rufolo et la Villa Cimbrone avec leurs jardins et leurs vues valent le déplacement indépendamment du Festival. Le centre médiéval, la Piazza Vescovado et la Cathédrale méritent également d'être explorés."
      }
    },
    {
      "@type": "Question",
      "name": "Peut-on visiter Ravello en une demi-journée depuis Amalfi ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, une demi-journée suffit pour visiter les deux villas et le centre médiéval. Prévoyez environ 3–4 heures : 1h pour la Villa Rufolo, 1h pour la Villa Cimbrone avec la Terrasse de l'Infini, et 30 min pour la cathédrale et la Piazza Vescovado."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Localisation', dd: 'Côte Amalfitaine, SA' },
  { dt: 'Altitude', dd: '350 m' },
  { dt: 'Population', dd: '~2 500 habitants' },
  { dt: 'Depuis Amalfi', dd: '~25 min (bus SITA)' },
  { dt: 'Transport', dd: 'Bus SITA uniquement' },
  { dt: 'À ne pas manquer', dd: 'Villa Rufolo, Villa Cimbrone' },
  { dt: 'Festival', dd: 'Juin–Sep 2026' },
  { dt: 'Meilleure période', dd: 'Mai–Oct' },
];
---

<BaseLayout
  title="Ravello 2026 : Guide Complet | Côte Amalfitaine"
  description="Tout sur Ravello : Villa Rufolo, Villa Cimbrone, le Festival de Ravello 2026, comment y arriver en bus depuis Amalfi. Le guide complet de la ville de la musique au-dessus de la Côte Amalfitaine."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/ravello-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Côte Amalfitaine · Musique & Jardins</p>
        <h1 class="font-serif text-display text-white mb-4">Ravello</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          À 350 mètres au-dessus de la mer Tyrrhénienne, Ravello domine la côte comme un décor de théâtre. Wagner y a composé. Greta Garbo s'y est cachée. Et chaque été, le Festival de Ravello transforme la Villa Rufolo en salle de concert suspendue entre ciel et mer.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Infos pratiques</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Comment y arriver</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Ravello est la seule ville de la Côte Amalfitaine sans accès direct à la mer — et c'est précisément ce qui fait son charme. Les vues depuis la Terrasse de l'Infini de la Villa Cimbrone figurent parmi les plus célèbres au monde, que Gore Vidal décrivit comme « les plus belles sur terre ».
        </p>

        <!-- Le saviez-vous ? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Le saviez-vous ?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">350 m</p>
              <p class="text-white/60 text-xs italic mt-1">altitude au-dessus de la mer</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1953</p>
              <p class="text-white/60 text-xs italic mt-1">année de fondation du Festival de Ravello</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">1880</p>
              <p class="text-white/60 text-xs italic mt-1">année où Wagner visita la Villa Rufolo</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Richard Wagner fut tellement ému par les jardins de la Villa Rufolo qu'il déclara avoir trouvé l'inspiration pour le jardin de Klingsor dans Parsifal. Un concert est organisé ici chaque année en sa mémoire.
          </p>
        </div>

        <!-- Que voir -->
        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Que voir à Ravello</h2>
          <div class="space-y-6">
            {[
              { title: 'Villa Rufolo', text: 'La villa du XIIIe siècle avec ses jardins en terrasses et le belvédère célèbre depuis lequel la mer se voit loin en contrebas. La scène de la Villa Rufolo est le lieu des concerts du Festival de Ravello. Ouvert tous les jours ; entrée ~7 €.' },
              { title: 'Villa Cimbrone', text: 'La villa la plus romantique de la côte, avec la Terrasse de l\'Infini (Belvedere dell\'Infinito) bordée de bustes de marbre dominant une étendue infinie de mer bleue. Ouverte toute l\'année de 9h au coucher du soleil ; entrée ~7 €.' },
              { title: 'Cathédrale de Ravello', text: 'La cathédrale du XIe siècle sur la Piazza Vescovado avec une remarquable porte en bronze du XIIe siècle. À l\'intérieur, deux ambons à mosaïques (XIIe–XIIIe s.) sont parmi les plus beaux exemples de marqueterie médiévale du sud de l\'Italie.' },
              { title: 'Bus SITA depuis Amalfi', text: 'La façon la plus facile et panoramique de rejoindre Ravello. Les bus partent de la place du port d\'Amalfi environ toutes les 40 minutes. Durée du trajet : ~25 minutes. Billet : ~1,30 €.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Comment y arriver -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 text-white">
          <h2 class="font-serif text-2xl font-bold text-white mb-6">Comment se rendre à Ravello</h2>
          <div class="overflow-x-auto rounded-2xl border border-white/10">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-white/5 text-white/70">
                  <th class="text-left px-4 py-3 font-semibold">Transport</th>
                  <th class="text-left px-4 py-3 font-semibold">Trajet</th>
                  <th class="text-left px-4 py-3 font-semibold">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-white/5">
                <tr><td class="px-4 py-3 text-white font-medium">Bus SITA</td><td class="px-4 py-3 text-white/60">Depuis le port d'Amalfi</td><td class="px-4 py-3 text-white/40 text-xs">~25 min, ~1,30 €, toutes les ~40 min</td></tr>
                <tr><td class="px-4 py-3 text-white font-medium">En voiture</td><td class="px-4 py-3 text-white/60">SP13 depuis Amalfi</td><td class="px-4 py-3 text-white/40 text-xs">Route étroite et sinueuse ; parkings payants à l'entrée</td></tr>
                <tr><td class="px-4 py-3 text-white font-medium">Taxi</td><td class="px-4 py-3 text-white/60">Depuis Amalfi ou Maiori</td><td class="px-4 py-3 text-white/40 text-xs">~20–25 €, à négocier à l'avance</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Coins cachés -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Coins cachés de Ravello</h2>
          <p class="text-slate-500 mb-8">Au-delà des villas : quatre endroits que peu de visiteurs découvrent.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Sentier de Ravello à Minori</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Un sentier de randonnée descendant vers Minori à travers des citronneraies et des terrasses cultivées. Vues extraordinaires sur la côte. Durée : ~1h30, niveau facile.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Chapelle de la Villa Cimbrone</h3>
              <p class="text-sm text-slate-600 leading-relaxed">La petite chapelle néogothique dans les jardins de la Villa Cimbrone, souvent ignorée des visiteurs pressés d'atteindre la Terrasse de l'Infini. Un moment de tranquillité insolite.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Bar Calce</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Le bar local de la Piazza Vescovado où les habitants de Ravello prennent leur café du matin. Atmosphère authentique et prix bien inférieurs aux établissements touristiques voisins.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Concert gratuit du Festival</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Chaque été, le Festival de Ravello propose quelques événements gratuits dans les espaces publics du village. Consultez le programme sur ravellofestival.com avant votre visite.</p>
            </div>
          </div>
        </div>

        <!-- Conseil local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Conseil local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">La Terrasse de l'Infini à l'heure dorée</h3>
              <p class="text-white/70 leading-relaxed">La Terrasse de l'Infini de la Villa Cimbrone est à couper le souffle à n'importe quelle heure, mais en fin d'après-midi (vers 17h–18h), la lumière dorée sur la mer est simplement magique. Évitez midi : les groupes de touristes occupent tout l'espace.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes sur Ravello</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Infos pratiques — Ravello</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Côte Amalfitaine</p>
          <nav class="space-y-1">
            {[
              { href: '/fr-fr/cote-amalfitaine/positano/', label: 'Positano' },
              { href: '/fr-fr/cote-amalfitaine/amalfi/', label: 'Amalfi' },
              { href: '/fr-fr/cote-amalfitaine/praiano/', label: 'Praiano' },
              { href: '/fr-fr/cote-amalfitaine/maiori/', label: 'Maiori' },
              { href: '/fr-fr/cote-amalfitaine/minori/', label: 'Minori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Découvrez aussi la côte"
    items={[
      { name: 'Amalfi',   href: '/fr-fr/cote-amalfitaine/amalfi/',   tag: 'Art & Histoire',    desc: 'La Cathédrale, le Cloître du Paradis et les ruelles de la république maritime.' },
      { name: 'Positano', href: '/fr-fr/cote-amalfitaine/positano/', tag: 'Iconique',            desc: 'Maisons colorées sur la mer et la plage la plus célèbre de la côte.' },
      { name: 'Praiano',  href: '/fr-fr/cote-amalfitaine/praiano/', tag: 'Coucher de soleil',   desc: 'Le coucher de soleil depuis San Gennaro et la plage de la Marina di Praia.' },
      { name: 'Capri',    href: '/fr-fr/isole/capri/',                tag: 'La plus iconique',   desc: 'Grotte Bleue, Faraglioni et la mondaine Piazzetta.' },
    ]}
  />

</BaseLayout>
