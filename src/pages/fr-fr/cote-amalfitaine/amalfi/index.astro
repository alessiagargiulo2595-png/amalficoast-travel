---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Côte Amalfitaine', url: '/fr-fr/cote-amalfitaine/' },
  { name: 'Amalfi', url: '/fr-fr/cote-amalfitaine/amalfi/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Amalfi",
  "description": "Amalfi est la capitale historique de la Côte Amalfitaine, ancienne puissante République Maritime médiévale. Célèbre pour la Cathédrale de Sant'Andrea, le Cloître du Paradis et son papier artisanal.",
  "url": "https://amalficoast-travel.com/fr-fr/cote-amalfitaine/amalfi/",
  "image": "https://amalficoast-travel.com/images/amalfi-hero.jpg",
  "touristType": ["Culture", "Histoire", "Mer", "Gastronomie"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "Salerne",
    "addressCountry": "IT",
    "postalCode": "84011"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6339,
    "longitude": 14.6027
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Comment se rendre à Amalfi depuis Naples ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depuis Naples, vous pouvez rejoindre Amalfi en ferry depuis le Molo Beverello (environ 90–105 min, saisonnier) ou en bus SITA depuis Sorrento via la SS163 (environ 90 min). En voiture, la SS163 est spectaculaire mais sinueuse : en été, il vaut mieux l'éviter."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle est la meilleure période pour visiter Amalfi ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Avril–juin et septembre–octobre sont idéaux : météo agréable, foule raisonnable, prix accessibles. Juillet et août sont la haute saison touristique. Novembre–mars est calme mais avec risque de pluie et services réduits."
      }
    },
    {
      "@type": "Question",
      "name": "Combien coûte le ferry de Salerne à Amalfi ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le ferry Travelmar de Salerne à Amalfi coûte environ 8–10 € par trajet. Les billets peuvent être achetés en ligne ou au guichet du port. Le service fonctionne approximativement d'avril à octobre."
      }
    },
    {
      "@type": "Question",
      "name": "Que voir à Amalfi en une journée ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "En une journée, vous pouvez visiter la Cathédrale de Sant'Andrea et le Cloître du Paradis, le Musée du Papier, le centre historique avec la Piazza del Duomo, et faire une promenade jusqu'à la Valle delle Ferriere. Le soir, dînez dans l'un des restaurants en bord de mer."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il un parking à Amalfi ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le stationnement est rare et coûteux (parkings Luna Rossa et Flavio Gioia : environ 4–5 €/heure). En été, une ZTL (zone à trafic limité) s'applique dans le centre historique. Il est recommandé d'arriver en ferry ou en bus SITA pour éviter la circulation sur la SS163."
      }
    }
  ]
};

const fastFacts = [
  { dt: 'Localisation', dd: 'Côte Amalfitaine, SA' },
  { dt: 'Population', dd: '~5 000 habitants' },
  { dt: 'Depuis Naples', dd: '~90 min (ferry)' },
  { dt: 'Depuis Sorrento', dd: '~90 min (bus SITA)' },
  { dt: 'ZTL', dd: 'Oui, en été' },
  { dt: 'Plage', dd: 'Galets (centre-ville)' },
  { dt: 'Meilleure période', dd: 'Avr–Juin / Sep–Oct' },
  { dt: 'Monnaie', dd: 'Euro (€)' },
];
---

<BaseLayout
  title="Amalfi 2026 : Guide Complet | Côte Amalfitaine"
  description="Tout sur Amalfi : comment y arriver, la Cathédrale, le Musée du Papier, horaires des ferries et bus, que voir, quand y aller. Le guide complet de la capitale historique de la Côte Amalfitaine."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/amalfi-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Côte Amalfitaine</p>
        <h1 class="font-serif text-display text-white mb-4">Amalfi</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La capitale historique de la côte : une République Maritime médiévale dont la tradition du papier artisanal vit encore dans ses ateliers, et dont la Cathédrale reste l'église la plus impressionnante du littoral tyrrhénien.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 transition-all duration-300">Infos pratiques</a>
          <a href="#how-to-get-here" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Comment y arriver</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Amalfi est bien plus qu'une carte postale. Entre le IXe et le XIIIe siècle, elle fut l'une des républiques maritimes les plus puissantes de la Méditerranée — au même rang que Venise, Gênes et Pise. Aujourd'hui, 5 000 habitants vivent sur les flancs d'une gorge spectaculaire creusée par le torrent Canneto, entre tours, couvents et une cathédrale qui justifie à elle seule le voyage.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            La ville a également donné au monde les Tables d'Amalfi — le plus ancien code maritime de l'Occident, datant d'environ le XIe siècle — et une tradition de fabrication du papier qui a produit le premier papier filigrané d'Europe.
          </p>
        </div>

        <!-- Le saviez-vous ? -->
        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Le saviez-vous ?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">IX</p>
              <p class="text-white/60 text-xs italic mt-1">siècle : fondation de la République Maritime</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">62</p>
              <p class="text-white/60 text-xs italic mt-1">marches du grand escalier de la Cathédrale</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">5 000</p>
              <p class="text-white/60 text-xs italic mt-1">habitants aujourd'hui</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Les Tables d'Amalfi (Tabula Amalfitana), le plus ancien code maritime de l'Occident, ont régi le commerce à travers la Méditerranée du XIe au XVIe siècle.
          </p>
        </div>

        <!-- Que voir -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Que voir à Amalfi</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Cathédrale de Sant'Andrea</h3>
                <p class="text-slate-600 leading-relaxed">La façade arabo-normande avec sa somptueuse mosaïque en noir et blanc et les 62 marches montant depuis la Piazza del Duomo sont l'image iconique d'Amalfi. Le Cloître du Paradis (Chiostro del Paradiso), un cloître arabo-normand du XIIIe siècle, est inclus dans le billet de la cathédrale. Ouvert tous les jours.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Musée du Papier (Museo della Carta)</h3>
                <p class="text-slate-600 leading-relaxed">Installé dans un moulin à papier du XIIIe siècle dans la Valle dei Mulini, ce musée retrace l'histoire de la fabrication du papier à Amalfi. Des démonstrations en direct montrent comment les feuilles sont fabriquées à la main selon des techniques traditionnelles. Entrée ~4 €.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Arsenal de la République Maritime</h3>
                <p class="text-slate-600 leading-relaxed">Le seul chantier naval médiéval de la République encore conservé, avec ses salles voûtées où étaient construites les galères. Aujourd'hui, il accueille des expositions temporaires et le Musée de la Boussole.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Valle delle Ferriere</h3>
                <p class="text-slate-600 leading-relaxed">Une réserve naturelle protégée au-dessus de la ville avec une cascade panoramique et une végétation luxuriante. Le sentier part du Musée du Papier et prend environ 2 heures aller-retour. Accès gratuit.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Comment y arriver -->
        <div id="how-to-get-here" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white mb-3 tracking-tight">Comment se rendre à Amalfi</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Amalfi est bien desservie par ferry et bus. En voiture, la SS163 est spectaculaire mais saturée en été — les transports en commun sont fortement recommandés.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">En ferry</h3><p class="text-white/50 text-sm leading-relaxed">Travelmar depuis Salerne (avril–octobre). NLG / Alilauro depuis Naples Molo Beverello (saisonnier). L'option la plus panoramique.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
                </div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Bus SITA</h3><p class="text-white/50 text-sm leading-relaxed">Depuis Sorrento le long de la SS163 (~90 min, ~2,50 €). Depuis Salerne direct (~75 min). Service toute l'année.</p></div>
              </div>
            </div>
            <a href="/fr-fr/guide/ferries/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">
              Guide complet des transports
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Horaires ferries -->
        <div>
          <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
            Horaires des ferries — Été 2026
          </h3>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">Travelmar — Salerne ↔ Amalfi</caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Départ Salerne</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivée Amalfi</th>
                  <th class="text-left px-4 py-3 font-semibold">Notes</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">07:15</td><td class="px-4 py-3 font-mono">08:30</td><td class="px-4 py-3 text-slate-500">Via Cetara, Maiori</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">09:00</td><td class="px-4 py-3 font-mono">10:15</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">11:00</td><td class="px-4 py-3 font-mono">12:15</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">14:15</td><td class="px-4 py-3 font-mono">15:30</td><td class="px-4 py-3 text-slate-500">—</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3 font-mono">16:30</td><td class="px-4 py-3 font-mono">17:45</td><td class="px-4 py-3 text-slate-500">—</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Horaires indicatifs pour 2026. Confirmez sur travelmar.it.</p>
        </div>

        <!-- Coins cachés -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-3 tracking-tight">Coins cachés d'Amalfi</h2>
          <p class="text-slate-500 mb-8">Au-delà des 62 marches : quatre découvertes que la plupart des visiteurs manquent.</p>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Fontana di Sant'Andrea</h3>
              <p class="text-sm text-slate-600 leading-relaxed">La fontaine baroque de la Piazza del Duomo, souvent ignorée des touristes pressés d'entrer dans la cathédrale. Un endroit idéal pour observer la vie locale le matin.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Valle dei Mulini</h3>
              <p class="text-sm text-slate-600 leading-relaxed">La vallée des moulins à papier, accessible à pied depuis le centre. Un parcours verdoyant avec d'anciens moulins restaurés et une atmosphère de village authentique loin des foules.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Plage de Santa Croce</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Une petite crique accessible uniquement à pied (20 min) ou en bateau depuis le port d'Amalfi. Moins connue que la plage principale, avec une eau cristalline.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Atelier de papier artisanal</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Plusieurs ateliers proposent des démonstrations de fabrication du papier à la main selon la méthode traditionnelle d'Amalfi. Une expérience unique à acheter sur place à des prix raisonnables.</p>
            </div>
          </div>
        </div>

        <!-- Conseil local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20">
              <svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
            </div>
            <div>
              <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Conseil local</p>
              <h3 class="font-serif text-2xl font-bold text-white mb-3 tracking-tight">Visitez la cathédrale tôt le matin</h3>
              <p class="text-white/70 leading-relaxed">La Cathédrale de Sant'Andrea est spectaculaire mais bondée en journée. Arrivez dès l'ouverture (9h00) pour profiter des mosaïques et du Cloître du Paradis sans la foule. Les guides de groupe n'arrivent généralement pas avant 10h30.</p>
            </div>
          </div>
          <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/2 w-80 h-80 bg-med-gold/10 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- FAQ -->
        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Questions fréquentes sur Amalfi</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Infos pratiques — Amalfi</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i, arr) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < arr.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <!-- Conseils d'initiés -->
        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Conseils d'initiés</p>
          <ul class="space-y-3">
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Arrivez en ferry depuis Salerne pour la plus belle entrée en scène sur la côte.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
              <span class="w-1.5 h-1.5 rounded-full bg-med-gold mt-1.5 flex-shrink-0"></span>
              <span>Achetez du papier artisanal d'Amalfi dans les boutiques de la Valle dei Mulini : moins cher qu'en centre-ville.</span>
            </li>
            <li class="flex items-start gap-2 text-sm text-charcoal">
