---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-fr';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Expériences', url: '/fr-fr/experiences/' },
  { name: 'Cours de Cuisine', url: '/fr-fr/experiences/cours-de-cuisine/' },
];

const facts = [
  { label: 'Durée', value: '4–5 heures' },
  { label: 'Zone', value: 'Péninsule Sorrentine · Côte Amalfitaine' },
  { label: 'Langue', value: 'Italien, Anglais' },
  { label: 'Inclus', value: 'Visite marché, cours, repas, recettes' },
  { label: 'Prix indicatif', value: 'à partir de €75 par personne' },
  { label: 'Idéal pour', value: 'Couples, groupes, amateurs de gastronomie' },
];

const otherExperiences = experiences.filter(e => e.id !== 'cours-de-cuisine');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Cours de Cuisine : Les Secrets de la Cuisine Côtière",
  "description": "Masterclass de cuisine campanienne sur la Péninsule Sorrentine et la Côte Amalfitaine. Ravioli alla Caprese, Gnocchi alla Sorrentina, Delizia al Limone et bien plus.",
  "location": {
    "@type": "Place",
    "name": "Péninsule Sorrentine et Côte Amalfitaine",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Cours de Cuisine Côte Amalfitaine 2026 | Cuisine Campanienne Authentique"
  description="Cours de cuisine sur la Péninsule Sorrentine et la Côte Amalfitaine : Ravioli alla Caprese, Totani e Patate, Delizia al Limone. Du marché aux fourneaux."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cooking-class-hero.jpg"
      alt="Cours de cuisine, sauce tomate campanienne - Péninsule Sorrentine"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Gastronomie · Péninsule Sorrentine</p>
      <h1 class="font-serif text-display text-white mb-6">Cours de Cuisine</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Les Secrets de la Cuisine Côtière.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Une plongée dans la culture méditerranéenne</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Les cours de cuisine sur la Péninsule Sorrentine et la Côte Amalfitaine ne sont pas de simples cours — ce sont de véritables plongées dans la culture méditerranéenne. Beaucoup de ces expériences commencent bien avant d'allumer les fourneaux : le rituel débute parmi les étals des marchés locaux ou dans les vergers en terrasses perchés au-dessus de la mer, où l'on apprend à choisir la tomate parfaite et à reconnaître le parfum du basilic "napolitain" à grandes feuilles.
          </p>
        </div>

        <!-- Le Menu de la Tradition -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Le Menu de la Tradition : Les Piliers de la Saveur</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Lors de ces masterclasses, les participants ont l'opportunité de s'essayer à des recettes qui représentent l'âme de la Campanie.
          </p>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Entrée — Impepata di Cozze</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un classique intemporel qui célèbre la fraîcheur de la mer. Peu d'ingrédients — moules, poivre noir, persil et citron de Sorrente — pour un résultat qui renferme toute la saveur du Golfe.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Premier Plat — Ravioli alla Caprese</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Le symbole du dimanche. Des pâtes fraîches préparées avec une pâte simple (eau et farine), fourrées à la typique caciotta sorrentine et à une pincée de marjolaine fraîche, servies avec une légère sauce tomate.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Plat Principal — Totani e Patate alla Praianese</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un plat typique des pêcheurs de la Costiera. La douceur du calmar se fond à l'onctuosité des pommes de terre locales, le tout déglacé au vin blanc et parfumé à l'ail et au piment.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">4</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Dessert — Delizia al Limone</h4>
                <p class="text-slate-600 text-sm leading-relaxed">La reine de la pâtisserie locale. Un moelleux en forme de dôme, fourré et recouvert d'une crème soyeuse parfumée au sfusato amalfitain ou au citron IGP de Sorrente.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Image éditoriale -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/cooking-class-pasta.jpg"
            alt="Préparation de pâtes fraîches lors d'un cours de cuisine sur la Côte Amalfitaine"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <!-- L'Art de Faire -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">L'Art de Faire</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            L'objectif de ces masterclasses est de dévoiler les secrets du régime méditerranéen. On commence souvent par la préparation des pâtes fraîches : apprendre à doser eau et farine pour créer les iconiques Ravioli alla Caprese ou les Gnocchi alla Sorrentina, qui exigent une technique particulière — et des doigts rapides ! — pour obtenir la bonne consistance poreuse qui absorbe la sauce tomate et le fior di latte filant de la région. Les secrets de la pâtisserie locale ne manquent jamais, où la précision s'allie au parfum des agrumes cueillis à l'aube.
          </p>
        </div>

        <!-- Conseil local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Conseil Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Pour une expérience authentique, choisissez les cours qui se tiennent dans d'anciennes maisons de campagne ou directement dans les vergers agrumicoles, à l'ombre des "pagliarelle".
          </p>
          <p class="text-slate-600 leading-relaxed">
            Un secret local pour des gnocchis parfaits ? Utilisez toujours de vieilles pommes de terre : elles contiennent moins d'eau et nécessitent donc moins de farine lors du pétrissage. Le résultat ? Un gnoccho incroyablement léger qui fond littéralement en bouche.
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            En Bref
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/fr-fr/experiences/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Toutes les expériences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Autres Expériences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Autres Expériences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
