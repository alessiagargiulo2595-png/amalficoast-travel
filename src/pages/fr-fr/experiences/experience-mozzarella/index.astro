---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-fr';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Expériences', url: '/fr-fr/experiences/' },
  { name: 'Expérience Mozzarella', url: '/fr-fr/experiences/experience-mozzarella/' },
];

const facts = [
  { label: 'Durée', value: '3–4 heures' },
  { label: 'Zone', value: 'Péninsule Sorrentine' },
  { label: 'Langue', value: 'Italien, Anglais' },
  { label: 'Inclus', value: 'Dégustation, tablier, recettes' },
  { label: 'Prix indicatif', value: 'à partir de €65 par personne' },
  { label: 'Idéal pour', value: 'Couples, familles, amateurs de gastronomie' },
];

const otherExperiences = experiences.filter(e => e.id !== 'experience-mozzarella');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Expérience Mozzarella : L'Art du Fromager",
  "description": "Une expérience authentique de fromagerie sur la Péninsule Sorrentine. Apprenez à faire la mozzarella et découvrez le légendaire Provolone del Monaco DOP.",
  "location": {
    "@type": "Place",
    "name": "Péninsule Sorrentine",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Expérience Mozzarella Péninsule Sorrentine 2026 | Art du Fromager"
  description="Apprenez à faire la mozzarella et découvrez le Provolone del Monaco DOP avec un maître fromager sur la Péninsule Sorrentine."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/mozzarella-provolone-hero.jpg"
      alt="Provolone del Monaco DOP, Péninsule Sorrentine"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Gastronomie · Péninsule Sorrentine</p>
      <h1 class="font-serif text-display text-white mb-6">Expérience Mozzarella</h1>
      <p class="text-lg md:text-xl font-light text-white/80">De la caille filante au trésor affiné des Monti Lattari.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">L'Art du Fromager</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Sur la Péninsule Sorrentine, l'art fromager est une vocation transmise depuis des siècles. Participer à cette expérience ne signifie pas seulement déguster — c'est mettre les mains dans la matière première née des pâturages préservés des Monti Lattari. De la fraîcheur immédiate de la mozzarella à la complexité du Provolone del Monaco, nous vous révélerons les secrets de l'excellence laitière campanienne.
          </p>
        </div>

        <!-- Image éditoriale -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/mozzarella-cagliata.jpg"
            alt="Caille fraîche travaillée par le maître fromager"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Provolone del Monaco DOP : L'Histoire derrière un Nom Légendaire</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Si la mozzarella est la "reine", le Provolone del Monaco est sans conteste le "roi" incontesté de nos montagnes. Mais pourquoi ce nom insolite ?
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            L'histoire remonte aux années 1700, lorsque les bergers des Monti Lattari descendaient à l'aube vers le port de Naples pour vendre leurs produits. Pour se protéger de l'humidité et du froid de la nuit lors du long voyage en mer, les fromagers se drapaient dans de lourdes capes en toile de jute sombre, semblables à un habit de moine. À leur arrivée sur le marché de Naples, les gens ont commencé à les appeler familièrement "les moines" et, par conséquent, l'exquis fromage qu'ils apportaient est devenu connu de tous sous le nom de Provolone del Monaco.
          </p>

          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-4">Un Cahier des Charges Rigoureux</h3>
          <p class="text-slate-600 text-lg leading-relaxed">
            Aujourd'hui ce fromage est protégé par l'appellation DOP. Il est produit exclusivement avec du lait de vache, dont au moins 20 % doit provenir de la race Agerolese, une race précieuse et rare qui confère au fromage une saveur unique : douce et beurrée au premier abord, mais avec une finale épicée et aromatique qui s'intensifie avec l'affinage (qui doit durer au moins 6 mois).
          </p>
        </div>

        <!-- Programme -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Ce qui se passe lors d'une expérience mozzarella</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Filage en Direct</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Vous regarderez le maître fromager transformer le lait en tresses et bouchées sous vos yeux.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Atelier Pratique</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Vous aurez l'occasion de "mozzare" (couper et façonner) de la mozzarella fraîche de vos propres mains, en sentant la chaleur et la texture de la caille filante.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Dégustation Verticale d'Affinages</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Une dégustation guidée qui part du fior di latte le plus frais pour finir avec le Provolone del Monaco DOP, accompagné de miel local et de noix de Sorrente.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Conseil local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Conseil Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Lors de la dégustation du Provolone del Monaco, cherchez les petits trous (occhiature) : ils doivent avoir la taille d'un grain de poivre. Mais le vrai secret est l'accord : essayez-le avec un verre de <strong>Gragnano frais et pétillant</strong>. Les bulles nettoient le palais de la richesse du fromage, faisant ressortir la note épicée de l'Agerolese.
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            En Bref
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/fr-fr/experiences/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Toutes les expériences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Autres Expériences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Autres Expériences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
