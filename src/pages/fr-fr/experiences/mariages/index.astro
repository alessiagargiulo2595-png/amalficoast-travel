---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-fr';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Expériences', url: '/fr-fr/experiences/' },
  { name: 'Mariages', url: '/fr-fr/experiences/mariages/' },
];

const facts = [
  { label: 'Type', value: 'Cérémonie civile ou religieuse' },
  { label: 'Zone', value: 'Péninsule Sorrentine · Côte Amalfitaine' },
  { label: 'Langue', value: 'Italien, Anglais, autres sur demande' },
  { label: 'Meilleure saison', value: 'Avril – Octobre' },
  { label: 'Idéal pour', value: 'Destination Wedding, couples internationaux' },
  { label: 'Organisation', value: 'Wedding planner local recommandé' },
];

const otherExperiences = experiences.filter(e => e.id !== 'mariages');

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Mariages sur la Côte Amalfitaine et la Péninsule Sorrentine",
  "description": "Guide des plus beaux lieux pour se marier sur la Côte Amalfitaine et la Péninsule Sorrentine : cloîtres médiévaux, églises à pic sur la mer et villas historiques pour un Destination Wedding inoubliable.",
  "areaServed": {
    "@type": "Place",
    "name": "Côte Amalfitaine et Péninsule Sorrentine",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "provider": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Mariages Côte Amalfitaine 2026 | Lieux, Églises & Destination Wedding"
  description="Se marier sur la Côte Amalfitaine et la Péninsule Sorrentine : les plus beaux lieux pour cérémonies civiles et religieuses, du Cloître San Francesco aux églises à pic sur la mer."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaService]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/matrimoni-chiostro-hero.jpg"
      alt="Cloître San Francesco, Sorrente - lieu pour mariages civils"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Wedding · Côte Amalfitaine</p>
      <h1 class="font-serif text-display text-white mb-6">Mariages</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Vœux Suspendus entre Roc et Sel.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">La capitale mondiale du Destination Wedding</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Ce n'est pas un hasard si Sorrente et la Côte Amalfitaine figurent parmi les destinations de mariage les plus convoitées au monde. Ici la beauté n'est pas qu'un détail, c'est une complice silencieuse : elle se retrouve dans la lumière dorée qui caresse les villages au coucher du soleil, dans l'architecture des églises millénaires et dans le parfum enivrant des fleurs d'oranger qui envahit l'air au printemps. Se marier ici signifie inscrire sa propre histoire d'amour dans un cadre légendaire, où chaque panorama semble peint expressément pour un album photographique inoubliable.
          </p>
        </div>

        <!-- Cérémonie civile -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Le Charme de la Cérémonie Civile : Histoire et Nature</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Au-delà des célébrations religieuses, le territoire offre des lieux municipaux d'une beauté époustouflante pour les cérémonies civiles, permettant de prononcer le "Oui" officiel dans des contextes qui fusionnent histoire et nature. De nombreuses administrations locales ont ouvert les portes de villas historiques et de jardins botaniques, transformant la bureaucratie en un moment de pure poésie.
          </p>

          <div class="space-y-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">Le Cloître San Francesco — Sorrente</h3>
              <p class="text-slate-600 leading-relaxed mb-4">
                Sans conteste le lieu le plus emblématique pour une cérémonie civile sur la Péninsule Sorrentine. Ce cloître du XIVe siècle est un joyau architectural où différents styles — du gothique tardif à la Renaissance — se fondent dans une étreinte d'arcs entrecroisés et de colonnes en tuf. L'atmosphère est intime, presque mystique, animée par des plantes grimpantes et des fleurs qui ornent les murs médiévaux.
              </p>
              <p class="text-slate-600 leading-relaxed">
                À quelques pas du cloître, la Villa Comunale offre une terrasse naturelle avec une vue imprenable sur Capri, parfaite pour les premières photos de jeunes mariés juste après la cérémonie.
              </p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">Terrasses et Musées</h3>
              <p class="text-slate-600 leading-relaxed">
                Au-delà du Cloître, Sorrente offre des lieux comme le Museo Correale di Terranova ou la Villa Fondi à Piano di Sorrento, où les jardins à pic sur la mer et les vestiges archéologiques témoignent d'une promesse éternelle.
              </p>
            </div>
          </div>
        </div>

        <!-- Églises monumentales -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Églises Monumentales : Autels entre Ciel et Mer</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Pour ceux qui rêvent d'une cérémonie religieuse, la Côte abrite quelques-uns des lieux de culte les plus suggestifs au monde, où la foi rencontre le vertige de la côte.
          </p>

          <div class="rounded-[2rem] overflow-hidden shadow-xl mb-6">
            <img
              src="/images/chiesa-annunziata-vico.webp"
              alt="Église de la Santissima Annunziata à Vico Equense, à pic sur le Golfe de Naples avec le Vésuve en arrière-plan"
              class="w-full h-72 object-cover"
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          </div>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Église de la Santissima Annunziata — Vico Equense</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Souvent décrite comme "la plus belle église d'Italie", c'est un joyau gothique à la façade rose perché sur un promontoire à pic sur la mer. Se marier ici signifie échanger ses vœux avec un regard qui embrasse tout le Golfe de Naples et le Vésuve à l'horizon. C'est la seule église au monde qui semble littéralement suspendue au-dessus des vagues.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Le Dôme d'Amalfi — Sant'Andrea</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Pour ceux qui rêvent d'une entrée triomphale. Son imposant escalier et son style arabo-normand offrent une majesté intemporelle au cœur de la Côte.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Santa Maria Assunta — Positano</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Célèbre pour son dôme en majolique jaune et verte qui brille sous le soleil, à quelques pas de la grande plage. Parfaite pour un mariage glamour et iconique qui respire l'esprit de la Dolce Vita.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Réceptions -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Expériences et Réceptions</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Des demeures historiques de Ravello — comme la Villa Cimbrone avec sa Terrasse de l'Infini — aux criques secrètes accessibles uniquement en bateau pour une fête exclusive au bord de la mer, les possibilités sont infinies. Beaucoup de couples choisissent d'accueillir leurs invités avec un typique apéritif sorrentinois dans les limoniers, transformant le week-end de mariage en une découverte gastronomique et détente.
          </p>
        </div>

        <!-- Conseil local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Conseil Local pour les Mariés</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Si vous choisissez la Santissima Annunziata à Vico Equense, planifiez la sortie de l'église au coucher du soleil : la lumière frappant la façade rose crée un reflet magique, parfait pour des photos sans filtre. Pour le Cloître San Francesco, notez que l'acoustique est extraordinaire : une harpe ou un quatuor à cordes rendra la cérémonie civile une expérience à couper le souffle.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Un conseil pratique pour les mariées : les ruelles de la Côte sont magnifiques mais traîtresses pour les talons aiguilles. Prévoyez des ballerines de luxe ou des compensés pour vous déplacer entre les ruelles, et gardez les hauts talons pour la réception !
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            En Bref
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/fr-fr/experiences/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Toutes les expériences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Autres Expériences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Autres Expériences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
