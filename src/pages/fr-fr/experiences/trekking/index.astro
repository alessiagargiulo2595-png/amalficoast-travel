---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Expériences', url: '/fr-fr/experiences/' },
  { name: 'Trekking & Sentier des Dieux', url: '/fr-fr/experiences/trekking/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quelle est la difficulté du Sentier des Dieux ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le Sentier des Dieux (d'Agerola à Nocelle) est classé EE (randonneurs expérimentés) : 8 km, ~500 m de dénivelé, 3-4 heures. Chaussures de randonnée, bonne condition physique et absence de vertige requis. Pas adapté aux jeunes enfants ni aux personnes à mobilité réduite." }
    },
    {
      "@type": "Question",
      "name": "Comment rejoindre le Sentier des Dieux ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Point de départ : Agerola (hameau San Lazzaro, 618 m d'altitude). Depuis Amalfi : bus SITA vers Agerola (~45 min, liaisons limitées). Depuis Naples ou Salerne : train/bus jusqu'à Amalfi, puis bus vers Agerola. Départ matinal (9h00-10h00) recommandé." }
    },
    {
      "@type": "Question",
      "name": "Peut-on faire le Sentier des Dieux en sens inverse ?",
      "acceptedAnswer": { "@type": "Answer", "text": "Techniquement oui, mais déconseillé : le sens Agerola→Nocelle est presque entièrement en descente et plus sûr. L'inverse (Nocelle→Agerola) implique 500 m de montée raide sur terrain instable. La signalétique CAI est conçue pour le sens traditionnel." }
    }
  ]
};

const trails = [
  { name: 'Sentier des Dieux', difficulty: 'EE', km: '8 km', time: '3-4h', start: 'Agerola (S. Lazzaro)', end: 'Nocelle (Positano)', highlights: 'Vues côtières à couper le souffle, flore méditerranéenne, pas d\'asphalte' },
  { name: 'Valle delle Ferriere', difficulty: 'E', km: '7 km A/R', time: '2h30-3h', start: 'Centre d\'Amalfi', end: 'Amalfi (retour)', highlights: 'Cascades, fougères tropicales, papyrus sauvages, ombre naturelle' },
  { name: "Via dell'Infinito (Ravello)", difficulty: 'E', km: '5 km A/R', time: '2h', start: 'Ravello', end: 'Ravello', highlights: 'Vue panoramique sur la côte, oliveraies, silence total' },
  { name: 'Punta Campanella', difficulty: 'E', km: '6 km A/R', time: '2h30', start: 'Termini (Massa Lubrense)', end: 'Termini', highlights: 'Pointe la plus au sud, ruines romaines, vue sur Capri, réserve marine' },
  { name: 'Monte Solaro (Capri)', difficulty: 'E', km: '4 km', time: '2h (montée)', start: 'Anacapri', end: 'Anacapri (télésiège retour)', highlights: '589 m, panorama 360°, sanctuaire, silence' },
];
---

<BaseLayout
  title="Trekking Côte Amalfitaine 2026 | Sentier des Dieux et Randonnées"
  description="Les meilleures randonnées sur la Côte Amalfitaine : Sentier des Dieux (Agerola-Nocelle), Valle delle Ferriere, Punta Campanella. Difficulté, durées et comment y aller."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/trekking-hero.jpg" alt="Sentier des Dieux, Côte Amalfitaine" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/80"></div>
    <div class="relative z-10 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/fr-fr/" class="hover:text-white transition-colors">Accueil</a>
        <span>/</span>
        <span class="text-white/60">Expériences</span>
        <span>/</span>
        <span class="text-white">Trekking</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Expériences</p>
        <h1 class="font-serif text-display text-white mb-4">Trekking & Sentier des Dieux</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La Côte Amalfitaine n'est pas que plages et ferries : c'est aussi l'un des paysages les plus spectaculaires d'Europe à parcourir à pied. Du légendaire Sentier des Dieux aux cascades de la Valle delle Ferriere.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Les 5 sentiers incontournables</h2>
      <div class="space-y-4">
        {trails.map(t => (
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6 hover:border-med-blue/30 transition-colors">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-semibold text-charcoal text-lg">{t.name}</h3>
              <span class={`text-[10px] uppercase tracking-wide px-2 py-1 rounded-full font-medium flex-shrink-0 ${t.difficulty === 'EE' ? 'bg-red-50 text-red-600' : 'bg-med-blue/5 text-med-blue'}`}>
                {t.difficulty === 'EE' ? 'EE - Exigeant' : 'E - Facile'}
              </span>
            </div>
            <div class="grid sm:grid-cols-4 gap-3 text-sm mb-3">
              <div><span class="text-slate-400">Distance</span><br /><span class="font-medium">{t.km}</span></div>
              <div><span class="text-slate-400">Durée</span><br /><span class="font-medium">{t.time}</span></div>
              <div><span class="text-slate-400">Départ</span><br /><span class="font-medium">{t.start}</span></div>
              <div><span class="text-slate-400">Arrivée</span><br /><span class="font-medium">{t.end}</span></div>
            </div>
            <p class="text-sm text-med-blue font-medium">{t.highlights}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Sentier des Dieux - Guide Rapide</p>
      <div class="grid sm:grid-cols-2 gap-6">
        <div><p class="text-white/60 text-sm mb-1">Accès au départ</p><p class="text-sm leading-relaxed">Depuis Amalfi : bus SITA vers Agerola (liaisons limitées, ~45 min). Conseillé : partir d'Amalfi à 8h30 pour prendre le bus de 9h15 vers Agerola.</p></div>
        <div><p class="text-white/60 text-sm mb-1">Retour depuis l'arrivée</p><p class="text-sm leading-relaxed">Depuis Nocelle : bus local vers Positano centre (~15 min) ou descente à pied (~1.000 marches, 45 min). Depuis Positano : bus SITA ou ferry vers Amalfi/Sorrente/Naples.</p></div>
        <div><p class="text-white/60 text-sm mb-1">Équipement</p><p class="text-sm leading-relaxed">Chaussures de randonnée (pas de sandales), 1,5L d'eau, chapeau, crème solaire, encas, veste légère. Le sentier n'a pas de points d'eau ni de commerces.</p></div>
        <div><p class="text-white/60 text-sm mb-1">Meilleure saison</p><p class="text-sm leading-relaxed">Avril-juin et septembre-octobre. En juillet-août la chaleur rend le parcours épuisant et bondé. En hiver possible mais boueux et glissant.</p></div>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Questions fréquentes</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>
  </div>

  <CorrelationSlider
    heading="Explorer les destinations de trekking"
    items={[
      { name: 'Positano',       href: '/fr-fr/cote-amalfitaine/positano/',             tag: 'Arrivée sentier', desc: 'Le village coloré où se termine le Sentier des Dieux.' },
      { name: 'Amalfi',         href: '/fr-fr/cote-amalfitaine/amalfi/',               tag: 'Départ Valle',    desc: 'Point de départ pour la Valle delle Ferriere.' },
      { name: 'Massa Lubrense', href: '/fr-fr/peninsule-sorrentine/massa-lubrense/',   tag: 'Punta Campanella', desc: 'Réserve marine avec le sentier vers Punta Campanella.' },
      { name: 'Capri',          href: '/fr-fr/iles/capri/',                             tag: 'Monte Solaro',    desc: 'Télésiège ou trekking jusqu\'au sommet de 589 m.' },
    ]}
  />

</BaseLayout>
