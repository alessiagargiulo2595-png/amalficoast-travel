---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-fr';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Expériences', url: '/fr-fr/experiences/' },
  { name: 'Restaurants Étoilés', url: '/fr-fr/experiences/restaurants-etoiles/' },
];

const facts = [
  { label: 'Guide', value: 'Michelin 2026' },
  { label: 'Zone', value: 'Péninsule Sorrentine · Côte Amalfitaine' },
  { label: 'Adresse phare', value: 'Quattro Passi - 3 Étoiles Michelin' },
  { label: 'Réservation', value: '3–4 mois à l\'avance (week-ends)' },
  { label: 'Idéal pour', value: 'Foodies, occasions spéciales, anniversaires' },
  { label: 'À ne pas manquer', value: 'Visite de la cave creusée dans le roc' },
];

const otherExperiences = experiences.filter(e => e.id !== 'restaurants-etoiles');

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Restaurants Michelin 2026 - Sorrente et Côte Amalfitaine",
  "description": "Le classement 2026 des meilleurs restaurants étoilés Michelin entre la Péninsule Sorrentine et la Côte Amalfitaine : Quattro Passi, Il Buco, Don Alfonso 1890 et plus encore.",
  "url": "https://amalficoast-travel.com/fr-fr/experiences/restaurants-etoiles/",
  "numberOfItems": 8,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Quattro Passi - Nerano (3 Étoiles Michelin)" },
    { "@type": "ListItem", "position": 2, "name": "Il Buco - Sorrente" },
    { "@type": "ListItem", "position": 3, "name": "Lorelei - Sorrente" },
    { "@type": "ListItem", "position": 4, "name": "Terrazza Bosquet - Sorrente" },
    { "@type": "ListItem", "position": 5, "name": "Don Alfonso 1890 - Sant'Agata sui Due Golfi" },
    { "@type": "ListItem", "position": 6, "name": "La Caravella - Amalfi" },
    { "@type": "ListItem", "position": 7, "name": "Glicine - Positano" },
    { "@type": "ListItem", "position": 8, "name": "Zass e Li Galli - Positano" },
  ],
};
---

<BaseLayout
  title="Restaurants Étoilés Côte Amalfitaine 2026 | Guide Michelin"
  description="Guide des meilleurs restaurants étoilés Michelin 2026 entre Sorrente et la Côte Amalfitaine : Quattro Passi (3 étoiles), Il Buco, Don Alfonso 1890 et les joyaux de Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/stellati-hero.jpg"
      alt="Plat de haute gastronomie dans un restaurant étoilé Michelin, Côte Amalfitaine"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Fine Dining · Côte Amalfitaine</p>
      <h1 class="font-serif text-display text-white mb-6">Restaurants Étoilés</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La Constellation des Saveurs 2026.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Un pèlerinage au cœur de l'excellence gastronomique</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            S'il existe une terre où la haute cuisine est chez elle, c'est bien la région qui embrasse Sorrente et la Côte Amalfitaine. En 2026, le Guide Michelin confirme ce territoire comme le plus lumineux d'Italie : la Campanie n'est pas seulement en tête pour le nombre total d'étoiles, mais détient un record unique de densité gastronomique.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Songez qu'en dépit d'être l'une des plus petites régions d'Italie par superficie, la Campanie abrite environ <strong>12 % des restaurants étoilés de toute la péninsule italienne</strong>, surpassant en concentration par kilomètre carré des titans du goût comme le Piémont et la Lombardie. Dans cette petite bande de terre suspendue au-dessus de la mer, l'excellence culinaire n'est pas l'exception mais une véritable vocation territoriale.
          </p>
        </div>

        <!-- Le Classement 2026 -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Le Classement 2026 : Les Protagonistes</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Le paysage gastronomique 2026 voit les grands noms reconfirmés, ceux qui ont fait de cette zone une destination de pèlerinage pour les foodies du monde entier.
          </p>

          <div class="space-y-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Quattro Passi — Nerano, Massa Lubrense</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Le Sommet Absolu</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                Le légendaire Quattro Passi à Nerano conserve ses prestigieuses 3 Étoiles Michelin, seul restaurant de la région à avoir atteint le sommet mondial. Sa cuisine est un hymne à la pureté des saveurs marines réinterprétées avec une technique irréprochable.
              </p>
            </div>

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Les Étoiles de Sorrente</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Une ville, trois adresses incontournables</span>
                </div>
              </div>
              <div class="space-y-4 mt-4">
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Il Buco</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Installé dans une évocatrice ancienne rampe de monastère, où l'histoire du bâtiment dialogue avec la cuisine du terroir.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Lorelei</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Cuisine d'avant-garde sur une terrasse de rêve : deux expériences sensorielles en une.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Terrazza Bosquet</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Temple iconique du goût au sein de l'Excelsior Vittoria : luxe, histoire et haute cuisine sous le même toit.</p>
                </div>
              </div>
            </div>

            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Icônes et Nouvelles Découvertes</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">De Sant'Agata à Positano</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                On ne peut pas dire avoir vécu la Côte sans mentionner le <strong>Don Alfonso 1890</strong> à Sant'Agata sui Due Golfi, pionnier de la durabilité, ou les joyaux d'Amalfi et Positano : <strong>La Caravella</strong>, <strong>Glicine</strong>, <strong>Zass</strong> et <strong>Li Galli</strong>.
              </p>
            </div>
          </div>
        </div>

        <!-- Au-delà de l'assiette -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Une Expérience Au-delà de l'Assiette</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Dîner dans un restaurant étoilé entre Sorrente et Amalfi, ce n'est pas seulement un dîner — c'est un voyage sensoriel. Il va de l'architecture des plats au soin obsessionnel pour les ingrédients "zéro kilomètre" issus des jardins en terrasses dominant la côte. Ici le luxe rencontre la terre : il n'est pas rare de voir des ingrédients humbles comme les anchois ou le citron transformés en chefs-d'œuvre de haute ingénierie gastronomique.
          </p>
        </div>

        <!-- Conseil local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Conseil Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Beaucoup de ces restaurants d'excellence possèdent des caves historiques creusées directement dans le calcaire ou le tuf. Même si vous n'êtes pas sommelier, demandez toujours à les visiter : ce sont de véritables musées souterrains gardant de rares millésimes de "vins héroïques" produits dans les vignobles en terrasses de Furore et Tramonti.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Un secret des habitants ? Pour les restaurants les plus célèbres de la Côte, les réservations de week-end doivent être faites au moins <strong>3–4 mois à l'avance</strong> : la vue est comprise, mais la table doit se mériter !
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            En Bref
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/fr-fr/experiences/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Toutes les expériences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Autres Expériences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Autres Expériences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
