---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { experiences } from '../../../../data/experiences-fr';

const lang = 'fr-fr';

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Expériences', url: '/fr-fr/experiences/' },
  { name: 'Tour du Limoncello', url: '/fr-fr/experiences/tour-limoncello/' },
];

const facts = [
  { label: 'Durée', value: '2–3 heures' },
  { label: 'Zone', value: 'Péninsule Sorrentine' },
  { label: 'Langue', value: 'Italien, Anglais' },
  { label: 'Inclus', value: 'Visite du verger, atelier, dégustation' },
  { label: 'Prix indicatif', value: 'à partir de €55 par personne' },
  { label: 'Idéal pour', value: 'Couples, familles, amateurs de gastronomie' },
];

const otherExperiences = experiences.filter(e => e.id !== 'tour-limoncello');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Tour du Limoncello : La Liqueur Dorée et la Légende du Femminiello",
  "description": "Un voyage sensoriel à travers les arômes du Citron de Sorrente IGP. Visite d'un verger agrumicole historique, atelier d'infusion et dégustation de Limoncello artisanal.",
  "location": {
    "@type": "Place",
    "name": "Péninsule Sorrentine",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Tour du Limoncello Sorrente 2026 | Femminiello IGP et Verger Historique"
  description="Visitez un verger agrumicole historique sur la Péninsule Sorrentine, découvrez le secret du Citron Femminiello IGP et apprenez à faire du Limoncello artisanal. Dégustation incluse."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/limoncello-mercato-hero.jpg"
      alt="Citrons Femminiello IGP au marché, Péninsule Sorrentine"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Gastronomie · Péninsule Sorrentine</p>
      <h1 class="font-serif text-display text-white mb-6">Tour du Limoncello</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La Liqueur Dorée et la Légende du Femminiello IGP de Sorrente.</p>
    </div>
  </section>

  <!-- Contenu + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Texte principal -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Un voyage à travers les arômes du Citron IGP</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Se promener dans un verger agrumicole sorrentinois, ce n'est pas seulement une excursion agricole — c'est une immersion dans un écosystème protégé où le temps semble s'être arrêté. Ici règne le Femminiello, la variété de citron qui a rendu Sorrente célèbre dans le monde entier et qui porte aujourd'hui le prestigieux label IGP (Indication Géographique Protégée).
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">L'Histoire et le Nom : Un Héritage Millénaire</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Le nom "Femminiello" vient de la fertilité extraordinaire de cette plante, qui fleurit plusieurs fois par an en produisant des fruits avec une constance presque "maternelle". Ses racines remontent à l'époque romaine — des fresques la représentant ont même été trouvées dans les fouilles de Pompéi — mais c'est grâce aux moines jésuites au XVIIe siècle que sa culture s'est largement répandue.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Ce citron est unique pour deux raisons fondamentales :
          </p>

          <div class="space-y-6">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">Les Pergolas</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Les plants poussent sous les typiques "pagliarelle" (treillages de paille) qui protègent les fruits du froid et du vent, retardant la maturation et permettant d'avoir des citrons frais toute l'année.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">Le Sol Volcanique</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Le sol fertile de la péninsule, riche en minéraux issus des anciennes éruptions du Vésuve, confère au Femminiello un goût acide mais équilibré et une peau extraordinairement riche en huiles essentielles.</p>
            </div>
          </div>
        </div>

        <!-- Image éditoriale -->
        <div class="rounded-[2rem] overflow-hidden shadow-xl">
          <img
            src="/images/limoncello-femminiello.jpg"
            alt="Citrons Femminiello IGP cueillis à la main sur la Péninsule Sorrentine"
            class="w-full h-72 object-cover"
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Qu'est-ce qui rend le Femminiello si spécial ?</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Contrairement au Sfusato Amalfitano — son "cousin" de la Côte Amalfitaine, plus allongé et plus grand — le Femminiello de Sorrente a une forme elliptique et une taille moyenne. Sa vraie magie réside dans la peau : épaisse, intensément parfumée et riche en terpènes. C'est précisément cette couche jaune, le "zeste", qui — infusée dans de l'alcool pur — libère l'arôme inimitable du vrai Limoncello.
          </p>
        </div>

        <!-- Programme -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Ce qui se passe lors d'un Tour du Limoncello</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Promenade guidée sous les pergolas</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un parcours sous les treillages de paille historiques avec le guide racontant l'histoire des anciennes familles d'agrumiculteurs et les secrets de la culture IGP.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Visite de l'atelier d'infusion</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Vous découvrirez chaque phase de la production artisanale : de la sélection et du râpage des zestes à l'infusion dans l'alcool pur, jusqu'au mélange avec le sirop de sucre.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Dégustation</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Une gorgée de Limoncello glacé, confiture de citron sur pain grillé et la célèbre zeste confite enrobée de chocolat noir.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Conseil local -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Conseil Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Faites attention à la couleur de la peau lors du tour. Le Femminiello parfait doit avoir un jaune citron éclatant. Si vous frottez légèrement la peau avec le pouce et que le parfum reste sur vos doigts pendant des heures, vous avez trouvé l'or de Sorrente. Autre secret ? Les vrais Sorrentinois mangent aussi la partie blanche (l'albédo) : elle est douce, spongieuse et très riche en vitamines !
          </p>
        </div>

      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            En Bref
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a href="/fr-fr/experiences/" class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors">
              ← Toutes les expériences
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Autres Expériences -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Autres Expériences</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {otherExperiences.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img src={exp.image} alt={exp.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" referrerpolicy="no-referrer" />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
