---
import BlogPostLayout from '../../../../layouts/BlogPostLayout.astro';

const lang = 'fr-fr';
const post = {
  title: 'Oasis Sauvages',
  subtitle: 'Plages Accessibles Uniquement par Mer',
  category: 'GUIDE',
  date: '28 Avril 2026',
  readTime: '9 min',
  image: '/images/spiagge-selvagge.jpg',
  imageAlt: 'Oasis Sauvages : plages sauvages accessibles uniquement par mer sur la Côte Amalfitaine',
  path: '/fr-fr/blog/oasis-sauvages-plages/',
};

const metaTitle = "Oasis Sauvages : Plages via Mer de la Côte Amalfitaine | Guide 2026";
const metaDescription = "Découvrez les plages les plus éloignées de la Côte Amalfitaine, accessibles uniquement par mer. Santa Croce à Amalfi, Cavallo Morto à Maiori, La Vite : les oasis authentiques.";

const breadcrumbs = [
  { name: 'Accueil', url: '/fr-fr/' },
  { name: 'Blog', url: '/fr-fr/blog/' },
  { name: 'Oasis Sauvages', url: '/fr-fr/blog/oasis-sauvages-plages/' },
];

const quickInfo = [
  { label: 'Plages atteintes', value: 'Uniquement par mer · Bateau privé ou excursion' },
  { label: 'Type d\'accès', value: 'Petites criques cachées entre falaises' },
  { label: 'Services', value: 'Absents ou mini-bar/restaurant' },
  { label: 'Spécialité', value: 'Eau cristalline, sources sous-marines' },
  { label: 'Idéal pour', value: 'Ceux qui cherchent l\'isolement et l\'authenticité' },
  { label: 'Meilleure période', value: 'Mai-septembre, mer calme' },
  { label: 'Équipement recommandé', value: 'Tuba, appareil photo sous-marin' },
  { label: 'Atmosphère', value: 'Sauvage, silencieuse, primordiale' },
];

const faq = [
  {
    q: 'Comment accède-t-on à ces plages?',
    a: 'Exclusivement par mer. La solution la plus authentique est de louer un gozzo sorrentino traditionnel avec un marin local d\'Amalfi ou des petits ports de la Côte. Alternativement, il existe des excursions organisées des principales villes côtières.',
  },
  {
    q: 'Sont-elles vraiment difficiles d\'accès?',
    a: 'Non, si vous avez un bateau ou participez à une excursion. Difficiles d\'accès à pied : les parois rocheuses sont insurmontables. Mais une fois en bateau, la navigation est simple et la mer est généralement calme de mai à septembre.',
  },
  {
    q: 'Y a-t-il des services sur la plage?',
    a: 'Ça dépend. Santa Croce a deux restaurants avec service lido. Cavallo Morto est complètement sauvage, sans services. La Vite a un petit lido-restaurant. Nous recommandons d\'apporter beaucoup d\'eau et de nourriture pour les plages libres.',
  },
  {
    q: 'Quelle est la meilleure période pour les visiter?',
    a: 'Mai-septembre, quand la mer est calme et la navigation sûre. Évitez les mois d\'hiver pour le risque de fortes vagues. Juin et septembre sont idéaux : moins bondés qu\'août, mais avec un excellent temps.',
  },
  {
    q: 'Puis-je nager et faire du snorkeling?',
    a: 'Absolument oui. L\'eau est cristalline et la visibilité sous-marine est excellente. Apportez un masque de snorkeling : vous verrez des fonds rocheux et une flore marine intacte. Parfait pour les plongeurs débutants.',
  },
  {
    q: 'Est-ce dangereux d\'y aller avec des enfants?',
    a: 'Si la mer est calme (vérifiez les prévisions), c\'est relativement sûr avec les enfants à bord du bateau. Une fois sur la plage, les criques sont protégées et l\'eau est tranquille. Déconseillé uniquement en cas de vagues.',
  },
];

const sidebarLinks = [
  { label: 'Plages confortables et équipées', href: '/fr-fr/blog/plages-confortables-equipees/' },
  { label: 'Où regarder le coucher de soleil', href: '/fr-fr/blog/coucher-soleil-plages/' },
  { label: 'Toutes les plages de la Côte', href: '/fr-fr/plages/' },
  { label: 'Les plages', href: '/fr-fr/plages/' },
  { label: 'Quand visiter', href: '/fr-fr/quand-visiter/' },
  { label: 'Comment venir', href: '/fr-fr/comment-venir/' },
];

const authorRole = 'Guide de Plage et d\'Aventure · Côte Amalfitaine';

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "Oasis Sauvages : Les Plages Accessibles Uniquement par Mer",
  "image": "/images/spiagge-selvagge.jpg",
  "datePublished": "2026-04-28",
  "dateModified": "2026-04-28",
  "author": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  },
  "description": "Découvrez les plages les plus éloignées et sauvages de la Côte Amalfitaine, accessibles uniquement par mer. Santa Croce, Cavallo Morto, La Vite : les oasis authentiques de la Mer Tyrrhénienne."
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<BlogPostLayout
  lang={lang}
  post={post}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  breadcrumbs={breadcrumbs}
  quickInfo={quickInfo}
  faq={faq}
  sidebarLinks={sidebarLinks}
  authorRole={authorRole}
>

  <!-- Intro -->
  <div>
    <p class="text-slate-600 text-xl leading-relaxed mb-6 font-light">
      Le vrai luxe, sur un territoire célèbre et fréquenté comme la Côte Amalfitaine, ne réside pas dans les clubs de plage les plus exclusifs ou les terrasses des resorts cinq étoiles, mais dans le silence presque surréel d\'une petite crique cachée qui ne connaît ni le bruit des voitures ni le passage frénétique du tourisme de masse. Le long de la ligne de côte déchiquetée qui serpente entre Amalfi et le promontoire de Cape d\'Orso, la nature a sculpté de petits chefs-d\'œuvre de roche et de galets protégés par des murs verticaux infranchissables, accessibles exclusivement en naviguant sur les eaux cristallines de la Mer Tyrrhénienne.
    </p>
  </div>

  <!-- Santa Croce -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Santa Croce : La Perle la Plus Célèbre</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      La plage de Santa Croce, située à quelques minutes de navigation de la jetée d\'Amalfi, est sans doute la plus célèbre parmi ces trésors cachés. Elle porte le nom des restes d\'une ancienne chapelle médiévale dédiée à Santa Croce, dont on peut encore voir les traces dans la garrigue méditerranéenne. C\'est un paradis de galets clairs qui reflètent la lumière solaire rendant l\'eau limpide, idéal pour ceux qui aiment nager au large ou faire du snorkeling le long des bords de la falaise.
    </p>
    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
      <h3 class="font-serif text-xl font-bold text-slate-900 mb-4">Pourquoi C\'est Spécial</h3>
      <p class="text-slate-600 leading-relaxed">
        Bien que la majorité du littoral soit occupée par deux restaurants historiques proposant un service lido et une cuisine locale d\'excellence, il existe une petite portion de plage libre pour ceux qui préfèrent un contact plus rustique et autonome avec la nature.
      </p>
    </div>
  </div>

  <!-- Cavallo Morto -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cavallo Morto : Éloignée et Spectaculaire</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Encore plus éloignée et sauvage est la plage de Cavallo Morto, également connue sous le nom de Bellavaia, située sur le territoire de Maiori. Malgré son nom sinistre, lié à de vieilles légendes locales, c\'est l\'une des plages les plus spectaculaires de toute la région. Étant orientée vers le sud-est, c\'est la première à recevoir les rayons du soleil à l\'aube, offrant un spectacle chromatique unique alors que la mer descend vers un bleu cobalt profond.
    </p>
    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
      <h3 class="font-serif text-xl font-bold text-slate-900 mb-4">Expérience Pure</h3>
      <p class="text-slate-600 leading-relaxed">
        Cette plage est complètement libre et dépourvue de tout service : il n\'y a pas de bars, pas de locations de parasols. C\'est la destination ultime pour ceux qui cherchent l\'isolement total et qui veulent s\'immerger dans un contexte primordial.
      </p>
    </div>
  </div>

  <!-- La Vite -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">La Vite : Nature Intacte</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Enfin, La Vite mérite une mention, une baie protégée dans la commune de Conca dei Marini. Une langue de galets enchâssée entre des rochers très hauts où la nature règne en maître. Vous trouverez ici un mélange harmonieux : une partie est gérée par un petit lido-restaurant qui semble suspendu au-dessus des vagues, mais il existe une zone de plage libre où étendre votre serviette et profiter de la mer en totale tranquillité.
    </p>
  </div>

  <!-- Consigli -->
  <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
    <div class="flex items-center gap-4 mb-6">
      <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      <h3 class="text-xl font-bold text-slate-900">Conseils Pratiques</h3>
    </div>
    <div class="space-y-6">
      <div>
        <p class="font-bold text-slate-900 mb-1">Logistique Fondamentale</p>
        <p class="text-slate-600 text-sm leading-relaxed">Apportez avec vous beaucoup d\'eau et de nourriture, car beaucoup de ces criques n\'ont pas de points de restauration et le reflet du soleil sur les roches blanches augmente drastiquement la température ressentie.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">L\'Expérience Authentique</p>
        <p class="text-slate-600 text-sm leading-relaxed">La façon la plus authentique de les vivre est de louer un gozzo sorrentino traditionnel avec un marin du cru. Ne vous limitez pas à vous faire déposer sur le rivage : demandez-leur de vous montrer les grottes marines adjacentes, comme l\'Arche des Amoureux.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Équipement Recommandé</p>
        <p class="text-slate-600 text-sm leading-relaxed">Le tuba et le masque de plongée sont essentiels. L\'eau est tellement cristalline que vous verrez les fonds rocheux à une profondeur surprenante. Apportez également un appareil photo sous-marin pour capturer la flore marine.</p>
      </div>
    </div>
  </div>

</BlogPostLayout>
