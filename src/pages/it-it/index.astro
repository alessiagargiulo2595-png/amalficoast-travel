---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'it-it';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": "Costiera Amalfitana",
    "alternateName": "Amalfi Coast",
    "description": "Patrimonio UNESCO, 50 km di scogliere sul Tirreno in Campania, Italia.",
    "url": "https://amalficoast-travel.com/it-it/",
    "geo": { "@type": "GeoCoordinates", "latitude": "40.634", "longitude": "14.602" },
    "containedInPlace": { "@type": "Country", "name": "Italy" }
  }
];

const silos = [
  {
    title: 'Costiera Amalfitana',
    subtitle: '50 km di scogliere UNESCO',
    href: '/it-it/costiera-amalfitana/',
    borghi: ['Positano', 'Amalfi', 'Ravello', 'Praiano', 'Maiori', 'Minori'],
    img: '/images/costiera-hero.jpg',
  },
  {
    title: 'Penisola Sorrentina',
    subtitle: 'La porta del Sud Italia',
    href: '/it-it/penisola-sorrentina/',
    borghi: ['Sorrento', 'Vico Equense', 'Massa Lubrense', "Sant'Agnello"],
    img: '/images/sorrento-hero.jpg',
  },
  {
    title: 'Isole del Golfo',
    subtitle: 'Capri, Ischia, Procida',
    href: '/it-it/isole/',
    borghi: ['Capri', 'Ischia', 'Procida'],
    img: '/images/capri-hero.jpg',
  },
];

const editorial = [
  { label: 'Guida', title: 'Quando visitare la Costiera Amalfitana', subtitle: 'Mese per mese: clima, folla e prezzi', href: '/it-it/quando-visitare/' },
  { label: 'Itinerari', title: 'Da 1 giorno a 1 settimana', subtitle: 'I migliori percorsi pronti da seguire', href: '/it-it/itinerari/' },
  { label: 'Spiagge', title: 'Le 8 spiagge più belle', subtitle: 'Da Positano a Cetara', href: '/it-it/spiagge/' },
  { label: 'Trasporti', title: 'Come arrivare e spostarsi', subtitle: 'Traghetti, bus SITA, auto', href: '/it-it/come-arrivare/' },
];
---

<BaseLayout
  title="Guida alla Costiera Amalfitana 2025 — Positano, Amalfi, Ravello"
  description="Guida turistica completa alla Costiera Amalfitana. Borghi, spiagge, traghetti, itinerari e consigli pratici aggiornati. Patrimonio UNESCO in Campania, Italia."
  lang={lang}
  schema={schema}
>

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center justify-center bg-charcoal overflow-hidden">
    <!-- Hero image -->
    <img src="/images/hero-hp.jpg" alt="Costiera Amalfitana vista dall'alto" class="absolute inset-0 w-full h-full object-cover object-center" />
    <!-- Overlay scuro per leggibilità testo -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/60"></div>

    <div class="relative text-center px-4 sm:px-6 max-w-4xl mx-auto">
      <p class="text-lemon-500 text-xs font-medium uppercase tracking-[0.3em] mb-6">Patrimonio dell'Umanità UNESCO · Campania, Italia</p>
      <h1 class="font-serif text-white leading-tight mb-6" style="font-size: clamp(2.8rem, 7vw, 5.5rem); letter-spacing: -0.02em;">
        La Costiera<br/>
        <em class="not-italic text-lemon-400">Amalfitana</em>
      </h1>
      <p class="text-blue-100 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10 font-light">
        Cinquanta chilometri di scogliere a picco sul Tirreno. Borghi arroccati, limoni giganti,
        traghetti colorati e un'Italia che non smette di sorprendere.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/it-it/costiera-amalfitana/positano/"
           class="inline-block bg-white text-capri-700 font-semibold px-8 py-3.5 rounded-full hover:bg-lemon-500 hover:text-charcoal transition-all shadow-lg text-sm">
          Inizia da Positano
        </a>
        <a href="/it-it/itinerari/"
           class="inline-block border border-white/40 text-white font-medium px-8 py-3.5 rounded-full hover:bg-white/10 transition-all text-sm">
          Scegli il tuo itinerario
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
      <span class="text-[10px] uppercase tracking-widest">Scopri</span>
      <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- INTRO EDITORIALE -->
  <section class="py-24">
    <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-text mx-auto text-center">
        <p class="text-med-blue text-xs uppercase tracking-[0.2em] font-medium mb-4">Perché questo posto è diverso</p>
        <h2 class="font-serif text-3xl md:text-4xl text-charcoal tracking-tight leading-tight mb-6">
          Non è solo una destinazione.<br/>È un'esperienza che cambia il modo di guardare il mare.
        </h2>
        <p class="text-gray-500 text-lg leading-relaxed">
          La Costiera Amalfitana è una delle coste più fotografate del mondo, eppure continua a sorprendere chi la visita dal vivo. Il profumo dei limoni, il suono dei traghetti al mattino, i vicoli troppo stretti per le automobili, i pranzi che durano fino al tramonto. Questa guida non ti dirà solo dove andare — ti aiuterà a capire come viverla.
        </p>
      </div>
    </div>
  </section>

  <!-- 3 SILOS — Image Cards con Overlay -->
  <section class="bg-charcoal py-24">
    <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-med-gold text-xs uppercase tracking-[0.2em] font-medium mb-3">Esplora per area</p>
        <h2 class="font-serif text-3xl md:text-4xl text-white tracking-tight">Tre territori, infinite storie</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {silos.map(silo => (
          <a href={silo.href} class="group relative aspect-[4/5] overflow-hidden rounded-[2rem] shadow-2xl block">
            <img
              src={silo.img}
              alt={silo.title}
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
            <div class="absolute bottom-8 left-8 right-8">
              <span class="text-med-gold text-xs font-bold uppercase tracking-[0.2em] mb-2 block">{silo.subtitle}</span>
              <h3 class="font-serif text-3xl font-bold text-white tracking-tight mb-3">{silo.title}</h3>
              <div class="flex flex-wrap gap-2">
                {silo.borghi.slice(0, 3).map(b => (
                  <span class="text-[10px] text-white/70 bg-white/10 px-2 py-0.5 rounded-full">{b}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- GRID EDITORIALE -->
  <section class="py-24">
    <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-med-blue text-xs uppercase tracking-[0.2em] font-medium mb-3">Guide pratiche</p>
          <h2 class="font-serif text-3xl md:text-4xl text-charcoal tracking-tight">Tutto quello che ti serve</h2>
        </div>
      </div>

      <!-- Grid asimmetrica -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Card grande -->
        <a href={editorial[0].href} class="group lg:col-span-2 lg:row-span-2 bg-med-cream rounded-[2rem] p-10 shadow-2xl border border-gray-100 hover:shadow-xl transition-all duration-300 flex flex-col justify-between min-h-72">
          <div>
            <span class="text-[10px] uppercase tracking-[0.2em] text-med-blue font-bold">{editorial[0].label}</span>
            <h3 class="font-serif text-3xl md:text-4xl text-charcoal tracking-tight mt-3 mb-3 group-hover:text-med-blue transition-colors leading-tight">{editorial[0].title}</h3>
            <p class="text-gray-400">{editorial[0].subtitle}</p>
          </div>
          <span class="text-sm font-medium text-med-blue group-hover:text-med-blue flex items-center gap-1 mt-8">
            Leggi la guida
            <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <!-- Cards piccole -->
        {editorial.slice(1).map(item => (
          <a href={item.href} class="group bg-white rounded-[2rem] p-8 shadow-2xl border border-gray-100 hover:shadow-xl transition-all duration-300">
            <span class="text-[10px] uppercase tracking-[0.2em] text-med-blue font-bold">{item.label}</span>
            <h3 class="font-serif text-xl text-charcoal tracking-tight mt-2 mb-2 group-hover:text-med-blue transition-colors">{item.title}</h3>
            <p class="text-gray-400 text-sm mb-6">{item.subtitle}</p>
            <span class="text-sm font-medium text-med-blue flex items-center gap-1">
              Leggi
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DID YOU KNOW — Icon Boxes -->
  <section class="bg-charcoal py-24">
    <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-med-gold text-xs uppercase tracking-[0.2em] font-medium text-center mb-12">Curiosità</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/20 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503-10.498 4.875 2.812M6.497 9.252 1.622 12.064m19.88 0-4.875 2.812M1.622 12.064l4.875 2.812m0 0 4.498 2.598a.75.75 0 0 0 .75 0l4.498-2.598m-9.746 0V17.25"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">50 km</div>
          <p class="text-white/70 font-medium mb-2">chilometri di costa</p>
          <p class="text-white/50 text-sm leading-relaxed">Da Positano a Vietri sul Mare, dichiarati Patrimonio UNESCO nel 1997.</p>
        </div>
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/20 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">IX sec.</div>
          <p class="text-white/70 font-medium mb-2">nascita di Amalfi</p>
          <p class="text-white/50 text-sm leading-relaxed">Prima potenza marinara d'Europa, con rotte commerciali fino a Costantinopoli.</p>
        </div>
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/20 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">350 m</div>
          <p class="text-white/70 font-medium mb-2">l'altitudine di Ravello</p>
          <p class="text-white/50 text-sm leading-relaxed">Wagner scrisse qui il Parsifal. Gore Vidal visse a Ravello per trent'anni.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- POSITANO SPOTLIGHT (Hidden Gem) -->
  <section class="py-24">
    <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-capri-500 text-xs uppercase tracking-widest font-medium mb-4">Inizia da qui</p>
          <h2 class="font-serif text-4xl md:text-5xl text-charcoal leading-tight mb-6">
            Positano.<br/><em class="not-italic text-gray-400">La cartolina vivente.</em>
          </h2>
          <p class="text-gray-500 leading-relaxed mb-6">
            Nessun posto sulla costiera è più fotografato di Positano, eppure nessuno riesce davvero a catturarne l'essenza in uno scatto. Le case color pastello, la Spiaggia Grande, i negozi di sandali fatti a mano, il profumo di limone ovunque. La guida completa ti dice come arrivarci, dove parcheggiare (se insisti), quando i traghetti partono e dove mangiare senza svuotare il portafoglio.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <span class="text-xs px-3 py-1.5 bg-capri-50 text-capri-600 rounded-full font-medium">ZTL attiva</span>
            <span class="text-xs px-3 py-1.5 bg-capri-50 text-capri-600 rounded-full font-medium">Traghetti da Napoli</span>
            <span class="text-xs px-3 py-1.5 bg-capri-50 text-capri-600 rounded-full font-medium">Sentiero degli Dei</span>
          </div>
          <a href="/it-it/costiera-amalfitana/positano/"
             class="inline-block bg-capri-500 text-white font-semibold px-8 py-3.5 rounded-full hover:bg-capri-600 transition-colors text-sm">
            Guida completa a Positano
          </a>
        </div>
        <div class="bg-med-cream rounded-[2rem] p-8 shadow-2xl space-y-4">
          <p class="text-[10px] uppercase tracking-widest text-gray-400 font-medium">Fast Facts · Positano</p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: 'Altitudine', value: '0–350 m' },
              { label: 'Popolazione', value: '≈ 3.900' },
              { label: 'ZTL', value: 'Sì (est.)' },
              { label: 'Accesso', value: 'Ferry · Bus' },
              { label: 'Provincia', value: 'Salerno (SA)' },
              { label: 'Best season', value: 'Mag · Set' },
            ].map(f => (
              <div class="bg-white rounded-2xl p-4 border border-gray-100">
                <p class="text-[10px] uppercase tracking-widest text-gray-400 mb-1">{f.label}</p>
                <p class="font-semibold text-charcoal text-sm">{f.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
