---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'it-it';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": "Costiera Amalfitana",
    "alternateName": "Amalfi Coast",
    "description": "Patrimonio UNESCO, 50 km di scogliere sul Tirreno in Campania, Italia.",
    "url": "https://amalficoast-travel.com/it-it/",
    "geo": { "@type": "GeoCoordinates", "latitude": "40.634", "longitude": "14.602" },
    "containedInPlace": { "@type": "Country", "name": "Italy" }
  }
];

const silos = [
  {
    title: 'Costiera Amalfitana',
    subtitle: '50 km di scogliere UNESCO',
    href: '/it-it/costiera-amalfitana/',
    borghi: ['Positano', 'Amalfi', 'Ravello', 'Praiano', 'Maiori', 'Minori'],
    img: '/images/costiera-hero.webp',
  },
  {
    title: 'Penisola Sorrentina',
    subtitle: 'La porta del Sud Italia',
    href: '/it-it/penisola-sorrentina/',
    borghi: ['Sorrento', 'Vico Equense', 'Massa Lubrense', "Sant'Agnello"],
    img: '/images/sorrento-hero.webp',
  },
  {
    title: 'Isole del Golfo',
    subtitle: 'Capri, Ischia, Procida',
    href: '/it-it/isole/',
    borghi: ['Capri', 'Ischia', 'Procida'],
    img: '/images/capri-hero.webp',
  },
];

const borghi = [
  {
    name: 'Positano',
    subtitle: 'La cartolina vivente',
    description: 'Celebre per le sue case color pastello che sfidano la gravità, boutique di lusso e spiagge iconiche.',
    img: '/images/positano-hero.webp',
    href: '/it-it/costiera-amalfitana/positano/',
    tags: ['Iconico', 'Moda', 'Spiaggia Grande'],
  },
  {
    name: 'Amalfi',
    subtitle: "L'antica Repubblica Marinara",
    description: 'Il cuore storico della costa, dominato dal maestoso Duomo di Sant\'Andrea e dalle antiche cartiere.',
    img: '/images/amalfi-hero.webp',
    href: '/it-it/costiera-amalfitana/amalfi/',
    tags: ['Storia', 'Duomo', 'Piazza'],
  },
  {
    name: 'Ravello',
    subtitle: 'La città della musica',
    description: 'Sospesa tra cielo e mare, offre i panorami più spettacolari dalle sue ville storiche e giardini incantati.',
    img: '/images/ravello-hero.webp',
    href: '/it-it/costiera-amalfitana/ravello/',
    tags: ['Musica', 'Villa Cimbrone', 'Panorama'],
  },
  {
    name: 'Praiano',
    subtitle: 'Il borgo dei tramonti',
    description: "Un'oasi di tranquillità con viste mozzafiato e una vivace scena artistica locale tra mare e monti.",
    img: '/images/praiano-hero.webp',
    href: '/it-it/costiera-amalfitana/praiano/',
    tags: ['Tramonti', 'Relax', 'Marina di Praia'],
  },
  {
    name: 'Maiori',
    subtitle: 'La spiaggia più lunga',
    description: 'Il lungomare più esteso della Costiera, autentica e meno affollata, con i resti di una Villa Romana.',
    img: '/images/maiori-hero.webp',
    href: '/it-it/costiera-amalfitana/maiori/',
    tags: ['Spiaggia', 'Relax', 'Autenticità'],
  },
  {
    name: 'Minori',
    subtitle: "L'anima gastronomica",
    description: 'Famosa per il limoncello, la pasta fresca e i resti della Villa Romana affacciata sul mare.',
    img: '/images/minori-hero.webp',
    href: '/it-it/costiera-amalfitana/minori/',
    tags: ['Gastronomia', 'Villa Romana', 'Limoni'],
  },
  {
    name: 'Vietri sul Mare',
    subtitle: 'La capitale della ceramica',
    description: 'La porta orientale della Costiera, celebre per le sue caratteristiche ceramiche dipinte a mano che decorano chiese e terrazze di tutto il Sud Italia.',
    img: '/images/vietri-hero.webp',
    href: '/it-it/costiera-amalfitana/vietri-sul-mare/',
    tags: ['Ceramica', 'Artigianato', 'Museo'],
  },
];

const topBeaches = [
  { name: 'Spiaggia Grande', location: 'Positano', href: '/it-it/spiagge/costiera-amalfitana/spiaggia-grande-positano/' },
  { name: 'Spiaggia di Ieranto', location: 'Massa Lubrense', href: '/it-it/penisola-sorrentina/spiaggia-di-ieranto/' },
  { name: 'Marina Piccola', location: 'Capri', href: '/it-it/spiagge/isole/marina-piccola-capri/' },
  { name: 'Fiordo di Furore', location: 'Praiano', href: '/it-it/spiagge/costiera-amalfitana/fiordo-di-furore/' },
];

const editorial = [
  { label: 'Guida', title: 'Quando visitare la Costiera Amalfitana', subtitle: 'Mese per mese: clima, folla e prezzi', href: '/it-it/quando-visitare/' },
  { label: 'Itinerari', title: 'Da 1 giorno a 1 settimana', subtitle: 'I migliori percorsi pronti da seguire', href: '/it-it/itinerari/' },
  { label: 'Spiagge', title: 'Le 8 spiagge più belle', subtitle: 'Da Positano a Cetara', href: '/it-it/spiagge/' },
  { label: 'Trasporti', title: 'Come arrivare e spostarsi', subtitle: 'Traghetti, bus SITA, auto', href: '/it-it/come-arrivare/' },
];
---

<BaseLayout
  title="Guida alla Costiera Amalfitana 2026 - Positano, Amalfi, Ravello"
  description="Guida turistica completa alla Costiera Amalfitana. Borghi, spiagge, traghetti, itinerari e consigli pratici aggiornati. Patrimonio UNESCO in Campania, Italia."
  lang={lang}
  schema={schema}
>

  <!-- HERO -->
  <section class="relative min-h-[90vh] flex items-center justify-center bg-charcoal overflow-hidden">
    <img src="/images/hero-hp.webp" alt="Costiera Amalfitana vista dall'alto" referrerpolicy="no-referrer" class="absolute inset-0 w-full h-full object-cover object-center" loading="eager" fetchpriority="high" decoding="sync" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/55 via-black/30 to-black/65"></div>

    <div class="relative text-center px-6 max-w-4xl mx-auto">
      <p class="text-med-gold text-xs font-medium uppercase tracking-[0.3em] mb-6">Patrimonio dell'Umanità UNESCO · Campania, Italia</p>
      <h1 class="font-serif text-white leading-tight mb-6" style="font-size: clamp(2.8rem, 7vw, 5.5rem); letter-spacing: -0.02em;">
        La Costiera<br/>
        <em class="not-italic text-med-gold">Amalfitana</em>
      </h1>
      <p class="text-blue-100 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10 font-light">
        Cinquanta chilometri di scogliere a picco sul Tirreno. Borghi arroccati, limoni giganti,
        traghetti colorati e un'Italia che non smette di sorprendere.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/it-it/costiera-amalfitana/positano/"
           class="inline-block bg-med-blue text-white font-semibold px-8 py-3.5 rounded-full hover:scale-105 hover:shadow-[0_8px_30px_rgba(0,91,150,0.5)] transition-all duration-300 text-sm">
          Inizia da Positano
        </a>
        <a href="/it-it/itinerari/"
           class="inline-block border-2 border-white/50 text-white font-medium px-8 py-3.5 rounded-full hover:bg-white/10 hover:border-white transition-all duration-300 text-sm">
          Scegli il tuo itinerario
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
      <span class="text-[10px] uppercase tracking-[0.3em]">Scopri</span>
      <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>

  <!-- INTRO EDITORIALE -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium mb-4">Perché questo posto è diverso</p>
        <h2 class="font-serif text-3xl md:text-4xl text-slate-900 tracking-tight leading-tight mb-6">
          Non è solo una destinazione.<br/>È un'esperienza che cambia il modo di guardare il mare.
        </h2>
        <p class="text-slate-500 text-lg leading-relaxed font-light">
          La Costiera Amalfitana è una delle coste più fotografate del mondo, eppure continua a sorprendere chi la visita dal vivo. Il profumo dei limoni, il suono dei traghetti al mattino, i vicoli troppo stretti per le automobili, i pranzi che durano fino al tramonto. Questa guida non ti dirà solo dove andare - ti aiuterà a capire come viverla.
        </p>
      </div>
    </div>
  </section>

  <!-- BORGHI INCANTATI -->
  <section id="borghi" class="py-24 bg-med-cream">
    <div class="max-w-7xl mx-auto px-6">

      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
        <div class="max-w-2xl">
          <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-3">Esplora la Costiera</p>
          <h2 class="font-serif text-4xl md:text-5xl font-bold text-slate-900 tracking-tight mb-4">I Borghi Incantati</h2>
          <p class="text-slate-500 text-lg font-light">Esplora le perle della costiera, ognuna con la sua anima e le sue tradizioni secolari.</p>
        </div>
        <a href="/it-it/costiera-amalfitana/" class="group flex items-center gap-2 text-med-blue font-semibold hover:text-med-gold transition-colors flex-shrink-0">
          Tutte le destinazioni
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Griglia borghi -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {borghi.map((b, i) => (
          <a href={b.href} class="group cursor-pointer fade-in-card" style={`animation-delay: ${i * 0.1}s`}>
            <div class="relative aspect-[4/5] overflow-hidden rounded-[3rem] mb-6 shadow-[0_20px_50px_rgba(0,0,0,0.3)]">
              <img
                src={b.img}
                alt={b.name}
                referrerpolicy="no-referrer"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />
              <div class="absolute bottom-8 left-8 right-8">
                <span class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2 block">{b.subtitle}</span>
                <h3 class="font-serif text-3xl font-bold text-white tracking-tight">{b.name}</h3>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed font-light mb-4">{b.description}</p>
            <div class="flex flex-wrap gap-2">
              {b.tags.map(tag => (
                <span class="text-[10px] uppercase tracking-wider font-bold text-med-blue bg-med-blue/5 px-3 py-1 rounded-full">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>

      <!-- Le spiagge più belle -->
      <div class="mt-32">
        <div class="text-center mb-12">
          <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-3">Acque cristalline</p>
          <h2 class="font-serif text-4xl font-bold text-slate-900 tracking-tight mb-4">Le Spiagge più Belle</h2>
          <div class="w-20 h-1 bg-med-gold mx-auto rounded-full"></div>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {topBeaches.map((beach) => (
            <a href={beach.href} class="bg-med-cream p-8 rounded-[2rem] shadow-sm border border-slate-100 text-center hover:shadow-xl transition-all duration-500 hover:scale-105 block">
              <h4 class="font-serif font-bold text-slate-900 mb-1">{beach.name}</h4>
              <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{beach.location}</p>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- 3 SILOS - Image Cards con Overlay -->
  <section class="bg-charcoal py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-14">
        <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium mb-3">Esplora per area</p>
        <h2 class="font-serif text-3xl md:text-4xl text-white tracking-tight">Tre territori, infinite storie</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {silos.map(silo => (
          <a href={silo.href} class="group relative aspect-[4/5] overflow-hidden rounded-[3rem] shadow-[0_20px_50px_rgba(0,0,0,0.3)] block hover:scale-[1.02] transition-transform duration-500">
            <img
              src={silo.img}
              alt={silo.title}
              referrerpolicy="no-referrer"
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent" />
            <div class="absolute bottom-8 left-8 right-8">
              <span class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2 block">{silo.subtitle}</span>
              <h3 class="font-serif text-3xl font-bold text-white tracking-tight mb-3">{silo.title}</h3>
              <div class="flex flex-wrap gap-2">
                {silo.borghi.slice(0, 3).map(b => (
                  <span class="text-[10px] text-white/70 bg-white/10 px-2 py-0.5 rounded-full">{b}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- GRID EDITORIALE -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium mb-3">Guide pratiche</p>
          <h2 class="font-serif text-3xl md:text-4xl text-slate-900 tracking-tight">Tutto quello che ti serve</h2>
        </div>
      </div>

      <!-- Grid asimmetrica -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Card grande -->
        <a href={editorial[0].href} class="group lg:col-span-2 lg:row-span-2 bg-med-cream rounded-[2rem] p-10 shadow-sm border border-slate-100 hover:shadow-xl transition-all duration-500 flex flex-col justify-between min-h-72">
          <div>
            <span class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-bold">{editorial[0].label}</span>
            <h3 class="font-serif text-3xl md:text-4xl text-slate-900 tracking-tight mt-3 mb-3 group-hover:text-med-blue transition-colors leading-tight">{editorial[0].title}</h3>
            <p class="text-slate-400 font-light">{editorial[0].subtitle}</p>
          </div>
          <span class="text-sm font-medium text-med-blue flex items-center gap-1 mt-8">
            Leggi la guida
            <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <!-- Cards piccole -->
        {editorial.slice(1).map(item => (
          <a href={item.href} class="group bg-med-cream rounded-[2rem] p-8 shadow-sm border border-slate-100 hover:shadow-xl transition-all duration-500 hover:scale-[1.02]">
            <span class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-bold">{item.label}</span>
            <h3 class="font-serif text-xl text-slate-900 tracking-tight mt-2 mb-2 group-hover:text-med-blue transition-colors">{item.title}</h3>
            <p class="text-slate-400 text-sm mb-6 font-light">{item.subtitle}</p>
            <span class="text-sm font-medium text-med-blue flex items-center gap-1">
              Leggi
              <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DID YOU KNOW - Icon Boxes -->
  <section class="bg-charcoal py-24">
    <div class="max-w-7xl mx-auto px-6">
      <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium text-center mb-12">Curiosità</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503-10.498 4.875 2.812M6.497 9.252 1.622 12.064m19.88 0-4.875 2.812M1.622 12.064l4.875 2.812m0 0 4.498 2.598a.75.75 0 0 0 .75 0l4.498-2.598m-9.746 0V17.25"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">50 km</div>
          <p class="text-white/70 font-medium mb-2">chilometri di costa</p>
          <p class="text-white/50 text-sm leading-relaxed font-light">Da Positano a Vietri sul Mare, dichiarati Patrimonio UNESCO nel 1997.</p>
        </div>
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">IX sec.</div>
          <p class="text-white/70 font-medium mb-2">nascita di Amalfi</p>
          <p class="text-white/50 text-sm leading-relaxed font-light">Prima potenza marinara d'Europa, con rotte commerciali fino a Costantinopoli.</p>
        </div>
        <div class="group bg-white/5 p-8 rounded-[2rem] border border-white/10 hover:bg-white/10 transition-all duration-300">
          <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
          </div>
          <div class="font-serif text-5xl font-bold text-white mb-3 tracking-tight">350 m</div>
          <p class="text-white/70 font-medium mb-2">l'altitudine di Ravello</p>
          <p class="text-white/50 text-sm leading-relaxed font-light">Wagner scrisse qui il Parsifal. Gore Vidal visse a Ravello per trent'anni.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- POSITANO SPOTLIGHT -->
  <section class="py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-med-gold text-xs uppercase tracking-[0.3em] font-medium mb-4">Inizia da qui</p>
          <h2 class="font-serif text-4xl md:text-5xl text-slate-900 leading-tight tracking-tight mb-6">
            Positano.<br/><em class="not-italic text-slate-400">La cartolina vivente.</em>
          </h2>
          <p class="text-slate-500 leading-relaxed mb-6 font-light">
            Nessun posto sulla costiera è più fotografato di Positano, eppure nessuno riesce davvero a catturarne l'essenza in uno scatto. Le case color pastello, la Spiaggia Grande, i negozi di sandali fatti a mano, il profumo di limone ovunque. La guida completa ti dice come arrivarci, dove parcheggiare (se insisti), quando i traghetti partono e dove mangiare senza svuotare il portafoglio.
          </p>
          <div class="flex flex-wrap gap-3 mb-8">
            <span class="text-xs px-3 py-1.5 bg-med-blue/5 text-med-blue rounded-full font-medium">ZTL attiva</span>
            <span class="text-xs px-3 py-1.5 bg-med-blue/5 text-med-blue rounded-full font-medium">Traghetti da Napoli</span>
            <span class="text-xs px-3 py-1.5 bg-med-blue/5 text-med-blue rounded-full font-medium">Sentiero degli Dei</span>
          </div>
          <a href="/it-it/costiera-amalfitana/positano/"
             class="inline-block bg-med-blue text-white font-semibold px-8 py-3.5 rounded-full hover:scale-105 hover:shadow-[0_8px_30px_rgba(0,91,150,0.5)] transition-all duration-300 text-sm">
            Guida completa a Positano
          </a>
        </div>
        <div class="bg-med-cream rounded-[2rem] p-8 shadow-sm border border-slate-100 hover:shadow-xl transition-all duration-500">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts · Positano</p>
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: 'Altitudine', value: '0–350 m' },
              { label: 'Popolazione', value: '≈ 3.900' },
              { label: 'ZTL', value: 'Sì (est.)' },
              { label: 'Accesso', value: 'Ferry · Bus' },
              { label: 'Provincia', value: 'Salerno (SA)' },
              { label: 'Best season', value: 'Mag · Set' },
            ].map(f => (
              <div class="bg-white rounded-2xl p-4 border border-slate-100">
                <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 mb-1">{f.label}</p>
                <p class="font-semibold text-slate-900 text-sm">{f.value}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

<script>
  const observer = new IntersectionObserver(
    (entries) => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); }),
    { threshold: 0.15 }
  );
  document.querySelectorAll('.fade-in-card').forEach(el => observer.observe(el));
</script>

</BaseLayout>
