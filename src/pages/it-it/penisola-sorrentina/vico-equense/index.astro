---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Penisola Sorrentina', url: '/it-it/penisola-sorrentina/' },
  { name: 'Vico Equense', url: '/it-it/penisola-sorrentina/vico-equense/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Dove si mangia la pizza al metro a Vico Equense?",
      "acceptedAnswer": { "@type": "Answer", "text": "La pizza al metro e stata inventata da Gigino Dell\'Amura nel 1938 alla Trattoria Universita della Pizza, oggi nota come Da Gigino, sulla via Nicotera. Si ordina a metro (minimo 1 metro) con condimenti a scelta per ogni trancio. Coda quasi certa la sera in estate." }
    },
    {
      "@type": "Question",
      "name": "Come arrivare a Vico Equense da Napoli?",
      "acceptedAnswer": { "@type": "Answer", "text": "Circumvesuviana da Napoli Centrale verso Sorrento: scendi a Vico Equense dopo circa 50 minuti (~€3.10). Frequenza ogni 30-40 min. In auto: autostrada A3 uscita Castellammare di Stabia, poi SS145 verso Sorrento." }
    },
    {
      "@type": "Question",
      "name": "Vico Equense vale una visita?",
      "acceptedAnswer": { "@type": "Answer", "text": "Si, soprattutto se vuoi evitare la folla di Sorrento. Il centro storico medievale, il Castello Giusso e la vista sul Golfo di Napoli sono autentici e poco frequentati. Ideale come tappa di mezza giornata tra Napoli e Sorrento." }
    }
  ]
};

const schemas = [faqSchema];

const fastFacts = [
  { dt: 'Posizione', dd: 'Penisola Sorrentina, NA' },
  { dt: 'Popolazione', dd: '~21.000 abitanti' },
  { dt: 'Da Napoli', dd: '~50 min (Circumvesuviana)' },
  { dt: 'Da Sorrento', dd: '~15 min (Circumvesuviana)' },
  { dt: 'Specialità', dd: 'Pizza al metro, fior di latte' },
  { dt: 'Spiagge', dd: 'Marina di Vico (ciottoli)' },
  { dt: 'Miglior periodo', dd: 'Apr–Ott' },
];
---

<BaseLayout
  title="Vico Equense 2025: Pizza al Metro, Castello Giusso e Come Arrivare"
  description="Guida a Vico Equense: la pizza al metro da Gigino, il Castello Giusso, la Marina di Vico e il centro storico medievale. Come arrivare con la Circumvesuviana da Napoli."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={schemas}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <img src="/images/vico-equense-hero.jpg" alt="Vico Equense, Penisola Sorrentina" class="absolute inset-0 w-full h-full object-cover" loading="eager"  referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/40 to-black/80 z-10"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Penisola Sorrentina · Pizza al Metro</p>
        <h1 class="font-serif text-display text-white mb-4">Vico Equense</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La piccola città medievale dove nel 1938 nacque la pizza al metro. Centro storico autentico, Castello Giusso a picco sul mare e molto meno turisti di Sorrento — che dista solo 15 minuti di Circumvesuviana.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_300px] gap-12">

      <div class="space-y-12">

        <p class="text-xl leading-relaxed text-charcoal">
          Vico Equense è spesso ignorata dai turisti che passano direttamente da Napoli a Sorrento con la Circumvesuviana. Errore: il centro storico medievale arroccato sulla scogliera, il Castello Giusso del XII secolo e soprattutto la pizza al metro di Gigino Dell\'Amura meritano almeno mezza giornata.
        </p>

        <div>
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Cosa vedere a Vico Equense</h2>
          <div class="space-y-6">
            {[
              { title: 'Castello Giusso', text: 'Il castello medievale del XII secolo arroccato sulla scogliera a 105 m sul mare. Oggi sede di eventi culturali e matrimoni. Visibile dall\'esterno gratuitamente; apertura per visite su prenotazione. La vista sul Golfo di Napoli è tra le più belle della penisola.' },
              { title: 'Pizza al Metro da Gigino', text: 'L\'inventore della pizza al metro: Gigino Dell\'Amura aprì nel 1938 quella che oggi si chiama Trattoria Universita della Pizza. Si ordina a metro con diverse farciture per ogni trancio. Prezzi onesti (~€8–12/metro), coda quasi certa la sera. Via Nicotera 15.' },
              { title: 'Duomo di Vico Equense', text: 'La Basilica della SS. Annunziata del XIV secolo, uno dei pochi edifici gotici della Campania. Facciata semplice ma interno con affreschi e una cripta medievale. Accesso gratuito, orari di apertura limitati.' },
              { title: 'Marina di Vico', text: 'Il piccolo porto e la spiaggia di ciottoli ai piedi della scogliera, raggiungibile con la strada che scende dal centro. Più tranquilla delle spiagge di Sorrento, con qualche stabilimento balneare e pescherecci.' },
            ].map(({ title, text }) => (
              <div class="border-l-2 border-med-blue/20 pl-5">
                <h3 class="font-semibold text-charcoal mb-1">{title}</h3>
                <p class="text-sm text-slate-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Domande frequenti</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-charcoal text-white rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts — Vico Equense</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/60 text-sm flex-shrink-0">{dt}</dt>
                  <dd class="text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/10"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Penisola Sorrentina</p>
          <nav class="space-y-1">
            {[
              { href: '/it-it/penisola-sorrentina/sorrento/', label: 'Sorrento' },
              { href: '/it-it/penisola-sorrentina/massa-lubrense/', label: 'Massa Lubrense' },
              { href: '/it-it/penisola-sorrentina/sant-agnello/', label: 'Sant\'Agnello' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Esplora la Penisola e le Isole"
    items={[
      { name: 'Sorrento',      href: '/it-it/penisola-sorrentina/sorrento/',      tag: 'Base ideale',  desc: 'Hub per Capri, Napoli e la Costiera. Limoncello e Piazza Tasso.' },
      { name: 'Massa Lubrense',href: '/it-it/penisola-sorrentina/massa-lubrense/', tag: 'Natura',      desc: 'Punta Campanella, Marina del Cantone e gli spaghetti di Nerano.' },
      { name: 'Capri',         href: '/it-it/isole/capri/',                        tag: 'La più iconica', desc: 'Grotta Azzurra, Faraglioni e la mondana Piazzetta.' },
      { name: 'Positano',      href: '/it-it/costiera-amalfitana/positano/',       tag: 'Fashion & Vista', desc: 'Le case colorate a picco sul mare della Costiera.' },
    ]}
  />

</BaseLayout>
