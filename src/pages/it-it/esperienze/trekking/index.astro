---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Esperienze', url: '/it-it/esperienze/' },
  { name: 'Trekking & Sentiero degli Dei', url: '/it-it/esperienze/trekking/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quanto e difficile il Sentiero degli Dei?",
      "acceptedAnswer": { "@type": "Answer", "text": "Il Sentiero degli Dei (da Agerola a Nocelle) e classificato come EE (Escursionisti Esperti): 8 km, ~500 m dislivello, tempo percorrenza 3-4 ore. Richiede scarpe da trekking, buone gambe e assenza di vertigini. Non e adatto a bambini piccoli o persone con problemi motori." }
    },
    {
      "@type": "Question",
      "name": "Come arrivare al Sentiero degli Dei?",
      "acceptedAnswer": { "@type": "Answer", "text": "Punto di partenza: Agerola (frazione San Lazzaro, 618 m slm). Da Amalfi bus SITA per Agerola (~45 min, corse limitate). Da Napoli o Salerno: treno/bus fino ad Amalfi, poi bus per Agerola. Si consiglia la partenza mattutina (9:00-10:00) per evitare il caldo pomeridiano." }
    },
    {
      "@type": "Question",
      "name": "Si puo fare il Sentiero degli Dei in senso inverso?",
      "acceptedAnswer": { "@type": "Answer", "text": "Tecnicamente si, ma non e consigliato: il senso Agerola→Nocelle e quasi tutto in discesa ed e piu sicuro. Il contrario (Nocelle→Agerola) prevede 500 m di salita ripida su terreno instabile. La segnaletica CAI e pensata per il senso tradizionale." }
    }
  ]
};

const trails = [
  { name: 'Sentiero degli Dei', difficulty: 'EE', km: '8 km', time: '3–4h', start: 'Agerola (S. Lazzaro)', end: 'Nocelle (Positano)', highlights: 'Vista costiera mozzafiato, flora mediterranea, niente asfalto' },
  { name: 'Valle delle Ferriere', difficulty: 'E', km: '7 km A/R', time: '2.5–3h', start: 'Amalfi centro', end: 'Amalfi (ritorno)', highlights: 'Cascate, felci tropicali, papiri selvatici, ombra naturale' },
  { name: 'Via dell\'Infinito (Ravello)', difficulty: 'E', km: '5 km A/R', time: '2h', start: 'Ravello', end: 'Ravello', highlights: 'Vista panoramica sulla costiera, oliveti, silenzio totale' },
  { name: 'Punta Campanella', difficulty: 'E', km: '6 km A/R', time: '2.5h', start: 'Termini (Massa Lubrense)', end: 'Termini', highlights: 'Punta più a sud, rovine romane, vista su Capri, riserva marina' },
  { name: 'Monte Solaro (Capri)', difficulty: 'E', km: '4 km', time: '2h (salita)', start: 'Anacapri', end: 'Anacapri (seggiovia ritorno)', highlights: '589 m, panorama 360°, santuario, silenzio' },
];
---

<BaseLayout
  title="Trekking Costiera Amalfitana 2025 | Sentiero degli Dei e Percorsi"
  description="I migliori percorsi di trekking sulla Costiera Amalfitana: Sentiero degli Dei (Agerola-Nocelle), Valle delle Ferriere, Punta Campanella. Difficoltà, orari e come arrivare."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative min-h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-500"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative z-10 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/60">Esperienze</span>
        <span>/</span>
        <span class="text-white">Trekking</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">Esperienze</p>
        <h1 class="font-serif text-display text-white mb-4">Trekking & Sentiero degli Dei</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La Costiera Amalfitana non è solo spiagge e traghetti: è anche uno dei paesaggi più spettacolari d\'Europa da percorrere a piedi. Dal leggendario Sentiero degli Dei alle cascate della Valle delle Ferriere.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">I 5 percorsi da non perdere</h2>
      <div class="space-y-4">
        {trails.map((t, i) => (
          <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:border-capri-300 transition-colors">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-semibold text-charcoal text-lg">{t.name}</h3>
              <span class={`text-[10px] uppercase tracking-wide px-2 py-1 rounded-full font-medium flex-shrink-0 ${t.difficulty === 'EE' ? 'bg-red-50 text-red-600' : 'bg-capri-50 text-capri-600'}`}>
                {t.difficulty === 'EE' ? 'EE — Impegnativo' : 'E — Facile'}
              </span>
            </div>
            <div class="grid sm:grid-cols-4 gap-3 text-sm mb-3">
              <div><span class="text-gray-400">Distanza</span><br /><span class="font-medium">{t.km}</span></div>
              <div><span class="text-gray-400">Tempo</span><br /><span class="font-medium">{t.time}</span></div>
              <div><span class="text-gray-400">Partenza</span><br /><span class="font-medium">{t.start}</span></div>
              <div><span class="text-gray-400">Arrivo</span><br /><span class="font-medium">{t.end}</span></div>
            </div>
            <p class="text-sm text-capri-600 font-medium">{t.highlights}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-2xl p-8">
      <p class="text-[10px] uppercase tracking-widest text-lemon-400 font-medium mb-4">Il Sentiero degli Dei — Guida Rapida</p>
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <p class="text-white/60 text-sm mb-1">Come arrivare all\'inizio</p>
          <p class="text-sm leading-relaxed">Da Amalfi: bus SITA per Agerola (corse limitate, ~45 min). Consigliato partire da Amalfi alle 8:30 per prendere il bus delle 9:15 per Agerola.</p>
        </div>
        <div>
          <p class="text-white/60 text-sm mb-1">Come tornare dalla fine</p>
          <p class="text-sm leading-relaxed">Da Nocelle: bus locale per Positano centro (~15 min) o discesa a piedi (~1.000 gradini, 45 min). Da Positano: bus SITA o traghetto per Amalfi/Sorrento/Napoli.</p>
        </div>
        <div>
          <p class="text-white/60 text-sm mb-1">Cosa portare</p>
          <p class="text-sm leading-relaxed">Scarpe da trekking (non sandali), 1.5L acqua, cappello, crema solare, snack, giacca leggera. Il sentiero non ha punti acqua o negozi.</p>
        </div>
        <div>
          <p class="text-white/60 text-sm mb-1">Stagione ideale</p>
          <p class="text-sm leading-relaxed">Aprile–giugno e settembre–ottobre. In luglio e agosto il calore rende il percorso estenuante e affollato. In inverno possibile ma con fango e sentiero sdrucciolevole.</p>
        </div>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

  <CorrelationSlider
    heading="Esplora le destinazioni del trekking"
    items={[
      { name: 'Positano',      href: '/it-it/costiera-amalfitana/positano/', tag: 'Arrivo Sentiero', desc: 'Il borgo colorato dove termina il Sentiero degli Dei.' },
      { name: 'Amalfi',        href: '/it-it/costiera-amalfitana/amalfi/',   tag: 'Partenza Valle', desc: 'Punto di partenza per la Valle delle Ferriere.' },
      { name: 'Massa Lubrense',href: '/it-it/penisola-sorrentina/massa-lubrense/', tag: 'Punta Campanella', desc: 'La riserva marina con il sentiero per Punta Campanella.' },
      { name: 'Capri',         href: '/it-it/isole/capri/',                  tag: 'Monte Solaro',  desc: 'Seggiovia o trekking fino ai 589 m di Monte Solaro.' },
    ]}
  />

</BaseLayout>
