---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { esperienze } from '../../../data/esperienze-it';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Esperienze', url: '/it-it/esperienze/' },
];

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Esperienze sulla Costiera Amalfitana",
  "description": "Le migliori esperienze autentiche sulla Costiera Amalfitana e Penisola Sorrentina: trekking, tour in barca, cucina locale e artigianato.",
  "url": "https://amalficoast-travel.com/it-it/esperienze/",
  "numberOfItems": esperienze.length,
  "itemListElement": esperienze.map((exp, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": exp.title,
    "url": `https://amalficoast-travel.com${exp.path}`,
  })),
};
---

<BaseLayout
  title="Esperienze Costiera Amalfitana 2026 | Trekking, Barca, Cucina"
  description="Le esperienze autentiche da non perdere sulla Costiera Amalfitana: Sentiero degli Dei, tour in barca alle grotte, lezioni di cucina campana e molto altro."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <img
      src="/images/esperienze-hero.jpg"
      alt="Esperienze autentiche sulla Costiera Amalfitana"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Esperienze</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Guida 2026</p>
        <h1 class="font-serif text-display text-white mb-4">Le Esperienze</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Oltre le spiagge e i belvedere. Scopri la Costiera Amalfitana attraverso le mani dei suoi artigiani, i suoi sentieri e il suo mare.
        </p>
      </div>
    </div>
  </section>

  <!-- Griglia esperienze -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {esperienze.map((exp) => (
          <a href={exp.path} class="group block">
            <div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden mb-6 shadow-2xl">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-8 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-2">{exp.category}</span>
                <h2 class="font-serif text-2xl font-bold text-white mb-2 leading-tight">{exp.title}</h2>
                <p class="text-white/70 text-sm leading-relaxed">{exp.description}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-2">{exp.subtitle}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Intro editoriale -->
  <section class="bg-white py-20 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Perché vivere un'esperienza locale</h2>
      <p class="text-slate-600 text-lg leading-relaxed mb-6">
        La Costiera Amalfitana è uno dei luoghi più fotografati al mondo. Ma la vera anima di questo territorio si trova nei caseifici della Penisola Sorrentina, nei sentieri sopra Positano, nelle grotte marine accessibili solo dal mare. Queste esperienze non si prenotano su un catalogo turistico: si trovano conoscendo le persone giuste.
      </p>
      <p class="text-slate-600 text-lg leading-relaxed">
        Le esperienze che raccontiamo sono selezionate per autenticità, non per popolarità.
      </p>
    </div>
  </section>

</BaseLayout>
