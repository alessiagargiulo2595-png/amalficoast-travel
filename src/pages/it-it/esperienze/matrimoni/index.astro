---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { esperienze } from '../../../../data/esperienze-it';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Esperienze', url: '/it-it/esperienze/' },
  { name: 'Matrimoni', url: '/it-it/esperienze/matrimoni/' },
];

const facts = [
  { label: 'Tipo', value: 'Rito civile o religioso' },
  { label: 'Zona', value: 'Penisola Sorrentina · Costiera Amalfitana' },
  { label: 'Lingua', value: 'Italiano, Inglese, altre su richiesta' },
  { label: 'Stagione migliore', value: 'Aprile – Ottobre' },
  { label: 'Ideale per', value: 'Destination Wedding, coppie internazionali' },
  { label: 'Organizzazione', value: 'Wedding planner locale consigliato' },
];

const altreEsperienze = esperienze.filter(e => e.id !== 'matrimoni');

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Matrimoni sulla Costiera Amalfitana e Penisola Sorrentina",
  "description": "Guida alle sedi più belle per sposarsi sulla Costiera Amalfitana e Penisola Sorrentina: chiostri medievali, chiese a picco sul mare e ville storiche per un Destination Wedding indimenticabile.",
  "areaServed": {
    "@type": "Place",
    "name": "Costiera Amalfitana e Penisola Sorrentina",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "provider": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Matrimoni Costiera Amalfitana 2026 | Sedi, Chiese e Destination Wedding"
  description="Sposarsi sulla Costiera Amalfitana e Penisola Sorrentina: le sedi più belle per riti civili e religiosi, dal Chiostro di San Francesco alle chiese a picco sul mare."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaService]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/matrimoni-chiostro-hero.jpg"
      alt="Chiostro di San Francesco, Sorrento — sede per matrimoni civili"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Wedding · Costiera Amalfitana</p>
      <h1 class="font-serif text-display text-white mb-6">Matrimoni</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Promesse Sospese tra Roccia e Sale.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">La capitale mondiale del Destination Wedding</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Non è un caso se Sorrento e la Costiera Amalfitana sono tra le mete più ambite al mondo per il Destination Wedding. Qui la bellezza non è solo un dettaglio, ma una complice silenziosa: si ritrova nella luce dorata che accarezza i borghi al tramonto, nell'architettura delle chiese millenarie e nel profumo inebriante dei fiori d'arancio che invade l'aria in primavera. Sposarsi in questi luoghi significa inserire la propria storia d'amore in una cornice leggendaria, dove ogni scorcio sembra dipinto apposta per un album fotografico indimenticabile.
          </p>
        </div>

        <!-- Rito civile -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Il Fascino del Rito Civile: Storia e Natura</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Oltre alle celebrazioni religiose, il territorio offre sedi comunali di una bellezza sconvolgente per i riti civili, permettendo di pronunciare il "Sì" ufficiale in contesti che fondono storia e natura. Molte amministrazioni locali hanno aperto le porte di ville storiche e giardini botanici, trasformando la burocrazia in un momento di pura poesia.
          </p>

          <div class="space-y-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">Il Chiostro di San Francesco — Sorrento</h3>
              <p class="text-slate-600 leading-relaxed mb-4">
                Senza dubbio il luogo più iconico per un rito civile in Penisola Sorrentina. Questo chiostro del XIV secolo è un gioiello di architettura dove stili diversi — dal tardo gotico al rinascimentale — si fondono in un abbraccio di archi intrecciati e colonne di tufo. L'atmosfera è raccolta, quasi mistica, resa viva da piante rampicanti e fiori che decorano le pareti medievali.
              </p>
              <p class="text-slate-600 leading-relaxed">
                A pochi passi dal chiostro, la Villa Comunale offre una terrazza naturale con una vista mozzafiato su Capri, perfetta per le prime foto da sposi subito dopo la cerimonia.
              </p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <h3 class="font-serif text-2xl font-bold text-slate-900 mb-3">Terrazze e Musei</h3>
              <p class="text-slate-600 leading-relaxed">
                Oltre al Chiostro, Sorrento offre luoghi come il Museo Correale di Terranova o la Villa Fondi a Piano di Sorrento, dove i giardini a picco sul mare e i reperti archeologici fanno da testimoni a una promessa eterna.
              </p>
            </div>
          </div>
        </div>

        <!-- Chiese monumentali -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Chiese Monumentali: Altari tra Cielo e Mare</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Per chi sogna una cerimonia religiosa, la Costiera ospita alcuni dei luoghi di culto più suggestivi al mondo, dove la fede incontra la vertigine della costa.
          </p>

          <!-- Immagine Santissima Annunziata -->
          <div class="rounded-[2rem] overflow-hidden shadow-xl mb-4">
            <img
              src="/images/chiesa-annunziata-vico.webp"
              alt="Chiesa della Santissima Annunziata a Vico Equense, a picco sul Golfo di Napoli con il Vesuvio sullo sfondo"
              class="w-full h-72 object-cover"
              loading="lazy"
              referrerpolicy="no-referrer"
            />
          </div>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Chiesa della Santissima Annunziata — Vico Equense</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Spesso definita "la chiesa più bella d'Italia", è un gioiello gotico dalla facciata rosa arroccato su un promontorio a picco sul mare. Celebrare qui significa scambiarsi le promesse con lo sguardo che spazia sull'intero Golfo di Napoli e il Vesuvio all'orizzonte. È l'unica chiesa al mondo che sembra letteralmente sospesa tra le onde.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Il Duomo di Amalfi — Sant'Andrea</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Per chi desidera un ingresso trionfale. La sua imponente scalinata e lo stile arabo-siciliano offrono una maestosità senza tempo nel cuore della Costiera.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Santa Maria Assunta — Positano</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Celebre per la sua cupola in maiolica gialla e verde che brilla sotto il sole, a pochi passi dalla spiaggia grande. Perfetta per un matrimonio glamour e iconico che profuma di Dolce Vita.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Esperienze e ricevimenti -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Esperienze e Ricevimenti</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Dalle storiche dimore di Ravello — come Villa Cimbrone con la sua Terrazza dell'Infinito — alle baie nascoste raggiungibili solo in barca per un party esclusivo in riva al mare, le possibilità sono infinite. Molte coppie scelgono di accogliere gli ospiti con un tipico aperitivo sorrentino tra i limoneti, trasformando il matrimonio in un weekend di scoperta gastronomica e relax.
          </p>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip per gli Sposi</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Se scegliete la Santissima Annunziata a Vico Equense, programmate l'uscita dalla chiesa al tramonto: la luce che colpisce la facciata rosa crea un riflesso magico, perfetto per scatti fotografici senza filtri. Per il Chiostro di San Francesco, tenete presente che l'acustica è straordinaria: un'arpa o un quartetto d'archi renderanno la cerimonia civile un'esperienza da brividi.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Un consiglio pratico per le spose: le stradine della Costiera sono bellissime ma insidiose per i tacchi a spillo. Prevedete un paio di "luxury flat" o zeppe gioiello per gli spostamenti tra i vicoli, e tenete i tacchi alti per il momento del ricevimento!
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/esperienze/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le esperienze
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Altre Esperienze -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Altre Esperienze</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {altreEsperienze.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
