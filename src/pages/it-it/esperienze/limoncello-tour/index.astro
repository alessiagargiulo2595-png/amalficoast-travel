---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { esperienze } from '../../../../data/esperienze-it';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Esperienze', url: '/it-it/esperienze/' },
  { name: 'Limoncello Tour', url: '/it-it/esperienze/limoncello-tour/' },
];

const facts = [
  { label: 'Durata', value: '2–3 ore' },
  { label: 'Zona', value: 'Penisola Sorrentina' },
  { label: 'Lingua', value: 'Italiano, Inglese' },
  { label: 'Incluso', value: 'Visita agrumeto, laboratorio, degustazione' },
  { label: 'Prezzo indicativo', value: 'da €55 a persona' },
  { label: 'Ideale per', value: 'Coppie, famiglie, amanti del food' },
];

const altreEsperienze = esperienze.filter(e => e.id !== 'limoncello-tour');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Limoncello Tour: L'Oro Giallo e il Mito del Femminiello",
  "description": "Un viaggio sensoriale tra i profumi del Limone di Sorrento IGP. Visita a un agrumeto storico, laboratorio di infusione e degustazione di Limoncello artigianale.",
  "location": {
    "@type": "Place",
    "name": "Penisola Sorrentina",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Limoncello Tour Sorrento 2026 | Femminiello IGP e Agrumeto Storico"
  description="Visita un agrumeto storico della Penisola Sorrentina, scopri il segreto del Limone Femminiello IGP e impara a fare il limoncello artigianale. Degustazione inclusa."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/limoncello-tour.jpg"
      alt="Limoncello Tour, Penisola Sorrentina"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Food · Penisola Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Limoncello Tour</h1>
      <p class="text-lg md:text-xl font-light text-white/80">L'Oro Giallo e il Mito del Femminiello di Sorrento IGP.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Un viaggio tra i profumi del Limone IGP</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Camminare in un agrumeto sorrentino non è solo un tour agricolo, è un'immersione in un ecosistema protetto dove il tempo sembra essersi fermato. Qui regna sovrano il Femminiello, la varietà di limone che ha reso Sorrento celebre in tutto il mondo e che oggi gode del prestigioso marchio IGP (Indicazione Geografica Protetta).
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">La Storia e il Nome: Un'Eredità Millenaria</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Il nome "Femminiello" deriva dalla straordinaria fertilità di questa pianta, che fiorisce più volte l'anno producendo frutti con una costanza quasi "materna". Le sue radici affondano nell'epoca romana — ne sono stati trovati affreschi persino negli scavi di Pompei — ma è grazie ai monaci gesuiti nel 1600 che la coltivazione si è diffusa capillarmente.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Questo limone è unico per due motivi fondamentali:
          </p>

          <div class="space-y-6">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">I Pergolati</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Le piante crescono sotto le tipiche "pagliarelle" (graticci di paglia) che proteggono i frutti dal freddo e dal vento, ritardandone la maturazione e permettendo di avere limoni freschi tutto l'anno.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <h4 class="font-bold text-slate-900 mb-2">Il Terreno Vulcanico</h4>
              <p class="text-slate-600 text-sm leading-relaxed">La terra fertile della penisola, ricca di minerali provenienti dalle antiche eruzioni del Vesuvio, conferisce al Femminiello un sapore acido ma equilibrato e una buccia ricchissima di oli essenziali.</p>
            </div>
          </div>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Cosa rende speciale il Femminiello?</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            A differenza dello Sfusato Amalfitano — suo "cugino" della Costiera, più allungato e grande — il Femminiello di Sorrento ha una forma ellittica e dimensioni medie. La sua vera magia risiede nella buccia: spessa, profumatissima e ricca di terpeni. È proprio questo strato giallo, la "scorza", l'unico ingrediente che — infuso nell'alcol puro — sprigiona l'aroma inconfondibile del vero Limoncello.
          </p>
        </div>

        <!-- Programma -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cosa si fa durante un limoncello tour</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Passeggiata guidata sotto i pergolati</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un percorso tra le pagliarelle storiche con la guida che racconta la storia delle antiche famiglie di limonicoltori e i segreti della coltivazione IGP.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Visita al laboratorio di infusione</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Scoprirete ogni fase della produzione artigianale: dalla selezione e raschiatura delle scorze all'infusione in alcol puro, fino alla miscelazione con lo sciroppo di zucchero.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Degustazione</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Assaggio di Limoncello ghiacciato, marmellate di limone su pane tostato e la famosa scorzetta candita ricoperta di cioccolato fondente.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Fate attenzione al colore della buccia durante il tour. Il Femminiello perfetto deve avere un colore giallo citrino brillante. Se strofinate leggermente la buccia con il pollice e il profumo persiste sulle vostre dita per ore, avete trovato l'oro di Sorrento. Un altro segreto? Il vero sorrentino mangia anche la parte bianca (l'albedo): è dolce, spugnosa e ricchissima di vitamine!
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/esperienze/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le esperienze
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Altre Esperienze -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Altre Esperienze</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {altreEsperienze.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
