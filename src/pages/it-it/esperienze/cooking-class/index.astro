---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { esperienze } from '../../../../data/esperienze-it';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Esperienze', url: '/it-it/esperienze/' },
  { name: 'Cooking Class', url: '/it-it/esperienze/cooking-class/' },
];

const facts = [
  { label: 'Durata', value: '4–5 ore' },
  { label: 'Zona', value: 'Penisola Sorrentina · Costiera Amalfitana' },
  { label: 'Lingua', value: 'Italiano, Inglese' },
  { label: 'Incluso', value: 'Visita mercato, lezione, pasto, ricette' },
  { label: 'Prezzo indicativo', value: 'da €75 a persona' },
  { label: 'Ideale per', value: 'Coppie, gruppi, appassionati di cucina' },
];

const altreEsperienze = esperienze.filter(e => e.id !== 'cooking-class');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Cooking Class: I Segreti della Cucina Costiera",
  "description": "Masterclass di cucina campana in Penisola Sorrentina e Costiera Amalfitana. Ravioli alla Caprese, Gnocchi alla Sorrentina, Delizia al Limone e molto altro.",
  "location": {
    "@type": "Place",
    "name": "Penisola Sorrentina e Costiera Amalfitana",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Cooking Class Costiera Amalfitana 2026 | Cucina Campana Autentica"
  description="Lezioni di cucina in Penisola Sorrentina e Costiera Amalfitana: Ravioli alla Caprese, Totani e Patate, Delizia al Limone. Dal mercato ai fornelli."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cooking-class-costiera.jpg"
      alt="Cooking Class, Penisola Sorrentina e Costiera Amalfitana"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Food · Penisola Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Cooking Class</h1>
      <p class="text-lg md:text-xl font-light text-white/80">I Segreti della Cucina Costiera.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Un tuffo nella cultura mediterranea</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Le lezioni di cucina in Penisola Sorrentina e Costiera Amalfitana non sono semplici corsi, ma veri e propri tuffi nella cultura mediterranea. Molte di queste esperienze iniziano ben prima di accendere i fornelli: il rito comincia tra i banchi dei mercati rionali o negli orti terrazzati a picco sul mare, dove si impara a scegliere il pomodoro perfetto e a riconoscere il profumo del basilico "napoletano" a foglia larga.
          </p>
        </div>

        <!-- Il Menù della Tradizione -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Il Menù della Tradizione: I Pilastri del Gusto</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Durante queste masterclass, i partecipanti hanno l'opportunità di cimentarsi con ricette che rappresentano l'anima della Campania.
          </p>

          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Antipasto — Impepata di Cozze</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un classico intramontabile che celebra la freschezza del mare. Pochi ingredienti — cozze, pepe, prezzemolo e limone di Sorrento — per un risultato che racchiude tutto il sapore del Golfo.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Primo — Ravioli alla Caprese</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Il simbolo della domenica. Una pasta fresca preparata con un impasto povero (acqua e farina), farcita con la tipica caciotta sorrentina e un pizzico di maggiorana fresca, servita con un sugo di pomodoro leggero.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Secondo — Totani e Patate alla Praianese</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Un piatto tipico dei pescatori della Costiera. La dolcezza del totano si fonde con la cremosità delle patate locali, il tutto sfumato con vino bianco e profumato con aglio e peperoncino.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">4</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Dolce — Delizia al Limone</h4>
                <p class="text-slate-600 text-sm leading-relaxed">La regina della pasticceria locale. Un soffice pan di spagna a cupola, farcito e ricoperto da una crema setosa profumata con lo sfusato amalfitano o il limone di Sorrento IGP.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- L'arte del fare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">L'Arte del Fare</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            L'obiettivo di queste masterclass è svelare i segreti della dieta mediterranea. Si parte spesso dalla preparazione della pasta fresca: imparare a dosare acqua e farina per creare gli iconici Ravioli alla Caprese o gli Gnocchi alla Sorrentina, che richiedono una tecnica particolare — e dita veloci! — per ottenere la giusta consistenza porosa che accolga il pomodoro e il fiordilatte filante della zona. Non mancano mai i segreti della pasticceria locale, dove la precisione si sposa con la fragranza degli agrumi colti all'alba.
          </p>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Se cercate un'esperienza autentica, scegliete le classi che si tengono nelle antiche case coloniche o direttamente negli agrumeti, all'ombra delle "pagliarelle".
          </p>
          <p class="text-slate-600 leading-relaxed">
            Un piccolo segreto dei locali per gli gnocchi? Usate sempre patate vecchie: contengono meno acqua e richiedono quindi meno farina durante l'impasto. Il risultato? Uno gnocco incredibilmente leggero che si scioglie letteralmente in bocca.
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/esperienze/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le esperienze
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Altre Esperienze -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Altre Esperienze</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {altreEsperienze.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
