---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { esperienze } from '../../../../data/esperienze-it';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Esperienze', url: '/it-it/esperienze/' },
  { name: 'Mozzarella Experience', url: '/it-it/esperienze/mozzarella-experience/' },
];

const facts = [
  { label: 'Durata', value: '3–4 ore' },
  { label: 'Zona', value: 'Penisola Sorrentina' },
  { label: 'Lingua', value: 'Italiano, Inglese' },
  { label: 'Incluso', value: 'Degustazione, grembiule, ricette' },
  { label: 'Prezzo indicativo', value: 'da €65 a persona' },
  { label: 'Ideale per', value: 'Coppie, famiglie, appassionati di cucina' },
];

const altreEsperienze = esperienze.filter(e => e.id !== 'mozzarella-experience');

const schemaEvent = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Mozzarella Experience: L'Arte del Casaro",
  "description": "Un'esperienza casearia autentica in Penisola Sorrentina. Impara a fare la mozzarella e scopri il leggendario Provolone del Monaco DOP.",
  "location": {
    "@type": "Place",
    "name": "Penisola Sorrentina",
    "address": {
      "@type": "PostalAddress",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "organizer": {
    "@type": "Organization",
    "name": "Amalfi Coast Travel"
  }
};
---

<BaseLayout
  title="Mozzarella Experience Penisola Sorrentina 2026 | Arte del Casaro"
  description="Impara a fare la mozzarella e scopri il Provolone del Monaco DOP con un mastro casaro in Penisola Sorrentina."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaEvent]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/mozzarella-experience.jpg"
      alt="Mozzarella Experience, Penisola Sorrentina"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Food · Penisola Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Mozzarella Experience</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Dalla cagliata filante al tesoro stagionato dei Monti Lattari.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">L'Arte del Casaro</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            In Penisola Sorrentina, l'arte casearia è una vocazione che si tramanda da secoli. Partecipare a questa esperienza non significa solo assaggiare, ma toccare con mano la materia prima che nasce dai pascoli incontaminati dei Monti Lattari. Dalla freschezza immediata della mozzarella alla complessità del Provolone del Monaco, vi sveleremo i segreti dell'eccellenza lattiero-casearia campana.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Il Provolone del Monaco DOP: Storia di un Nome Leggendario</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Se la mozzarella è la "regina", il Provolone del Monaco è senza dubbio il "re" indiscusso dei nostri monti. Ma perché questo nome così particolare?
          </p>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La storia risale al 1700, quando i pastori che vivevano sui Monti Lattari scendevano all'alba verso il porto di Napoli per vendere i loro prodotti. Per proteggersi dall'umidità e dal freddo della notte durante il lungo tragitto via mare, i casari si avvolgevano in pesanti mantelli di tela di sacco scura, simili al saio di un monaco. Al loro arrivo al mercato di Napoli, la gente iniziò a chiamarli familiarmente "i monaci" e, di conseguenza, il formaggio squisito che portavano con sé divenne per tutti il Provolone del Monaco.
          </p>

          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-4">Un Disciplinare Rigoroso</h3>
          <p class="text-slate-600 text-lg leading-relaxed">
            Oggi questo formaggio è tutelato dal marchio DOP. Viene prodotto esclusivamente con latte vaccino, di cui almeno il 20% deve provenire dalla vacca di razza Agerolese, una razza pregiata e rara che conferisce al formaggio un sapore unico: dolce e burroso all'inizio, ma con un retrogusto piccante e aromatico che si intensifica con la stagionatura (che deve durare almeno 6 mesi).
          </p>
        </div>

        <!-- Programma -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Cosa si fa durante una mozzarella experience</h2>
          <div class="space-y-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">La Filatura in diretta</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Osserverete il mastro casaro mentre trasforma il latte in trecce e bocconcini sotto i vostri occhi.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Mani in Pasta</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Avrete l'opportunità di "mozzare" con le vostre mani la mozzarella fresca, sentendo il calore e la consistenza della pasta filante.</p>
              </div>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
              <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
              <div>
                <h4 class="font-bold text-slate-900 mb-1">Verticale di Stagionature</h4>
                <p class="text-slate-600 text-sm leading-relaxed">Una degustazione guidata che parte dal fior di latte freschissimo e arriva al Provolone del Monaco DOP, accompagnato da miele locale e noci di Sorrento.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Quando assaggiate il Provolone del Monaco, cercate i "piccoli fori" (le occhiature): devono essere della grandezza di un chicco di pepe. Ma il vero segreto è l'abbinamento: provatelo con un calice di <strong>Gragnano frizzante freddo</strong>. La bollicina pulisce il palato dalla grassezza del formaggio, esaltando la nota piccante dell'Agerolese.
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/esperienze/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le esperienze
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Altre Esperienze -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Altre Esperienze</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {altreEsperienze.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
