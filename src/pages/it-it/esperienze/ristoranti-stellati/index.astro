---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { esperienze } from '../../../../data/esperienze-it';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Esperienze', url: '/it-it/esperienze/' },
  { name: 'Ristoranti Stellati', url: '/it-it/esperienze/ristoranti-stellati/' },
];

const facts = [
  { label: 'Guida', value: 'Michelin 2026' },
  { label: 'Zona', value: 'Penisola Sorrentina · Costiera Amalfitana' },
  { label: 'Top indirizzo', value: 'Quattro Passi — 3 Stelle Michelin' },
  { label: 'Prenotazione', value: '3–4 mesi in anticipo (weekend)' },
  { label: 'Ideale per', value: 'Foodies, occasioni speciali, anniversari' },
  { label: 'Da non perdere', value: 'Visita alla cantina scavata nella roccia' },
];

const altreEsperienze = esperienze.filter(e => e.id !== 'ristoranti-stellati');

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Ristoranti Stellati Michelin 2026 — Sorrento e Costiera Amalfitana",
  "description": "La classifica 2026 dei migliori ristoranti stellati tra Penisola Sorrentina e Costiera Amalfitana: Quattro Passi, Il Buco, Don Alfonso 1890 e molto altro.",
  "url": "https://amalficoast-travel.com/it-it/esperienze/ristoranti-stellati/",
  "numberOfItems": 8,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Quattro Passi — Nerano (3 Stelle Michelin)" },
    { "@type": "ListItem", "position": 2, "name": "Il Buco — Sorrento" },
    { "@type": "ListItem", "position": 3, "name": "Lorelei — Sorrento" },
    { "@type": "ListItem", "position": 4, "name": "Terrazza Bosquet — Sorrento" },
    { "@type": "ListItem", "position": 5, "name": "Don Alfonso 1890 — Sant'Agata sui Due Golfi" },
    { "@type": "ListItem", "position": 6, "name": "La Caravella — Amalfi" },
    { "@type": "ListItem", "position": 7, "name": "Glicine — Positano" },
    { "@type": "ListItem", "position": 8, "name": "Zass e Li Galli — Positano" },
  ],
};
---

<BaseLayout
  title="Ristoranti Stellati Costiera Amalfitana 2026 | Guida Michelin"
  description="La guida ai migliori ristoranti stellati Michelin 2026 tra Sorrento e la Costiera Amalfitana: Quattro Passi (3 stelle), Il Buco, Don Alfonso 1890 e le perle di Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ristoranti-stellati.jpg"
      alt="Ristoranti Stellati Michelin, Costiera Amalfitana"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/75"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Fine Dining · Costiera Amalfitana</p>
      <h1 class="font-serif text-display text-white mb-6">Ristoranti Stellati</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Il Firmamento del Gusto 2026.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">

        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Un pellegrinaggio nel cuore della gastronomia d'eccellenza</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Se esiste una terra dove l'alta cucina è di casa, quella è la regione che abbraccia Sorrento e la Costiera Amalfitana. Nel 2026, la Guida Michelin conferma questo territorio come il più luminoso d'Italia: la Campania non è solo ai vertici per numero di stelle totali, ma detiene un primato unico per densità gastronomica.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Basti pensare che, pur essendo una delle regioni più piccole per estensione, la Campania ospita circa il <strong>12% dei ristoranti stellati dell'intera penisola italiana</strong>, superando in concentrazione per chilometro quadrato giganti del gusto come il Piemonte e la Lombardia. In questo fazzoletto di terra sospeso sul mare, la cucina d'eccellenza non è un'eccezione, ma una vera e propria vocazione territoriale.
          </p>
        </div>

        <!-- La Classifica 2026 -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">La Classifica 2026: I Protagonisti</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-8">
            Il panorama gastronomico del 2026 vede riconfermati i grandi nomi che hanno reso la zona una meta di pellegrinaggio per i foodies di tutto il mondo.
          </p>

          <div class="space-y-6">

            <!-- Quattro Passi -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Quattro Passi — Nerano, Massa Lubrense</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Il Vertice Assoluto</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                Il leggendario Quattro Passi a Nerano mantiene le prestigiose 3 Stelle Michelin, unico ristorante della regione a toccare il tetto del mondo. La sua cucina è un inno alla purezza dei sapori marini reinterpretati con una tecnica impeccabile.
              </p>
            </div>

            <!-- Stelle di Sorrento -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Le Stelle di Sorrento</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Una città, tre indirizzi imperdibili</span>
                </div>
              </div>
              <div class="space-y-4 mt-4">
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Il Buco</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Situato in una suggestiva ex rampa di un monastero, dove la storia dell'edificio dialoga con la cucina del territorio.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Lorelei</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Cucina d'avanguardia su una terrazza mozzafiato: due esperienze sensoriali in una.</p>
                </div>
                <div>
                  <h4 class="font-bold text-slate-900 mb-1">Terrazza Bosquet</h4>
                  <p class="text-slate-600 text-sm leading-relaxed">Iconico tempio del gusto all'interno dell'Excelsior Vittoria: lusso, storia e alta cucina sotto lo stesso tetto.</p>
                </div>
              </div>
            </div>

            <!-- Icone e nuove scoperte -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <div class="flex items-start gap-4 mb-3">
                <span class="text-med-gold font-bold text-lg leading-none mt-1">★</span>
                <div>
                  <h3 class="font-serif text-2xl font-bold text-slate-900">Icone e Nuove Scoperte</h3>
                  <span class="text-med-gold text-xs font-bold uppercase tracking-wider">Da Sant'Agata a Positano</span>
                </div>
              </div>
              <p class="text-slate-600 leading-relaxed">
                Non si può dire di aver vissuto la Costiera senza citare il <strong>Don Alfonso 1890</strong> a Sant'Agata sui Due Golfi, pioniere della sostenibilità, o le perle di Amalfi e Positano: <strong>La Caravella</strong>, <strong>Glicine</strong>, <strong>Zass</strong> e <strong>Li Galli</strong>.
              </p>
            </div>

          </div>
        </div>

        <!-- Oltre il piatto -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">Un'Esperienza Oltre il Piatto</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Mangiare in uno stellato tra Sorrento e Amalfi non è solo una cena, ma un viaggio sensoriale. Si spazia dall'architettura dei piatti alla cura maniacale per la materia prima a "metro zero", proveniente dagli orti verticali che dominano la costa. Qui il lusso incontra la terra: non è raro trovare ingredienti poveri come l'alice o il limone trasformati in capolavori di alta ingegneria gastronomica.
          </p>
        </div>

        <!-- Local Tip -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Local Tip</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Molte di queste eccellenze vantano cantine storiche scavate direttamente nella roccia calcarea o nel tufo. Anche se non siete esperti sommelier, chiedete sempre di visitarle: sono veri musei sotterranei che custodiscono annate rare di "vini eroici" prodotti sui terrazzamenti di Furore e Tramonti.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Un segreto dei locali? Per i ristoranti più famosi della Costiera, le prenotazioni per i weekend vanno effettuate con almeno <strong>3–4 mesi di anticipo</strong>: il panorama è incluso, ma il tavolo va conquistato!
          </p>
        </div>

      </div>

      <!-- Sidebar Fast Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3 text-med-gold">
            Fast Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-[10px] uppercase tracking-wider font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/esperienze/"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le esperienze
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- Altre Esperienze -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-12">Altre Esperienze</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        {altreEsperienze.map((exp) => (
          <a href={exp.path} class="group flex gap-6 items-start">
            <div class="w-28 h-28 rounded-[1.5rem] overflow-hidden flex-shrink-0 shadow-md">
              <img
                src={exp.image}
                alt={exp.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
            </div>
            <div class="pt-1">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em]">{exp.category}</span>
              <h3 class="font-serif text-xl font-bold text-slate-900 mt-1 mb-2 group-hover:text-med-blue transition-colors">{exp.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{exp.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
