---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
];

const itinerari1g = [
  { name: 'Costiera Amalfitana da Napoli', href: '/it-it/itinerari/1-giorno/costiera-amalfitana-da-napoli/', desc: 'Amalfi, Ravello e Positano in un giorno da Napoli.' },
  { name: 'Costiera da Salerno', href: '/it-it/itinerari/1-giorno/costiera-amalfitana-da-salerno/', desc: 'La porta est della Costiera: Vietri, Maiori, Amalfi.' },
  { name: 'Penisola Sorrentina da Napoli', href: '/it-it/itinerari/1-giorno/penisola-sorrentina-da-napoli/', desc: 'Sorrento, Massa Lubrense e Sant\'Agata sui Due Golfi.' },
  { name: 'Trekking Sentiero degli Dei', href: '/it-it/itinerari/1-giorno/trekking-sentiero-degli-dei/', desc: 'Agerola → Nocelle: 8 km, 4 ore, viste mozzafiato.' },
  { name: 'Capri da Sorrento', href: '/it-it/itinerari/1-giorno/capri-da-sorrento/', desc: 'Grotta Azzurra, Faraglioni e Anacapri in giornata.' },
];

const itinerari3g = [
  { name: 'Classico Costiera Amalfitana', href: '/it-it/itinerari/3-giorni/classico-costiera-amalfitana/', desc: 'Il meglio della Costiera: Positano, Amalfi, Ravello.' },
  { name: 'Sorrento, Pompei e Storia', href: '/it-it/itinerari/3-giorni/sorrento-pompei-storia/', desc: 'Arte, archeologia e costa: Pompei, Ercolano, Sorrento.' },
  { name: 'Isole: Ischia e Procida', href: '/it-it/itinerari/3-giorni/isole-ischia-procida/', desc: 'Terme, colori e borghi di pescatori nel Golfo di Napoli.' },
];

const itinerari7g = [
  { name: 'Grand Tour Costiera & Penisola', href: '/it-it/itinerari/7-giorni/grand-tour-costiera-penisola/', desc: 'Il tour completo: Napoli, Costiera, isole e Penisola Sorrentina.' },
  { name: 'Slow Travel: Borghi e Cibo', href: '/it-it/itinerari/7-giorni/slow-travel-borghi-cibo/', desc: 'Una settimana lenta tra mercati, trattorie e sentieri minori.' },
];
---

<BaseLayout
  title="Itinerari Costiera Amalfitana 2026 | 1, 3 e 7 Giorni"
  description="Itinerari pronti per la Costiera Amalfitana: da 1 giorno a 1 settimana. Trekking Sentiero degli Dei, Capri, Positano, Amalfi e isole del Golfo di Napoli."
  lang={lang}
  breadcrumbs={breadcrumbs}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/itinerari-hero.jpg" alt="Costiera Amalfitana, Atrani" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Itinerari</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Pianifica il viaggio</p>
        <h1 class="font-serif text-display text-white mb-4">Itinerari</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Hai 1 giorno, 3 giorni o una settimana? Ecco gli itinerari più apprezzati per la Costiera Amalfitana, le isole e la Penisola Sorrentina - con percorsi, trasporti e consigli pratici.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-2">Itinerari di 1 giorno</h2>
      <p class="text-slate-500 text-sm mb-6">Escursioni da Napoli, Salerno o Sorrento. Perfetti per chi è di passaggio.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {itinerari1g.map(i => (
          <a href={i.href} class="group bg-white border border-slate-200 rounded-2xl p-5 hover:border-med-blue/30 hover:shadow-sm transition-all">
            <span class="text-[10px] uppercase tracking-wide bg-med-blue/5 text-med-blue px-2 py-0.5 rounded-full font-medium">1 giorno</span>
            <h3 class="font-semibold text-charcoal mt-3 mb-1 group-hover:text-med-blue transition-colors">{i.name}</h3>
            <p class="text-xs text-slate-500">{i.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-2">Itinerari di 3 giorni</h2>
      <p class="text-slate-500 text-sm mb-6">Un weekend lungo per esplorare senza fretta una zona specifica.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {itinerari3g.map(i => (
          <a href={i.href} class="group bg-white border border-slate-200 rounded-2xl p-5 hover:border-med-blue/30 hover:shadow-sm transition-all">
            <span class="text-[10px] uppercase tracking-wide bg-med-cream text-med-gold px-2 py-0.5 rounded-full font-medium">3 giorni</span>
            <h3 class="font-semibold text-charcoal mt-3 mb-1 group-hover:text-med-blue transition-colors">{i.name}</h3>
            <p class="text-xs text-slate-500">{i.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-2">Itinerari di 7 giorni</h2>
      <p class="text-slate-500 text-sm mb-6">Una settimana per coprire Costiera, isole e Penisola Sorrentina con calma.</p>
      <div class="grid sm:grid-cols-2 gap-4">
        {itinerari7g.map(i => (
          <a href={i.href} class="group bg-white border border-slate-200 rounded-2xl p-5 hover:border-med-blue/30 hover:shadow-sm transition-all">
            <span class="text-[10px] uppercase tracking-wide bg-red-50 text-red-600 px-2 py-0.5 rounded-full font-medium">7 giorni</span>
            <h3 class="font-semibold text-charcoal mt-3 mb-1 group-hover:text-med-blue transition-colors">{i.name}</h3>
            <p class="text-xs text-slate-500">{i.desc}</p>
          </a>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
