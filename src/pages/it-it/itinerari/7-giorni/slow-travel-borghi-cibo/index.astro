---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: 'Slow Travel — 7 giorni', url: '/it-it/itinerari/7-giorni/slow-travel-borghi-cibo/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Cos'è lo slow travel sulla Costiera Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "Lo slow travel sulla Costiera significa restare più giorni nello stesso borgo invece di spostarsi ogni giorno, mangiare nei ristoranti locali (non quelli per turisti), camminare sui sentieri minori, andare al mercato, comprare i prodotti locali (limoni, alici, vino rosso di Ravello). È l'opposto dell'itinerario tutto-incluso." }
    },
    {
      "@type": "Question",
      "name": "Quali sono i borghi meno turistici della Costiera Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "I borghi meno visitati sono: Praiano (tra Positano e Amalfi, niente ZTL, spiaggia tranquilla), Cetara (famosa per la colatura di alici, autentica), Furore (il borgo che non c'è, costruito nella forra), Conca dei Marini (300 abitanti, vicino alla Grotta dello Smeraldo). Tutti raggiungibili in bus SITA dalla SS163." }
    }
  ]
};

const days = [
  { day: 'Giorno 1', title: 'Arrivo a Praiano', items: ['Praiano: il borgo centrale senza ZTL. Meno turisti di Positano, prezzi più bassi.', 'Spiaggia della Gavitella: piccola, bellissima, accessibile a piedi.', 'Cena in una delle trattorie sul porto: pesce del giorno.'] },
  { day: 'Giorno 2', title: 'Sentiero degli Dei', items: ['Bus SITA per Amalfi, poi per Agerola (partenza sentiero).', 'Sentiero degli Dei (Agerola→Nocelle, 8 km, 3-4h, EE).', 'Rientro a Praiano via Positano in bus SITA.'] },
  { day: 'Giorno 3', title: 'Amalfi e Furore', items: ['Bus SITA per Amalfi. Mattina: mercato del giovedì (prodotti locali, mozzarella, limoni).', 'Furore: il Fiordo di Furore, fermata a richiesta sul bus SITA. Il borgo nella forra.', 'Museo della Carta di Amalfi: la carta artigianale prodotta dal XIII secolo.'] },
  { day: 'Giorno 4', title: 'Ravello e Scala', items: ['Bus per Ravello (25 min). Mattina tranquilla senza folla alle 9:00.', 'Sentiero Ravello→Scala: 4 km tra oliveti e vigneti, vista sul golfo. Pranzo a Scala.', 'Pomeriggio: aperitivo con vista, degustazione vino rosso Ravello.'] },
  { day: 'Giorno 5', title: 'Cetara e Vietri', items: ['Bus SITA est per Cetara (famosa per la colatura di alici DOP). Mercato del pesce.', 'Visita al Museo della Colatura di Alici e acquisto diretto dai produttori.', 'Vietri sul Mare: ceramiche, Museo della Ceramica. Passeggiata sul lungomare.'] },
  { day: 'Giorno 6', title: 'Valle delle Ferriere', items: ['Mattina: escursione Valle delle Ferriere da Amalfi (7 km A/R, 3h, E). Cascate e felci tropicali.', 'Pomeriggio: bagno nelle cale isolate vicino ad Amalfi o tour in kayak.', 'Cena di pesce fresco ad Amalfi.'] },
  { day: 'Giorno 7', title: 'Mercato e Partenza', items: ['Mattina libera al mercato locale. Acquisto prodotti tipici: limoncello artigianale, alici, ceramiche.', 'Pranzo lento in trattoria. Saluti.', 'Bus SITA per Salerno (60 min) o Sorrento (90 min) per raggiungere treni o aeroporto.'] },
];
---

<BaseLayout
  title="Slow Travel Costiera Amalfitana 7 Giorni 2025 | Borghi, Cibo e Sentieri"
  description="Itinerario slow travel di 7 giorni sulla Costiera Amalfitana: Praiano, Furore, Cetara, Valle delle Ferriere e Sentiero degli Dei. Borghi autentici, mercati e cibo locale."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33] via-med-blue to-[#0077cc]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Slow Travel — 7 giorni</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 7 giorni</p>
        <h1 class="font-serif text-display text-white mb-4">Slow Travel: Borghi e Cibo</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Una settimana lenta tra borghi autentici, mercati locali e sentieri minori. Praiano come base, Furore, Cetara, Valle delle Ferriere. La Costiera senza fretta, senza tour guidati.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Durata</p>
          <p class="font-semibold text-charcoal">7 giorni / 6 notti</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base</p>
          <p class="font-semibold text-charcoal">Praiano o Amalfi</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Stagione ideale</p>
          <p class="font-semibold text-charcoal">Maggio–Giugno / Set–Ott</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Ritmo</p>
          <p class="font-semibold text-charcoal">Lento</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Il programma giorno per giorno</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-charcoal text-white rounded-[2rem] p-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Prodotti da non perdere</p>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <p class="font-semibold mb-1">Limone sfusato amalfitano IGP</p>
          <p class="text-white/70">I limoni enormi della Costiera: aroma unico, scorza spessa. Comprarli direttamente dai coltivatori ad Amalfi o Minori.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Colatura di alici di Cetara DOP</p>
          <p class="text-white/70">Il garum moderno: liquido ambrato di alici fermentate. Cetara ne produce la versione DOP migliore d'Italia.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Vino di Ravello</p>
          <p class="text-white/70">I vigneti ad alta quota producono un rosso leggero e profumato. Degustazione nelle cantine di Ravello.</p>
        </div>
        <div>
          <p class="font-semibold mb-1">Ceramiche di Vietri sul Mare</p>
          <p class="text-white/70">La capitale italiana della ceramica: piastrelle, piatti e oggetti d'arte dipinti a mano. Scegli i laboratori artigianali locali.</p>
        </div>
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
