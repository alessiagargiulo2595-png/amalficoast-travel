---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: 'Grand Tour — 7 giorni', url: '/it-it/itinerari/7-giorni/grand-tour-costiera-penisola/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quale è il modo migliore per organizzare 7 giorni tra Costiera e Penisola Sorrentina?",
      "acceptedAnswer": { "@type": "Answer", "text": "Il percorso classico è: 2 notti a Napoli (giorno 1-2), poi spostarsi a Sorrento o Amalfi come base per la Costiera (giorno 3-5), con escursione a Capri (giorno 4 o 5), poi isole nel finale (giorno 6-7). Usare bus SITA, Circumvesuviana e aliscafi evita l'auto completamente." }
    },
    {
      "@type": "Question",
      "name": "Quante notti a Napoli conviene fare prima della Costiera?",
      "acceptedAnswer": { "@type": "Answer", "text": "1-2 notti sono sufficienti per Napoli: Spaccanapoli, Museo Archeologico Nazionale, pizza verace, Certosa di San Martino. Con 2 notti puoi includere Ercolano o Pompei come day trip. Napoli è il punto di arrivo/partenza naturale per la zona." }
    }
  ]
};

const days = [
  { day: 'Giorno 1', title: 'Napoli', items: ['Arrivo a Napoli. Spaccanapoli, centro storico UNESCO.', 'Museo Archeologico Nazionale: reperti da Pompei, mosaici, bronzi.', 'Pizza verace nel quartiere storico: Da Michele, Sorbillo o Brandi.'] },
  { day: 'Giorno 2', title: 'Pompei o Ercolano', items: ['Day trip in Circumvesuviana: Ercolano Scavi (mattina, 2-3h) + Vesuvio (pomeriggio).', 'In alternativa: Pompei intera giornata (3-4h agli scavi).', 'Rientro a Napoli per la cena.'] },
  { day: 'Giorno 3', title: 'Sorrento e arrivo Costiera', items: ['Circumvesuviana Napoli→Sorrento (70 min). Check-in a Sorrento o Amalfi.', 'Pomeriggio: Sorrento centro, Vallone dei Mulini, Marina Grande.', 'Bus SITA per Positano (opzionale, 50 min): primo contatto con la Costiera.'] },
  { day: 'Giorno 4', title: 'Capri', items: ['Aliscafo da Sorrento per Capri (20-25 min). Prima corsa 7:30.', 'Grotta Azzurra di mattina presto. Anacapri e Monte Solaro a seggiovia.', 'Faraglioni nel pomeriggio. Aperitivo in Piazzetta. Rientro sera.'] },
  { day: 'Giorno 5', title: 'Amalfi e Ravello', items: ['Bus SITA Sorrento→Amalfi (90 min) o traghetto Sorrento→Amalfi.', 'Duomo, Chiostro del Paradiso, Museo della Carta.', 'Bus per Ravello (25 min): Villa Rufolo, Villa Cimbrone. Cena ad Amalfi.'] },
  { day: 'Giorno 6', title: 'Positano e Tour in Barca', items: ['Bus SITA per Positano (45 min da Amalfi). Mattina libera in spiaggia.', 'Tour in barca da Positano (Grotta Smeraldo, cale, ~€50-80, 4h).', 'Rientro ad Amalfi o Positano. Cena sul porto.'] },
  { day: 'Giorno 7', title: 'Ischia o Procida e Partenza', items: ['Traghetto Amalfi/Napoli→Ischia o Procida (escursione mezza giornata).', 'Procida: Marina Corricella, Terra Murata, spiaggia del Pozzo Vecchio.', 'Rientro a Napoli per la partenza.'] },
];
---

<BaseLayout
  title="Grand Tour Costiera Amalfitana 7 Giorni 2025 | Napoli, Capri, Positano, Amalfi"
  description="Itinerario di 7 giorni completo tra Napoli, Costiera Amalfitana, Capri e isole del Golfo. Pompei, Sorrento, Positano, Amalfi, Ravello: il Grand Tour del Sud Italia."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33] via-med-blue to-[#0077cc]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Grand Tour — 7 giorni</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 7 giorni</p>
        <h1 class="font-serif text-display text-white mb-4">Grand Tour Costiera & Penisola</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Una settimana per vedere tutto: Napoli, Pompei, Sorrento, Capri, Positano, Amalfi, Ravello e un'isola. Il Grand Tour del Golfo di Napoli, senza auto, solo mezzi pubblici.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Durata</p>
          <p class="font-semibold text-charcoal">7 giorni / 6 notti</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Basi</p>
          <p class="font-semibold text-charcoal">Napoli + Amalfi/Sorrento</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Trasporti</p>
          <p class="font-semibold text-charcoal">Treno + bus + aliscafi</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Budget trasporti</p>
          <p class="font-semibold text-charcoal">~€80–120</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Il programma giorno per giorno</h2>
      <div class="space-y-6">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli per il Grand Tour</p>
      <ul class="space-y-2">
        {[
          'Campania Express: biglietto giornaliero Circumvesuviana (valido per Napoli-Sorrento-Pompei-Ercolano) ~€10.',
          'Prenota Capri e la Grotta Azzurra con 1-2 giorni di anticipo in luglio-agosto.',
          'Cambia base a metà viaggio: 2 notti Napoli + 3 notti Amalfi/Sorrento + eventuale 1 notte isola.',
          'Il giorno del tour in barca è flessibile: spostalo in base al meteo marino.',
          'Portati scarpe comode per i sampietrini di Napoli e le scalinate di Positano.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
