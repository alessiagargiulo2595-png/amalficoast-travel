---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: 'Trekking Sentiero degli Dei', url: '/it-it/itinerari/1-giorno/trekking-sentiero-degli-dei/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Come organizzare il Sentiero degli Dei in un giorno da Napoli?",
      "acceptedAnswer": { "@type": "Answer", "text": "Parti da Napoli con la Circumvesuviana fino a Sorrento (70 min), poi bus SITA per Amalfi (90 min), poi bus locale per Agerola (45 min). Il sentiero Agerola→Nocelle è 8 km, 3-4h. Da Nocelle bus locale per Positano (15 min), poi bus SITA o traghetto per Sorrento e Circumvesuviana per Napoli." }
    },
    {
      "@type": "Question",
      "name": "Serve prenotare per il Sentiero degli Dei?",
      "acceptedAnswer": { "@type": "Answer", "text": "In alta stagione (luglio-agosto) il Sentiero degli Dei richiede prenotazione obbligatoria sul portale del Parco dei Monti Lattari. Il costo è simbolico (~€5). Fuori stagione non è richiesta. Verifica sempre le condizioni sul sito ufficiale prima di partire." }
    },
    {
      "@type": "Question",
      "name": "Cosa portare per il Sentiero degli Dei?",
      "acceptedAnswer": { "@type": "Answer", "text": "Obbligatorio: scarpe da trekking (non sandali o sneaker lisce), almeno 1.5L di acqua, protezione solare, cappello. Il sentiero non ha fontane né negozi. Portare uno spuntino. In primavera/autunno una giacca leggera è consigliata per il vento in quota." }
    }
  ]
};

const schedule = [
  { time: '07:00', place: 'Napoli', action: 'Circumvesuviana per Sorrento (70 min, ~€3.90)' },
  { time: '08:15', place: 'Sorrento', action: 'Bus SITA per Amalfi (90 min, ~€3.50) — corsa delle 8:30' },
  { time: '10:00', place: 'Amalfi', action: 'Bus locale per Agerola, fraz. San Lazzaro (45 min, ~€1.50). Inizio sentiero.' },
  { time: '11:00', place: 'Agerola (618 m)', action: 'Partenza Sentiero degli Dei. 8 km, ~500 m discesa, EE.' },
  { time: '14:30', place: 'Nocelle', action: 'Arrivo Nocelle. Pausa e pranzo in uno dei rifugi/bar locali.' },
  { time: '15:15', place: 'Nocelle → Positano', action: 'Bus locale per Positano centro (15 min) o a piedi (~1.000 gradini, 45 min)' },
  { time: '16:00', place: 'Positano', action: 'Passeggiata, gelato, spiaggia (1h libera)' },
  { time: '17:15', place: 'Positano', action: 'Bus SITA per Sorrento (~50 min), poi Circumvesuviana per Napoli (70 min)' },
];
---

<BaseLayout
  title="Sentiero degli Dei in 1 Giorno da Napoli 2025 | Itinerario Trekking"
  description="Come fare il Sentiero degli Dei (Agerola-Nocelle) in un giorno da Napoli: orari, trasporti, prenotazione e consigli. 8 km di trekking con vista sulla Costiera Amalfitana."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-500"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Sentiero degli Dei — 1 giorno</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">Itinerario · Trekking · 1 giorno</p>
        <h1 class="font-serif text-display text-white mb-4">Trekking Sentiero degli Dei</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          8 km da Agerola a Nocelle/Positano con la Costiera Amalfitana sotto i piedi. Il sentiero più spettacolare del Sud Italia — fattibile in giornata da Napoli con i mezzi pubblici.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-4 gap-4 mb-8">
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Distanza</p>
          <p class="font-semibold text-charcoal">8 km</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Dislivello</p>
          <p class="font-semibold text-charcoal">~500 m ↓</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Difficoltà</p>
          <p class="font-semibold text-red-600">EE</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Costo trasporti</p>
          <p class="font-semibold text-charcoal">~€12–18</p>
        </div>
      </div>

      <div class="bg-red-50 border border-red-200 rounded-2xl p-5">
        <p class="font-semibold text-red-800 mb-1">Prenotazione obbligatoria in estate</p>
        <p class="text-sm text-red-700">Luglio-agosto: prenotazione richiesta sul portale del Parco dei Monti Lattari (~€5). Controlla le condizioni prima di partire.</p>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Il programma ora per ora</h2>
      <div class="space-y-0">
        {schedule.map((s, i) => (
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="w-8 h-8 rounded-full bg-capri-600 text-white text-xs font-mono flex items-center justify-center flex-shrink-0">{i + 1}</div>
              {i < schedule.length - 1 && <div class="w-px flex-1 bg-gray-200 my-1"></div>}
            </div>
            <div class="pb-6">
              <span class="text-xs font-mono text-capri-600 font-semibold">{s.time}</span>
              <p class="font-semibold text-charcoal text-sm">{s.place}</p>
              <p class="text-sm text-gray-600">{s.action}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-lemon-50 border border-lemon-200 rounded-2xl p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli per il trekking</p>
      <ul class="space-y-2">
        {[
          'Stagione ideale: aprile-giugno e settembre-ottobre. Luglio-agosto è caldissimo e affollato.',
          'Il bus da Amalfi per Agerola ha corse limitate: controlla gli orari su eavsrl.it la sera prima.',
          'Parti sempre in direzione Agerola→Nocelle: quasi tutto in discesa, segnaletica pensata per questo senso.',
          'Il sentiero non ha punti acqua: porta almeno 1.5L. L\'ultimo bar è ad Agerola prima della partenza.',
          'Da Nocelle si scende a Positano a piedi (~1.000 gradini, 45 min) o in bus (15 min, ~€1.50).',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-lemon-500 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
