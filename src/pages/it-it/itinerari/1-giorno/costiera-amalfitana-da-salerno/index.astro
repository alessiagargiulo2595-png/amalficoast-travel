---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: '1 Giorno da Salerno', url: '/it-it/itinerari/1-giorno/costiera-amalfitana-da-salerno/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Come si arriva alla Costiera Amalfitana da Salerno?",
      "acceptedAnswer": { "@type": "Answer", "text": "Da Salerno hai due opzioni: traghetto Travelmar per Amalfi (45 min, ~€8, stagionale apr-ott) oppure bus SITA dalla stazione di Salerno (direzione Amalfi via SS163, ~60 min, ~€2.80). Il traghetto è più panoramico e veloce; il bus è attivo tutto l'anno." }
    },
    {
      "@type": "Question",
      "name": "Vale la pena partire dalla porta est della Costiera (Vietri, Maiori)?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sì, soprattutto in bassa stagione quando i borghi sono meno affollati. Vietri sul Mare è famosa per le ceramiche, Maiori ha il lungomare più lungo della Costiera e un'atmosfera rilassata. Minori vale una sosta per le rovine della Villa Romana." }
    }
  ]
};

const schedule = [
  { time: '08:30', place: 'Salerno', action: 'Traghetto Travelmar per Amalfi (apr-ott, 45 min, ~€8) o bus SITA (60 min, ~€2.80)', transport: 'ferry' },
  { time: '09:30', place: 'Amalfi', action: 'Duomo di Sant\'Andrea, Chiostro del Paradiso, Museo della Carta (2.5h)', transport: 'visit' },
  { time: '12:00', place: 'Amalfi', action: 'Pranzo in centro (trattorie sul corso o sul porto)', transport: 'visit' },
  { time: '13:30', place: 'Amalfi → Maiori', action: 'Bus SITA est per Maiori (20 min, ~€1.50). Lungomare e spiaggia.', transport: 'bus' },
  { time: '15:00', place: 'Maiori → Minori', action: 'A piedi lungo il lungomare (20 min) o bus. Villa Romana di Minori (gratuita).', transport: 'walk' },
  { time: '16:00', place: 'Minori → Vietri sul Mare', action: 'Bus SITA per Vietri (~30 min). Ceramiche, Museo della Ceramica, passeggiata.', transport: 'bus' },
  { time: '17:30', place: 'Vietri → Salerno', action: 'Bus per Salerno (15 min) o a piedi lungo la costa (45 min panoramici)', transport: 'bus' },
];

const tips = [
  'Salerno è collegata a Napoli e Roma in treno ad alta velocità: ottimo punto di partenza.',
  'Il traghetto Travelmar da Salerno è panoramico e arriva ad Amalfi senza percorrere la SS163.',
  'La parte est della Costiera (Maiori, Minori, Vietri) è molto meno affollata di Positano.',
  'Vietri sul Mare è la capitale italiana delle ceramiche: ottima per souvenir di qualità.',
  'In bassa stagione il bus SITA è l\'unica opzione (traghetto sospeso): parte da Piazza della Concordia.',
];

const transportBadge: Record<string, { label: string; cls: string }> = {
  train: { label: 'TRENO', cls: 'bg-orange-100 text-orange-700' },
  ferry: { label: 'NAVE', cls: 'bg-blue-100 text-blue-700' },
  bus:   { label: 'BUS', cls: 'bg-green-100 text-green-700' },
  walk:  { label: 'PIEDI', cls: 'bg-gray-100 text-slate-500' },
  visit: { label: '', cls: '' },
};
---

<BaseLayout
  title="Costiera Amalfitana da Salerno in 1 Giorno 2026 | Itinerario Est"
  description="Itinerario di 1 giorno dalla porta est della Costiera Amalfitana: Amalfi, Maiori, Minori e Vietri sul Mare partendo da Salerno. Orari traghetti e bus SITA."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Costiera Amalfitana da Salerno" class="absolute inset-0 w-full h-full object-cover opacity-30" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33]/80 via-med-blue/60 to-[#0077cc]/50"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Costiera da Salerno — 1 giorno</span>
      </nav>
      <div class="max-w-2xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 1 giorno</p>
        <h1 class="font-serif text-display text-white mb-4">Costiera Amalfitana da Salerno</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          La porta est della Costiera: meno folla, più autenticità. Amalfi in traghetto da Salerno, poi i borghi tranquilli di Maiori, Minori e le ceramiche di Vietri.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-4xl mx-auto">
      <div class="grid grid-cols-3 gap-6">
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Durata</p><p class="font-bold text-charcoal text-lg">1 giorno</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Costo trasporti</p><p class="font-bold text-charcoal text-lg">~€12–18</p></div>
        </div>
        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 text-center shadow-sm flex flex-col items-center gap-3">
          <svg class="w-7 h-7 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <div><p class="text-xs text-slate-400 uppercase tracking-wide mb-0.5">Difficoltà</p><p class="font-bold text-charcoal text-lg">Facile</p></div>
        </div>
      </div>
    </section>

    <div class="lg:grid lg:grid-cols-12 lg:gap-12 items-start">
      <section class="lg:col-span-8">
        <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Il programma ora per ora</h2>
        <div class="relative">
          <div class="space-y-12 border-l-2 border-slate-200 pl-8 ml-3">
            {schedule.map((s) => {
              const badge = transportBadge[s.transport] ?? transportBadge.visit;
              return (
                <div class="relative">
                  <div class="absolute -left-[41px] flex h-5 w-5 items-center justify-center rounded-full bg-med-blue ring-4 ring-white shadow-sm"></div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-mono text-med-blue font-bold text-sm">{s.time}</span>
                    {badge.label && <span class={`text-[9px] font-bold uppercase tracking-wider px-1.5 py-0.5 rounded ${badge.cls}`}>{badge.label}</span>}
                  </div>
                  <p class="font-semibold text-charcoal text-base leading-snug">{s.place}</p>
                  <p class="text-slate-600 text-sm mt-1 leading-relaxed">{s.action}</p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <aside class="lg:col-span-4 mt-12 lg:mt-0">
        <div class="lg:sticky lg:top-24 space-y-6">
          <div class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2a7 7 0 0 1 7 7c0 3-1.7 5.2-4 6.4V17a1 1 0 0 1-1 1H10a1 1 0 0 1-1-1v-1.6C6.7 14.2 5 12 5 9a7 7 0 0 1 7-7z"/><path d="M10 21h4M12 17v4"/></svg>
              Insider Tips
            </p>
            <ul class="space-y-3">
              {tips.map(tip => (
                <li class="flex gap-2.5 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="bg-white border border-slate-200 rounded-[2rem] p-6">
            <p class="font-semibold text-charcoal mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-med-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>
              Mappa Rapida
            </p>
            <a href="https://maps.google.com/maps?q=Amalfi,Italy" target="_blank" rel="noopener" class="flex items-center justify-between bg-slate-50 hover:bg-med-blue/5 rounded-xl px-4 py-3 text-sm text-med-blue font-medium transition-colors group">
              Apri percorso in Google Maps
              <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </aside>
    </div>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">{q.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>

  </div>
</BaseLayout>
