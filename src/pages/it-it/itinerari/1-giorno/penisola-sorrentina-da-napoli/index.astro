---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: 'Penisola Sorrentina da Napoli', url: '/it-it/itinerari/1-giorno/penisola-sorrentina-da-napoli/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Come arrivare a Sorrento da Napoli?",
      "acceptedAnswer": { "@type": "Answer", "text": "Il modo più semplice è la Circumvesuviana: treno da Napoli Porta Nolana o Piazza Garibaldi fino a Sorrento (70 min, ~€3.90). Corse ogni 30-40 min. In alternativa, aliscafo da Napoli Beverello (Alilauro/NLG, ~60 min, ~€15) ma il prezzo è più alto." }
    },
    {
      "@type": "Question",
      "name": "Cosa vedere nella Penisola Sorrentina in un giorno?",
      "acceptedAnswer": { "@type": "Answer", "text": "Da Sorrento: il centro storico e il Vallone dei Mulini (30 min), poi bus per Massa Lubrense (20 min) con vista su Capri e il Golfo. Sant'Agata sui Due Golfi offre uno dei panorami più belli della zona. Punta Campanella è raggiungibile a piedi (sentiero 6 km A/R, 2.5h)." }
    }
  ]
};

const schedule = [
  { time: '08:00', place: 'Napoli Porta Nolana', action: 'Circumvesuviana per Sorrento (70 min, ~€3.90)' },
  { time: '09:15', place: 'Sorrento', action: 'Centro storico, Piazza Tasso, Vallone dei Mulini, negozi di limoncello (1.5h)' },
  { time: '11:00', place: 'Sorrento', action: 'Bus SITA per Massa Lubrense (20 min, ~€1.50). Panorama su Capri.' },
  { time: '12:00', place: 'Massa Lubrense', action: 'Pranzo in trattoria locale. Vista doppio golfo da Punta Campanella.' },
  { time: '13:30', place: 'Massa Lubrense → Sant\'Agata sui Due Golfi', action: 'Bus o taxi (15 min). Belvedere del Deserto (panorama Golfo di Napoli + Salerno).' },
  { time: '15:00', place: 'Sant\'Agata → Sorrento', action: 'Bus di rientro per Sorrento (30 min). Tempo libero sul porto.' },
  { time: '16:30', place: 'Sorrento', action: 'Marina Piccola, passeggiata, aperitivo con vista Vesuvio' },
  { time: '18:00', place: 'Sorrento', action: 'Circumvesuviana per Napoli (70 min)' },
];
---

<BaseLayout
  title="Penisola Sorrentina in 1 Giorno da Napoli 2025 | Sorrento, Massa Lubrense"
  description="Itinerario di 1 giorno nella Penisola Sorrentina da Napoli: Sorrento, Massa Lubrense, Sant'Agata sui Due Golfi. Circumvesuviana, bus SITA e panorami sul Golfo."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-500"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Penisola Sorrentina — 1 giorno</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">Itinerario · 1 giorno</p>
        <h1 class="font-serif text-display text-white mb-4">Penisola Sorrentina da Napoli</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Sorrento, Massa Lubrense e il punto dove si vedono entrambi i golfi. Un giorno nella penisola che si allunga verso Capri — meno folla della Costiera, panorami altrettanto spettacolari.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Durata</p>
          <p class="font-semibold text-charcoal">1 giorno</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Costo trasporti</p>
          <p class="font-semibold text-charcoal">~€10–15</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Difficoltà</p>
          <p class="font-semibold text-charcoal">Facile</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Il programma ora per ora</h2>
      <div class="space-y-0">
        {schedule.map((s, i) => (
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="w-8 h-8 rounded-full bg-capri-600 text-white text-xs font-mono flex items-center justify-center flex-shrink-0">{i + 1}</div>
              {i < schedule.length - 1 && <div class="w-px flex-1 bg-gray-200 my-1"></div>}
            </div>
            <div class="pb-6">
              <span class="text-xs font-mono text-capri-600 font-semibold">{s.time}</span>
              <p class="font-semibold text-charcoal text-sm">{s.place}</p>
              <p class="text-sm text-gray-600">{s.action}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-lemon-50 border border-lemon-200 rounded-2xl p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli pratici</p>
      <ul class="space-y-2">
        {[
          'La Circumvesuviana è economica ma lenta e spesso sovraffollata in estate: tieni d\'occhio il bagaglio.',
          'Sant\'Agata sui Due Golfi: il nome dice tutto — dal belvedere si vedono sia il Golfo di Napoli che quello di Salerno.',
          'Massa Lubrense è ideale per un pranzo economico con pescato del giorno: meno turistica di Sorrento.',
          'Se vuoi fare il sentiero di Punta Campanella (6 km A/R), parti da Massa Lubrense entro le 10:00.',
          'Il limoncello di Sorrento si produce con i limoni IGP della zona: acquistalo nei negozi locali, non in aeroporto.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-lemon-500 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
