---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: '1 Giorno da Napoli', url: '/it-it/itinerari/1-giorno/costiera-amalfitana-da-napoli/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Come si arriva alla Costiera Amalfitana da Napoli in un giorno?",
      "acceptedAnswer": { "@type": "Answer", "text": "Il percorso più pratico è: treno Napoli→Salerno (40 min, Trenitalia/Italo), poi traghetto Travelmar Salerno→Amalfi (45 min, stagionale apr-ott) oppure bus SITA da Salerno. In alternativa, treno Napoli→Sorrento (Circumvesuviana, 70 min) e bus SITA Sorrento→Amalfi (90 min)." }
    },
    {
      "@type": "Question",
      "name": "Cosa vedere in un giorno sulla Costiera Amalfitana partendo da Napoli?",
      "acceptedAnswer": { "@type": "Answer", "text": "Con una giornata: arriva ad Amalfi (Duomo, centro storico, 2h), poi Ravello in bus (25 min, Villa Rufolo e panorami, 1.5h), poi torna ad Amalfi e prendi il bus per Positano (45 min, passeggiata e spiaggia, 1.5h). Tornate da Positano in bus o traghetto." }
    },
    {
      "@type": "Question",
      "name": "A che ora partire da Napoli per la Costiera Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "Parti da Napoli entro le 7:30-8:00. Il treno delle 7:45 arriva a Salerno alle 8:25; il traghetto Travelmar parte intorno alle 9:00 e arriva ad Amalfi prima delle 10:00. Questo ti dà 8-9 ore di visita prima del rientro." }
    }
  ]
};

const schedule = [
  { time: '07:45', place: 'Napoli Centrale', action: 'Treno per Salerno (Trenitalia/Italo, 40 min, ~€5-12)' },
  { time: '09:00', place: 'Salerno', action: 'Traghetto Travelmar per Amalfi (45 min, ~€8, stagionale apr-ott)' },
  { time: '09:45', place: 'Amalfi', action: 'Duomo di Sant\'Andrea, Chiostro del Paradiso, corso e centro storico (2h)' },
  { time: '12:00', place: 'Amalfi → Ravello', action: 'Bus SITA locale per Ravello (25 min, ~€1.50). Pranzo in piazza.' },
  { time: '13:30', place: 'Ravello', action: 'Villa Rufolo, belvedere, Villa Cimbrone (1.5h)' },
  { time: '15:15', place: 'Ravello → Amalfi → Positano', action: 'Bus per Amalfi (25 min), poi bus SITA per Positano (45 min)' },
  { time: '16:30', place: 'Positano', action: 'Passeggiata via Cristoforo Colombo, Spiaggia Grande, aperitivo (1.5h)' },
  { time: '18:30', place: 'Positano', action: 'Bus SITA per Sorrento (50 min), poi Circumvesuviana per Napoli (70 min)' },
];
---

<BaseLayout
  title="Costiera Amalfitana in 1 Giorno da Napoli 2025 | Itinerario Completo"
  description="Itinerario di 1 giorno sulla Costiera Amalfitana partendo da Napoli: Amalfi, Ravello e Positano in treno, traghetto e bus SITA. Orari, prezzi e consigli pratici."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-500"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Costiera da Napoli — 1 giorno</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">Itinerario · 1 giorno</p>
        <h1 class="font-serif text-display text-white mb-4">Costiera Amalfitana da Napoli</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Amalfi, Ravello e Positano in una giornata senza auto. Treno fino a Salerno, traghetto fino ad Amalfi, poi bus SITA lungo la Costiera. Fattibile, spettacolare, economico.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Durata</p>
          <p class="font-semibold text-charcoal">1 giorno</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Costo trasporti</p>
          <p class="font-semibold text-charcoal">~€25–40</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Difficoltà</p>
          <p class="font-semibold text-charcoal">Facile</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Il programma ora per ora</h2>
      <div class="space-y-0">
        {schedule.map((s, i) => (
          <div class="flex gap-4 group">
            <div class="flex flex-col items-center">
              <div class="w-8 h-8 rounded-full bg-capri-600 text-white text-xs font-mono flex items-center justify-center flex-shrink-0">{i + 1}</div>
              {i < schedule.length - 1 && <div class="w-px flex-1 bg-gray-200 my-1"></div>}
            </div>
            <div class="pb-6">
              <span class="text-xs font-mono text-capri-600 font-semibold">{s.time}</span>
              <p class="font-semibold text-charcoal text-sm">{s.place}</p>
              <p class="text-sm text-gray-600">{s.action}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-lemon-50 border border-lemon-200 rounded-2xl p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli pratici</p>
      <ul class="space-y-2">
        {[
          'Il traghetto Travelmar da Salerno è stagionale (apr-ott): in inverno usa il bus SITA da Salerno.',
          'Compra il biglietto del bus SITA in tabaccheria prima di salire — non si vende a bordo.',
          'In luglio-agosto il bus Amalfi→Positano può impiegare 1.5h invece di 45 min: calcola il margine.',
          'Ravello vale il detour: Villa Rufolo (€7) è uno dei belvedere più belli della Costiera.',
          'Il rientro da Positano in bus SITA è più lento (curve + traffico) — calcola almeno 1h per Sorrento.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-lemon-500 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
