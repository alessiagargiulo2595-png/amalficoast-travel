---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: 'Capri da Sorrento', url: '/it-it/itinerari/1-giorno/capri-da-sorrento/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quanto tempo ci vuole da Sorrento a Capri in aliscafo?",
      "acceptedAnswer": { "@type": "Answer", "text": "L'aliscafo da Sorrento (Marina Piccola) a Capri (Marina Grande) impiega circa 20-25 minuti. Le compagnie principali sono NLG e Alilauro. In estate le corse partono ogni 30-60 min dalle 7:00 alle 20:00. Il biglietto A/R costa ~€18-22." }
    },
    {
      "@type": "Question",
      "name": "È possibile vedere la Grotta Azzurra in un giorno da Sorrento?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sì, ma richiede un'organizzazione precisa. Prendi il primo aliscafo da Sorrento (7:30-8:00), arriva a Capri e vai subito alla Grotta Azzurra prima della folla (meglio prima delle 10:00). Poi esplori Capri e Anacapri nel pomeriggio. Rientro a Sorrento con l'ultimo aliscafo (intorno alle 18:30-19:00)." }
    },
    {
      "@type": "Question",
      "name": "Capri vs Anacapri: quale visitare in un giorno?",
      "acceptedAnswer": { "@type": "Answer", "text": "Entrambe meritano, ma con un solo giorno scegli in base agli interessi: Capri città è più chic, piena di negozi e con i Faraglioni. Anacapri è più tranquilla, con Villa San Michele e la seggiovia per Monte Solaro (589 m). Una buona giornata include mattina alla Grotta Azzurra, pranzo ad Anacapri, pomeriggio a Capri e Faraglioni." }
    }
  ]
};

const schedule = [
  { time: '07:30', place: 'Sorrento, Marina Piccola', action: 'Aliscafo NLG/Alilauro per Capri (20-25 min, ~€9-11 a/r disponibile)' },
  { time: '08:00', place: 'Capri, Marina Grande', action: 'Bus per Grotta Azzurra (20 min, ~€2). Arriva prima delle 10 per evitare code.' },
  { time: '08:30', place: 'Grotta Azzurra', action: 'Barchetta a remi nella grotta (€15 + ingresso €14). Attesa variabile.' },
  { time: '10:00', place: 'Anacapri', action: 'Bus da Capri per Anacapri (15 min). Villa San Michele (~€7). Seggiovia Monte Solaro (589 m, ~€13 A/R).' },
  { time: '12:30', place: 'Anacapri', action: 'Pranzo in trattoria locale (meno cara di Capri)' },
  { time: '14:00', place: 'Capri', action: 'Bus per Capri centro. Piazzetta, Via Camerelle, Giardini di Augusto, Faraglioni vista.' },
  { time: '16:00', place: 'Capri, Marina Grande', action: 'Giro in barchetta attorno ai Faraglioni (~€18-25 p.p., 1-2h)' },
  { time: '18:00', place: 'Capri, Marina Grande', action: 'Aliscafo di rientro per Sorrento (20-25 min)' },
];
---

<BaseLayout
  title="Capri da Sorrento in 1 Giorno 2025 | Grotta Azzurra, Faraglioni, Anacapri"
  description="Itinerario di 1 giorno a Capri partendo da Sorrento: Grotta Azzurra, Anacapri, Monte Solaro e Faraglioni. Aliscafi, orari e consigli per evitare le code."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-500"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Capri da Sorrento — 1 giorno</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">Itinerario · 1 giorno</p>
        <h1 class="font-serif text-display text-white mb-4">Capri da Sorrento</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          25 minuti di aliscafo e sei sull'isola più famosa d'Italia. Grotta Azzurra di mattina presto, Monte Solaro ad Anacapri, Faraglioni nel pomeriggio: la giornata perfetta a Capri.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Durata</p>
          <p class="font-semibold text-charcoal">1 giorno</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Costo trasporti</p>
          <p class="font-semibold text-charcoal">~€40–60</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Difficoltà</p>
          <p class="font-semibold text-charcoal">Facile</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Il programma ora per ora</h2>
      <div class="space-y-0">
        {schedule.map((s, i) => (
          <div class="flex gap-4">
            <div class="flex flex-col items-center">
              <div class="w-8 h-8 rounded-full bg-capri-600 text-white text-xs font-mono flex items-center justify-center flex-shrink-0">{i + 1}</div>
              {i < schedule.length - 1 && <div class="w-px flex-1 bg-gray-200 my-1"></div>}
            </div>
            <div class="pb-6">
              <span class="text-xs font-mono text-capri-600 font-semibold">{s.time}</span>
              <p class="font-semibold text-charcoal text-sm">{s.place}</p>
              <p class="text-sm text-gray-600">{s.action}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-lemon-50 border border-lemon-200 rounded-2xl p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli per Capri in giornata</p>
      <ul class="space-y-2">
        {[
          'Grotta Azzurra: prima delle 10:00 è quasi senza coda. Dopo le 11 l\'attesa può essere 1-2 ore.',
          'In luglio-agosto prenota l\'aliscafo online il giorno prima: le prime corse si esauriscono.',
          'Capri è cara: pranzo ad Anacapri costa il 30-40% meno che in Piazzetta.',
          'La seggiovia per Monte Solaro da Anacapri è imperdibile: 589 m, vista 360° su Costiera e Napoli.',
          'L\'aliscafo non parte con mare mosso: controlla il meteo marino e tieni un piano B (traghetto più stabile).',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-lemon-500 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
