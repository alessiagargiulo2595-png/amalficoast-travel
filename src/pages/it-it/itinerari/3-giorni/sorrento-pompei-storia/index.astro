---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: 'Sorrento, Pompei e Storia', url: '/it-it/itinerari/3-giorni/sorrento-pompei-storia/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quanto tempo serve per visitare Pompei?",
      "acceptedAnswer": { "@type": "Answer", "text": "Per una visita completa di Pompei servono almeno 3-4 ore. Una visita essenziale (Forum, Via dell'Abbondanza, Casa del Fauno, Anfiteatro) può farsi in 2-2.5 ore. Si consiglia di arrivare all'apertura (9:00) per evitare il caldo pomeridiano e le code. Biglietto ~€18-20, gratuito under 18." }
    },
    {
      "@type": "Question",
      "name": "Vale la pena visitare anche Ercolano oltre a Pompei?",
      "acceptedAnswer": { "@type": "Answer", "text": "Sì, Ercolano è spesso preferita dai visitatori esperti: più piccola di Pompei (2h sufficienti) ma con reperti meglio conservati perché seppellita da fango (non cenere). Il biglietto combinato Pompei+Ercolano esiste. Con 3 giorni, visita Ercolano nel pomeriggio del giorno 2 e Pompei al mattino del giorno 3." }
    }
  ]
};

const days = [
  {
    day: 'Giorno 1',
    title: 'Sorrento',
    items: [
      'Arrivo a Sorrento con Circumvesuviana da Napoli (70 min, ~€3.90).',
      'Centro storico: Piazza Tasso, Cattedrale, Vallone dei Mulini (vallata vulcanica nel centro città).',
      'Museo Correale: reperti romani, vedute di Sorrento nel XVIII sec.',
      'Marina Grande: il porto dei pescatori, cena con vista.',
    ],
  },
  {
    day: 'Giorno 2',
    title: 'Ercolano e Vesuvio',
    items: [
      'Circumvesuviana fino a Ercolano Scavi (20 min da Napoli, 50 min da Sorrento).',
      'Sito archeologico di Ercolano: conservazione straordinaria, 2-3 ore.',
      'Pomeriggio: bus/navetta per il Vesuvio (cratere a 1.281 m, ~€12 ingresso + guida obbligatoria). Vista sul Golfo di Napoli.',
      'Rientro a Sorrento in Circumvesuviana.',
    ],
  },
  {
    day: 'Giorno 3',
    title: 'Pompei',
    items: [
      'Circumvesuviana fino a Pompei Scavi - Villa dei Misteri (35 min da Napoli, 45 min da Sorrento).',
      'Scavi di Pompei: Forum, Terme, anfiteatro, case patrizie. Almeno 3h.',
      'Pranzo a Pompei moderna, poi visita al Museo del Tesoro di San Gennaro (facoltativo).',
      'Rientro verso Napoli o Sorrento nel pomeriggio.',
    ],
  },
];
---

<BaseLayout
  title="Sorrento, Pompei ed Ercolano in 3 Giorni 2025 | Itinerario Storico"
  description="Itinerario di 3 giorni tra storia e mare: Sorrento, Ercolano, Vesuvio e Pompei. Orari Circumvesuviana, prezzi biglietti e consigli pratici."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-500"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Sorrento, Pompei e Storia</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">Itinerario · 3 giorni</p>
        <h1 class="font-serif text-display text-white mb-4">Sorrento, Pompei e Storia</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Tre giorni tra archeologia e Golfo di Napoli: Sorrento come base, Ercolano e il Vesuvio nel secondo giorno, Pompei nel terzo. Tutto in treno, senza auto.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Durata</p>
          <p class="font-semibold text-charcoal">3 giorni / 2 notti</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Base consigliata</p>
          <p class="font-semibold text-charcoal">Sorrento</p>
        </div>
        <div class="bg-offwhite rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Trasporto chiave</p>
          <p class="font-semibold text-charcoal">Circumvesuviana</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-8">Il programma giorno per giorno</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
            <div class="bg-capri-50 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-capri-600 text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-capri-800">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-capri-400 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-lemon-50 border border-lemon-200 rounded-2xl p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli pratici</p>
      <ul class="space-y-2">
        {[
          'Pompei ed Ercolano: arriva all\'apertura (9:00). Il caldo pomeridiano e le code rendono la visita difficile.',
          'Biglietto combinato Pompei + Ercolano: vale la pena se visiti entrambi nello stesso giorno o in giorni consecutivi.',
          'La Circumvesuviana è frequente ma lenta: da Sorrento a Pompei Scavi ~45 min, da Napoli ~35 min.',
          'Il Vesuvio: il bus navetta parte da Ercolano e da Pompei (controlla gli orari stagionali). La guida è obbligatoria per legge.',
          'Sorrento di sera è magnifica: aperitivo a Marina Grande, cena sul corso principale.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-lemon-500 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
