---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: 'Isole: Ischia e Procida', url: '/it-it/itinerari/3-giorni/isole-ischia-procida/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Meglio Ischia o Procida per un weekend?",
      "acceptedAnswer": { "@type": "Answer", "text": "Dipende dal tipo di viaggio: Ischia è grande (46 km²), con terme, spiagge variegate, castelli e una vita notturna. Richiede almeno 2 giorni. Procida è piccola (4 km²), autentica, con i colori pastello iconici, pescatori e poca folla. Con 3 giorni puoi fare 2 notti a Ischia e 1 giorno di escursione a Procida." }
    },
    {
      "@type": "Question",
      "name": "Come arrivare a Ischia e Procida da Napoli?",
      "acceptedAnswer": { "@type": "Answer", "text": "Da Napoli Beverello: aliscafo per Ischia Porto (~50 min, €20-24) o traghetto (~75 min, €12-14). Per Procida: aliscafo da Napoli (~35 min, €15-18). Da Pozzuoli: traghetto Medmar/Caremar per Ischia e Procida, più economico (~€10-13). Si consiglia di prenotare online in estate." }
    }
  ]
};

const days = [
  {
    day: 'Giorno 1',
    title: 'Arrivo a Ischia',
    items: [
      'Traghetto o aliscafo da Napoli Beverello per Ischia Porto (50-75 min).',
      'Check-in. Pomeriggio: Ischia Ponte e il Castello Aragonese (ingresso ~€24, 2h).',
      'Spiaggia dei Maronti (la più lunga dell\'isola, sabbia nera vulcanica) o aperitivo a Forio.',
      'Cena a Lacco Ameno o Ischia Porto: cucina ischitana, coniglio all\'ischitana.',
    ],
  },
  {
    day: 'Giorno 2',
    title: 'Terme e Spiagge di Ischia',
    items: [
      'Mattina: giardini termali (Poseidon o Negombo, ~€35-40 ingresso). Terme naturali, piscine, saune.',
      'Pomeriggio: Spiaggia di Citara (Forio), una delle più belle dell\'isola.',
      'Tramonto dal Belvedere di Sant\'Angelo, il borgo più pittoresco di Ischia.',
      'Cena a Sant\'Angelo o rientro a Ischia Porto.',
    ],
  },
  {
    day: 'Giorno 3',
    title: 'Escursione a Procida',
    items: [
      'Aliscafo da Ischia per Procida (20 min, ~€9). Prima corsa 8:00.',
      'Marina Corricella: il porto dei pescatori, le case color pastello, il bar sul molo.',
      'Terra Murata: il borgo medievale più alto dell\'isola, vista sul Golfo.',
      'Spiaggia del Pozzo Vecchio (la spiaggia de Il Postino) per il bagno di mezzogiorno.',
      'Rientro a Napoli in aliscafo da Procida (35 min).',
    ],
  },
];
---

<BaseLayout
  title="Ischia e Procida in 3 Giorni 2025 | Itinerario Isole del Golfo di Napoli"
  description="Itinerario di 3 giorni tra Ischia e Procida: terme, spiagge vulcaniche, Marina Corricella e Castello Aragonese. Come arrivare, dove dormire e cosa vedere."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33] via-med-blue to-[#0077cc]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Isole: Ischia e Procida</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.2em] mb-3">Itinerario · 3 giorni</p>
        <h1 class="font-serif text-display text-white mb-4">Isole: Ischia e Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Due isole, due caratteri opposti: Ischia grande e termale, Procida piccola e autentica. Un weekend perfetto nel Golfo di Napoli, lontani dalla folla della Costiera.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Durata</p>
          <p class="font-semibold text-charcoal">3 giorni / 2 notti</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Base</p>
          <p class="font-semibold text-charcoal">Ischia Porto o Forio</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-gray-100">
          <p class="text-xs text-gray-400 mb-1">Trasporto</p>
          <p class="font-semibold text-charcoal">Aliscafi + bus isola</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-8">Il programma giorno per giorno</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
            <div class="bg-blue-50 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli pratici</p>
      <ul class="space-y-2">
        {[
          'A Ischia il bus circolare (CS/CD) gira tutto il giorno: una singola ~€1.50, giornaliero ~€6.',
          'Prenotare i giardini termali online: Poseidon e Negombo si esauriscono in estate.',
          'Procida in giornata: prendi il primo aliscafo (8:00) per avere tempo prima che arrivi la folla.',
          'Ischia in bassa stagione (ottobre-novembre): le terme sono aperte, pochi turisti, prezzi bassi.',
          'L\'aliscafo non parte con mare mosso: verifica il meteo prima di prenotare.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
