---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Itinerari', url: '/it-it/itinerari/' },
  { name: 'Classico Costiera — 3 giorni', url: '/it-it/itinerari/3-giorni/classico-costiera-amalfitana/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Dove dormire per visitare la Costiera Amalfitana in 3 giorni?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le basi migliori sono Amalfi (più centrale, buona scelta di hotel e B&B, ben servita da bus e traghetti) oppure Positano (più romantica ma più cara). Sorrento è ottima per chi vuole una città più comoda con più servizi e prezzi più bassi, con day trip verso la Costiera." }
    },
    {
      "@type": "Question",
      "name": "3 giorni sulla Costiera: meglio in alta o bassa stagione?",
      "acceptedAnswer": { "@type": "Answer", "text": "Maggio-giugno e settembre-ottobre sono i mesi migliori: clima perfetto, meno folla rispetto a luglio-agosto, prezzi più bassi. In luglio-agosto i bus sono stracolmi, i parcheggi esauriti e le spiagge affollate. In inverno molte strutture chiudono ma i borghi sono silenziosi e autentici." }
    }
  ]
};

const days = [
  {
    day: 'Giorno 1',
    title: 'Arrivo e Positano',
    items: [
      'Arrivo a Sorrento o Amalfi. Check-in.',
      'Pomeriggio a Positano: Spiaggia Grande, via Cristoforo Colombo, chiesa di Santa Maria Assunta.',
      'Aperitivo con vista dal belvedere sopra il paese.',
      'Cena a Positano o rientro in bus ad Amalfi.',
    ],
  },
  {
    day: 'Giorno 2',
    title: 'Amalfi e Ravello',
    items: [
      'Mattina: Duomo di Amalfi, Chiostro del Paradiso, Museo della Carta (carta amalfitana, XIII sec.).',
      'Bus SITA per Ravello (25 min). Villa Rufolo, Villa Cimbrone, panorami sulla Costiera.',
      'Pranzo a Ravello, poi rientro ad Amalfi nel pomeriggio.',
      'Cena sul porto di Amalfi: pesce del giorno, mozzarella di bufala.',
    ],
  },
  {
    day: 'Giorno 3',
    title: 'Praiano e Grotta dello Smeraldo',
    items: [
      'Mattina: bus SITA verso Positano, fermata a Praiano (passeggio tranquillo, spiaggia Gavitella).',
      'Grotta dello Smeraldo vicino a Conca dei Marini: ingresso ~€5, luce verde spettacolare.',
      'Pomeriggio libero ad Amalfi o escursione in barca (tour costiera da Amalfi, ~€40-70 p.p.).',
      'Partenza nel tardo pomeriggio verso Napoli/Salerno.',
    ],
  },
];
---

<BaseLayout
  title="Costiera Amalfitana in 3 Giorni 2025 | Itinerario Classico Completo"
  description="Itinerario classico di 3 giorni sulla Costiera Amalfitana: Positano, Amalfi, Ravello e Grotta dello Smeraldo. Dove dormire, cosa vedere e come spostarsi."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#001a33] via-med-blue to-[#0077cc]"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/70"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/it-it/itinerari/" class="hover:text-white transition-colors">Itinerari</a>
        <span>/</span>
        <span class="text-white">Classico Costiera — 3 giorni</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Itinerario · 3 giorni</p>
        <h1 class="font-serif text-display text-white mb-4">Classico Costiera Amalfitana</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Tre giorni per vedere il meglio della Costiera: Positano, Amalfi, Ravello e la Grotta dello Smeraldo. Il percorso classico, ottimizzato per chi usa i mezzi pubblici.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="grid sm:grid-cols-3 gap-4">
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Durata</p>
          <p class="font-semibold text-charcoal">3 giorni / 2 notti</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Base consigliata</p>
          <p class="font-semibold text-charcoal">Amalfi o Positano</p>
        </div>
        <div class="bg-med-cream rounded-2xl p-4 text-center border border-slate-100">
          <p class="text-xs text-slate-400 mb-1">Trasporti</p>
          <p class="font-semibold text-charcoal">Bus SITA + traghetti</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-8">Il programma giorno per giorno</h2>
      <div class="space-y-8">
        {days.map(d => (
          <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <div class="bg-med-blue/5 px-6 py-4 flex items-center gap-3">
              <span class="text-[10px] uppercase tracking-wide bg-med-blue text-white px-2 py-1 rounded-full font-medium">{d.day}</span>
              <h3 class="font-semibold text-charcoal">{d.title}</h3>
            </div>
            <ul class="px-6 py-4 space-y-2">
              {d.items.map(item => (
                <li class="flex items-start gap-2 text-sm text-charcoal">
                  <span class="w-1.5 h-1.5 rounded-full bg-med-blue/50 mt-1.5 flex-shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-med-cream border border-med-gold/20 rounded-[2rem] p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli per 3 giorni sulla Costiera</p>
      <ul class="space-y-2">
        {[
          'Base ad Amalfi: posizione centrale, più economica di Positano, ottimi collegamenti con bus e traghetti.',
          'Compra biglietti bus SITA in blocco (tabaccheria) all\'arrivo: risparmia tempo ogni mattina.',
          'Ravello non ha spiagge ma è il belvedere più bello della Costiera: dedicagli almeno mezza giornata.',
          'Tour in barca il giorno 3 è facoltativo ma trasforma la giornata: prenota il giorno prima.',
          'In estate: spostati entro le 9:00 per evitare bus stracolmi e code ai siti.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
