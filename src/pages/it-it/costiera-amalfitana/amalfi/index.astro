---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Costiera Amalfitana', url: '/it-it/costiera-amalfitana/' },
  { name: 'Amalfi', url: '/it-it/costiera-amalfitana/amalfi/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Amalfi",
  "description": "Amalfi è la capitale storica della Costiera Amalfitana, già potente Repubblica Marinara medievale. Famosa per il Duomo di Sant'Andrea, il Museo della Carta e il caratteristico centro storico.",
  "url": "https://amalficoast-travel.com/it-it/costiera-amalfitana/amalfi/",
  "image": "https://amalficoast-travel.com/images/amalfi-hero.jpg",
  "touristType": ["Cultura", "Storia", "Mare", "Gastronomia"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84011"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6339,
    "longitude": 14.6027
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Amalfi, Costiera Amalfitana",
  "description": "Città costiera della Costiera Amalfitana in provincia di Salerno, Campania. Ex Repubblica Marinara.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6339,
    "longitude": 14.6027
  },
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Costiera Amalfitana"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Come si arriva ad Amalfi da Napoli?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Da Napoli si può arrivare ad Amalfi in traghetto da Molo Beverello (circa 90–105 min, stagionale) oppure in bus SITA da Sorrento via SS163 (circa 90 min). In auto la SS163 è spettacolare ma tortuosa: in estate si consiglia di evitarla."
      }
    },
    {
      "@type": "Question",
      "name": "Qual è il periodo migliore per visitare Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Aprile–giugno e settembre–ottobre sono i mesi ideali: clima mite, folla contenuta, prezzi ragionevoli. Luglio e agosto sono il picco del turismo. Novembre–marzo è tranquillo ma con rischio di piogge e servizi ridotti."
      }
    },
    {
      "@type": "Question",
      "name": "Quanto costa il traghetto da Salerno ad Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Il traghetto Travelmar da Salerno ad Amalfi costa circa €8–10 a tratta. Il biglietto è acquistabile online o in biglietteria al porto. Il servizio è attivo indicativamente da aprile a ottobre."
      }
    },
    {
      "@type": "Question",
      "name": "Cosa vedere ad Amalfi in un giorno?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In un giorno si possono visitare il Duomo di Sant'Andrea e il Chiostro del Paradiso, il Museo della Carta, il centro storico con Piazza del Duomo, e fare una passeggiata alla Valle delle Ferriere. La sera, cena in uno dei ristoranti sul lungomare."
      }
    },
    {
      "@type": "Question",
      "name": "C'è parcheggio ad Amalfi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I parcheggi sono scarsi e costosi (parcheggio Luna Rossa e parcheggio Flavio Gioia: circa €4–5/ora). In estate vige la ZTL nel centro storico. Si raccomanda di arrivare con traghetto o bus SITA per evitare il problema del traffico sulla SS163."
      }
    }
  ]
};
---

<BaseLayout
  title="Amalfi 2025: Guida Completa | Costiera Amalfitana"
  description="Tutto su Amalfi: Duomo di Sant'Andrea, Museo della Carta, come arrivare, orari traghetti e bus, cosa vedere, quando andare. La guida definitiva alla capitale della Costiera Amalfitana."
  lang={lang}
  pageKey="amalfi"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, placeSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/amalfi-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager"  referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Repubblica Marinara · Patrimonio UNESCO</p>
        <h1 class="font-serif text-display text-white mb-4">Amalfi</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La città che ha dato il nome all'intera costiera. Capitale di una delle quattro Repubbliche Marinare medievali, oggi è un labirinto di vicoli, scalinate e profumo di limoni — con il Duomo di Sant'Andrea che domina tutto dall'alto.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">
            Fast Facts
          </a>
          <a href="#come-arrivare" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            Come arrivare
          </a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">
            FAQ
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <!-- Main Content -->
      <div class="space-y-16">

        <!-- Intro -->
        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Amalfi non è solo una città: è un pezzo di storia italiana incastonato nella roccia. Tra il IX e il XII secolo fu una delle potenze marittime più influenti del Mediterraneo — rivale di Venezia, Genova e Pisa. Oggi quella grandezza sopravvive nel Duomo, nell'Arsenale medievale e in una cultura locale che ha resistito ai secoli.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Con circa 5.000 abitanti, è anche il centro logistico della Costiera: i traghetti fermano qui, i bus si incrociano qui, e da qui partono le escursioni verso Ravello, la Valle delle Ferriere e le calette più remote. È la base ideale per esplorare l'intera area senza dipendere dall'auto.
          </p>
        </div>

        <!-- Did You Know -->
        <div class="bg-charcoal rounded-[2rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Lo sapevi?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">IX sec.</p>
              <p class="text-sm text-slate-600 mt-1">fondazione della Repubblica Marinara</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">1343</p>
              <p class="text-sm text-slate-600 mt-1">anno del maremoto che distrusse il porto</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">62</p>
              <p class="text-sm text-slate-600 mt-1">gradini della scalinata del Duomo</p>
            </div>
          </div>
          <p class="text-sm text-slate-500 mt-6 italic">
            La <em>Tavola Amalfitana</em>, il primo codice marittimo del Mediterraneo occidentale (XI sec.), fu usata come riferimento legale per la navigazione fino al 1570.
          </p>
        </div>

        <!-- Cosa Vedere -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Cosa vedere ad Amalfi</h2>
          <div class="space-y-8">

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Duomo di Sant'Andrea</h3>
                <p class="text-slate-600 leading-relaxed">Il simbolo assoluto di Amalfi. La facciata arabo-normanna con mosaici dorati domina Piazza del Duomo dalla cima di 62 scalini. All'interno le reliquie di Sant'Andrea Apostolo. Il Chiostro del Paradiso (ingresso a pagamento) è un capolavoro di architettura medievale. Aperto tutti i giorni.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Museo della Carta</h3>
                <p class="text-slate-600 leading-relaxed">Ospitato in una cartiera del XIII secolo ancora funzionante, racconta l'invenzione della carta bambagina — portata dagli arabi e perfezionata dagli amalfitani. Una delle industrie che rese Amalfi ricca. Visita guidata inclusa nel biglietto (~€5). Aperto da marzo a novembre.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Arsenale della Repubblica</h3>
                <p class="text-slate-600 leading-relaxed">Le grotte medievali dove venivano costruite le galee amalfitane. Oggi ospita il Museo Civico con la Tavola Amalfitana originale. L'edificio è uno dei pochi resti dell'architettura civile medievale della costiera. Ingresso libero nelle ore di apertura.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Valle delle Ferriere</h3>
                <p class="text-slate-600 leading-relaxed">Una riserva naturale a 10 minuti a piedi dal centro. Il sentiero risale il torrente Canneto tra cascate, felci giganti e antiche cartiere abbandonate. Circa 5 km andata e ritorno, livello facile. Ideale nelle ore fresche della mattina.</p>
              </div>
            </div>

            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">5</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Piazza del Duomo e il centro storico</h3>
                <p class="text-slate-600 leading-relaxed">Il cuore pulsante di Amalfi: bar, gelaterie, botteghe di ceramiche e limoncello. Da Piazza del Duomo si diramano vicoli che salgono verso i quartieri alti, dove la vita locale scorre lontano dai turisti. Da esplorare a piedi senza meta.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Come Arrivare -->
        <div id="come-arrivare" class="bg-charcoal rounded-[3rem] p-10 md:p-14 text-white relative overflow-hidden">
          <div class="relative z-10">
            <h2 class="font-serif text-3xl font-bold text-white tracking-tight mb-6">Come arrivare ad Amalfi</h2>
            <p class="text-white/60 mb-10 leading-relaxed">Amalfi non ha stazione ferroviaria. Le opzioni migliori sono il traghetto (da aprile a ottobre) e il bus SITA. In estate l'auto è sconsigliata: la SS163 è spesso congestionata e i parcheggi quasi inesistenti.</p>
            <div class="grid sm:grid-cols-2 gap-8 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0"><svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M8 11V7a4 4 0 018 0v4"/></svg></div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Via Mare</h3><p class="text-white/50 text-sm leading-relaxed">Traghetti stagionali da Salerno, Positano, Sorrento.</p></div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-2xl bg-med-gold/10 text-med-gold flex items-center justify-center flex-shrink-0"><svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg></div>
                <div><h3 class="font-serif text-xl font-bold text-white mb-2">Bus SITA</h3><p class="text-white/50 text-sm leading-relaxed">Da Salerno o Sorrento lungo la SS163. Circa 2.50 euro tutto anno.</p></div>
              </div>
            </div>
            <a href="/it-it/guida/traghetti/" class="inline-flex items-center gap-2 text-med-gold font-bold text-xs uppercase tracking-[0.3em] hover:underline">Guida completa trasporti <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></a>
          </div>
          <div class="absolute top-0 right-0 -translate-y-1/3 translate-x-1/3 w-72 h-72 bg-white/5 rounded-full blur-3xl pointer-events-none"></div>
        </div>

        <!-- Dettagli orari -->
        <div>

          <!-- Ferry Schedules -->
          <div class="mb-10">
            <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 17l1.5-6H19.5L21 17M3 17h18M3 17l-1.5 3h21L21 17M8 11V7a4 4 0 018 0v4"/></svg>
              Orari Traghetti — Estate 2025
            </h3>
            <p class="text-sm text-slate-500 mb-4">Servizi attivi indicativamente da aprile a ottobre. Verificare sempre gli orari aggiornati sui siti ufficiali delle compagnie.</p>

            <div class="overflow-x-auto rounded-2xl border border-slate-200">
              <table class="w-full text-sm">
                <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                  Travelmar — Tratta Salerno ↔ Amalfi
                </caption>
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Partenza Salerno</th>
                    <th class="text-left px-4 py-3 font-semibold">Arrivo Amalfi</th>
                    <th class="text-left px-4 py-3 font-semibold">Durata</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">07:15</td>
                    <td class="px-4 py-3 font-mono">08:30</td>
                    <td class="px-4 py-3 text-slate-500">~75 min (via Cetara, Maiori)</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">09:00</td>
                    <td class="px-4 py-3 font-mono">10:15</td>
                    <td class="px-4 py-3 text-slate-500">~75 min</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">11:00</td>
                    <td class="px-4 py-3 font-mono">12:15</td>
                    <td class="px-4 py-3 text-slate-500">~75 min</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">14:15</td>
                    <td class="px-4 py-3 font-mono">15:30</td>
                    <td class="px-4 py-3 text-slate-500">~75 min</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">17:00</td>
                    <td class="px-4 py-3 font-mono">18:15</td>
                    <td class="px-4 py-3 text-slate-500">~75 min</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <div class="overflow-x-auto rounded-2xl border border-slate-200 mt-6">
              <table class="w-full text-sm">
                <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                  NLG / Alilauro — Tratta Napoli (Beverello) ↔ Amalfi
                </caption>
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Partenza Napoli</th>
                    <th class="text-left px-4 py-3 font-semibold">Arrivo Amalfi</th>
                    <th class="text-left px-4 py-3 font-semibold">Durata</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">09:00</td>
                    <td class="px-4 py-3 font-mono">10:45</td>
                    <td class="px-4 py-3 text-slate-500">~105 min</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">11:15</td>
                    <td class="px-4 py-3 font-mono">13:00</td>
                    <td class="px-4 py-3 text-slate-500">~105 min</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">14:30</td>
                    <td class="px-4 py-3 font-mono">16:15</td>
                    <td class="px-4 py-3 text-slate-500">~105 min</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-400 mt-2">* Gli orari sono indicativi per la stagione 2025. Consulta travelmar.it e nlg.it per confermare.</p>
          </div>

          <!-- Bus Schedules -->
          <div>
            <h3 class="font-semibold text-charcoal text-xl mb-4 flex items-center gap-2">
              <svg class="w-5 h-5 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><path stroke-linecap="round" d="M3 10h18M8 19v2M16 19v2"/></svg>
              Bus SITA — Tratta Sorrento ↔ Amalfi (SS163)
            </h3>
            <p class="text-sm text-slate-500 mb-4">Il bus SITA collega Sorrento ad Amalfi lungo la SS163 passando per Positano e Praiano (~90 min, ~€2,50). Corse frequenti tutto l'anno.</p>

            <div class="overflow-x-auto rounded-2xl border border-slate-200">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-med-blue/5 text-charcoal">
                    <th class="text-left px-4 py-3 font-semibold">Partenza Sorrento</th>
                    <th class="text-left px-4 py-3 font-semibold">Arrivo Amalfi</th>
                    <th class="text-left px-4 py-3 font-semibold">Frequenza</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">07:00</td>
                    <td class="px-4 py-3 font-mono">08:30</td>
                    <td class="px-4 py-3 text-slate-500">Solo feriali</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">08:30</td>
                    <td class="px-4 py-3 font-mono">10:00</td>
                    <td class="px-4 py-3 text-slate-500">Ogni giorno</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">10:00</td>
                    <td class="px-4 py-3 font-mono">11:30</td>
                    <td class="px-4 py-3 text-slate-500">Ogni giorno</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">12:00</td>
                    <td class="px-4 py-3 font-mono">13:30</td>
                    <td class="px-4 py-3 text-slate-500">Ogni giorno</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">14:30</td>
                    <td class="px-4 py-3 font-mono">16:00</td>
                    <td class="px-4 py-3 text-slate-500">Ogni giorno</td>
                  </tr>
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3 font-mono">16:30</td>
                    <td class="px-4 py-3 font-mono">18:00</td>
                    <td class="px-4 py-3 text-slate-500">Ogni giorno</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-slate-400 mt-2">* Orari indicativi. In estate aggiungono corse extra. Consulta sitasudtrasporti.it per l'orario aggiornato.</p>
          </div>
        </div>

        <!-- Hidden Gems -->
        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-6">Luoghi nascosti di Amalfi</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Pontone e Scala</h3>
              <p class="text-sm text-slate-600 leading-relaxed">I due borghi medievali sopra Amalfi, raggiungibili a piedi in 40–60 minuti lungo antichi sentieri lastricati. Quasi nessun turista. Scala è uno dei comuni più piccoli d'Italia con vedute straordinarie sulla valle.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Spiaggia di Santa Croce</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Una caletta nascosta a est del centro, raggiungibile a piedi in 20 minuti o in barca dal porto. Meno frequentata della spiaggia principale, con acque particolarmente limpide e una piccola grotta.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Rione Vagliendola</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Il quartiere alto di Amalfi, arroccato sulla collina dietro il Duomo. Vicoli silenziosi, archi medievali e scorci sul mare lontano dal traffico turistico del lungomare. Da esplorare nelle ore calde del pomeriggio.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Pasticceria Pansa (dal 1830)</h3>
              <p class="text-sm text-slate-600 leading-relaxed">La pasticceria più antica della costiera, in Piazza del Duomo. Famosa per i dolci al limone, le delizie e i cioccolatini alla mandorla. Un'istituzione locale che merita una sosta anche solo per un caffè.</p>
            </div>
          </div>
        </div>

        <!-- Consiglio Local -->
        <div class="relative overflow-hidden rounded-[3rem] bg-med-blue p-10 md:p-14 text-white shadow-2xl">
          <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
            <div class="w-20 h-20 rounded-2xl bg-white/10 flex items-center justify-center flex-shrink-0 border border-white/20"><svg class="w-10 h-10 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg></div>
