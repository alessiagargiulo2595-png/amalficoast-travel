---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Costiera Amalfitana', url: '/it-it/costiera-amalfitana/' },
  { name: 'Minori', url: '/it-it/costiera-amalfitana/minori/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Minori",
  "description": "Minori è il borgo della limonara e dei dolci, con i resti di una villa romana del I sec. d.C. e le pasticcerie più celebri della Costiera Amalfitana. Autentica e meno frequentata.",
  "url": "https://amalficoast-travel.com/it-it/costiera-amalfitana/minori/",
  "image": "https://amalficoast-travel.com/images/minori-hero.jpg",
  "touristType": ["Gastronomia", "Archeologia", "Autenticità", "Mare"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Minori",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6500,
    "longitude": 14.6275
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Minori, Costiera Amalfitana",
  "description": "Borgo della limonara e della pasticceria artigianale sulla Costiera Amalfitana.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6500,
    "longitude": 14.6275
  },
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Costiera Amalfitana"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Cosa c'è da vedere a Minori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le attrazioni principali di Minori sono la Villa Romana del I sec. d.C. (unica nel suo genere sulla costiera), la Basilica di Santa Trofimena, le limonaie terrazzate e le pasticcerie artigianali — in particolare quelle specializzate in delizie al limone e scialatielli freschi."
      }
    },
    {
      "@type": "Question",
      "name": "Come si arriva a Minori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Minori è raggiungibile in bus SITA da Amalfi (~10 min) e da Salerno (~40 min), e in traghetto da Salerno con Travelmar (stagionale, ~50 min). Si trova a pochi minuti da Maiori, con cui condivide le fermate dei bus."
      }
    },
    {
      "@type": "Question",
      "name": "Minori è famosa per i dolci?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sì, Minori è considerata la capitale della pasticceria della Costiera Amalfitana. Le specialità locali sono le delizie al limone, la torta ricotta e pera, i biscotti al limone e gli scialatielli — pasta artigianale inventata qui dallo chef Enrico Cosentino negli anni '70."
      }
    },
    {
      "@type": "Question",
      "name": "La spiaggia di Minori è sabbiosa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La spiaggia di Minori è mista: ghiaia fine e sabbia scura. Non è sabbiosa come quella di Maiori (a soli 2 km), ma è ben attrezzata con stabilimenti balneari e zona libera. Le acque sono calme e limpide."
      }
    },
    {
      "@type": "Question",
      "name": "Quanto dura la visita alla Villa Romana di Minori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La Villa Romana del I sec. d.C. si visita in 30–45 minuti. L'ingresso è gratuito. Gli scavi hanno riportato alla luce un triclinio estivo, terme e un ninfeo. Il sito è aperto dal martedì alla domenica."
      }
    }
  ]
};
---

<BaseLayout
  title="Minori 2025: Guida Completa | Villa Romana e Dolci della Costiera"
  description="Tutto su Minori: villa romana, pasticcerie, spiaggia, come arrivare. La guida al borgo della limonara e dei sapori autentici della Costiera Amalfitana."
  lang={lang}
  pageKey="minori"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, placeSchema, faqSchema]}
>

  <section class="relative min-h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/minori-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.2em] mb-3">La capitale della pasticceria · Villa Romana del I sec.</p>
        <h1 class="font-serif text-display text-white mb-4">Minori</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Minori profuma di limoni e zucchero a velo. Borgo della limonara e delle delizie al limone, custodisce anche i resti più antichi della costiera: una villa romana del I secolo affacciata sul mare, ancora visitabile gratuitamente nel centro del paese.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-lemon-400 text-charcoal text-sm font-semibold rounded-full hover:bg-lemon-300 transition-colors">Fast Facts</a>
          <a href="#come-arrivare" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Come arrivare</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Minori è piccola — meno di 3.000 abitanti — ma concentra una densità di sapori e storia che sorprende. È il luogo dove gli scialatielli furono inventati, dove le delizie al limone raggiungono la perfezione, e dove i romani costruirono una delle ville marittime più lussuose del I secolo d.C.
          </p>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Adiacente a Maiori e vicinissima ad Amalfi, Minori è spesso visitata come tappa di un giorno. Ma chi ci dedica più tempo scopre i sentieri tra le limonaie terrazzate, il lungofiumara lungo il torrente Regina e la vita locale di un borgo che non ha mai cercato la fama turistica.
          </p>
        </div>

        <div class="bg-blue-50 border-l-4 border-med-blue/20 rounded-r-2xl p-8">
          <p class="text-[10px] uppercase tracking-[0.2em] text-med-blue font-medium mb-4">Lo sapevi?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">I sec.</p>
              <p class="text-sm text-gray-600 mt-1">d.C. — età della villa romana</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">1978</p>
              <p class="text-sm text-gray-600 mt-1">anno dell'invenzione degli scialatielli</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">€0</p>
              <p class="text-sm text-gray-600 mt-1">ingresso alla villa romana</p>
            </div>
          </div>
          <p class="text-sm text-gray-500 mt-6 italic">
            Gli <em>scialatielli</em> — pasta fresca larga e corta condita con frutti di mare — furono creati dallo chef Enrico Cosentino a Minori nel 1978. Oggi sono il primo piatto simbolo di tutta la Costiera Amalfitana.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Cosa vedere a Minori</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-12 h-12 rounded-2xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue font-serif font-bold text-lg">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Villa Romana del I sec. d.C.</h3>
                <p class="text-gray-600 leading-relaxed">Scoperta nel 1932 nel pieno centro di Minori, è uno dei siti archeologici più particolari della costiera: una villa marittima con triclinio estivo, terme, ninfeo e cisterne ancora in ottimo stato. Ingresso gratuito. Aperta dal martedì alla domenica (verificare orari stagionali).</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-12 h-12 rounded-2xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue font-serif font-bold text-lg">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Pasticcerie e delizie al limone</h3>
                <p class="text-gray-600 leading-relaxed">Minori è la capitale indiscussa della pasticceria della costiera. Le delizie al limone di sal de Riso, le torte di ricotta e pere di Gambardella e i biscotti al limone di Andreina sono conosciuti in tutta Italia. Un tour delle pasticcerie del centro è un'esperienza imprescindibile.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-12 h-12 rounded-2xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue font-serif font-bold text-lg">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Basilica di Santa Trofimena</h3>
                <p class="text-gray-600 leading-relaxed">La chiesa principale di Minori, ricostruita nel XVIII secolo, custodisce le reliquie della martire Santa Trofimena (patrona della città) in una cripta romanica del IX secolo. L'interno è sobrio e luminoso, con un pavimento a mosaico ottocentesco. Ingresso gratuito.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-12 h-12 rounded-2xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue font-serif font-bold text-lg">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Sentiero Minori–Ravello</h3>
                <p class="text-gray-600 leading-relaxed">Il percorso più classico da Minori risale la valle verso Ravello attraverso limonaie terrazzate e scalinate storiche. Circa 5 km, 1h30 di cammino in salita. Si arriva direttamente in Piazza del Duomo a Ravello. Il ritorno in bus costa ~€1,30.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-12 h-12 rounded-2xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue font-serif font-bold text-lg">5</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Spiaggia e lungomare di Minori</h3>
                <p class="text-gray-600 leading-relaxed">La spiaggia mista di Minori è meno frequentata di Maiori (a soli 2 km) ma altrettanto attrezzata. Il lungofiumara lungo il torrente Regina è il salotto all'aperto del paese: bar, gelaterie e panchine con vista sul mare. Ideale la sera per il passeggio.</p>
              </div>
            </div>
          </div>
        </div>

        <div id="come-arrivare">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Come arrivare a Minori</h2>
          <p class="text-gray-600 mb-8 leading-relaxed">Minori è servita dal bus SITA e da traghetti stagionali. Si trova tra Maiori e Atrani, a 10 minuti da Amalfi.</p>
          <div class="overflow-x-auto rounded-2xl border border-gray-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-gray-500 px-4 py-2 bg-gray-50 rounded-t-2xl border-b border-gray-200 font-medium">
                Connessioni principali verso Minori
              </caption>
              <thead>
                <tr class="bg-blue-50 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Provenienza</th>
                  <th class="text-left px-4 py-3 font-semibold">Mezzo</th>
                  <th class="text-left px-4 py-3 font-semibold">Durata</th>
                  <th class="text-left px-4 py-3 font-semibold">Biglietto</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3">Amalfi</td><td class="px-4 py-3">Bus SITA</td><td class="px-4 py-3 font-mono">~10 min</td><td class="px-4 py-3 text-gray-500">~€1,30</td></tr>
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3">Maiori</td><td class="px-4 py-3">Bus SITA / a piedi</td><td class="px-4 py-3 font-mono">~10 min</td><td class="px-4 py-3 text-gray-500">~€1,30</td></tr>
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3">Salerno</td><td class="px-4 py-3">Traghetto (stagionale)</td><td class="px-4 py-3 font-mono">~50 min</td><td class="px-4 py-3 text-gray-500">~€8</td></tr>
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3">Ravello</td><td class="px-4 py-3">A piedi (discesa)</td><td class="px-4 py-3 font-mono">~1h30</td><td class="px-4 py-3 text-gray-500">Gratuito</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-gray-400 mt-2">* Consulta sitasudtrasporti.it e travelmar.it per orari aggiornati.</p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Luoghi nascosti di Minori</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-med-cream rounded-[2rem] p-6 border border-gray-100">
              <h3 class="font-semibold text-charcoal mb-2">Limonaie terrazzate</h3>
              <p class="text-sm text-gray-600 leading-relaxed">I "giardini" di limoni sfusato amalfitano IGP sulle terrazze sopra Minori. Alcuni produttori locali aprono i loro orti su prenotazione. Il limone sfusato è più grande, meno acido e profumato del comune limone: la base di tutto il limoncello della costiera.</p>
            </div>
            <div class="bg-med-cream rounded-[2rem] p-6 border border-gray-100">
              <h3 class="font-semibold text-charcoal mb-2">Sal de Riso — la pasticceria originale</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Il pasticcere Sal de Riso ha reso famosa Minori in tutta Italia con le sue delizie al limone e le torte di ricotta. Il laboratorio originale è a Minori: meglio acquistare qui che nelle filiali delle città.</p>
            </div>
            <div class="bg-med-cream rounded-[2rem] p-6 border border-gray-100">
              <h3 class="font-semibold text-charcoal mb-2">Atrani (a 5 minuti)</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Il comune più piccolo d'Italia per superficie (0,12 km²) è a pochi minuti a piedi da Minori. Una piazzetta romantica sul mare, quasi senza turisti, con la chiesa di San Salvatore de' Birecto dove venivano incoronati i dogi di Amalfi.</p>
            </div>
            <div class="bg-med-cream rounded-[2rem] p-6 border border-gray-100">
              <h3 class="font-semibold text-charcoal mb-2">Fiera di Santa Trofimena</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Il 13 luglio si svolge la festa patronale con processione a mare delle reliquie della santa. Una delle tradizioni religiose più sentite della costiera, con fuochi d'artificio sul mare. Chi capita a Minori in quella data assiste a qualcosa di irripetibile.</p>
            </div>
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Domande frequenti su Minori</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-gray-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-charcoal text-white rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.2em] text-med-gold font-medium mb-4">Fast Facts — Minori</p>
          <dl class="space-y-3">
            {[
              { dt: 'Posizione', dd: 'Costiera Amalfitana, SA' },
              { dt: 'Altitudine', dd: '0–5 m slm' },
              { dt: 'Popolazione', dd: '~2.900 abitanti' },
              { dt: 'ZTL', dd: 'No' },
              { dt: 'Mezzi', dd: 'Bus SITA, Traghetto' },
              { dt: 'Spiaggia', dd: 'Ghiaia fine mista' },
              { dt: 'Specialità', dd: 'Delizie al limone, scialatielli' },
              { dt: 'Miglior periodo', dd: 'Apr–Giu / Set–Ott' },
              { dt: 'Valuta', dd: 'Euro (€)' },
            ].map(({ dt, dd }, i, arr) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/60 text-sm flex-shrink-0">{dt}</dt>
                  <dd class="text-sm text-right">{dd}</dd>
                </div>
                {i < arr.length - 1 && <div class="border-t border-white/10"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-lemon-300 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.2em] text-lemon-700 font-medium mb-3">Consigli degli insider</p>
          <ul class="space-y-3">
            {[
              'Combina Minori e Maiori in una mezza giornata: sono a 10 minuti a piedi l\'una dall\'altra.',
              'La villa romana al centro del paese è gratuita: non saltarla anche se sembrerà piccola dall\'esterno.',
              'Compra le delizie al limone direttamente da Sal de Riso a Minori: costano meno che nelle rivendite di tutta la costiera.',
              'Fai la salita a Ravello a piedi attraverso le limonaie: è uno dei percorsi più belli e meno battuti della costiera.',
            ].map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border border-gray-200 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-medium mb-3">Esplora la Costiera</p>
          <nav class="space-y-1">
            {[
              { href: '/it-it/costiera-amalfitana/positano/', label: 'Positano' },
              { href: '/it-it/costiera-amalfitana/amalfi/', label: 'Amalfi' },
              { href: '/it-it/costiera-amalfitana/ravello/', label: 'Ravello' },
              { href: '/it-it/costiera-amalfitana/praiano/', label: 'Praiano' },
              { href: '/it-it/costiera-amalfitana/maiori/', label: 'Maiori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-blue-50 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Esplora anche sulla Costiera"
    items={[
      { name: 'Positano',  href: '/it-it/costiera-amalfitana/positano/', tag: 'Fashion & Vista',  desc: 'Le case colorate a picco sul mare, boutique di lusso e la spiaggia Fornillo.' },
      { name: 'Amalfi',    href: '/it-it/costiera-amalfitana/amalfi/',   tag: 'Arte & Storia',    desc: 'Il Duomo, il Chiostro del Paradiso e i vicoli della Repubblica marinara.' },
      { name: 'Ravello',   href: '/it-it/costiera-amalfitana/ravello/',  tag: 'Musica & Giardini', desc: 'Villa Rufolo, Villa Cimbrone e il Festival Musicale a 350 m sul mare.' },
      { name: 'Praiano',   href: '/it-it/costiera-amalfitana/praiano/', tag: 'Tramonto & Quiete', desc: 'Il tramonto da San Gennaro, la spiaggia Gavitella e la Marina di Praia.' },
      { name: 'Maiori',    href: '/it-it/costiera-amalfitana/maiori/',   tag: 'Spiaggia & Relax', desc: 'La spiaggia di sabbia più lunga della costiera: 300 m di lungomare.' },
      { name: 'Procida',   href: '/it-it/isole/procida/',                tag: 'La più autentica', desc: 'Case colorate a Marina Corricella, Capitale italiana della Cultura 2022.' },
    ]}
  />

</BaseLayout>
