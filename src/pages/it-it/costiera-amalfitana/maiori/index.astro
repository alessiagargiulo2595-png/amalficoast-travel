---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Costiera Amalfitana', url: '/it-it/costiera-amalfitana/' },
  { name: 'Maiori', url: '/it-it/costiera-amalfitana/maiori/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Maiori",
  "description": "Maiori ha la spiaggia sabbiosa più lunga della Costiera Amalfitana (300 m). Meno elitaria dei vicini, è la scelta ideale per chi cerca il mare comodo e accessibile senza rinunciare al paesaggio UNESCO.",
  "url": "https://amalficoast-travel.com/it-it/costiera-amalfitana/maiori/",
  "image": "https://amalficoast-travel.com/images/maiori-hero.jpg",
  "touristType": ["Mare", "Spiaggia sabbiosa", "Famiglia", "Relax"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Maiori",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6493,
    "longitude": 14.6450
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Maiori, Costiera Amalfitana",
  "description": "Comune costiero con la spiaggia sabbiosa più lunga della Costiera Amalfitana.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6493,
    "longitude": 14.6450
  },
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Costiera Amalfitana"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "La spiaggia di Maiori è sabbiosa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sì, la spiaggia di Maiori è la più lunga della costiera (circa 300 m) ed è di sabbia e ghiaia fine, a differenza delle spiagge di ciottoli di Positano e Amalfi. Ha una zona libera gratuita e stabilimenti con lettini e ombrelloni."
      }
    },
    {
      "@type": "Question",
      "name": "Come si arriva a Maiori?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Maiori è raggiungibile in traghetto da Salerno (Travelmar, circa 50 min, stagionale) e in bus SITA dalla SS163 (da Amalfi ~15 min, da Salerno ~45 min). Ha anche un parcheggio più capiente rispetto agli altri borghi della costiera."
      }
    },
    {
      "@type": "Question",
      "name": "Maiori è adatta alle famiglie con bambini?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Maiori è probabilmente la destinazione più adatta alle famiglie di tutta la costiera: spiaggia sabbiosa, lungomare pianeggiante, prezzi più accessibili, parcheggi disponibili e meno scale rispetto a Positano o Ravello."
      }
    },
    {
      "@type": "Question",
      "name": "Cosa vedere a Maiori oltre alla spiaggia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oltre alla spiaggia, vale la pena visitare la Collegiata di Santa Maria a Mare (chiesa medievale sulla collina), il Castello di San Nicola de Thoro-Plano (ruderi medievali con panorama), e fare l'escursione alla Valle del Torrente Reginna."
      }
    },
    {
      "@type": "Question",
      "name": "Maiori è più economica di Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sì, decisamente. Maiori è una delle destinazioni più economiche della costiera. Hotel, ristoranti e appartamenti costano in media il 40–50% in meno rispetto a Positano o Ravello. È una buona base per esplorare l'intera costiera senza spendere una fortuna."
      }
    }
  ]
};
---

<BaseLayout
  title="Maiori 2025: Guida Completa | Spiaggia Sabbiosa Costiera Amalfitana"
  description="Tutto su Maiori: la spiaggia sabbiosa più lunga della costiera, come arrivare, cosa vedere, prezzi e consigli. La guida alla destinazione più accessibile della Costiera Amalfitana."
  lang={lang}
  pageKey="maiori"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, placeSchema, faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/maiori-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.2em] mb-3">La spiaggia sabbiosa più lunga · Ideale per famiglie</p>
        <h1 class="font-serif text-display text-white mb-4">Maiori</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Mentre il resto della costiera offre ciottoli e calette, Maiori vanta 300 metri di spiaggia sabbiosa, un lungomare pianeggiante e prezzi umani. La scelta intelligente per chi vuole godersi l'UNESCO senza sacrificare il comfort.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-lemon-400 text-charcoal text-sm font-semibold rounded-full hover:bg-lemon-300 transition-colors">Fast Facts</a>
          <a href="#come-arrivare" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Come arrivare</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Maiori è il contrario di Positano: niente boutique di lusso, niente file per i selfie, niente prezzi da capogiro. Ha invece qualcosa che gli altri borghi della costiera non possono offrire: una vera spiaggia sabbiosa, un lungomare comodo e la sensazione di un luogo vissuto tutto l'anno dai suoi abitanti.
          </p>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Storicamente colpita da alluvioni (la più devastante nel 1954), Maiori ha ricostruito il suo lungomare e oggi offre servizi che altri borghi non hanno: parcheggi, supermercati, farmacie, banche. Una base pratica per esplorare l'intera costiera senza spendere una fortuna.
          </p>
        </div>

        <div class="bg-charcoal rounded-[2rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.2em] text-med-gold font-medium mb-4">Lo sapevi?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">300 m</p>
              <p class="text-sm text-gray-600 mt-1">la spiaggia sabbiosa più lunga della costiera</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">5.600</p>
              <p class="text-sm text-gray-600 mt-1">abitanti residenti</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">15 min</p>
              <p class="text-sm text-gray-600 mt-1">da Amalfi in bus o traghetto</p>
            </div>
          </div>
          <p class="text-sm text-gray-500 mt-6 italic">
            Maiori fu il comune più colpito dall'alluvione del 26 ottobre 1954, che causò oltre 300 vittime sull'intera costiera. Il lungomare fu completamente ricostruito negli anni '60.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Cosa vedere a Maiori</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/20 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Spiaggia di Maiori</h3>
                <p class="text-gray-600 leading-relaxed">La spiaggia sabbiosa più lunga della costiera: 300 metri di sabbia e ghiaia fine con stabilimenti balneari e zona libera. Lettini e ombrelloni disponibili. Acque calme e poco profonde nella parte centrale, ideale per bambini. Aperta tutto l'anno.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/20 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Collegiata di Santa Maria a Mare</h3>
                <p class="text-gray-600 leading-relaxed">La chiesa medievale del XIII secolo si raggiunge salendo una scalinata panoramica dal lungomare. L'interno conserva un crocifisso ligneo del XV secolo e una Madonna nera venerata dai pescatori locali. Vista sul mare dalla terrazza esterna. Ingresso libero.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/20 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Castello di San Nicola de Thoro-Plano</h3>
                <p class="text-gray-600 leading-relaxed">I ruderi di un castello medievale arroccato sulla collina sopra Maiori, raggiungibili a piedi in circa 40 minuti. Panorama straordinario sulla costiera da Capo d'Orso a Capo Sottile. Non restaurato: atmosfera autentica e nessuna fila.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/20 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Valle del Torrente Reginna</h3>
                <p class="text-gray-600 leading-relaxed">La valle alle spalle di Maiori offre sentieri facili tra limoneti, castagneti e mulini abbandonati. Il percorso principale sale verso il Santuario dell'Avvocata (1.100 m slm) con panorami incredibili. Accesso gratuito dal centro di Maiori.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/20 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">5</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Capo d'Orso e Torre Normanna</h3>
                <p class="text-gray-600 leading-relaxed">Il promontorio a est di Maiori con una torre di avvistamento normanna del XI secolo. Raggiungibile a piedi dal lungomare in 20 minuti. Vista panoramica sul Golfo di Salerno. Punto di arrivo di molte escursioni in kayak.</p>
              </div>
            </div>
          </div>
        </div>

        <div id="come-arrivare">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Come arrivare a Maiori</h2>
          <p class="text-gray-600 mb-8 leading-relaxed">Maiori è uno dei borghi più accessibili della costiera: traghetto da Salerno, bus SITA e parcheggi più disponibili rispetto ai vicini.</p>
          <div class="overflow-x-auto rounded-2xl border border-gray-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-gray-500 px-4 py-2 bg-gray-50 rounded-t-2xl border-b border-gray-200 font-medium">
                Travelmar — Tratta Salerno ↔ Maiori (stagionale)
              </caption>
              <thead>
                <tr class="bg-blue-50 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Partenza Salerno</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivo Maiori</th>
                  <th class="text-left px-4 py-3 font-semibold">Durata</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3 font-mono">07:15</td><td class="px-4 py-3 font-mono">08:00</td><td class="px-4 py-3 text-gray-500">~45 min (via Cetara)</td></tr>
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3 font-mono">09:00</td><td class="px-4 py-3 font-mono">09:45</td><td class="px-4 py-3 text-gray-500">~45 min</td></tr>
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3 font-mono">11:00</td><td class="px-4 py-3 font-mono">11:45</td><td class="px-4 py-3 text-gray-500">~45 min</td></tr>
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3 font-mono">14:15</td><td class="px-4 py-3 font-mono">15:00</td><td class="px-4 py-3 text-gray-500">~45 min</td></tr>
              </tbody>
            </table>
          </div>
          <div class="overflow-x-auto rounded-2xl border border-gray-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-gray-500 px-4 py-2 bg-gray-50 rounded-t-2xl border-b border-gray-200 font-medium">
                Bus SITA — Connessioni principali verso Maiori
              </caption>
              <thead>
                <tr class="bg-blue-50 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Provenienza</th>
                  <th class="text-left px-4 py-3 font-semibold">Durata</th>
                  <th class="text-left px-4 py-3 font-semibold">Biglietto</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3">Amalfi</td><td class="px-4 py-3 font-mono">~15 min</td><td class="px-4 py-3 text-gray-500">~€1,30</td></tr>
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3">Salerno</td><td class="px-4 py-3 font-mono">~45 min</td><td class="px-4 py-3 text-gray-500">~€2,50</td></tr>
                <tr class="hover:bg-gray-50 transition-colors"><td class="px-4 py-3">Sorrento</td><td class="px-4 py-3 font-mono">~100 min</td><td class="px-4 py-3 text-gray-500">~€3,50</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-gray-400 mt-2">* Consulta travelmar.it e sitasudtrasporti.it per orari aggiornati.</p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Luoghi nascosti di Maiori</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[2.5rem] p-8 border border-gray-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Spiaggia di Erchie</h3>
              <p class="text-sm text-gray-600 leading-relaxed">A pochi chilometri da Maiori, Erchie è una piccola cala con spiaggia sabbiosa, torre saracena e un antico convento. Raggiungibile in bus SITA o in barca da Maiori. Tra le spiagge più belle e meno frequentate della costiera.</p>
            </div>
            <div class="bg-white rounded-[2.5rem] p-8 border border-gray-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Santuario dell'Avvocata</h3>
              <p class="text-sm text-gray-600 leading-relaxed">A 1.100 m di altitudine sopra Maiori, raggiungibile a piedi in 3–4 ore o in auto. Vista panoramica straordinaria su tutta la costiera. Il 25 marzo si svolge la processione secolare più partecipata della zona.</p>
            </div>
            <div class="bg-white rounded-[2.5rem] p-8 border border-gray-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Forno a legna di Maiori</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Nelle vie interne del centro storico si trovano ancora panetterie e pizzerie con forno a legna frequentate solo dai residenti. Una pizza a pranzo qui costa la metà rispetto ai ristoranti sul lungomare.</p>
            </div>
            <div class="bg-white rounded-[2.5rem] p-8 border border-gray-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Kayak lungo la costa</h3>
              <p class="text-sm text-gray-600 leading-relaxed">Maiori è il punto di partenza ideale per escursioni in kayak verso Minori, Cetara e le grotte marine tra Capo d'Orso e Capo Sottile. Noleggio disponibile sul lungomare da aprile a ottobre.</p>
            </div>
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Domande frequenti su Maiori</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-gray-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-charcoal text-white rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.2em] text-med-gold font-medium mb-4">Fast Facts — Maiori</p>
          <dl class="space-y-3">
            {[
              { dt: 'Posizione', dd: 'Costiera Amalfitana, SA' },
              { dt: 'Altitudine', dd: '0–10 m slm' },
              { dt: 'Popolazione', dd: '~5.600 abitanti' },
              { dt: 'ZTL', dd: 'No' },
              { dt: 'Mezzi', dd: 'Bus SITA, Traghetto' },
              { dt: 'Spiaggia', dd: 'Sabbia e ghiaia (300 m)' },
              { dt: 'Miglior periodo', dd: 'Giu–Set' },
              { dt: 'Adatta a', dd: 'Famiglie, base economica' },
              { dt: 'Valuta', dd: 'Euro (€)' },
            ].map(({ dt, dd }, i, arr) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/60 text-sm flex-shrink-0">{dt}</dt>
                  <dd class="text-sm text-right">{dd}</dd>
                </div>
                {i < arr.length - 1 && <div class="border-t border-white/10"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-lemon-300 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.2em] text-lemon-700 font-medium mb-3">Consigli degli insider</p>
          <ul class="space-y-3">
            {[
              'Usa Maiori come base: i prezzi sono i più bassi della costiera e Amalfi è a 15 minuti in bus.',
              'La spiaggia libera è gratuita e ampia: arriva entro le 9:00 per trovare posto nelle file più vicine al mare.',
              'L\'escursione al Santuario dell\'Avvocata vale il viaggio: prenota una guida locale per i sentieri meno conosciuti.',
              'A Maiori i ristoranti sul lungomare hanno prezzi normali, non da turista: puoi mangiare bene a meno di €20.',
            ].map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border border-gray-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-medium mb-3">Esplora la Costiera</p>
          <nav class="space-y-1">
            {[
              { href: '/it-it/costiera-amalfitana/positano/', label: 'Positano' },
              { href: '/it-it/costiera-amalfitana/amalfi/', label: 'Amalfi' },
              { href: '/it-it/costiera-amalfitana/ravello/', label: 'Ravello' },
              { href: '/it-it/costiera-amalfitana/praiano/', label: 'Praiano' },
              { href: '/it-it/costiera-amalfitana/minori/', label: 'Minori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-blue-50 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Esplora anche sulla Costiera"
    items={[
      { name: 'Positano',  href: '/it-it/costiera-amalfitana/positano/', tag: 'Fashion & Vista',  desc: 'Le case colorate a picco sul mare, boutique di lusso e la spiaggia Fornillo.' },
      { name: 'Amalfi',    href: '/it-it/costiera-amalfitana/amalfi/',   tag: 'Arte & Storia',    desc: 'Il Duomo, il Chiostro del Paradiso e i vicoli della Repubblica marinara.' },
      { name: 'Ravello',   href: '/it-it/costiera-amalfitana/ravello/',  tag: 'Musica & Giardini', desc: 'Villa Rufolo, Villa Cimbrone e il Festival Musicale a 350 m sul mare.' },
      { name: 'Praiano',   href: '/it-it/costiera-amalfitana/praiano/', tag: 'Tramonto & Quiete', desc: 'Il tramonto da San Gennaro, la spiaggia Gavitella e la Marina di Praia.' },
