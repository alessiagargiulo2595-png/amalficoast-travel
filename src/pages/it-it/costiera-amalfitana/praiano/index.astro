---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Costiera Amalfitana', url: '/it-it/costiera-amalfitana/' },
  { name: 'Praiano', url: '/it-it/costiera-amalfitana/praiano/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Praiano",
  "description": "Praiano è il segreto meglio custodito della Costiera Amalfitana: meno turisti, tramonti spettacolari dalla Baia di Praia, spiagge di ciottoli e un'atmosfera autentica lontana dalla folla.",
  "url": "https://amalficoast-travel.com/it-it/costiera-amalfitana/praiano/",
  "image": "https://amalficoast-travel.com/images/praiano-hero.jpg",
  "touristType": ["Mare", "Tramonto", "Autenticità", "Snorkeling"],
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "Salerno",
    "addressCountry": "IT",
    "postalCode": "84010"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6123,
    "longitude": 14.5337
  }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Praiano, Costiera Amalfitana",
  "description": "Borgo marinaro tra Positano e Amalfi, famoso per i tramonti sulla Baia di Praia e le acque limpide.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6123,
    "longitude": 14.5337
  },
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "Costiera Amalfitana"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Come si arriva a Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Praiano è servita dal bus SITA sulla SS163, tra Positano (~20 min) e Amalfi (~30 min). In estate alcuni traghetti si fermano alla Baia di Praia (verificare gli orari stagionali). In auto la SS163 è percorribile ma il parcheggio è limitato."
      }
    },
    {
      "@type": "Question",
      "name": "Quali sono le spiagge di Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Le spiagge principali sono la Spiaggia della Gavitella (raggiungibile con un ascensore dalla strada) e la Baia di Praia (con stabilimento balneare). Entrambe sono di ciottoli con acque cristalline. La Spiaggia di San Pietro è più raccolta e meno frequentata."
      }
    },
    {
      "@type": "Question",
      "name": "Praiano è meno affollata di Positano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sì, Praiano è significativamente meno affollata di Positano e Amalfi. Non ci sono grandi alberghi di lusso né negozi di moda: il borgo è rimasto autentico e frequentato soprattutto da chi vuole mare e tranquillità. È la scelta ideale per chi vuole la costiera senza la folla."
      }
    },
    {
      "@type": "Question",
      "name": "Da dove si vede il tramonto più bello di Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Il tramonto più spettacolare si vede dalla terrazza panoramica vicino alla Chiesa di San Gennaro, nel centro del borgo. La Baia di Praia offre anch'essa viste magnifiche. In estate molti viaggiatori vengono appositamente da Positano e Amalfi per il tramonto di Praiano."
      }
    },
    {
      "@type": "Question",
      "name": "Si può fare snorkeling a Praiano?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sì, Praiano è uno dei posti migliori della costiera per lo snorkeling grazie alle acque particolarmente limpide. La zona intorno alla Grotta dello Smeraldo (accessibile in barca) e le secche vicino alla Baia di Praia sono ricche di vita marina."
      }
    }
  ]
};
---

<BaseLayout
  title="Praiano 2026: Guida Completa | Il Segreto della Costiera Amalfitana"
  description="Tutto su Praiano: spiagge, tramonti, come arrivare, cosa vedere. La guida al borgo più autentico della Costiera Amalfitana, tra Positano e Amalfi."
  lang={lang}
  pageKey="praiano"
  breadcrumbs={breadcrumbs}
  schema={[touristAttractionSchema, placeSchema, faqSchema]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/praiano-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager"  referrerpolicy="no-referrer"/>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Il segreto meglio custodito · Tra Positano e Amalfi</p>
        <h1 class="font-serif text-display text-white mb-4">Praiano</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          A metà strada tra Positano e Amalfi, Praiano è rimasta autentica mentre i suoi vicini diventavano mete di massa. Tramonti leggendari, acque limpide per lo snorkeling e una quiete difficile da trovare altrove sulla costiera.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-med-gold text-white text-sm font-semibold rounded-full hover:scale-105 hover:shadow-[0_8px_25px_rgba(212,175,55,0.4)] transition-all duration-300">Fast Facts</a>
          <a href="#come-arrivare" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Come arrivare</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content Grid -->
  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Praiano è ciò che Positano era trent'anni fa: un borgo di pescatori con case bianche sul promontorio, scale che scendono al mare e una vita locale ancora genuina. Non ci sono boutique di moda né code per i selfie. C'è silenzio, c'è il mare turchese e ci sono i tramonti più belli della costiera.
          </p>
          <p class="mt-4 text-slate-600 leading-relaxed">
            Con circa 2.000 abitanti, Praiano si divide in due nuclei: il borgo alto con la Chiesa di San Luca e il punto panoramico più celebre, e la Marina di Praia in basso, con il piccolo porto e la spiaggia di ciottoli. Tra i due, scale e sentieri attraversano uliveti e limoneti ancora coltivati.
          </p>
        </div>

        <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Lo sapevi?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">~2.000</p>
              <p class="text-white/60 text-xs italic mt-1">abitanti residenti</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">20 min</p>
              <p class="text-white/60 text-xs italic mt-1">da Positano in bus</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-5xl font-bold text-med-gold">3</p>
              <p class="text-white/60 text-xs italic mt-1">spiagge raggiungibili a piedi</p>
            </div>
          </div>
          <p class="text-white/40 text-xs mt-6 italic">
            Il nome "Praiano" deriva probabilmente dal latino <em>Plaianum</em>, da <em>plaia</em> (spiaggia). La Marina di Praia era già un approdo romano.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Cosa vedere a Praiano</h2>
          <div class="space-y-8">
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">1</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Tramonto da Chiesa San Gennaro</h3>
                <p class="text-slate-600 leading-relaxed">La terrazza della Chiesa di San Gennaro, nel centro del borgo, è il belvedere più scenografico di Praiano. Il sole tramonta esattamente davanti, tingendo il mare di arancio e rosso. Gratuito, nessuna fila. Arriva 30 minuti prima del tramonto per trovare posto.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">2</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Spiaggia della Gavitella</h3>
                <p class="text-slate-600 leading-relaxed">La spiaggia più accessibile di Praiano, raggiungibile tramite un ascensore pubblico dalla SS163. Ciottoli fini, acque cristalline e uno stabilimento balneare. Meno affollata della Spiaggia Grande di Positano, con vista sulle Li Galli.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">3</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Marina di Praia</h3>
                <p class="text-slate-600 leading-relaxed">Il piccolo porto naturale di Praiano, incastonato in una stretta forra. Barche di pescatori, un paio di ristoranti di pesce fresco e la Torre di Grado medievale. Il luogo più autentico del borgo, frequentato soprattutto dai residenti.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">4</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Grotta dello Smeraldo (vicino)</h3>
                <p class="text-slate-600 leading-relaxed">La celebre grotta marina è tecnicamente nel comune di Conca dei Marini, a 5 minuti in bus da Praiano. L'acqua verde smeraldo è causata dalla luce che filtra attraverso la roccia sommersa. Visita in barca dall'interno. Biglietto circa €5.</p>
              </div>
            </div>
            <div class="grid sm:grid-cols-[auto_1fr] gap-4">
              <div class="w-14 h-14 rounded-[1rem] bg-med-gold/10 flex items-center justify-center flex-shrink-0 text-med-gold font-serif font-bold text-xl">5</div>
              <div>
                <h3 class="font-semibold text-charcoal text-lg mb-1">Sentiero Praiano–Positano</h3>
                <p class="text-slate-600 leading-relaxed">Un percorso di 4 km sulla mulattiera storica tra Praiano e Positano, con vedute sulla costiera e sui terrazzamenti. Circa 1h30 di cammino. Livello medio. Si può tornare in bus sulla SS163.</p>
              </div>
            </div>
          </div>
        </div>

        <div id="come-arrivare">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-6">Come arrivare a Praiano</h2>
          <p class="text-slate-600 mb-8 leading-relaxed">Praiano è servita dal bus SITA sulla SS163. In estate alcuni traghetti si fermano alla Marina di Praia (verificare disponibilità). L'auto è sconsigliata in alta stagione.</p>
          <div class="overflow-x-auto rounded-2xl border border-slate-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-slate-500 px-4 py-2 bg-slate-50 rounded-t-2xl border-b border-slate-200 font-medium">
                Bus SITA — Connessioni principali verso Praiano
              </caption>
              <thead>
                <tr class="bg-med-blue/5 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Provenienza</th>
                  <th class="text-left px-4 py-3 font-semibold">Durata</th>
                  <th class="text-left px-4 py-3 font-semibold">Biglietto</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3">Positano</td><td class="px-4 py-3 font-mono">~20 min</td><td class="px-4 py-3 text-slate-500">~€1,30</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3">Amalfi</td><td class="px-4 py-3 font-mono">~30 min</td><td class="px-4 py-3 text-slate-500">~€1,30</td></tr>
                <tr class="hover:bg-slate-50 transition-colors"><td class="px-4 py-3">Sorrento</td><td class="px-4 py-3 font-mono">~60 min</td><td class="px-4 py-3 text-slate-500">~€2,50</td></tr>
              </tbody>
            </table>
          </div>
          <p class="text-xs text-slate-400 mt-2">* Consulta sitasudtrasporti.it per orari aggiornati.</p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-6">Luoghi nascosti di Praiano</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Spiaggia di San Pietro</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Una piccola caletta raggiungibile scendendo circa 200 gradini da un sentiero laterale del borgo. Quasi sconosciuta ai turisti di passaggio. Ciottoli bianchi e acqua trasparente, nessuno stabilimento balneare.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Murales di Praiano</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Lungo le scale e i vicoli del borgo sono stati dipinti murales di artisti locali che raccontano la storia e i mestieri di Praiano. Un percorso d'arte a cielo aperto scopribile passeggiando senza meta.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Torre di Grado</h3>
              <p class="text-sm text-slate-600 leading-relaxed">La torre aragonese del XVI secolo che sorvegliava la Marina di Praia dai pirati saraceni. Si raggiunge facilmente dal porto. Non visitabile all'interno, ma il contesto è perfetto per le fotografie al tramonto.</p>
            </div>
            <div class="bg-white rounded-[3rem] p-8 border border-slate-100 hover:shadow-xl transition-all duration-300">
              <h3 class="font-semibold text-charcoal mb-2">Piscina naturale La Praia</h3>
              <p class="text-sm text-slate-600 leading-relaxed">Una formazione rocciosa naturale vicino alla Marina di Praia che crea una piccola piscina naturale protetta dalle onde. Perfetta per fare il bagno in sicurezza con bambini, specialmente la mattina presto.</p>
            </div>
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-slate-900 mb-8">Domande frequenti su Praiano</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-slate-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-slate-900 text-white rounded-[3rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-4">Fast Facts — Praiano</p>
          <dl class="space-y-3">
            {[
              { dt: 'Posizione', dd: 'Costiera Amalfitana, SA' },
              { dt: 'Altitudine', dd: '0–120 m slm' },
              { dt: 'Popolazione', dd: '~2.000 abitanti' },
              { dt: 'ZTL', dd: 'No (parcheggi limitati)' },
              { dt: 'Mezzi', dd: 'Bus SITA SS163' },
              { dt: 'Spiagge', dd: 'Ciottoli, 3 calette' },
              { dt: 'Miglior periodo', dd: 'Mag–Giu / Set–Ott' },
              { dt: 'Tramonto', dd: 'Il più bello della costiera' },
              { dt: 'Valuta', dd: 'Euro (€)' },
            ].map(({ dt, dd }, i, arr) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/40 text-sm font-light flex-shrink-0">{dt}</dt>
                  <dd class="text-white font-medium text-sm text-right">{dd}</dd>
                </div>
                {i < arr.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-med-gold/30 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Consigli degli insider</p>
          <ul class="space-y-3">
            {[
              'Vieni a Praiano per il tramonto, anche solo per una sera, partendo da Positano o Amalfi con il bus.',
              'Prenota un tavolo al ristorante sul porto di Marina di Praia almeno 2 giorni prima in alta stagione.',
              'L\'ascensore per la Gavitella è gratuito: usalo invece di scendere i gradini col caldo.',
              'Praiano è più economica dei vicini: hotel, ristoranti e appartamenti costano mediamente il 30–40% in meno.',
            ].map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border border-slate-100 rounded-[2rem] p-6 shadow-sm">
          <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-medium mb-3">Esplora la Costiera</p>
          <nav class="space-y-1">
            {[
              { href: '/it-it/costiera-amalfitana/positano/', label: 'Positano' },
              { href: '/it-it/costiera-amalfitana/amalfi/', label: 'Amalfi' },
              { href: '/it-it/costiera-amalfitana/ravello/', label: 'Ravello' },
              { href: '/it-it/costiera-amalfitana/maiori/', label: 'Maiori' },
              { href: '/it-it/costiera-amalfitana/minori/', label: 'Minori' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-med-blue/5 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Esplora anche sulla Costiera"
    items={[
      { name: 'Positano',  href: '/it-it/costiera-amalfitana/positano/', tag: 'Fashion & Vista',  desc: 'Le case colorate a picco sul mare, boutique di lusso e la spiaggia Fornillo.' },
      { name: 'Amalfi',    href: '/it-it/costiera-amalfitana/amalfi/',   tag: 'Arte & Storia',    desc: 'Il Duomo, il Chiostro del Paradiso e i vicoli della Repubblica marinara.' },
      { name: 'Ravello',   href: '/it-it/costiera-amalfitana/ravello/',  tag: 'Musica & Giardini', desc: 'Villa Rufolo, Villa Cimbrone e il Festival Musicale a 350 m sul mare.' },
      { name: 'Maiori',    href: '/it-it/costiera-amalfitana/maiori/',   tag: 'Spiaggia & Relax', desc: 'La spiaggia di sabbia più lunga della costiera: 300 m di lungomare.' },
      { name: 'Minori',    href: '/it-it/costiera-amalfitana/minori/',   tag: 'Sapori & Cultura', desc: 'Villa romana del I sec., scialatielli freschi e pasticcerie artigianali.' },
      { name: 'Capri',     href: '/it-it/isole/capri/',                  tag: 'La più iconica',   desc: 'Grotta Azzurra, Faraglioni e la mondana Piazzetta.' },
    ]}
  />

</BaseLayout>
