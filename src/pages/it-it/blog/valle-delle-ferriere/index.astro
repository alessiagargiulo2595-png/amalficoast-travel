---
import BlogPostLayout from '../../../../layouts/BlogPostLayout.astro';

const lang = 'it-it';
const post = {
  title: 'Valle delle Ferriere',
  subtitle: 'Trekking nel Cuore Verde e Selvaggio di Amalfi',
  category: 'SCOPERTE',
  date: '22 Aprile 2026',
  readTime: '8 min',
  image: '/images/valle-ferriere-hero.jpg',
  imageAlt: 'Cascata nella Valle delle Ferriere, Amalfi - Costiera Amalfitana',
  path: '/it-it/blog/valle-delle-ferriere/',
};

const metaTitle = 'Valle delle Ferriere Amalfi: Trekking, Cascate e Felci Preistoriche 2026';
const metaDescription = 'Guida completa al trekking nella Valle delle Ferriere di Amalfi: percorso, felci giganti preistoriche, antiche cartiere medievali, cascate e consigli pratici per visitare la riserva naturale.';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Blog', url: '/it-it/blog/' },
  { name: 'Valle delle Ferriere', url: '/it-it/blog/valle-delle-ferriere/' },
];

const quickInfo = [
  { label: 'Punto di partenza', value: 'Pontone o Amalfi (centro)' },
  { label: 'Difficolta', value: 'E - Escursionistico (Facile/Medio)' },
  { label: 'Durata', value: 'Circa 3-4 ore (con soste)' },
  { label: 'Lunghezza', value: '6 km circa' },
  { label: 'Costo riserva', value: 'ca. €5 a persona' },
  { label: 'Equipaggiamento', value: 'Scarpe da trekking obbligatorie' },
  { label: 'Cosa vedere', value: 'Cascate, felci preistoriche, antiche cartiere' },
  { label: 'Periodo migliore', value: 'Aprile - Giugno / Autunno' },
];

const faq = [
  {
    q: 'Il sentiero e adatto ai bambini?',
    a: "Si, il sentiero principale e ben tracciato e non presenta pericoli estremi. Tuttavia, non e percorribile con i passeggini a causa dei gradini e delle radici affioranti. Con bambini piccoli e consigliabile partire da Pontone (discesa) anziche da Amalfi (salita).",
  },
  {
    q: 'Si puo fare il bagno nel torrente?',
    a: "Sebbene l'acqua sia limpidissima e invitante, e estremamente fredda (circa 12-14°C) e, trattandosi di una zona protetta, e bene evitare per non disturbare l'ecosistema locale.",
  },
  {
    q: 'Qual e il periodo migliore per la visita?',
    a: 'La primavera (aprile-giugno) e il momento magico: le cascate sono al massimo della portata e la vegetazione e di un verde esplosivo. Anche l\'autunno offre colori caldi meravigliosi. In estate la valle resta fresca grazie al microclima, ma la portata delle cascate si riduce.',
  },
  {
    q: "C'e campo per il cellulare nella valle?",
    a: "In molti punti della valle il segnale e assente o molto debole. E l'occasione perfetta per un digital detox, ma ricordate di scaricare la mappa offline e di avvisare qualcuno del vostro percorso prima di partire.",
  },
  {
    q: "Come si prenota l'accesso alla riserva integrale?",
    a: "L'accesso alla zona protetta delle cascate e delle felci rare e spesso gestito da associazioni locali o dal comune di Amalfi. Verificate prima della visita sul sito del comune o chiamate il punto informazioni turistiche di Amalfi. Il contributo e di circa €5 a persona.",
  },
  {
    q: 'Cosa si intende per Woodwardia radicans?',
    a: "E una rarissima felce gigante risalente all'epoca preistorica (Terziario), sopravvissuta nelle valli umide del Mediterraneo grazie a microclimi particolari. Le sue fronde possono raggiungere i 2 metri. Nella Valle delle Ferriere costituisce uno degli habitat piu importanti d'Europa per questa specie.",
  },
  {
    q: 'Serve una guida o si puo fare da soli?',
    a: 'Il sentiero principale e ben segnalato e percorribile in autonomia. Tuttavia, per scoprire i dettagli storici delle cartiere, l\'ecologia della riserva e i punti di osservazione migliori, una guida locale aggiunge un valore enorme all\'esperienza.',
  },
];

const sidebarLinks = [
  { label: 'Trekking & Sentiero degli Dei', href: '/it-it/esperienze/trekking/' },
  { label: 'Scopri Amalfi', href: '/it-it/costiera-amalfitana/amalfi/' },
  { label: 'Bus SITA per Amalfi', href: '/it-it/guida/bus-sita/' },
  { label: 'Le spiagge', href: '/it-it/spiagge/' },
  { label: 'Quando visitare', href: '/it-it/quando-visitare/' },
  { label: 'Come arrivare', href: '/it-it/come-arrivare/' },
];

const relatedArticles = [
  {
    title: 'Grotta dello Smeraldo',
    category: 'SCOPERTE',
    date: '22 Aprile 2026',
    image: '/images/grotta-smeraldo-hero.webp',
    imageAlt: 'Grotta dello Smeraldo - Conca dei Marini, Costiera Amalfitana',
    path: '/it-it/blog/grotta-dello-smeraldo/'
  },
  {
    title: 'Atrani',
    category: 'SCOPERTE',
    date: '22 Aprile 2026',
    image: '/images/atrani-hero.jpg',
    imageAlt: "Atrani - il borgo più piccolo d'Italia sulla Costiera Amalfitana",
    path: '/it-it/blog/atrani/'
  }
];

const authorRole = 'Nature & Trekking Guide · Costiera Amalfitana';

const keyTakeaways = [
  'La Valle delle Ferriere ospita la Woodwardia radicans, una felce gigante preistorica sopravvissuta dal Terziario grazie a un microclima unico al Mediterraneo.',
  'Il nome deriva dalle antiche ferriere medievali che sfruttavano il torrente Canneto; lungo il sentiero si trovano le rovine delle storiche cartiere che producevano la celebre Carta di Amalfi.',
  'Il sentiero e classificato E (Escursionistico): circa 6 km, 3-4 ore con soste. Partenza consigliata da Pontone per procedere in discesa verso Amalfi.',
  'La zona delle cascate e delle felci rare e una riserva integrale protetta: prenotazione e contributo (~€5) obbligatori — meglio organizzarsi prima.',
  'Periodo migliore: primavera (aprile-giugno) per cascate al massimo e verde esplosivo; autunno per i colori caldi del bosco.',
];
---

<BlogPostLayout
  lang={lang}
  post={post}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  breadcrumbs={breadcrumbs}
  quickInfo={quickInfo}
  faq={faq}
  sidebarLinks={sidebarLinks}
  authorRole={authorRole}
  relatedArticles={relatedArticles}
>

  <!-- Key Takeaways -->
  <div class="bg-slate-900 text-white p-8 rounded-[2rem]">
    <div class="flex items-center gap-3 mb-6">
      <svg class="w-5 h-5 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <h2 class="font-serif text-lg font-bold text-med-gold uppercase tracking-[0.15em]">Key Takeaways</h2>
    </div>
    <ul class="space-y-4">
      {keyTakeaways.map((point) => (
        <li class="flex items-start gap-3">
          <span class="w-1.5 h-1.5 rounded-full bg-med-gold flex-shrink-0 mt-2"></span>
          <span class="text-white/80 text-sm leading-relaxed">{point}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Intro -->
  <div>
    <p class="text-slate-600 text-xl leading-relaxed mb-6 font-light">
      Mentre la folla si accalca tra i vicoli di Amalfi o sulle spiagge di Positano, esiste un sentiero che conduce in un mondo parallelo, fatto di cascate, felci preistoriche e un silenzio interrotto solo dal fruscio dell'acqua. La Valle delle Ferriere e il segreto meglio custodito della Costiera Amalfitana: un polmone verde che sembra appartenere a una foresta pluviale tropicale piuttosto che al Mediterraneo.
    </p>
  </div>

  <!-- Microclima -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Un Microclima Unico al Mondo</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Cio che rende la Valle delle Ferriere un luogo magico e la sua particolare conformazione geologica. Le alte pareti rocciose proteggono il fondo della valle dai venti caldi, mantenendo un'umidita costante e una temperatura fresca anche in piena estate.
    </p>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm my-6">
      <h3 class="font-serif text-xl font-bold text-slate-900 mb-4">La Woodwardia radicans: Un Fossile Vivente</h3>
      <p class="text-slate-600 leading-relaxed mb-4">
        Questo microclima ha permesso la sopravvivenza della <strong>Woodwardia radicans</strong>, una rarissima felce gigante risalente all'epoca preistorica (Terziario). Le sue fronde possono raggiungere i 2 metri di lunghezza e costituiscono uno degli habitat piu importanti d'Europa per questa specie.
      </p>
      <p class="text-slate-600 leading-relaxed">
        Camminare tra queste fronde enormi, circondati da muschi e sorgenti, da l'impressione di aver fatto un salto indietro nel tempo di milioni di anni. E un'esperienza che nessuna fotografia riesce a restituire pienamente.
      </p>
    </div>
  </div>

  <!-- Archeologia industriale -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Archeologia Industriale tra i Limoni</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Il nome della valle deriva dalle antiche ferriere che un tempo sfruttavano la forza dell'acqua del torrente Canneto per la produzione del ferro. Ma non solo: lungo il sentiero si incontrano i resti delle storiche <strong>cartiere di Amalfi</strong>.
    </p>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Qui veniva prodotta la celebre <strong>Carta d'Amalfi</strong> (o Charta Bambagina), esportata in tutto il mondo medievale. Vedere le rovine di questi imponenti edifici avvolti dalla vegetazione regala alla valle un'atmosfera decadente e affascinante, simile a una citta perduta.
    </p>

    <blockquote class="border-l-4 border-med-gold pl-6 my-8">
      <p class="text-slate-700 text-xl font-serif italic leading-relaxed">
        "La Valle delle Ferriere e il luogo dove la forza dell'acqua ha costruito la storia di Amalfi."
      </p>
    </blockquote>
  </div>

  <!-- Guida pratica -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Guida Pratica al Sentiero</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Il trekking nella Valle delle Ferriere e adatto a quasi tutti, ma richiede un minimo di preparazione. Esistono due accessi principali.
    </p>

    <div class="space-y-4 mb-8">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Da Pontone (Consigliato)</h4>
          <p class="text-slate-600 text-sm leading-relaxed">E l'accesso piu panoramico. Partendo dalla piazzetta di Pontone (frazione di Scala), il sentiero e per lo piu in discesa verso Amalfi. Ottimo per chi non ama le salite e vuole godersi il percorso senza affaticarsi troppo.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Da Amalfi</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Si parte dalla parte alta del paese, superando il Museo della Carta. E un percorso in salita, piu faticoso ma molto suggestivo perche risale il corso del torrente. Permette di vedere le antiche cartiere subito all'inizio del cammino.</p>
        </div>
      </div>
    </div>

    <div class="overflow-hidden rounded-[2rem] border border-slate-100 shadow-sm">
      <table class="w-full text-sm">
        <thead class="bg-slate-900 text-white">
          <tr>
            <th class="text-left p-5 font-serif font-bold text-med-gold">Parametro</th>
            <th class="text-left p-5 font-serif font-bold text-med-gold">Dettaglio</th>
          </tr>
        </thead>
        <tbody class="bg-white">
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Difficolta</td>
            <td class="p-5 text-slate-600">E - Escursionistico (Facile / Medio)</td>
          </tr>
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Durata</td>
            <td class="p-5 text-slate-600">Circa 3-4 ore (con soste)</td>
          </tr>
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Lunghezza</td>
            <td class="p-5 text-slate-600">6 km circa</td>
          </tr>
          <tr class="border-b border-slate-100">
            <td class="p-5 font-bold text-slate-900">Dislivello</td>
            <td class="p-5 text-slate-600">~400 m (Pontone → Amalfi)</td>
          </tr>
          <tr>
            <td class="p-5 font-bold text-slate-900">Costo riserva</td>
            <td class="p-5 text-slate-600">ca. €5 a persona (prenotazione consigliata)</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Local Tips -->
  <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
    <div class="flex items-center gap-4 mb-6">
      <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      <h3 class="text-xl font-bold text-slate-900">I Consigli dell'Esperto</h3>
    </div>
    <div class="space-y-6">
      <div>
        <p class="font-bold text-slate-900 mb-1">La Riserva Integrale: prenota prima</p>
        <p class="text-slate-600 text-sm leading-relaxed">Il cuore della valle e una riserva protetta. Per accedere alla zona delle cascate e delle felci rare e necessario prenotare l'ingresso (spesso gestito da associazioni locali) e pagare un piccolo contributo. Fatelo in anticipo, specialmente nei weekend primaverili.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Abbigliamento: non sottovalutate il freddo</p>
        <p class="text-slate-600 text-sm leading-relaxed">Anche se giu ad Amalfi ci sono 30°C, nella valle la temperatura scende drasticamente. Portate una giacca leggera e indossate assolutamente scarpe da trekking: le pietre vicino al torrente possono essere molto scivolose.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Lo Spuntino del Camminatore</p>
        <p class="text-slate-600 text-sm leading-relaxed">Fermatevi in una delle botteghe di Pontone prima di scendere e fatevi preparare un panino con il fiordilatte dei Monti Lattari e pomodori locali. Mangiarlo vicino a una cascata non ha prezzo.</p>
      </div>
    </div>
  </div>

</BlogPostLayout>
