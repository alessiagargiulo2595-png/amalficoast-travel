---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { blogPosts } from '../../../data/blog';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Blog', url: '/it-it/blog/' },
];

// Ricava categorie uniche dall'elenco articoli
const categories = ['Tutte', ...new Set(blogPosts.map(p => p.category))];

const schemaBlog = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Blog - Amalfi Coast Travel",
  "description": "Storie, guide e curiosita dalla Costiera Amalfitana: grotte, borghi nascosti, cucina locale e consigli per viaggiare come un locale.",
  "url": "https://amalficoast-travel.com/it-it/blog/",
  "inLanguage": "it-IT",
  "blogPost": blogPosts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.title,
    "url": `https://amalficoast-travel.com${post.path}`,
    "datePublished": post.date,
    "image": post.image,
  })),
};
---

<BaseLayout
  title="Blog Costiera Amalfitana | Storie, Guide e Curiosita"
  description="Storie, guide di viaggio e curiosita sulla Costiera Amalfitana: grotte marine, borghi nascosti, gastronomia locale e consigli pratici per esplorare come un locale."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaBlog]}
>

  <!-- Hero -->
  <section class="relative h-[60vh] flex items-end bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-slate-900"></div>
    <div
      class="absolute inset-0 bg-cover bg-center opacity-40"
      style="background-image: url('https://images.unsplash.com/photo-1590523214157-1996a7946396?auto=format&fit=crop&w=1600&q=80')"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/30 to-black/80"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 pt-32 w-full">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Blog</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costiera Amalfitana</p>
        <h1 class="font-serif text-display text-white mb-4">Blog</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Storie vere, grotte nascoste, sapori autentici. La Costiera oltre le cartoline.
        </p>
      </div>
    </div>
  </section>

  <!-- Griglia articoli -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto">

      <!-- Header + filtri -->
      <div class="mb-14">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Articoli</p>
            <h2 class="font-serif text-3xl font-bold text-slate-900">Tutte le storie</h2>
          </div>
          <p id="blog-counter" class="text-slate-400 text-sm hidden sm:block">
            {blogPosts.length} {blogPosts.length === 1 ? 'articolo' : 'articoli'}
          </p>
        </div>

        <!-- Tag categorie -->
        <div class="flex flex-wrap gap-3">
          {categories.map((cat) => (
            <button
              data-filter={cat}
              data-active={cat === 'Tutte' ? 'true' : undefined}
              class="filter-btn"
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

      <!-- Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" id="blog-grid">
        {blogPosts.map((post) => (
          <div data-category={post.category} class="blog-card">
            <a href={post.path} class="group block">
              <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-5 shadow-lg">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/10 to-transparent"></div>
                <div class="absolute top-5 left-5">
                  <span class="bg-med-gold text-slate-900 text-[10px] font-bold uppercase tracking-[0.2em] px-3 py-1.5 rounded-full">
                    {post.category}
                  </span>
                </div>
              </div>
              <div class="px-1">
                <div class="flex items-center gap-3 text-slate-400 text-xs mb-3">
                  <span>{post.date}</span>
                  <span>·</span>
                  <span>{post.readTime} di lettura</span>
                </div>
                <h2 class="font-serif text-xl font-bold text-slate-900 mb-3 leading-tight group-hover:text-med-blue transition-colors">
                  {post.title}
                </h2>
                <p class="text-slate-500 text-sm leading-relaxed">{post.excerpt}</p>
                <div class="mt-4 flex items-center gap-1 text-med-gold text-sm font-medium">
                  Leggi l'articolo
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>

      <!-- Nessun risultato -->
      <div id="blog-empty" class="hidden text-center py-20">
        <p class="text-slate-400 text-lg mb-6">Nessun articolo trovato in questa categoria.</p>
        <button data-filter="Tutte" class="filter-btn" id="reset-btn">
          Mostra tutti
        </button>
      </div>

    </div>
  </section>

  <!-- Editoriale -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Perche un blog sulla Costiera Amalfitana?</h2>
      <p class="text-slate-600 text-lg leading-relaxed mb-6">
        Esistono migliaia di guide turistiche sulla Costiera. Questo blog nasce per raccontare quello che le guide non dicono: le grotte scoperte per caso, i sapori autentici lontani dai menu per turisti, i sentieri che i locali percorrono ancora ogni mattina.
      </p>
      <p class="text-slate-600 text-lg leading-relaxed">
        Ogni articolo e scritto come se lo stessimo raccontando a un amico.
      </p>
    </div>
  </section>

</BaseLayout>

<style>
  .filter-btn {
    @apply px-5 py-2 rounded-full text-sm font-medium transition-colors cursor-pointer;
    background-color: #0f172a; /* slate-900 */
    color: white;
  }
  .filter-btn[data-active="true"] {
    background-color: #D4AF37; /* med-gold */
    color: #0f172a;
  }
  .blog-card[data-hidden] {
    display: none;
  }
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
  const cards = document.querySelectorAll<HTMLElement>('[data-category]');
  const emptyMsg = document.getElementById('blog-empty');
  const counterEl = document.getElementById('blog-counter');

  function applyFilter(filter: string) {
    // Aggiorna bottoni attivi
    buttons.forEach(b => {
      if (b.dataset.filter === filter) {
        b.setAttribute('data-active', 'true');
      } else {
        b.removeAttribute('data-active');
      }
    });

    // Mostra/nascondi card
    let visible = 0;
    cards.forEach(card => {
      const match = filter === 'Tutte' || card.dataset.category === filter;
      if (match) {
        card.removeAttribute('data-hidden');
        visible++;
      } else {
        card.setAttribute('data-hidden', '');
      }
    });

    // Aggiorna contatore
    if (counterEl) {
      counterEl.textContent = `${visible} ${visible === 1 ? 'articolo' : 'articoli'}`;
    }

    // Messaggio vuoto
    if (emptyMsg) {
      emptyMsg.classList.toggle('hidden', visible > 0);
    }
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'Tutte'));
  });
</script>
