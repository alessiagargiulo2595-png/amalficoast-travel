---
import BlogPostLayout from '../../../../layouts/BlogPostLayout.astro';

const lang = 'it-it';
const post = {
  title: 'Delizia al Limone',
  subtitle: 'Storia e Segreti della Cupola più Amata della Costiera',
  category: 'FOOD',
  date: '22 Aprile 2026',
  readTime: '7 min',
  image: '/images/delizia-limone-hero.jpg',
  imageAlt: 'Delizia al Limone - dolce simbolo della Costiera Amalfitana',
  path: '/it-it/blog/delizia-al-limone/',
};

const metaTitle = 'Delizia al Limone: Storia, Ricetta e Dove Mangiarla | Costiera Amalfitana 2026';
const metaDescription = "La storia della Delizia al Limone inventata da Carmine Marzuillo nel 1978, i segreti della ricetta originale con limoni IGP e i tre indirizzi imperdibili sulla Costiera Amalfitana.";

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Food', url: '/it-it/blog/' },
  { name: 'Delizia al Limone', url: '/it-it/blog/delizia-al-limone/' },
];

const quickInfo = [
  { label: 'Creatore', value: 'Carmine Marzuillo (1978)' },
  { label: 'Ingrediente chiave', value: 'Limone IGP (Sfusato o Femminiello)' },
  { label: 'Preparazione', value: '45 min + 2 ore riposo' },
  { label: 'Cottura', value: '20 minuti' },
  { label: 'Porzioni', value: '8 cupoline' },
  { label: 'Difficolta', value: 'Media (precisione nella crema)' },
  { label: 'Abbinamento', value: 'Limoncello ghiacciato o passito di Tramonti' },
  { label: 'Dove mangiarla', value: 'Sal De Riso (Minori) · Pansa (Amalfi)' },
];

const faq = [
  {
    q: 'Qual è la differenza tra la Delizia al Limone e un normale Pan di Spagna al limone?',
    a: 'La struttura della Delizia è molto più complessa: prevede una doppia crema (pasticcera e chantilly al limone) e una glassatura esterna che la mantiene umida e soffice, a differenza di una classica torta che tende ad asciugarsi.',
  },
  {
    q: 'Posso usare limoni comuni del supermercato?',
    a: "Puoi, ma il risultato non sarà lo stesso. Il segreto della Delizia è negli oli essenziali della buccia dei limoni IGP di Sorrento o Amalfi, che non sono trattati e hanno un profumo infinitamente più persistente.",
  },
  {
    q: 'Esiste una versione della Delizia per celiaci?',
    a: 'Molte pasticcerie artigianali in Costiera ora offrono versioni gluten-free utilizzando farine di riso o amidi, mantenendo intatta la magia della crema al limone.',
  },
  {
    q: 'Chi ha inventato la Delizia al Limone?',
    a: "Il maestro pasticciere sorrentino Carmine Marzuillo, che la presentò per la prima volta nel 1978 a un concorso gastronomico a Formia. In pochi anni divenne il dolce simbolo dell'intera Costiera Amalfitana.",
  },
  {
    q: 'Dove si mangia la migliore Delizia al Limone della Costiera?',
    a: 'I luoghi più celebri sono: la Pasticceria Sal De Riso a Minori (probabilmente la più famosa al mondo), la Pasticceria Pansa accanto al Duomo di Amalfi e l\'Antico Francischiello a Massa Lubrense, luogo d\'origine della ricetta.',
  },
];

const sidebarLinks = [
  { label: 'Limoncello Tour', href: '/it-it/esperienze/limoncello-tour/' },
  { label: 'Cooking Class', href: '/it-it/esperienze/cooking-class/' },
  { label: 'Alici di Cetara', href: '/it-it/blog/alici-di-cetara/' },
  { label: 'Quando visitare', href: '/it-it/quando-visitare/' },
  { label: 'Come arrivare', href: '/it-it/come-arrivare/' },
];

const authorRole = 'Food Critic & Local Expert · Costiera Amalfitana';

const relatedArticles = [
  {
    title: 'Le Alici di Cetara',
    category: 'FOOD',
    date: '22 Aprile 2026',
    image: '/images/alici-cetara-hero.jpg',
    imageAlt: 'Alici di Cetara e Colatura DOP - Costiera Amalfitana',
    path: '/it-it/blog/alici-di-cetara/'
  },
  {
    title: 'Vini della Costa d\'Amalfi',
    category: 'FOOD',
    date: '18 Aprile 2026',
    image: '/images/vini-costa-amalfi-hero.jpg',
    imageAlt: "Vigneti eroici della Costa d'Amalfi - Tramonti e Scala",
    path: '/it-it/blog/vini-costa-amalfi/'
  }
];

const schemaRecipe = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  "name": "Delizia al Limone",
  "description": "La cupola morbida di pan di spagna, intrisa di bagna al limoncello e ricoperta da una nuvola di crema al limone. Il dolce simbolo della Costiera Amalfitana.",
  "image": "https://amalficoast-travel.com/images/delizia-limone-hero.jpg",
  "author": { "@type": "Person", "name": "Carmine Marzuillo" },
  "datePublished": "2026-04-22",
  "url": "https://amalficoast-travel.com/it-it/blog/delizia-al-limone/",
  "prepTime": "PT45M",
  "cookTime": "PT20M",
  "totalTime": "PT3H",
  "recipeYield": "8 porzioni",
  "recipeCategory": "Dessert",
  "recipeCuisine": "Italiana",
  "keywords": "delizia al limone, dolce campano, limone IGP, limoncello",
  "recipeIngredient": [
    "4 uova fresche", "120 g zucchero", "120 g farina 00",
    "500 ml latte intero", "4 tuorli", "150 g zucchero (per la crema)",
    "50 g amido di mais", "scorza di 2 limoni IGP non trattati",
    "300 ml panna fresca da montare", "100 ml Limoncello di Sorrento",
    "50 ml acqua", "30 g zucchero (per la bagna)",
  ],
  "recipeInstructions": [
    { "@type": "HowToStep", "name": "Preparare il pan di spagna", "text": "Montare le uova con lo zucchero a lungo fino a ottenere un composto gonfio e spumoso. Incorporare la farina setacciata con movimenti delicati. Versare negli stampini a semisfera e cuocere a 180°C per 18-20 minuti." },
    { "@type": "HowToStep", "name": "Preparare la crema al limone", "text": "Scaldare il latte con la scorza di limone. Sbattere i tuorli con zucchero e amido, versare il latte caldo a filo e cuocere fino ad addensamento. Far raffreddare completamente." },
    { "@type": "HowToStep", "name": "Montare la chantilly al limone", "text": "Montare la panna a neve ferma. Unire la crema pasticcera fredda alla panna montata con movimenti delicati." },
    { "@type": "HowToStep", "name": "Preparare la bagna al limoncello", "text": "Sciogliere lo zucchero nell'acqua calda. Aggiungere il Limoncello a temperatura ambiente. Lasciare raffreddare." },
    { "@type": "HowToStep", "name": "Assemblare e glassare", "text": "Tagliare le cupole di pan di spagna a metà. Inzuppare con la bagna al limoncello. Farcire con la crema al limone. Ricoprire completamente con la crema allungata con un cucchiaio di latte. Riporre in frigo per almeno 2 ore." },
  ],
};
---

<BlogPostLayout
  lang={lang}
  post={post}
  metaTitle={metaTitle}
  metaDescription={metaDescription}
  breadcrumbs={breadcrumbs}
  quickInfo={quickInfo}
  faq={faq}
  sidebarLinks={sidebarLinks}
  authorRole={authorRole}
  relatedArticles={relatedArticles}
  extraSchema={[schemaRecipe]}
>

  <!-- Intro -->
  <div>
    <p class="text-slate-600 text-xl leading-relaxed mb-6 font-light">
      Se la Costiera Amalfitana avesse un sapore, sarebbe senza dubbio quello della Delizia al Limone. Questa morbida cupola di pan di spagna, intrisa di sciroppo profumato e ricoperta da una nuvola di crema al limone, è molto più di un dolce: è l'essenza del sole di Sorrento e Amalfi racchiusa in un morso.
    </p>
  </div>

  <!-- La Storia -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">La Storia: L'Invenzione di un Maestro</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      A differenza di molti dolci della tradizione campana che affondano le radici nei secoli scorsi, la Delizia al Limone ha una data di nascita precisa: <strong>1978</strong>.
    </p>
    <p class="text-slate-600 text-lg leading-relaxed mb-6">
      Il suo creatore è il maestro pasticciere sorrentino <strong>Carmine Marzuillo</strong>, che la presentò per la prima volta a un concorso gastronomico a Formia. L'idea era semplice ma rivoluzionaria: utilizzare lo Sfusato Amalfitano e il Femminiello Sorrentino per creare un dolce che fosse leggero, fresco ed estremamente profumato. Il successo fu immediato, e in pochi anni la Delizia è passata dai laboratori di Sorrento alle tavole di tutto il mondo.
    </p>

    <blockquote class="border-l-4 border-med-gold pl-6 my-8">
      <p class="text-slate-700 text-xl font-serif italic leading-relaxed">
        "Un equilibrio perfetto tra l'acidità dell'agrume e la dolcezza della crema: la Delizia è il bacio del sole sulla tavola."
      </p>
    </blockquote>
  </div>

  <!-- Dove mangiare -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Dove Mangiare la Migliore Delizia al Limone</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Sebbene oggi si trovi in ogni pasticceria della regione, ci sono dei luoghi "sacri" dove la degustazione diventa un'esperienza mistica.
    </p>

    <div class="space-y-4">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">1</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Pasticceria Sal De Riso — Minori</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Probabilmente la più famosa al mondo. La versione di Salvatore De Riso è celebre per l'equilibrio della bagnatura e la qualità della materia prima. Irrinunciabile.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">2</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Pasticceria Pansa — Amalfi</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Situata proprio accanto al Duomo, qui la Delizia si mangia circondati dalla storia, con una ricetta che rispetta rigorosamente i canoni classici.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-10 h-10 rounded-full bg-med-gold/10 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-sm">3</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Antico Francischiello — Massa Lubrense</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Il luogo dove la famiglia Marzuillo ha reso questo dolce una leggenda. È qui che è nata la ricetta originale.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- La Ricetta -->
  <div>
    <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">La Ricetta: Come Rifarla a Casa</h2>
    <p class="text-slate-600 text-lg leading-relaxed mb-8">
      Preparare una vera Delizia richiede pazienza e, soprattutto, limoni di qualità IGP. Ecco gli ingredienti e i passaggi fondamentali.
    </p>

    <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm mb-6">
      <h3 class="font-serif text-xl font-bold text-slate-900 mb-6">Gli Ingredienti (per 8 cupoline)</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <div>
          <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.2em] mb-3">Pan di Spagna</p>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>4 uova fresche</li>
            <li>120 g zucchero</li>
            <li>120 g farina 00</li>
          </ul>
        </div>
        <div>
          <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.2em] mb-3">Crema al Limone</p>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>500 ml latte intero</li>
            <li>4 tuorli</li>
            <li>150 g zucchero</li>
            <li>50 g amido di mais</li>
            <li>Scorza 2 limoni IGP</li>
            <li>300 ml panna fresca</li>
          </ul>
        </div>
        <div>
          <p class="text-med-gold text-[10px] font-bold uppercase tracking-[0.2em] mb-3">Bagna</p>
          <ul class="space-y-2 text-slate-600 text-sm">
            <li>100 ml Limoncello</li>
            <li>50 ml acqua</li>
            <li>30 g zucchero</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-8 h-8 rounded-full bg-slate-900 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">1</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Il Pan di Spagna</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Montare le uova con lo zucchero a lungo fino a ottenere un composto gonfio e spumoso. Incorporare la farina setacciata con movimenti delicati dal basso verso l'alto. Cuocere negli stampini a semisfera a 180°C per 18-20 minuti.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-8 h-8 rounded-full bg-slate-900 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">2</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">La Crema al Limone</h4>
          <p class="text-slate-600 text-sm leading-relaxed">Scaldare il latte con la scorza di limone. Sbattere i tuorli con zucchero e amido, versare il latte caldo a filo e cuocere fino ad addensamento. Far raffreddare completamente, poi alleggerire con la panna montata a neve ferma.</p>
        </div>
      </div>
      <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm flex gap-5">
        <div class="w-8 h-8 rounded-full bg-slate-900 flex-shrink-0 flex items-center justify-center text-med-gold font-bold text-xs">3</div>
        <div>
          <h4 class="font-bold text-slate-900 mb-1">Il Segreto del Maestro: il Montaggio</h4>
          <p class="text-slate-600 text-sm leading-relaxed">La Delizia va montata "al contrario": si farcisce la cupolina, si spruzza con la bagna al limoncello, si ricopre con la crema allungata e si lascia riposare in frigo per almeno 2 ore. Il riposo è fondamentale affinché i sapori si fondano perfettamente.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Local Tips -->
  <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
    <div class="flex items-center gap-4 mb-6">
      <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      <h3 class="text-xl font-bold text-slate-900">I Consigli dell'Esperto</h3>
    </div>
    <div class="space-y-6">
      <div>
        <p class="font-bold text-slate-900 mb-1">La Temperatura</p>
        <p class="text-slate-600 text-sm leading-relaxed">Non mangiatela mai troppo fredda di frigo. Lasciatela fuori per 10-15 minuti prima di servirla: la crema deve essere setosa e il pan di spagna deve sciogliersi in bocca.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Il Colore</p>
        <p class="text-slate-600 text-sm leading-relaxed">Diffidate dalle Delizie di un giallo troppo acceso. La vera crema al limone artigianale ha un colore giallo paglierino delicato. Il giallo "evidenziatore" è spesso sinonimo di coloranti artificiali.</p>
      </div>
      <div>
        <p class="font-bold text-slate-900 mb-1">Abbinamento</p>
        <p class="text-slate-600 text-sm leading-relaxed">Accompagnatela con un bicchierino di Limoncello ghiacciato o, se volete osare, con un calice di vino bianco passito della zona di Tramonti.</p>
      </div>
    </div>
  </div>

</BlogPostLayout>
