---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Guida Pratica', url: '/it-it/guida/' },
  { name: 'Parcheggi e ZTL', url: '/it-it/guida/parcheggi-ztl/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Si puo andare in auto a Positano?",
      "acceptedAnswer": { "@type": "Answer", "text": "In estate Positano e chiusa al traffico dalle 9:00 alle 18:00 (ZTL). Solo i residenti e chi ha prenotazione in hotel possono entrare. Il consiglio migliore: parcheggia a Sorrento o Praiano e vieni in bus SITA o traghetto." }
    },
    {
      "@type": "Question",
      "name": "Dove parcheggiare per visitare la Costiera Amalfitana?",
      "acceptedAnswer": { "@type": "Answer", "text": "Le opzioni migliori: 1) Lascia l\'auto a Salerno o Vietri sul Mare e prendi il bus/traghetto. 2) Parcheggia a Sorrento (garage Achille Lauro, ~€2/h) e prendi bus SITA o aliscafo. 3) Usa i parcheggi a pagamento di Amalfi (Luna Rossa, Flavio Gioia, ~€4-5/h) come base." }
    },
    {
      "@type": "Question",
      "name": "Quanto costa il parcheggio ad Amalfi?",
      "acceptedAnswer": { "@type": "Answer", "text": "I parcheggi principali di Amalfi (Luna Rossa e Flavio Gioia) costano ~€4-5/ora o ~€25-30/giorno. Sono quasi sempre pieni in luglio e agosto. Si consiglia di arrivare prima delle 9:00 o utilizzare i mezzi pubblici." }
    }
  ]
};

const ztlData = [
  { location: 'Positano', ztl: 'Sì', period: 'Giu–Set (9:00–18:00)', note: 'Accesso riservato a residenti e clienti hotel. Bus SITA o traghetto consigliati.' },
  { location: 'Amalfi', ztl: 'Sì', period: 'Tutto l\'anno (centro)', note: 'ZTL permanente nel nucleo storico. Parcheggi a pagamento sul lungomare (~€4/h).' },
  { location: 'Ravello', ztl: 'Sì', period: 'Estate (10:00–19:00)', note: 'Solo bus SITA da Amalfi (25 min, ~€1.50) o auto con autorizzazione hotel.' },
  { location: 'Sorrento', ztl: 'Sì', period: 'Estate (centro)', note: 'Garage coperti disponibili. Piazza Lauro ~€2/h.' },
  { location: 'Praiano', ztl: 'No', period: '—', note: 'Parcheggi liberi e a pagamento sulla SS163. Ottimo punto di sosta.' },
  { location: 'Maiori', ztl: 'No', period: '—', note: 'Lungomare con parcheggi disponibili. Più facile rispetto ai borghi a ovest.' },
  { location: 'Minori', ztl: 'No', period: '—', note: 'Parcheggi sul lungomare, gratuiti o a pagamento basso.' },
];
---

<BaseLayout
  title="Parcheggi e ZTL Costiera Amalfitana 2026 | Dove Lasciare l\'Auto"
  description="Guida completa a parcheggi e ZTL sulla Costiera Amalfitana: Positano, Amalfi, Ravello, Sorrento. Dove lasciare l\'auto e come raggiungere i borghi senza stress."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/parcheggi-hero.jpg" alt="Sorrento, Penisola Sorrentina" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/60">Guida Pratica</span>
        <span>/</span>
        <span class="text-white">Parcheggi e ZTL</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Guida Pratica</p>
        <h1 class="font-serif text-display text-white mb-4">Parcheggi e ZTL</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          La Costiera Amalfitana in estate è un incubo per chi guida: ZTL ovunque, strade strettissime e parcheggi carissimi. Il consiglio principale: lascia l\'auto e usa i mezzi pubblici. Ecco come.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section class="max-w-text">
      <div class="bg-red-50 border border-red-200 rounded-[2rem] p-6 mb-8">
        <p class="font-semibold text-red-800 mb-2">⚠️ Attenzione alle ZTL</p>
        <p class="text-sm text-red-700">Le ZTL (Zone a Traffico Limitato) della Costiera Amalfitana sono monitorate con telecamere. Entrare senza autorizzazione comporta una multa di €80–160 che arriva direttamente all\'indirizzo dell\'autonoleggio o di casa. Non è uno scherzo.</p>
      </div>
      <p class="text-xl leading-relaxed text-charcoal">
        La strategia ottimale per visitare la Costiera in auto è quella del "parcheggio strategico": lasci l\'auto in un punto accessibile (Salerno, Vietri, Sorrento o Praiano) e usi da lì bus, traghetti o aliscafi.
      </p>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">ZTL e parcheggi per ogni borgo</h2>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-med-blue/5 text-charcoal">
              <th class="text-left px-4 py-3 font-semibold">Borgo</th>
              <th class="text-left px-4 py-3 font-semibold">ZTL</th>
              <th class="text-left px-4 py-3 font-semibold">Periodo</th>
              <th class="text-left px-4 py-3 font-semibold">Consiglio</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            {ztlData.map(r => (
              <tr class="hover:bg-slate-50 transition-colors">
                <td class="px-4 py-3 font-semibold text-charcoal">{r.location}</td>
                <td class="px-4 py-3">
                  {r.ztl === 'Sì'
                    ? <span class="text-[10px] bg-red-50 text-red-600 px-2 py-0.5 rounded-full font-medium">Sì</span>
                    : <span class="text-[10px] bg-med-blue/5 text-med-blue px-2 py-0.5 rounded-full font-medium">No</span>
                  }
                </td>
                <td class="px-4 py-3 text-slate-500">{r.period}</td>
                <td class="px-4 py-3 text-slate-600 text-xs">{r.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Le 3 strategie migliori</h2>
      <div class="grid md:grid-cols-3 gap-6">
        {[
          {
            title: 'Base a Salerno',
            desc: 'Parcheggio gratuito o low-cost a Salerno (Piazza della Concordia, ~€5/giorno). Poi traghetto Travelmar per Amalfi, Positano e Capri. Ideale da aprile a ottobre.',
            badge: 'Economica',
          },
          {
            title: 'Base a Sorrento',
            desc: 'Garage Achille Lauro o parcheggio EAV (~€2-3/h, ~€15/giorno). Da Sorrento: aliscafo Capri (25 min), bus SITA Positano (50 min), Circumvesuviana Napoli (70 min).',
            badge: 'Versatile',
          },
          {
            title: 'Base a Praiano',
            desc: 'Praiano non ha ZTL e ha parcheggi disponibili. Ottima posizione centrale sulla SS163: a 15 min da Positano e 25 min da Amalfi in bus. Meno scelta di servizi.',
            badge: 'Centrale',
          },
        ].map(s => (
          <div class="bg-med-cream rounded-[2rem] p-6 border border-slate-100">
            <span class="text-[10px] uppercase tracking-wide bg-med-blue/5 text-med-blue px-2 py-1 rounded-full font-medium">{s.badge}</span>
            <h3 class="font-semibold text-charcoal mt-3 mb-2">{s.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-slate-900 mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-slate-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-slate-600 leading-relaxed text-sm border-t border-slate-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
