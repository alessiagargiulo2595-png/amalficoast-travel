---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Guida Pratica', url: '/it-it/guida/' },
  { name: 'Traghetti & Aliscafi', url: '/it-it/guida/traghetti/' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qual e la differenza tra traghetto e aliscafo sulla Costiera?",
      "acceptedAnswer": { "@type": "Answer", "text": "Il traghetto e lento (50-90 min Napoli-Capri) ma piu economico e stabile. L\'aliscafo e veloce (40-50 min) ma piu caro e non circola con mare mosso. In estate preferire l\'aliscafo per risparmiare tempo; in inverno o con maltempo il traghetto e piu affidabile." }
    },
    {
      "@type": "Question",
      "name": "Si prenotano online i traghetti per la Costiera?",
      "acceptedAnswer": { "@type": "Answer", "text": "Si, quasi tutte le compagnie permettono la prenotazione online: nlg.it, alilauro.it, snav.it, travelmar.it, caremar.it. In estate (luglio-agosto) si consiglia di prenotare almeno 1-2 giorni prima per i traghetti da Napoli per Capri e Ischia." }
    },
    {
      "@type": "Question",
      "name": "Quanto costa il traghetto da Napoli a Capri?",
      "acceptedAnswer": { "@type": "Answer", "text": "Traghetto Napoli-Capri (Caremar/SNAV): ~€13-15 andata. Aliscafo (NLG/Alilauro): ~€20-23 andata. Da Sorrento: ~€18-22 A/R in aliscafo. I prezzi variano leggermente tra compagnie e stagione." }
    },
    {
      "@type": "Question",
      "name": "I traghetti circolano in inverno?",
      "acceptedAnswer": { "@type": "Answer", "text": "Si, ma con frequenze ridotte. Napoli-Capri: almeno 4-5 corse al giorno tutto l\'anno. Napoli-Ischia: servizio annuale frequente. I collegamenti stagionali (Positano, Amalfi, Salerno) sono attivi da aprile a ottobre." }
    }
  ]
};

const routes = [
  {
    from: 'Napoli Beverello',
    to: 'Capri',
    time: '40–50 min (aliscafo) / 75 min (traghetto)',
    price: '€20–23 / €13–15',
    companies: 'NLG, Alilauro, SNAV, Caremar',
    seasonal: false,
  },
  {
    from: 'Napoli Beverello',
    to: 'Ischia (Casamicciola/Porto)',
    time: '50 min (aliscafo) / 75 min (traghetto)',
    price: '€20–24 / €12–14',
    companies: 'Alilauro, SNAV, Caremar, Medmar',
    seasonal: false,
  },
  {
    from: 'Napoli Beverello',
    to: 'Procida',
    time: '35 min (aliscafo)',
    price: '€15–18',
    companies: 'Alilauro, SNAV',
    seasonal: false,
  },
  {
    from: 'Sorrento',
    to: 'Capri',
    time: '20–25 min (aliscafo)',
    price: '€18–22',
    companies: 'NLG, Alilauro',
    seasonal: false,
  },
  {
    from: 'Pozzuoli',
    to: 'Ischia / Procida',
    time: '35 min / 15 min (traghetto)',
    price: '€10–13 / €7–9',
    companies: 'Medmar, Caremar',
    seasonal: false,
  },
  {
    from: 'Salerno',
    to: 'Amalfi / Positano / Capri',
    time: '45 min / 65 min / 100 min',
    price: '€8–12 / €12–16 / €18–22',
    companies: 'Travelmar, NLG',
    seasonal: true,
  },
  {
    from: 'Napoli Beverello',
    to: 'Positano / Amalfi',
    time: '75 min / 90 min',
    price: '€15–20 / €18–22',
    companies: 'NLG, Alilauro',
    seasonal: true,
  },
];
---

<BaseLayout
  title="Traghetti e Aliscafi Costiera Amalfitana 2025 | Orari e Prezzi"
  description="Guida completa ai traghetti e aliscafi della Costiera Amalfitana: Napoli-Capri, Napoli-Ischia, Sorrento-Capri, Salerno-Amalfi-Positano. Compagnie, orari e prezzi aggiornati."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[faqSchema]}
>

  <section class="relative bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-500"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/10 to-black/50"></div>
    <div class="relative max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/60">Guida Pratica</span>
        <span>/</span>
        <span class="text-white">Traghetti & Aliscafi</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">Guida Pratica</p>
        <h1 class="font-serif text-display text-white mb-4">Traghetti & Aliscafi</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Tutte le rotte marittime della Campania: Napoli, Sorrento, Salerno, Positano, Amalfi, Capri, Ischia e Procida. Compagnie, orari indicativi e prezzi aggiornati per la stagione 2025.
        </p>
      </div>
    </div>
  </section>

  <div class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16 space-y-16">

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Tutte le rotte principali</h2>
      <div class="overflow-x-auto rounded-2xl border border-gray-200">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-capri-50 text-capri-800">
              <th class="text-left px-4 py-3 font-semibold">Da</th>
              <th class="text-left px-4 py-3 font-semibold">A</th>
              <th class="text-left px-4 py-3 font-semibold">Durata</th>
              <th class="text-left px-4 py-3 font-semibold">Prezzo (A/R)</th>
              <th class="text-left px-4 py-3 font-semibold">Compagnie</th>
              <th class="text-left px-4 py-3 font-semibold">Stagionale</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {routes.map(r => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-4 py-3 font-medium text-charcoal">{r.from}</td>
                <td class="px-4 py-3">{r.to}</td>
                <td class="px-4 py-3 text-gray-600">{r.time}</td>
                <td class="px-4 py-3 font-mono text-sm">{r.price}</td>
                <td class="px-4 py-3 text-gray-500 text-xs">{r.companies}</td>
                <td class="px-4 py-3">
                  {r.seasonal
                    ? <span class="text-[10px] bg-lemon-50 text-lemon-700 px-2 py-0.5 rounded-full font-medium">Apr–Ott</span>
                    : <span class="text-[10px] bg-capri-50 text-capri-600 px-2 py-0.5 rounded-full font-medium">Tutto l\'anno</span>
                  }
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-2">* Prezzi e durate indicativi. Verifica sempre sulle compagnie: nlg.it, alilauro.it, snav.it, caremar.it, medmar.it, travelmar.it</p>
    </section>

    <section>
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Le compagnie e i loro punti di forza</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { name: 'NLG', desc: 'Napoli→Capri, Sorrento→Capri. Aliscafi veloci e frequenti. Prenota su nlg.it.' },
          { name: 'Alilauro', desc: 'Napoli→Capri/Ischia/Procida/Sorrento. La più grande flotta di aliscafi. alilauro.it.' },
          { name: 'SNAV', desc: 'Napoli→Capri/Ischia/Procida. Anche traghetti veloci. snav.it.' },
          { name: 'Caremar', desc: 'Traghetti lenti Napoli→Capri/Ischia/Procida. I più economici ma i più lenti. caremar.it.' },
          { name: 'Medmar', desc: 'Traghetti Pozzuoli→Ischia/Procida. Economici, frequenti. medmar.it.' },
          { name: 'Travelmar', desc: 'Salerno→Amalfi→Positano stagionale. La rotta da Salerno. travelmar.it.' },
        ].map(c => (
          <div class="bg-offwhite rounded-xl p-4 border border-gray-100">
            <p class="font-semibold text-charcoal mb-1">{c.name}</p>
            <p class="text-xs text-gray-600">{c.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="bg-lemon-50 border border-lemon-200 rounded-2xl p-8">
      <p class="font-semibold text-charcoal text-lg mb-3">Consigli pratici</p>
      <ul class="space-y-2">
        {[
          'In luglio e agosto prenota i biglietti il giorno prima: le prime partenze del mattino (7:00–8:30) si esauriscono.',
          'L\'aliscafo non parte con mare mosso (Beaufort 4–5): controlla sempre le previsioni meteo marine prima.',
          'Il porto di imbarco a Napoli per quasi tutto è il Molo Beverello (piazza Municipio). Medmar parte da Pozzuoli.',
          'Con bambini piccoli il traghetto è più stabile dell\'aliscafo: meno rollio, ponte esterno accessibile.',
          'Il biglietto di ritorno si può acquistare anche nell\'isola: non è necessario comprarlo all\'andata.',
        ].map(tip => (
          <li class="flex items-start gap-2 text-sm text-charcoal">
            <span class="w-1.5 h-1.5 rounded-full bg-lemon-500 mt-1.5 flex-shrink-0"></span>
            <span>{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <section id="faq">
      <h2 class="font-serif text-2xl font-semibold text-charcoal mb-6">Domande frequenti</h2>
      <div class="space-y-4">
        {faqSchema.mainEntity.map((q) => (
          <details class="group border border-gray-200 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
              {q.name}
              <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
              {q.acceptedAnswer.text}
            </div>
          </details>
        ))}
      </div>
    </section>

  </div>

</BaseLayout>
