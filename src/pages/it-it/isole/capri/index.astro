---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Isole del Golfo', url: '/it-it/isole/' },
  { name: 'Capri', url: '/it-it/isole/capri/' },
];

const touristAttractionSchema = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  "name": "Capri",
  "description": "Capri è l'isola più famosa del Golfo di Napoli: Grotta Azzurra, Faraglioni, la mondana Piazzetta e le ville imperiali di Augusto e Tiberio la rendono unica al mondo.",
  "url": "https://amalficoast-travel.com/it-it/isole/capri/",
  "touristType": ["Cultura", "Lusso", "Mare", "Escursionismo"],
  "address": { "@type": "PostalAddress", "addressLocality": "Capri", "addressRegion": "Napoli", "addressCountry": "IT", "postalCode": "80073" },
  "geo": { "@type": "GeoCoordinates", "latitude": 40.5530, "longitude": 14.2270 }
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "Capri, Golfo di Napoli",
  "geo": { "@type": "GeoCoordinates", "latitude": 40.5530, "longitude": 14.2270 },
  "containedInPlace": { "@type": "AdministrativeArea", "name": "Golfo di Napoli" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Come si arriva a Capri da Napoli?",
      "acceptedAnswer": { "@type": "Answer", "text": "Da Napoli Molo Beverello si raggiunge Capri in traghetto (~50 min, Caremar/SNAV) o aliscafo (~40 min, NLG/Alilauro). Da Sorrento l'aliscafo impiega solo 20-25 minuti. I biglietti si acquistano online o in biglietteria. In estate si consiglia di prenotare con anticipo." }
    },
    {
      "@type": "Question",
      "name": "Si possono portare le auto a Capri?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. Capri ha un divieto quasi totale di accesso alle auto private: solo i residenti possono portare veicoli. I turisti si spostano a piedi, con i bus locali, con i taxi (open-air) o con le funicolari. E uno dei motivi per cui l'isola e cosi piacevole da visitare." }
    },
    {
      "@type": "Question",
      "name": "Quanto costa l'ingresso alla Grotta Azzurra?",
      "acceptedAnswer": { "@type": "Answer", "text": "L'ingresso alla Grotta Azzurra costa circa 14 euro a persona (include il giro in barchetta nella grotta). La barca da Marina Grande costa extra (~15 euro andata e ritorno). In alta stagione la fila puo essere di 1-2 ore. Si consiglia di andarci la mattina presto." }
    },
    {
      "@type": "Question",
      "name": "Capri o Anacapri: qual e meglio?",
      "acceptedAnswer": { "@type": "Answer", "text": "Capri (il comune principale) e piu mondana, con la Piazzetta e i negozi di lusso. Anacapri, in cima all'isola, e piu tranquilla e autentica, con Villa San Michele e la seggiovia per Monte Solaro. Per un giorno intero vale visitare entrambe; per mezza giornata scegli in base allo stile che preferisci." }
    },
    {
      "@type": "Question",
      "name": "Quando e meglio visitare Capri?",
      "acceptedAnswer": { "@type": "Answer", "text": "Maggio, giugno e settembre sono i mesi ideali: clima perfetto, mare gia caldo, folla gestibile. Luglio e agosto sono caldissimi e sovraffollati (il numero di visitatori giornalieri supera i 10.000). Aprile e ottobre sono tranquilli ma con qualche servizio ridotto." }
    }
  ]
};

const schemas = [touristAttractionSchema, placeSchema, faqSchema];

const fastFacts = [
  { dt: 'Posizione', dd: 'Golfo di Napoli, NA' },
  { dt: 'Superficie', dd: '10,4 km²' },
  { dt: 'Popolazione', dd: '~14.000 abitanti' },
  { dt: 'Auto private', dd: 'Vietate ai turisti' },
  { dt: 'Da Napoli', dd: '40–50 min (aliscafo/traghetto)' },
  { dt: 'Da Sorrento', dd: '20–25 min (aliscafo)' },
  { dt: 'Spiagge', dd: 'Rocce e ciottoli' },
  { dt: 'Miglior periodo', dd: 'Mag–Giu / Set' },
  { dt: 'Valuta', dd: 'Euro (€)' },
];

const tips = [
  'Parti col primo aliscafo del mattino (7:00–8:00): arrivi prima della folla e trovi la Grotta Azzurra senza coda.',
  'Salta il taxi dalla Marina: prendi la funicolare per Capri o il bus per Anacapri — costa 1/10.',
  'La Piazzetta è cara ma l\'aperitivo è quasi obbligatorio: scegli un posto, siediti e goditi lo spettacolo.',
  'I Giardini di Augusto (accesso ~€1) offrono la vista sui Faraglioni che si trova su tutte le cartoline: gratuiti fino alle 10:00.',
];
---

<BaseLayout
  title="Capri 2025: Guida Completa | Grotta Azzurra, Faraglioni e Piazzetta"
  description="Guida completa a Capri: Grotta Azzurra, Faraglioni, Piazzetta, Villa San Michele, Monte Solaro. Come arrivare da Napoli e Sorrento, orari traghetti, cosa vedere."
  lang={lang}
  pageKey="capri"
  breadcrumbs={breadcrumbs}
  schema={schemas}
>

  <section class="relative min-h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <img src="/images/capri-hero.jpg" alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.2em] mb-3">Isola del Golfo di Napoli · No auto private</p>
        <h1 class="font-serif text-display text-white mb-4">Capri</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          Un'isola di roccia calcarea che emerge dal Tirreno con una forza visiva unica. La Grotta Azzurra che colora l'acqua di blu elettrico, i Faraglioni che si ergono dal mare, la Piazzetta dove il mondo si dà appuntamento da un secolo. Capri non delude mai.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-lemon-400 text-charcoal text-sm font-semibold rounded-full hover:bg-lemon-300 transition-colors">Fast Facts</a>
          <a href="#come-arrivare" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Come arrivare</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Capri è probabilmente l'isola più famosa d'Italia. Imperatori romani, intellettuali del '900, divi di Hollywood: tutti hanno ceduto al suo fascino. Non è una destinazione economica, non è una destinazione tranquilla in estate — ma è un'esperienza che rimane.
          </p>
          <p class="mt-4 text-gray-600 leading-relaxed">
            L'isola si divide in due comuni: Capri (in basso, più mondana) e Anacapri (in alto, più silenziosa). La Marina Grande è il porto principale. Da lì funicolare o taxi portano al centro in pochi minuti. Senza auto, ci si muove a piedi, in bus o in taxi open-air — il che contribuisce enormemente al fascino del luogo.
          </p>
        </div>

        <div class="bg-blue-50 border-l-4 border-med-blue/20 rounded-r-2xl p-8">
          <p class="text-[10px] uppercase tracking-[0.2em] text-med-blue font-medium mb-4">Lo sapevi?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">27 a.C.</p>
              <p class="text-sm text-gray-600 mt-1">Augusto acquistò Capri da Napoli</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">12</p>
              <p class="text-sm text-gray-600 mt-1">ville imperiali romane sull'isola</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-med-blue">10.000+</p>
              <p class="text-sm text-gray-600 mt-1">visitatori al giorno in agosto</p>
            </div>
          </div>
          <p class="text-sm text-gray-500 mt-6 italic">
            La Grotta Azzurra era già nota ai romani come "bagno di Tiberio". Fu riscoperta dagli artisti europei nel 1826 e da allora è diventata una delle attrazioni più visitate d'Italia.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Cosa vedere a Capri</h2>
          <div class="space-y-8">
            {[
              {
                n: 1,
                title: 'Grotta Azzurra',
                text: 'La grotta marina più famosa del Mediterraneo: la luce solare filtra attraverso una cavità sommersa e illumina l\'acqua di un blu elettrico irreale. Si entra sdraiati in minuscole barche a remi. Ingresso ~€14. Raggiungibile in barca da Marina Grande o a piedi (poi in barca). Evitare in caso di mare mosso.',
              },
              {
                n: 2,
                title: 'I Faraglioni',
                text: 'Le tre grandi rocce che emergono dal mare a est dell\'isola sono il simbolo assoluto di Capri. Si ammirano dai Giardini di Augusto, dal belvedere di Punta Tragara o da vicino in giro in barca. La barca attraversa l\'arco naturale del secondo Faraglione (quello di Mezzo): un momento indimenticabile.',
              },
              {
                n: 3,
                title: 'Piazzetta (Piazza Umberto I)',
                text: 'Il salotto del mondo: quattro bar con tavolini all\'aperto, la torre dell\'orologio, la scalinata della Chiesa di Santo Stefano. L\'aperitivo qui costa caro (~€8–12), ma sedersi alla Piazzetta è un rito. La sera si anima ulteriormente. Gratuito passeggiare; a pagamento sedersi.',
              },
              {
                n: 4,
                title: 'Villa San Michele (Anacapri)',
                text: 'Costruita dal medico svedese Axel Munthe a fine \'800 sui resti di una villa di Tiberio, è uno dei giardini più romantici d\'Italia. La vista sulla costiera e sul Golfo di Napoli dal belvedere è straordinaria. Ingresso ~€8. Aperta tutto l\'anno.',
              },
              {
                n: 5,
                title: 'Monte Solaro (Anacapri)',
                text: 'La vetta più alta dell\'isola (589 m) raggiungibile in seggiovia da Anacapri (~15 min, ~€12 A/R). Panorama a 360° su Capri, Ischia, Procida, la costiera e il Vesuvio. In cima: silenzio assoluto, bar e il Santuario della Madonna del Soccorso. Imperdibile.',
              },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-12 h-12 rounded-2xl bg-blue-100 flex items-center justify-center flex-shrink-0 text-med-blue font-serif font-bold text-lg">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-gray-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div id="come-arrivare">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Come arrivare a Capri</h2>
          <p class="text-gray-600 mb-8 leading-relaxed">Capri è raggiungibile in traghetto o aliscafo da Napoli, Sorrento, Positano e Amalfi (stagionale). Non esiste collegamento in auto: i traghetti che trasportano veicoli sono riservati ai residenti.</p>

          <div class="overflow-x-auto rounded-2xl border border-gray-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-gray-500 px-4 py-2 bg-gray-50 rounded-t-2xl border-b border-gray-200 font-medium">
                Aliscafi da Napoli Beverello → Marina Grande, Capri
              </caption>
              <thead>
                <tr class="bg-blue-50 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Partenza Napoli</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivo Capri</th>
                  <th class="text-left px-4 py-3 font-semibold">Compagnia</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {[
                  ['07:15', '07:55', 'NLG'],
                  ['08:00', '08:40', 'Alilauro'],
                  ['09:15', '09:55', 'NLG'],
                  ['10:30', '11:10', 'SNAV'],
                  ['12:00', '12:40', 'NLG'],
                  ['14:30', '15:10', 'Alilauro'],
                  ['16:00', '16:40', 'NLG'],
                ].map(([p, a, c]) => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{p}</td>
                    <td class="px-4 py-3 font-mono">{a}</td>
                    <td class="px-4 py-3 text-gray-500">{c}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <div class="overflow-x-auto rounded-2xl border border-gray-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-gray-500 px-4 py-2 bg-gray-50 rounded-t-2xl border-b border-gray-200 font-medium">
                Aliscafi da Sorrento → Marina Grande, Capri
              </caption>
              <thead>
                <tr class="bg-blue-50 text-charcoal">
                  <th class="text-left px-4 py-3 font-semibold">Partenza Sorrento</th>
                  <th class="text-left px-4 py-3 font-semibold">Arrivo Capri</th>
                  <th class="text-left px-4 py-3 font-semibold">Durata</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {[
                  ['08:00', '08:25', '~25 min'],
                  ['09:30', '09:55', '~25 min'],
                  ['11:00', '11:25', '~25 min'],
                  ['13:30', '13:55', '~25 min'],
                  ['15:30', '15:55', '~25 min'],
                  ['17:30', '17:55', '~25 min'],
                ].map(([p, a, d]) => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3 font-mono">{p}</td>
                    <td class="px-4 py-3 font-mono">{a}</td>
                    <td class="px-4 py-3 text-gray-500">{d}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-gray-400 mt-2">* Orari indicativi estate 2025. Consulta nlg.it, alilauro.it, snav.it per confermare.</p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Luoghi nascosti di Capri</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Arco Naturale', text: 'Un arco di roccia calcarea a 185 m sul mare, raggiungibile a piedi da Capri centro in 40 minuti. Quasi nessuna fila, panorama spettacolare sul mare orientale. Il percorso passa per la Villa Malaparte (fotografabile dall\'esterno).' },
              { title: 'Belvedere di Punta Cannone', text: 'Un belvedere poco frequentato dietro la Certosa di San Giacomo con vista diretta sui Faraglioni. Gratuito, senza file, raggiungibile a piedi in 10 minuti dalla Piazzetta. La foto dei Faraglioni da qui è migliore di quella dai Giardini di Augusto.' },
              { title: 'Grotta di Matromania', text: 'Un\'antica grotta sacra alle ninfe, trasformata in ninfeo romano. Raggiungibile a piedi dall\'Arco Naturale in 15 minuti. Quasi nessun turista. Nei pressi si trova Villa Malaparte, l\'iconica casa rossa sulla scogliera.' },
              { title: 'Bagni di Tiberio', text: 'I resti della villa marittima di Tiberio sulla riva nord di Capri, raggiungibili in barca da Marina Grande o a piedi in 20 minuti. Ingresso libero. Nella baia vicina si può fare il bagno in un mare eccezionalmente limpido.' },
            ].map(({ title, text }) => (
              <div class="bg-med-cream rounded-[2rem] p-6 border border-gray-100">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Domande frequenti su Capri</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-gray-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-charcoal text-white rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.2em] text-med-gold font-medium mb-4">Fast Facts — Capri</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/60 text-sm flex-shrink-0">{dt}</dt>
                  <dd class="text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/10"></div>}
              </>
            ))}
          </dl>
        </div>

        <div class="bg-med-cream border border-lemon-300 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.2em] text-lemon-700 font-medium mb-3">Consigli degli insider</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-med-cream0 mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="bg-white border border-gray-200 rounded-[2rem] p-6">
          <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-medium mb-3">Altre isole del Golfo</p>
          <nav class="space-y-1">
            {[
              { href: '/it-it/isole/ischia/', label: 'Ischia' },
              { href: '/it-it/isole/procida/', label: 'Procida' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-blue-50 hover:text-med-blue transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-med-blue/30"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Esplora le altre isole e la Costiera"
    items={[
      { name: 'Ischia',    href: '/it-it/isole/ischia/',                 tag: 'Terme & Natura',   desc: 'Terme naturali, Castello Aragonese, Monte Epomeo e spiagge vulcaniche.' },
      { name: 'Procida',   href: '/it-it/isole/procida/',                tag: 'La più autentica', desc: 'Case colorate a Marina Corricella, Capitale italiana della Cultura 2022.' },
      { name: 'Positano',  href: '/it-it/costiera-amalfitana/positano/', tag: 'Fashion & Vista',  desc: 'Le case colorate a picco sul mare, boutique di lusso e la spiaggia Fornillo.' },
      { name: 'Amalfi',    href: '/it-it/costiera-amalfitana/amalfi/',   tag: 'Arte & Storia',    desc: 'Il Duomo, il Chiostro del Paradiso e i vicoli della Repubblica marinara.' },
      { name: 'Ravello',   href: '/it-it/costiera-amalfitana/ravello/',  tag: 'Musica & Giardini', desc: 'Villa Rufolo, Villa Cimbrone e il Festival Musicale a 350 m sul mare.' },
    ]}
  />

</BaseLayout>
