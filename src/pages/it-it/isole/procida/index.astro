---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import CorrelationSlider from '../../../../components/CorrelationSlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Isole del Golfo', url: '/it-it/isole/' },
  { name: 'Procida', url: '/it-it/isole/procida/' },
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Procida",
    "description": "Procida è la più piccola e autentica delle isole del Golfo di Napoli: case colorate a Marina Corricella, Terra Murata medievale, Capitale italiana della Cultura 2022 e la spiaggia dell'Isola di Arturo di Elsa Morante.",
    "url": "https://amalficoast-travel.com/it-it/isole/procida/",
    "touristType": ["Cultura", "Autenticità", "Mare", "Letteratura"],
    "address": { "@type": "PostalAddress", "addressLocality": "Procida", "addressRegion": "Napoli", "addressCountry": "IT", "postalCode": "80079" },
    "geo": { "@type": "GeoCoordinates", "latitude": 40.7620, "longitude": 14.0270 }
  },
  {
    "@context": "https://schema.org",
    "@type": "Place",
    "name": "Procida, Golfo di Napoli",
    "geo": { "@type": "GeoCoordinates", "latitude": 40.7620, "longitude": 14.0270 },
    "containedInPlace": { "@type": "AdministrativeArea", "name": "Golfo di Napoli" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Come si arriva a Procida da Napoli?",
        "acceptedAnswer": { "@type": "Answer", "text": "Da Napoli Molo Beverello partono aliscafi per Procida (~35 min, SNAV/Caremar). Da Pozzuoli i traghetti Caremar impiegano ~15 min ed è il collegamento più economico e frequente. In estate i traghetti giornalieri sono molto numerosi." }
      },
      {
        "@type": "Question",
        "name": "Perché Procida è diventata famosa?",
        "acceptedAnswer": { "@type": "Answer", "text": "Procida è sempre stata amata dagli artisti: Elsa Morante vi ambientò 'L'isola di Arturo' (1957), Massimo Troisi vi girò 'Il Postino' (1994). La notorietà internazionale è esplosa nel 2022 quando è stata nominata Capitale italiana della Cultura, portando milioni di turisti a scoprirla." }
      },
      {
        "@type": "Question",
        "name": "Marina Corricella vale la visita?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sì, Marina Corricella è uno dei borghi marinari più belli e fotografati d'Italia: case multicolori gialle, arancioni, rosa e blu che si affacciano direttamente sul mare senza una strada carrabile. Si raggiunge a piedi in 15 minuti da Marina Grande. Il tramonto da qui è indimenticabile." }
      },
      {
        "@type": "Question",
        "name": "Procida è adatta a una gita giornaliera?",
        "acceptedAnswer": { "@type": "Answer", "text": "Sì, Procida è piccola (4,1 km²) e si esplora comodamente in un giorno. In una giornata si visitano Marina Grande, Marina Corricella, Terra Murata, Spiaggia del Pozzo Vecchio e la Chiaiolella. I traghetti da Pozzuoli permettono di partire la mattina e tornare la sera." }
      },
      {
        "@type": "Question",
        "name": "Qual è la spiaggia più bella di Procida?",
        "acceptedAnswer": { "@type": "Answer", "text": "La Spiaggia del Pozzo Vecchio (chiamata 'L'isola di Arturo' dopo il film) è la più famosa e suggestiva. La Chiaiolella è la più grande e attrezzata. La Spiaggia di Ciraccio è più tranquilla. Tutte le spiagge di Procida hanno acque molto limpide grazie alla posizione aperta sul Tirreno." }
      }
    ]
  }
];

const faqSchema = schemas[2];

const fastFacts = [
  { dt: 'Posizione', dd: 'Golfo di Napoli, NA' },
  { dt: 'Superficie', dd: '4,1 km²' },
  { dt: 'Popolazione', dd: '~10.000 abitanti' },
  { dt: 'Capitale Cultura', dd: '2022' },
  { dt: 'Da Napoli', dd: '~35 min (aliscafo)' },
  { dt: 'Da Pozzuoli', dd: '~15 min (traghetto)' },
  { dt: 'Spiagge', dd: 'Sabbia scura e chiara' },
  { dt: 'Miglior periodo', dd: 'Mag–Giu / Set–Ott' },
  { dt: 'Valuta', dd: 'Euro (€)' },
];

const tips = [
  'Prendi il traghetto da Pozzuoli invece di Napoli: costa meno, ci vuole meno e c\'è meno ressa.',
  'Noleggia una bici o uno scooter: Procida è piccola e girare a piedi fa sudare molto d\'estate.',
  'Marina Corricella al tramonto: arriva alle 19:00 quando la luce è dorata e i pescatori tornano con le barche.',
  'Mangia al porto di Corricella: il pesce fresco è pescato il giorno stesso e i prezzi sono onesti.',
];
---

<BaseLayout
  title="Procida 2025: Guida Completa | Marina Corricella e Isola di Arturo"
  description="Guida completa a Procida: Marina Corricella, Terra Murata, Spiaggia del Pozzo Vecchio, come arrivare da Napoli e Pozzuoli. Capitale italiana della Cultura 2022."
  lang={lang}
  pageKey="procida"
  breadcrumbs={breadcrumbs}
  schema={schemas}
>

  <section class="relative min-h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-500 opacity-70"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">Capitale italiana della Cultura 2022 · L'isola di Arturo</p>
        <h1 class="font-serif text-display text-white mb-4">Procida</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La più piccola delle isole del Golfo è anche la più autentica. Case gialle, arancioni e rosa a picco sul porto di Corricella, vicoli medievali di Terra Murata, la spiaggia dove Elsa Morante ambientò il suo capolavoro. Procida è rimasta sé stessa mentre il mondo la scopriva.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-lemon-400 text-charcoal text-sm font-semibold rounded-full hover:bg-lemon-300 transition-colors">Fast Facts</a>
          <a href="#come-arrivare" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Come arrivare</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Procida non ha cercato il turismo — il turismo ha trovato lei. Elsa Morante ci ambientò "L'isola di Arturo" nel 1957. Massimo Troisi ci girò "Il Postino" nel 1994. Nel 2022 è stata Capitale italiana della Cultura. Eppure è rimasta genuina: pescatori che escono all'alba, donne che stendono il bucato sui balconi colorati, bambini che giocano nei vicoli di Terra Murata.
          </p>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Con soli 4,1 km² è la più piccola isola abitata del Golfo. Si gira quasi tutta a piedi in un giorno, oppure in bici. I colori delle case — pastello caldo, intonaci sbiaditi dal sole — sono la prima cosa che colpisce arrivando in traghetto. La seconda è il silenzio, relativamente raro per un'isola così vicina a Napoli.
          </p>
        </div>

        <div class="bg-capri-50 border-l-4 border-capri-500 rounded-r-2xl p-8">
          <p class="text-[10px] uppercase tracking-widest text-capri-500 font-medium mb-4">Lo sapevi?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-capri-600">4,1 km²</p>
              <p class="text-sm text-gray-600 mt-1">superficie — la più piccola del Golfo</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-capri-600">1994</p>
              <p class="text-sm text-gray-600 mt-1">anno de "Il Postino" con Troisi</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-capri-600">2022</p>
              <p class="text-sm text-gray-600 mt-1">Capitale italiana della Cultura</p>
            </div>
          </div>
          <p class="text-sm text-gray-500 mt-6 italic">
            Il film "Il Postino" fu l'ultimo di Massimo Troisi: l'attore morì di infarto poche ore dopo aver completato le riprese a Procida, il 4 giugno 1994. Il film vinse 5 nomination all'Oscar.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Cosa vedere a Procida</h2>
          <div class="space-y-8">
            {[
              { n: 1, title: 'Marina Corricella', text: 'Il cuore visivo di Procida: un borgo marinaro senza strade carrabili, con case multicolori che scendono direttamente sul porto. Non esiste una strada: si cammina su scalinate e vicoli. I pescatori riparano le reti al mattino, i ristoranti aprono a mezzogiorno. Il tramonto qui è tra i più belli del Golfo.' },
              { n: 2, title: 'Terra Murata', text: 'Il nucleo medievale dell\'isola, arroccato sul punto più alto (91 m). All\'interno: l\'ex carcere borbonico (ora in restauro), il palazzo d\'Avalos, la chiesa di San Michele Arcangelo con un soffitto ligneo dipinto del XVII secolo e una straordinaria vista sul Golfo. Raggiunti a piedi in 20 minuti da Marina Grande.' },
              { n: 3, title: 'Spiaggia del Pozzo Vecchio (Isola di Arturo)', text: 'La spiaggia più famosa di Procida, set del film "Il Postino" e ambientazione del romanzo di Elsa Morante. Ciottoli e sabbia scura, acque limpidissime, una grotta marina sulla sinistra. Raggiungibile a piedi in 15 minuti da Marina Grande o in barca.' },
              { n: 4, title: 'Marina Grande (Sent\'Cosimo)', text: 'Il porto principale di Procida, con il pontile dei traghetti e le case colorate del lungomare. Il mercato del pesce si svolge la mattina presto vicino al porto. L\'arco di accesso a Corricella è da qui: un passaggio che regala una delle prime viste più sorprendenti dell\'isola.' },
              { n: 5, title: 'Spiaggia della Chiaiolella', text: 'La spiaggia più grande e attrezzata di Procida, nella baia della Chiaiolella sul lato ovest dell\'isola. Sabbia mista, stabilimenti balneari, gelaterie e ristoranti. Di fronte si vede l\'isolotto di Vivara, riserva naturale WWF (visitabile su prenotazione).' },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-12 h-12 rounded-2xl bg-capri-100 flex items-center justify-center flex-shrink-0 text-capri-600 font-serif font-bold text-lg">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-gray-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div id="come-arrivare">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Come arrivare a Procida</h2>
          <p class="text-gray-600 mb-8 leading-relaxed">Procida è la più vicina a Napoli e Pozzuoli: ideale per una gita giornaliera. Da Pozzuoli è il collegamento più rapido ed economico.</p>
          <div class="overflow-x-auto rounded-2xl border border-gray-200">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-gray-500 px-4 py-2 bg-gray-50 rounded-t-2xl border-b border-gray-200 font-medium">Connessioni principali verso Procida</caption>
              <thead>
                <tr class="bg-capri-50 text-capri-800">
                  <th class="text-left px-4 py-3 font-semibold">Provenienza</th>
                  <th class="text-left px-4 py-3 font-semibold">Mezzo</th>
                  <th class="text-left px-4 py-3 font-semibold">Durata</th>
                  <th class="text-left px-4 py-3 font-semibold">Compagnia</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {[
                  ['Pozzuoli', 'Traghetto', '~15 min', 'Caremar / Medmar'],
                  ['Napoli Beverello', 'Aliscafo', '~35 min', 'SNAV / Caremar'],
                  ['Napoli Mergellina', 'Aliscafo', '~40 min', 'Alilauro'],
                  ['Ischia Porto', 'Traghetto', '~35 min', 'Caremar'],
                ].map(([p, m, d, c]) => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3">{p}</td>
                    <td class="px-4 py-3">{m}</td>
                    <td class="px-4 py-3 font-mono">{d}</td>
                    <td class="px-4 py-3 text-gray-500">{c}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-gray-400 mt-2">* Consulta caremar.it e snav.it per orari aggiornati.</p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Luoghi nascosti di Procida</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Isolotto di Vivara', text: 'Una riserva naturale WWF collegata a Procida da un ponte pedonale. Flora e fauna mediterranea intatta, vista sul Golfo e sui Campi Flegrei. Visitabile solo su prenotazione con guide autorizzate (vivara.it). Uno dei luoghi più silenziosi e incontaminati della Campania.' },
              { title: 'Palazzo d\'Avalos', text: 'Il palazzo dei principi d\'Avalos su Terra Murata, prima residenza nobiliare poi carcere borbonico (chiuso nel 1988). In restauro per diventare museo. La terrazza esterna è aperta al pubblico: panorama a 360° su tutto il Golfo di Napoli.' },
              { title: 'Spiaggia di Ciraccio', text: 'La spiaggia meno frequentata di Procida, sul lato ovest vicino alla Chiaiolella. Sabbia scura, acque calme e quasi nessun stabilimento balneare. Meta preferita dei residenti nella settimana. Si raggiunge a piedi dalla Chiaiolella in 10 minuti.' },
              { title: 'Pasticceria Crescenzo', text: 'Una delle pasticcerie storiche di Procida, famosa per i "linguine" (dolci al limone locali) e le graffe fritte. Nascosta nei vicoli di Marina Grande, frequentata soprattutto dai residenti. Il miglior posto per fare colazione sull\'isola.' },
            ].map(({ title, text }) => (
              <div class="bg-offwhite rounded-2xl p-6 border border-gray-100">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Domande frequenti su Procida</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-gray-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6 lg:sticky lg:top-24 self-start">
        <div id="fast-facts" class="bg-charcoal text-white rounded-2xl p-6">
          <p class="text-[10px] uppercase tracking-widest text-lemon-400 font-medium mb-4">Fast Facts — Procida</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/60 text-sm flex-shrink-0">{dt}</dt>
                  <dd class="text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/10"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-lemon-50 border border-lemon-300 rounded-2xl p-6">
          <p class="text-[10px] uppercase tracking-widest text-lemon-700 font-medium mb-3">Consigli degli insider</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-lemon-500 mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-6">
          <p class="text-[10px] uppercase tracking-widest text-gray-400 font-medium mb-3">Altre isole del Golfo</p>
          <nav class="space-y-1">
            {[
              { href: '/it-it/isole/capri/', label: 'Capri' },
              { href: '/it-it/isole/ischia/', label: 'Ischia' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-capri-300"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

  <CorrelationSlider
    heading="Esplora le altre isole e la Costiera"
    items={[
      { name: 'Capri',     href: '/it-it/isole/capri/',                  tag: 'La più iconica',   desc: 'Grotta Azzurra, Faraglioni e la mondana Piazzetta nel Golfo di Napoli.' },
      { name: 'Ischia',    href: '/it-it/isole/ischia/',                 tag: 'Terme & Natura',   desc: 'Terme naturali, Castello Aragonese, Monte Epomeo e spiagge vulcaniche.' },
      { name: 'Positano',  href: '/it-it/costiera-amalfitana/positano/', tag: 'Fashion & Vista',  desc: 'Le case colorate a picco sul mare, boutique di lusso e la spiaggia Fornillo.' },
      { name: 'Amalfi',    href: '/it-it/costiera-amalfitana/amalfi/',   tag: 'Arte & Storia',    desc: 'Il Duomo, il Chiostro del Paradiso e i vicoli della Repubblica marinara.' },
      { name: 'Ravello',   href: '/it-it/costiera-amalfitana/ravello/',  tag: 'Musica & Giardini', desc: 'Villa Rufolo, Villa Cimbrone e il Festival Musicale a 350 m sul mare.' },
    ]}
  />

</BaseLayout>
