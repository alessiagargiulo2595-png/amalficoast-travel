---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Isole del Golfo', url: '/it-it/isole/' },
  { name: 'Ischia', url: '/it-it/isole/ischia/' },
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "TouristAttraction",
    "name": "Ischia",
    "description": "Ischia è l'isola vulcanica più grande del Golfo di Napoli: terme naturali, il Castello Aragonese, la Spiaggia dei Maronti e il Monte Epomeo la rendono la meta ideale per chi cerca natura, relax e cultura.",
    "url": "https://amalficoast-travel.com/it-it/isole/ischia/",
    "touristType": ["Terme", "Natura", "Cultura", "Mare"],
    "address": { "@type": "PostalAddress", "addressLocality": "Ischia", "addressRegion": "Napoli", "addressCountry": "IT", "postalCode": "80077" },
    "geo": { "@type": "GeoCoordinates", "latitude": 40.7300, "longitude": 13.9000 }
  },
  {
    "@context": "https://schema.org",
    "@type": "Place",
    "name": "Ischia, Golfo di Napoli",
    "geo": { "@type": "GeoCoordinates", "latitude": 40.7300, "longitude": 13.9000 },
    "containedInPlace": { "@type": "AdministrativeArea", "name": "Golfo di Napoli" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Come si arriva a Ischia da Napoli?",
        "acceptedAnswer": { "@type": "Answer", "text": "Da Napoli Molo Beverello partono traghetti (Caremar, Medmar, ~75 min) e aliscafi (~50 min). Da Pozzuoli i traghetti Caremar impiegano ~35 min. In estate è consigliabile prenotare i biglietti di ritorno con anticipo, soprattutto la domenica." }
      },
      {
        "@type": "Question",
        "name": "Le terme di Ischia sono a pagamento?",
        "acceptedAnswer": { "@type": "Answer", "text": "La maggior parte dei parchi termali è a pagamento (€15–35 a persona per una giornata). I più famosi sono Negombo, Poseidon e Terme di Citara. Esistono anche alcune sorgenti termali naturali gratuite, come la spiaggia termale di Sant'Angelo (mare caldo per effetto vulcanico)." }
      },
      {
        "@type": "Question",
        "name": "Vale la pena visitare il Castello Aragonese di Ischia?",
        "acceptedAnswer": { "@type": "Answer", "text": "Assolutamente sì. Il Castello Aragonese è uno dei castelli medievali meglio conservati d'Italia, costruito su un isolotto collegato all'isola da un ponte. All'interno si trovano una cattedrale, un convento, celle monacali e una terrazza con vista straordinaria. Ingresso ~€12." }
      },
      {
        "@type": "Question",
        "name": "Ischia è meglio di Capri?",
        "acceptedAnswer": { "@type": "Answer", "text": "Dipende dalle preferenze. Capri è più mondana, esclusiva e cara. Ischia è più grande, più verde, con terme naturali, spiagge di sabbia nera e un'atmosfera meno elitaria. Per famiglie e chi ama natura e relax, Ischia è spesso la scelta migliore. Per mondanità e viste iconiche, Capri." }
      },
      {
        "@type": "Question",
        "name": "Quanti giorni servono per visitare Ischia?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ischia è grande (46 km²) e merita almeno 2–3 giorni per essere esplorata. Con un giorno solo si può vedere Ischia Ponte, il Castello Aragonese e un parco termale. Con 2 giorni si aggiungono Sant'Angelo, la Spiaggia dei Maronti e l'escursione al Monte Epomeo." }
      }
    ]
  }
];

const faqSchema = schemas[2];

const fastFacts = [
  { dt: 'Posizione', dd: 'Golfo di Napoli, NA' },
  { dt: 'Superficie', dd: '46,3 km²' },
  { dt: 'Popolazione', dd: '~62.000 abitanti' },
  { dt: 'Vulcano', dd: 'Epomeo (789 m)' },
  { dt: 'Da Napoli', dd: '50–75 min' },
  { dt: 'Da Pozzuoli', dd: '~35 min (traghetto)' },
  { dt: 'Spiagge', dd: 'Sabbia scura vulcanica' },
  { dt: 'Terme', dd: 'Naturali e parchi termali' },
  { dt: 'Valuta', dd: 'Euro (€)' },
];

const tips = [
  'Prenota il parco termale con anticipo: Negombo e Poseidon esauriscono i posti veloci in luglio e agosto.',
  'Noleggia uno scooter o un\'auto per girare l\'isola: i bus locali esistono ma sono lenti e affollati.',
  'Sant\'Angelo è una delle frazioni più belle d\'Italia: arriva a piedi dal parcheggio (auto vietate nel centro).',
  'La spiaggia termale naturale di Sant\'Angelo costa zero: l\'acqua è calda per effetto vulcanico, non serve il parco.',
];
---

<BaseLayout
  title="Ischia 2025: Guida Completa | Terme, Castello Aragonese e Monte Epomeo"
  description="Guida completa a Ischia: Castello Aragonese, terme, Spiaggia dei Maronti, Monte Epomeo, Sant'Angelo. Come arrivare da Napoli e Pozzuoli, orari traghetti."
  lang={lang}
  pageKey="ischia"
  breadcrumbs={breadcrumbs}
  schema={schemas}
>

  <section class="relative min-h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-br from-capri-900 via-capri-700 to-capri-600 opacity-70"></div>
    <div class="relative z-20 max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        {breadcrumbs.map((b, i) => (
          <>
            {i > 0 && <span>/</span>}
            {i < breadcrumbs.length - 1
              ? <a href={b.url} class="hover:text-white transition-colors">{b.name}</a>
              : <span class="text-white">{b.name}</span>
            }
          </>
        ))}
      </nav>
      <div class="max-w-3xl">
        <p class="text-lemon-400 text-sm font-medium uppercase tracking-widest mb-3">L'isola verde · Terme naturali · Vulcano Epomeo</p>
        <h1 class="font-serif text-display text-white mb-4">Ischia</h1>
        <p class="text-xl text-white/80 leading-relaxed max-w-2xl">
          La più grande delle isole del Golfo, Ischia è un vulcano estinto coperto di verde, con terme naturali che sgorgano dal sottosuolo, spiagge di sabbia vulcanica scura e un castello medievale che sembra uscito da un romanzo. La scelta perfetta per chi vuole natura, relax e storia.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
          <a href="#fast-facts" class="px-5 py-2.5 bg-lemon-400 text-charcoal text-sm font-semibold rounded-full hover:bg-lemon-300 transition-colors">Fast Facts</a>
          <a href="#come-arrivare" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">Come arrivare</a>
          <a href="#faq" class="px-5 py-2.5 bg-white/10 backdrop-blur text-white text-sm font-medium rounded-full border border-white/20 hover:bg-white/20 transition-colors">FAQ</a>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-editorial mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-12">

      <div class="space-y-16">

        <div class="prose-editorial">
          <p class="text-xl leading-relaxed text-charcoal">
            Ischia è il contrario di Capri: grande, verde, accessibile e termale. Con 46 km² è la più grande isola del Golfo di Napoli, e la sua origine vulcanica si sente letteralmente sotto i piedi — nell'acqua calda delle terme naturali, nella sabbia scura delle spiagge, nel paesaggio aspro del Monte Epomeo.
          </p>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Si divide in sei comuni: Ischia, Ischia Ponte (il più bello, con il castello), Casamicciola, Lacco Ameno, Forio e Barano. Sant'Angelo, nel comune di Serrara Fontana, è la perla dell'isola: un borgo senza auto affacciato su una piccola baia con acque termali naturali.
          </p>
        </div>

        <div class="bg-capri-50 border-l-4 border-capri-500 rounded-r-2xl p-8">
          <p class="text-[10px] uppercase tracking-widest text-capri-500 font-medium mb-4">Lo sapevi?</p>
          <div class="grid sm:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-capri-600">789 m</p>
              <p class="text-sm text-gray-600 mt-1">altitudine del Monte Epomeo</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-capri-600">100+</p>
              <p class="text-sm text-gray-600 mt-1">sorgenti termali naturali sull'isola</p>
            </div>
            <div class="text-center">
              <p class="font-serif text-4xl font-bold text-capri-600">5 mln</p>
              <p class="text-sm text-gray-600 mt-1">presenze turistiche all'anno</p>
            </div>
          </div>
          <p class="text-sm text-gray-500 mt-6 italic">
            Ischia è la prima colonia greca d'Occidente: i coloni di Eubea la fondarono nell'VIII sec. a.C. chiamandola <em>Pithecusae</em>. Le terme erano già sfruttate nell'antichità.
          </p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Cosa vedere a Ischia</h2>
          <div class="space-y-8">
            {[
              { n: 1, title: 'Castello Aragonese di Ischia', text: 'Un castello medievale su un isolotto roccioso collegato all\'isola da un ponte del XV secolo. All\'interno: la cattedrale, le celle delle monache di clausura (con ossuario), il carcere borbonico e una terrazza panoramica sul Golfo. Ingresso ~€12. Aperto tutto l\'anno. Uno dei castelli più affascinanti d\'Italia.' },
              { n: 2, title: 'Parco Termale Negombo', text: 'Il più bello e ben curato dei parchi termali di Ischia, nella baia di San Montano (Lacco Ameno). Piscine a diverse temperature, giardini botanici, spiaggia privata di sabbia nera e accesso diretto al mare. Ingresso ~€30–35. Aperto da aprile a ottobre. Da prenotare con anticipo.' },
              { n: 3, title: 'Monte Epomeo', text: 'La vetta dell\'isola (789 m) si raggiunge a piedi in 2–3 ore da Fontana oppure in mulo. In cima: una piccola chiesa scavata nel tufo, silenzio assoluto e panorama su tutto il Golfo di Napoli. Il tramonto dal Epomeo è uno dei più belli della Campania.' },
              { n: 4, title: 'Sant\'Angelo', text: 'Il borgo più pittoresco di Ischia: case colorate su un promontorio senza auto, collegato all\'isola da un sottile istmo. Spiaggia termale naturale (acqua calda gratuita), ristoranti di pesce fresco e un\'atmosfera quasi fuori dal tempo. Da raggiungere a piedi dal parcheggio di Succhivo.' },
              { n: 5, title: 'Giardini La Mortella', text: 'Uno dei giardini botanici più belli d\'Europa, creato dal compositore William Walton e dalla moglie Susana nel 1956. Piante esotiche, laghetti, terrazze panoramiche e un piccolo museo musicale. Ingresso ~€12. Aperto da aprile a novembre (mercoledì, venerdì, sabato, domenica).' },
            ].map(({ n, title, text }) => (
              <div class="grid sm:grid-cols-[auto_1fr] gap-4">
                <div class="w-12 h-12 rounded-2xl bg-capri-100 flex items-center justify-center flex-shrink-0 text-capri-600 font-serif font-bold text-lg">{n}</div>
                <div>
                  <h3 class="font-semibold text-charcoal text-lg mb-1">{title}</h3>
                  <p class="text-gray-600 leading-relaxed">{text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div id="come-arrivare">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Come arrivare a Ischia</h2>
          <p class="text-gray-600 mb-8 leading-relaxed">Ischia si raggiunge principalmente da Napoli Beverello e da Pozzuoli. I traghetti trasportano anche le auto (utile per un soggiorno lungo). In alta stagione prenotare il biglietto di ritorno.</p>
          <div class="overflow-x-auto rounded-2xl border border-gray-200 mb-6">
            <table class="w-full text-sm">
              <caption class="text-left text-xs text-gray-500 px-4 py-2 bg-gray-50 rounded-t-2xl border-b border-gray-200 font-medium">Connessioni principali verso Ischia Porto</caption>
              <thead>
                <tr class="bg-capri-50 text-capri-800">
                  <th class="text-left px-4 py-3 font-semibold">Provenienza</th>
                  <th class="text-left px-4 py-3 font-semibold">Mezzo</th>
                  <th class="text-left px-4 py-3 font-semibold">Durata</th>
                  <th class="text-left px-4 py-3 font-semibold">Compagnia</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {[
                  ['Napoli Beverello', 'Aliscafo', '~50 min', 'Alilauro / SNAV'],
                  ['Napoli Beverello', 'Traghetto', '~75 min', 'Caremar / Medmar'],
                  ['Pozzuoli', 'Traghetto', '~35 min', 'Caremar / Medmar'],
                  ['Napoli Mergellina', 'Aliscafo', '~45 min', 'Alilauro'],
                ].map(([p, m, d, c]) => (
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-4 py-3">{p}</td>
                    <td class="px-4 py-3">{m}</td>
                    <td class="px-4 py-3 font-mono">{d}</td>
                    <td class="px-4 py-3 text-gray-500">{c}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-xs text-gray-400">* Consulta caremar.it, medmar.it, alilauro.it per orari aggiornati.</p>
        </div>

        <div>
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-6">Luoghi nascosti di Ischia</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            {[
              { title: 'Spiaggia dei Maronti', text: 'La spiaggia più lunga di Ischia (2 km di sabbia nera vulcanica) nel comune di Barano. Accessibile in barca dal porto di Sant\'Angelo o a piedi scendendo una ripida scalinata. In alcuni punti, l\'acqua fuoriesce calda dal sottosuolo direttamente sulla spiaggia.' },
              { title: 'Museo di Pithecusae (Lacco Ameno)', text: 'Il museo archeologico nell\'ottocentesca Villa Arbusto conserva la Coppa di Nestore, uno dei più antichi esempi di scrittura greca alfabetica (VIII sec. a.C.). Praticamente sconosciuto ai turisti. Ingresso ~€5.' },
              { title: 'Terme Comunali di Casamicciola', text: 'Le terme più antiche e meno costose di Ischia (ingresso ~€5). Piscine termali all\'aperto frequentate principalmente dai residenti. Nessuna spa di lusso, ma acqua termale autentica a prezzi accessibili.' },
              { title: 'Forio e la Chiesa del Soccorso', text: 'La chiesa bianca di Santa Maria del Soccorso su un promontorio a Forio è una delle immagini simbolo di Ischia. Il tramonto da qui è tra i più fotografati dell\'isola. Gratuita, aperta tutto il giorno. Il lungomare di Forio è il più vivace dell\'isola la sera.' },
            ].map(({ title, text }) => (
              <div class="bg-offwhite rounded-2xl p-6 border border-gray-100">
                <h3 class="font-semibold text-charcoal mb-2">{title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{text}</p>
              </div>
            ))}
          </div>
        </div>

        <div id="faq">
          <h2 class="font-serif text-3xl font-semibold text-charcoal mb-8">Domande frequenti su Ischia</h2>
          <div class="space-y-4">
            {faqSchema.mainEntity.map((q) => (
              <details class="group border border-gray-200 rounded-2xl overflow-hidden">
                <summary class="flex items-center justify-between px-6 py-4 cursor-pointer select-none text-charcoal font-medium hover:bg-gray-50 transition-colors">
                  {q.name}
                  <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <div class="px-6 pb-5 text-gray-600 leading-relaxed text-sm border-t border-gray-100 pt-4">
                  {q.acceptedAnswer.text}
                </div>
              </details>
            ))}
          </div>
        </div>

      </div>

      <aside class="space-y-6">
        <div id="fast-facts" class="bg-charcoal text-white rounded-2xl p-6 sticky top-24">
          <p class="text-[10px] uppercase tracking-widest text-lemon-400 font-medium mb-4">Fast Facts — Ischia</p>
          <dl class="space-y-3">
            {fastFacts.map(({ dt, dd }, i) => (
              <>
                <div class="flex justify-between items-start gap-3">
                  <dt class="text-white/60 text-sm flex-shrink-0">{dt}</dt>
                  <dd class="text-sm text-right">{dd}</dd>
                </div>
                {i < fastFacts.length - 1 && <div class="border-t border-white/10"></div>}
              </>
            ))}
          </dl>
        </div>
        <div class="bg-lemon-50 border border-lemon-300 rounded-2xl p-6">
          <p class="text-[10px] uppercase tracking-widest text-lemon-700 font-medium mb-3">Consigli degli insider</p>
          <ul class="space-y-3">
            {tips.map(tip => (
              <li class="flex items-start gap-2 text-sm text-charcoal">
                <span class="w-1.5 h-1.5 rounded-full bg-lemon-500 mt-1.5 flex-shrink-0"></span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-white border border-gray-200 rounded-2xl p-6">
          <p class="text-[10px] uppercase tracking-widest text-gray-400 font-medium mb-3">Altre isole del Golfo</p>
          <nav class="space-y-1">
            {[
              { href: '/it-it/isole/capri/', label: 'Capri' },
              { href: '/it-it/isole/procida/', label: 'Procida' },
            ].map(({ href, label }) => (
              <a href={href} class="flex items-center gap-2 px-3 py-2 rounded-xl text-sm text-charcoal hover:bg-capri-50 hover:text-capri-600 transition-colors">
                <span class="w-1.5 h-1.5 rounded-full bg-capri-300"></span> {label}
              </a>
            ))}
          </nav>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
