---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocalePath } from '../../i18n/translations';

const lang = 'it-it';
const t = getTranslations(lang);

const months = [
  { name: 'Gennaio', weather: '8–14°C', sea: 'Freddo', crowds: 'Deserta', notes: 'La costiera è quasi deserta. Molti alberghi e ristoranti chiusi. Per chi ama il silenzio assoluto e la fotografia senza persone in scena.' },
  { name: 'Febbraio', weather: '9–15°C', sea: 'Freddo', crowds: 'Deserta', notes: 'Simile a gennaio. Qualche apertura per il Carnevale. Mimose in fiore sulle colline.' },
  { name: 'Marzo', weather: '11–17°C', sea: 'Fresco', crowds: 'Bassa', notes: 'La costiera si risveglia. Limoni e agrumi in maturazione. Qualche turista ma ancora tranquillo. Ottimo per trekking.' },
  { name: 'Aprile', weather: '13–20°C', sea: 'Fresco', crowds: 'Media', notes: 'Periodo ideale: temperatura piacevole, paesaggi verdissimi, relativamente pochi turisti. I traghetti riprendono. Pasqua porta qualche folla.' },
  { name: 'Maggio', weather: '16–24°C', sea: 'Temperato', crowds: 'Media-alta', notes: 'Uno dei mesi migliori dell\'anno. Tutto aperto, mare già balneabile per i più audaci, fiori ovunque. Prenotare alloggio in anticipo.' },
  { name: 'Giugno', weather: '20–28°C', sea: 'Caldo', crowds: 'Alta', notes: 'Prima settimana ancora gestibile, poi inizia l\'alta stagione. Mare splendido, serate lunghe e luminose. Prezzi alti.' },
  { name: 'Luglio', weather: '23–32°C', sea: 'Caldo', crowds: 'Altissima', notes: 'Mese più affollato. Traffico intenso sulla SS163, spiagge piene, prezzi massimi. Da evitare per chi non ama le folle, altrimenti il mare è magnifico.' },
  { name: 'Agosto', weather: '23–32°C', sea: 'Caldo', crowds: 'Altissima', notes: 'Come luglio, anche peggio. Ferragosto porta l\'esodo estivo italiano. Se vieni, prenota tutto con mesi d\'anticipo. Magia serale però ineguagliabile.' },
  { name: 'Settembre', weather: '20–27°C', sea: 'Caldo', crowds: 'Media-alta', notes: 'Settembre è il mese segreto dei conoscitori: mare ancora caldo, folla in calo dalla seconda metà, prezzi che scendono. Probabilmente il mese migliore in assoluto.' },
  { name: 'Ottobre', weather: '16–22°C', sea: 'Temperato', crowds: 'Bassa', notes: 'La costiera ritorna a se stessa. I locali riaprono per il fine settimana. Colori autunnali sulle colline, limoni maturi. Eccellente per trekking e fotografia.' },
  { name: 'Novembre', weather: '12–17°C', sea: 'Fresco', crowds: 'Deserta', notes: "Molte strutture chiudono. Possibili piogge. Per chi vuole silenzio assoluto, prezzi minimi e un'Italia autentica." },
  { name: 'Dicembre', weather: '9–14°C', sea: 'Freddo', crowds: 'Molto bassa', notes: 'Qualche apertura per le feste di Natale. Presepi viventi a Praiano e nelle grotte. Atmosfera unica ma servizi limitati.' },
];

const crowdColor: Record<string, string> = {
  'Deserta': 'bg-green-100 text-green-700',
  'Bassa': 'bg-green-100 text-green-700',
  'Media': 'bg-yellow-100 text-yellow-700',
  'Media-alta': 'bg-orange-100 text-orange-700',
  'Alta': 'bg-red-100 text-red-700',
  'Altissima': 'bg-red-200 text-red-800',
  'Molto bassa': 'bg-green-100 text-green-700',
};
---

<BaseLayout
  title={t.meta.when_to_visit_title}
  description={t.meta.when_to_visit_description}
  lang={lang}
  pageKey="when-to-visit"
>
  <!-- Hero -->
  <section class="bg-charcoal text-white py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-white/80 text-sm uppercase tracking-[0.3em] mb-3">Guida stagionale</p>
      <h1 class="text-4xl md:text-5xl font-bold font-serif mb-4">Quando visitare la Costiera Amalfitana</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">Ogni mese ha i suoi pro e i suoi contro. Guida completa mese per mese al clima, alla folla e ai prezzi.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-lg text-slate-600 leading-relaxed">
      La domanda più comune di chi pianifica un viaggio sulla Costiera Amalfitana è: quando andare? La risposta onesta è che non esiste il momento perfetto in senso assoluto — dipende da cosa stai cercando. In luglio e agosto il mare è magnifico ma la costiera è sovraffollata; in primavera e autunno il paesaggio è stupendo e la folla minima, ma qualche servizio è ridotto. Questa guida mese per mese ti aiuterà a scegliere il periodo giusto per te.
    </p>
  </section>

  <!-- Raccomandazione top -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-green-50 border border-green-200 rounded-[2rem] p-6 text-center">
        <div class="text-3xl mb-2">⭐</div>
        <h3 class="font-bold text-green-800 mb-1">Periodo migliore</h3>
        <p class="text-green-700 font-semibold text-lg">Maggio · Settembre</p>
        <p class="text-green-600 text-sm mt-2">Temperatura ideale, mare balneabile, folla gestibile</p>
      </div>
      <div class="bg-yellow-50 border border-yellow-200 rounded-[2rem] p-6 text-center">
        <div class="text-3xl mb-2">✅</div>
        <h3 class="font-bold text-yellow-800 mb-1">Buona alternativa</h3>
        <p class="text-yellow-700 font-semibold text-lg">Aprile · Ottobre</p>
        <p class="text-yellow-600 text-sm mt-2">Meno caldo, prezzi più bassi, paesaggi bellissimi</p>
      </div>
      <div class="bg-red-50 border border-red-200 rounded-[2rem] p-6 text-center">
        <div class="text-3xl mb-2">⚠️</div>
        <h3 class="font-bold text-red-800 mb-1">Da evitare (se possibile)</h3>
        <p class="text-red-700 font-semibold text-lg">Luglio · Agosto</p>
        <p class="text-red-600 text-sm mt-2">Sovraffollato, costoso, traffico intenso</p>
      </div>
    </div>
  </section>

  <!-- Tabella mesi -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-serif text-slate-900 mb-8">Guida mese per mese</h2>
      <div class="space-y-4">
        {months.map(month => (
          <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h3 class="font-bold text-slate-900 text-lg w-24">{month.name}</h3>
              <span class="text-sm text-slate-500 flex items-center gap-1">🌡️ {month.weather}</span>
              <span class="text-sm text-slate-500 flex items-center gap-1">🌊 Mare: {month.sea}</span>
              <span class={`text-xs font-semibold px-3 py-1 rounded-full ${crowdColor[month.crowds]}`}>
                Folla: {month.crowds}
              </span>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">{month.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Eventi -->
  <section class="bg-med-blue py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-serif text-slate-900 mb-8">Eventi da non perdere</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-2xl mb-3">🎵</div>
          <h3 class="font-bold text-slate-900 mb-1">Ravello Festival</h3>
          <p class="text-med-blue text-sm font-medium mb-2">Luglio – Settembre</p>
          <p class="text-slate-600 text-sm">Concerti di musica classica nella terrazza affacciata sul mare di Villa Rufolo. Uno degli eventi culturali più emozionanti d'Italia. Prenota i biglietti con anticipo.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-2xl mb-3">⛵</div>
          <h3 class="font-bold text-slate-900 mb-1">Regata Storica delle Antiche Repubbliche Marinare</h3>
          <p class="text-med-blue text-sm font-medium mb-2">Giugno (ogni 4 anni ad Amalfi)</p>
          <p class="text-slate-600 text-sm">La regata che vede gareggiare Amalfi, Venezia, Genova e Pisa. Quando tocca ad Amalfi, la città si veste di costumi medievali.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-2xl mb-3">🕯️</div>
          <h3 class="font-bold text-slate-900 mb-1">Luminara di Sant'Andrea</h3>
          <p class="text-med-blue text-sm font-medium mb-2">27 Giugno e 30 Novembre</p>
          <p class="text-slate-600 text-sm">La festa del patrono di Amalfi illumina il Duomo e la piazza con migliaia di candele. Uno spettacolo notturno straordinario e molto sentito dalla comunità locale.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-2xl mb-3">🍋</div>
          <h3 class="font-bold text-slate-900 mb-1">Sagra del Limone</h3>
          <p class="text-med-blue text-sm font-medium mb-2">Agosto (vari borghi)</p>
          <p class="text-slate-600 text-sm">Degustazioni di limoncello, dolci al limone, mercati artigiani. Il limone sfusato amalfitano è un prodotto IGP: cogli l'occasione per portarne a casa.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Hai scelto quando venire?</h2>
      <p class="text-slate-600 mb-6">Scopri come organizzare al meglio i tuoi giorni sulla costiera.</p>
      <a href={getLocalePath(lang, 'itineraries')}
        class="inline-block bg-med-blue text-white font-semibold px-8 py-3 rounded-full hover:bg-med-blue transition-colors">
        Vedi gli itinerari
      </a>
    </div>
  </section>
</BaseLayout>
