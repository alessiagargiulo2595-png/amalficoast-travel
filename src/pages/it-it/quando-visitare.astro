---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocalePath } from '../../i18n/translations';

const lang = 'it-it';
const t = getTranslations(lang);

const months = [
  { name: 'Gennaio', weather: '8–14°C', sea: 'Freddo', crowds: 'Deserta', notes: 'La costiera è quasi deserta. Molti alberghi e ristoranti chiusi. Per chi ama il silenzio assoluto e la fotografia senza persone in scena.' },
  { name: 'Febbraio', weather: '9–15°C', sea: 'Freddo', crowds: 'Deserta', notes: 'Simile a gennaio. Qualche apertura per il Carnevale. Mimose in fiore sulle colline.' },
  { name: 'Marzo', weather: '11–17°C', sea: 'Fresco', crowds: 'Bassa', notes: 'La costiera si risveglia. Limoni e agrumi in maturazione. Qualche turista ma ancora tranquillo. Ottimo per trekking.' },
  { name: 'Aprile', weather: '13–20°C', sea: 'Fresco', crowds: 'Media', notes: 'Periodo ideale: temperatura piacevole, paesaggi verdissimi, relativamente pochi turisti. I traghetti riprendono. Pasqua porta qualche folla.' },
  { name: 'Maggio', weather: '16–24°C', sea: 'Temperato', crowds: 'Media-alta', notes: "Uno dei mesi migliori dell'anno. Tutto aperto, mare già balneabile per i più audaci, fiori ovunque. Prenotare alloggio in anticipo." },
  { name: 'Giugno', weather: '20–28°C', sea: 'Caldo', crowds: 'Alta', notes: 'Prima settimana ancora gestibile, poi inizia l\'alta stagione. Mare splendido, serate lunghe e luminose. Prezzi alti.' },
  { name: 'Luglio', weather: '23–32°C', sea: 'Caldo', crowds: 'Altissima', notes: 'Mese più affollato. Traffico intenso sulla SS163, spiagge piene, prezzi massimi. Da evitare per chi non ama le folle, altrimenti il mare è magnifico.' },
  { name: 'Agosto', weather: '23–32°C', sea: 'Caldo', crowds: 'Altissima', notes: 'Come luglio, anche peggio. Ferragosto porta l\'esodo estivo italiano. Se vieni, prenota tutto con mesi d\'anticipo. Magia serale però ineguagliabile.' },
  { name: 'Settembre', weather: '20–27°C', sea: 'Caldo', crowds: 'Media-alta', notes: 'Settembre è il mese segreto dei conoscitori: mare ancora caldo, folla in calo dalla seconda metà, prezzi che scendono. Probabilmente il mese migliore in assoluto.' },
  { name: 'Ottobre', weather: '16–22°C', sea: 'Temperato', crowds: 'Bassa', notes: 'La costiera ritorna a se stessa. I locali riaprono per il fine settimana. Colori autunnali sulle colline, limoni maturi. Eccellente per trekking e fotografia.' },
  { name: 'Novembre', weather: '12–17°C', sea: 'Fresco', crowds: 'Deserta', notes: "Molte strutture chiudono. Possibili piogge. Per chi vuole silenzio assoluto, prezzi minimi e un'Italia autentica." },
  { name: 'Dicembre', weather: '9–14°C', sea: 'Freddo', crowds: 'Molto bassa', notes: 'Qualche apertura per le feste di Natale. Presepi viventi a Praiano e nelle grotte. Atmosfera unica ma servizi limitati.' },
];

const crowdColor: Record<string, string> = {
  'Deserta':    'bg-med-gold/10 text-med-gold',
  'Bassa':      'bg-med-gold/10 text-med-gold',
  'Molto bassa':'bg-med-gold/10 text-med-gold',
  'Media':      'bg-med-blue/10 text-med-blue',
  'Media-alta': 'bg-med-blue/15 text-med-blue',
  'Alta':       'bg-slate-200 text-slate-700',
  'Altissima':  'bg-slate-800 text-white',
};
---

<BaseLayout
  title={t.meta.when_to_visit_title}
  description={t.meta.when_to_visit_description}
  lang={lang}
  pageKey="when-to-visit"
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img src="/images/quando-visitare-hero.jpg" alt="Villa Cimbrone, Ravello" class="absolute inset-0 w-full h-full object-cover" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 text-center">
      <p class="text-med-gold text-sm uppercase tracking-[0.3em] mb-3 font-medium">Guida stagionale</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Quando visitare la Costiera Amalfitana</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto font-light">Ogni mese ha i suoi pro e i suoi contro. Guida completa mese per mese al clima, alla folla e ai prezzi.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-lg text-slate-600 leading-relaxed">
      La domanda più comune di chi pianifica un viaggio sulla Costiera Amalfitana è: quando andare? La risposta onesta è che non esiste il momento perfetto in senso assoluto — dipende da cosa stai cercando. In luglio e agosto il mare è magnifico ma la costiera è sovraffollata; in primavera e autunno il paesaggio è stupendo e la folla minima, ma qualche servizio è ridotto. Questa guida mese per mese ti aiuterà a scegliere il periodo giusto per te.
    </p>
  </section>

  <!-- Raccomandazione top -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Migliore -->
      <div class="bg-slate-900 border border-white/10 rounded-[3rem] p-8 text-center">
        <div class="w-12 h-12 rounded-2xl bg-med-gold/15 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-2">Periodo migliore</p>
        <p class="font-serif text-2xl font-bold text-white mb-2">Maggio · Settembre</p>
        <p class="text-white/50 text-sm">Temperatura ideale, mare balneabile, folla gestibile</p>
      </div>

      <!-- Buona alternativa -->
      <div class="bg-white border border-slate-100 rounded-[3rem] p-8 text-center shadow-sm">
        <div class="w-12 h-12 rounded-2xl bg-med-blue/10 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-med-blue" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-med-blue font-medium mb-2">Buona alternativa</p>
        <p class="font-serif text-2xl font-bold text-slate-900 mb-2">Aprile · Ottobre</p>
        <p class="text-slate-500 text-sm">Meno caldo, prezzi più bassi, paesaggi bellissimi</p>
      </div>

      <!-- Da evitare -->
      <div class="bg-white border border-slate-100 rounded-[3rem] p-8 text-center shadow-sm">
        <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
          <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
          </svg>
        </div>
        <p class="text-[10px] uppercase tracking-[0.3em] text-slate-500 font-medium mb-2">Da evitare (se possibile)</p>
        <p class="font-serif text-2xl font-bold text-slate-900 mb-2">Luglio · Agosto</p>
        <p class="text-slate-500 text-sm">Sovraffollato, costoso, traffico intenso</p>
      </div>

    </div>
  </section>

  <!-- Tabella mesi -->
  <section class="pb-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-serif text-slate-900 mb-8">Guida mese per mese</h2>
      <div class="space-y-4">
        {months.map(month => (
          <div class="bg-white rounded-[3rem] shadow-sm border border-slate-100 p-6 sm:p-8">
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <h3 class="font-bold text-slate-900 text-lg w-24">{month.name}</h3>
              <span class="text-sm text-slate-500 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z"/></svg>
                {month.weather}
              </span>
              <span class="text-sm text-slate-500 flex items-center gap-1.5">
                <svg class="w-4 h-4 text-med-blue flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3.744 12 2.25l5.25 1.494m-10.5 0 5.25 1.494M6.75 3.744 2.25 9l4.5 5.256 5.25-1.494M17.25 3.744 21.75 9l-4.5 5.256-5.25-1.494M12 15.75 6.75 14.25m5.25 1.5 5.25-1.5"/></svg>
                Mare: {month.sea}
              </span>
              <span class={`text-xs font-semibold px-3 py-1 rounded-full ${crowdColor[month.crowds]}`}>
                Folla: {month.crowds}
              </span>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">{month.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Eventi -->
  <section class="bg-slate-900 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-3">Calendario</p>
      <h2 class="text-2xl font-bold font-serif text-white mb-10">Eventi da non perdere</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Ravello Festival</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Luglio – Settembre</p>
          <p class="text-white/60 text-sm leading-relaxed">Concerti di musica classica nella terrazza affacciata sul mare di Villa Rufolo. Uno degli eventi culturali più emozionanti d'Italia. Prenota i biglietti con anticipo.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Regata delle Antiche Repubbliche Marinare</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Giugno (ogni 4 anni ad Amalfi)</p>
          <p class="text-white/60 text-sm leading-relaxed">La regata che vede gareggiare Amalfi, Venezia, Genova e Pisa. Quando tocca ad Amalfi, la città si veste di costumi medievali.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Luminara di Sant'Andrea</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">27 Giugno e 30 Novembre</p>
          <p class="text-white/60 text-sm leading-relaxed">La festa del patrono di Amalfi illumina il Duomo e la piazza con migliaia di candele. Uno spettacolo notturno straordinario e molto sentito dalla comunità locale.</p>
        </div>

        <div class="bg-white/5 border border-white/10 rounded-[3rem] p-8">
          <div class="w-10 h-10 rounded-xl bg-med-gold/15 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
          </div>
          <h3 class="font-serif font-bold text-white text-lg mb-1">Sagra del Limone</h3>
          <p class="text-med-gold text-xs font-medium uppercase tracking-widest mb-3">Agosto (vari borghi)</p>
          <p class="text-white/60 text-sm leading-relaxed">Degustazioni di limoncello, dolci al limone, mercati artigiani. Il limone sfusato amalfitano è un prodotto IGP: cogli l'occasione per portarne a casa.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Hai scelto quando venire?</h2>
      <p class="text-slate-600 mb-6">Scopri come organizzare al meglio i tuoi giorni sulla costiera.</p>
      <a href={getLocalePath(lang, 'itineraries')}
        class="inline-block bg-med-blue text-white font-semibold px-8 py-3 rounded-full hover:shadow-lg transition-shadow">
        Vedi gli itinerari
      </a>
    </div>
  </section>

</BaseLayout>
