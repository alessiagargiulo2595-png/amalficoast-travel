---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import LocalitySlider from '../../../../../components/LocalitySlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Costiera Amalfitana', url: '/it-it/costiera-amalfitana/' },
  { name: 'Ravello Festival', url: '/it-it/eventi/costiera-amalfitana/ravello-festival/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Ravello Festival 2026",
  "startDate": "2026-07-04",
  "endDate": "2026-09-05",
  "location": {
    "@type": "Place",
    "name": "Villa Rufolo, Ravello",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Ravello",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/it-it/eventi/costiera-amalfitana/ravello-festival/"
};

const facts = [
  { dt: 'Periodo', dd: '4 Luglio – 5 Settembre 2026' },
  { dt: 'Sede', dd: 'Belvedere di Villa Rufolo' },
  { dt: 'Genere', dd: 'Sinfonica · Jazz · Danza' },
  { dt: 'Biglietti', dd: 'Prenotazione obbligatoria' },
  { dt: 'Accesso', dd: 'Bus SITA da Amalfi' },
];
---

<BaseLayout
  title="Ravello Festival 2026: Programma e Biglietti Villa Rufolo"
  description="Guida completa al Ravello Festival 2026. Programma, biglietti, come arrivare a Villa Rufolo con i trasporti pubblici dalla Costiera Amalfitana."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ravello-hero.jpg"
      alt="Ravello Festival, Villa Rufolo"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">4 Luglio – 5 Settembre 2026</span>
        <span class="text-white/70 text-sm">Ravello, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Ravello Festival</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        La magia della musica sospesa tra cielo e mare.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Informazioni sull'Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Il Ravello Festival giunge alla sua 74esima edizione confermandosi come l'appuntamento culturale più prestigioso della regione. Il palco sospeso di Villa Rufolo ospita orchestre internazionali in una cornice architettonica unica.</p>
            <p>Per la stagione 2026, si raccomanda la prenotazione anticipata dei biglietti tramite i canali ufficiali, data la capienza limitata della struttura.</p>
          </div>
        </div>

        <!-- Programma in Evidenza -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Programma in Evidenza</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Concerto all'Alba</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">L'evento più iconico</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Un'esperienza unica che inizia alle 4:45 del mattino. La musica accompagna il sorgere del sole sulle montagne della costa.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Wagnerian Days</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Omaggio al Maestro</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Una settimana interamente dedicata alle opere di Wagner nei luoghi che hanno ispirato il Klingsor's Garden.</p>
            </div>
          </div>
        </div>

        <!-- Logistica -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Come arrivare</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Mezzo</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servizio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Note</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Linea Amalfi–Ravello</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Ultima corsa serale ore 22:00</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Navetta privata</td>
                  <td class="px-6 py-4 text-slate-600">Hotel della costa</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Disponibile per concerti serali</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Dettagli Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Si consiglia di arrivare con largo anticipo. Verificare il programma aggiornato sui canali ufficiali.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <LocalitySlider
    heading="Località Vicine al Festival"
    items={[
      { name: 'Ravello',  href: '/it-it/costiera-amalfitana/ravello/',   image: '/images/ravello-hero.jpg',   tag: 'Sede evento' },
      { name: 'Amalfi',   href: '/it-it/costiera-amalfitana/amalfi/',    image: '/images/amalfi-hero.jpg',    tag: 'Costiera' },
      { name: 'Positano', href: '/it-it/costiera-amalfitana/positano/',  image: '/images/positano-hero.jpg',  tag: 'Iconica' },
      { name: 'Praiano',  href: '/it-it/costiera-amalfitana/praiano/',   image: '/images/praiano-hero.jpg',   tag: 'Autentica' },
    ]}
  />

</BaseLayout>
