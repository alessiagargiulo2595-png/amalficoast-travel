---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import LocalitySlider from '../../../../../components/LocalitySlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Eventi', url: '/it-it/eventi/' },
  { name: 'Regata delle Repubbliche Marinare', url: '/it-it/eventi/costiera-amalfitana/regata-storica-amalfi/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Regata delle Antiche Repubbliche Marinare 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-06-30",
  "location": {
    "@type": "Place",
    "name": "Porto di Amalfi",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Amalfi",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/it-it/eventi/costiera-amalfitana/regata-storica-amalfi/"
};

const facts = [
  { dt: 'Periodo', dd: 'Giugno 2026' },
  { dt: 'Sede', dd: 'Porto di Amalfi' },
  { dt: 'Tipo', dd: 'Regata storica & corteo' },
  { dt: 'Costumi', dd: 'Medievali, spettacolari' },
  { dt: 'Accesso', dd: 'Ferry da Napoli 1h30' },
];
---

<BaseLayout
  title="Regata delle Antiche Repubbliche Marinare Amalfi 2026 – Corteo Storico e Gara Remiera"
  description="La Regata delle Antiche Repubbliche Marinare 2026 ad Amalfi. Cortei storici in costume medievale e la sfida remiera tra Amalfi, Venezia, Genova e Pisa nel porto della città."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/amalfi-hero.jpg"
      alt="Regata delle Antiche Repubbliche Marinare, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">Giugno 2026</span>
        <span class="text-white/70 text-sm">Amalfi, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Regata delle Repubbliche Marinare</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Amalfi, Venezia, Genova e Pisa sfidate sul mare con cortei in costume medievale.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Informazioni sull'Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>La Regata delle Antiche Repubbliche Marinare è uno degli spettacoli storici più suggestivi d'Italia. Quattro città che furono potenze marinare nel Medioevo — Amalfi, Venezia, Genova e Pisa — si sfidano in una gara remiera a bordo di galee storiche, preceduta da un corteo in costume con oltre trecento figuranti.</p>
            <p>Quando la regata si svolge ad Amalfi, il porto si trasforma in un palcoscenico medievale straordinario: le case colorate sulla scogliera, la cattedrale sullo sfondo e le galee dalle vele colorate offrono uno spettacolo irripetibile. I costumi, le armature e le bandiere delle quattro repubbliche riportano la città al suo glorioso passato marittimo.</p>
          </div>
        </div>

        <!-- Il Programma -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Il Programma</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Il Corteo Storico</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Trecento figuranti in costume</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Il corteo storico percorre le vie del centro storico di Amalfi con oltre trecento figuranti in costume medievale che rappresentano le quattro repubbliche, i loro dogi, capitani e marinai.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">La Gara Remiera</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Le galee sul mare</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Quattro equipaggi di otto rematori si sfidano su galee storiche nel porto di Amalfi. La città vincitrice conserva il trofeo fino all'edizione successiva in un'altra delle quattro città.</p>
            </div>
          </div>
        </div>

        <!-- Come arrivare -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Come arrivare</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Mezzo</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servizio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Note</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Da Napoli</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">1h30, arrivo diretto al porto di Amalfi</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">Da Sorrento o Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">SS163, fermata Amalfi centro</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Dettagli Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Si consiglia di arrivare con largo anticipo. Verificare il programma aggiornato sui canali ufficiali.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <LocalitySlider
    heading="Località della Costiera Amalfitana"
    items={[
      { name: 'Amalfi',   href: '/it-it/costiera-amalfitana/amalfi/',   image: '/images/amalfi-hero.jpg',   tag: 'Sede evento' },
      { name: 'Ravello',  href: '/it-it/costiera-amalfitana/ravello/',   image: '/images/ravello-hero.jpg',   tag: 'Cultura' },
      { name: 'Positano', href: '/it-it/costiera-amalfitana/positano/', image: '/images/positano-hero.jpg',  tag: 'Iconica' },
      { name: 'Praiano',  href: '/it-it/costiera-amalfitana/praiano/',  image: '/images/praiano-hero.jpg',   tag: 'Autentica' },
    ]}
  />

</BaseLayout>
