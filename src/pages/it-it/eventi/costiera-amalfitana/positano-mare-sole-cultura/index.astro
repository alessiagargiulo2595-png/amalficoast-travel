---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import LocalitySlider from '../../../../../components/LocalitySlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Eventi', url: '/it-it/eventi/' },
  { name: 'Positano Arte & Cultura', url: '/it-it/eventi/costiera-amalfitana/positano-mare-sole-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Positano Mare Sole Cultura 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-31",
  "location": {
    "@type": "Place",
    "name": "Positano",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Positano",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/it-it/eventi/costiera-amalfitana/positano-mare-sole-cultura/"
};

const facts = [
  { dt: 'Periodo', dd: 'Agosto 2026' },
  { dt: 'Sede', dd: 'Positano' },
  { dt: 'Tipo', dd: 'Arte, musica e letteratura' },
  { dt: 'Accesso', dd: 'Bus SITA o ferry' },
  { dt: 'Ingresso', dd: 'Varia per evento' },
];
---

<BaseLayout
  title="Positano Mare Sole Cultura 2026 – Arte, Musica e Letteratura sulla Costiera"
  description="Positano Mare Sole Cultura ad agosto 2026. Rassegna estiva di arte, musica e letteratura con eventi nelle terrazze panoramiche e negli spazi culturali di Positano."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/positano-hero.jpg"
      alt="Positano Mare Sole Cultura"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">Agosto 2026</span>
        <span class="text-white/70 text-sm">Positano, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Positano Arte & Cultura</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Arte, musica e letteratura sulla spiaggia più famosa della Costiera.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Informazioni sull'Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Positano Mare Sole Cultura è la rassegna estiva che trasforma Positano in un palcoscenico d'eccezione per tutta la durata di agosto. Le terrazze con vista sul mare, la spiaggia Grande e i giardini dei grandi hotel diventano sede di concerti, presentazioni letterarie, mostre d'arte e performance di danza.</p>
            <p>La rassegna nasce dalla vocazione storica di Positano come luogo di incontro tra artisti e intellettuali internazionali — da Picasso a Steinbeck, da Rudolf Nureyev ai registi neorealisti italiani che vi ambientarono i loro film. Un programma ricco che accompagna le serate estive della città verticale.</p>
          </div>
        </div>

        <!-- Il Programma -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Il Programma Culturale</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Musica e danza</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Concerti con vista mare</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Concerti di musica classica, jazz e contemporanea nelle terrazze panoramiche di Positano. Spettacoli di danza nei giardini dei grandi hotel che si specchiano sul mare.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Letteratura e arte</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Presentazioni e mostre</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Presentazioni di libri, mostre di pittura e fotografia negli spazi culturali della città. Incontri con autori italiani e internazionali legati alla tradizione artistica di Positano.</p>
            </div>
          </div>
        </div>

        <!-- Come arrivare -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Come arrivare</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Mezzo</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servizio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Note</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Da Napoli o Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Arrivo diretto al porto di Positano</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">SS163 Amalfitana</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Fermata Positano, poi discesa a piedi</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Dettagli Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Si consiglia di arrivare con largo anticipo. Verificare il programma aggiornato sui canali ufficiali.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <LocalitySlider
    heading="Scopri Positano"
    items={[
      { name: 'Positano', href: '/it-it/costiera-amalfitana/positano/', image: '/images/positano-hero.jpg',  tag: 'Sede evento' },
      { name: 'Praiano',  href: '/it-it/costiera-amalfitana/praiano/',  image: '/images/praiano-hero.jpg',   tag: 'Autentica' },
      { name: 'Amalfi',   href: '/it-it/costiera-amalfitana/amalfi/',   image: '/images/amalfi-hero.jpg',    tag: 'Storica' },
      { name: 'Ravello',  href: '/it-it/costiera-amalfitana/ravello/',  image: '/images/ravello-hero.jpg',   tag: 'Cultura' },
    ]}
  />

</BaseLayout>
