---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import LocalitySlider from '../../../../../components/LocalitySlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Eventi', url: '/it-it/eventi/' },
  { name: 'Festival del Limone – Minori', url: '/it-it/eventi/costiera-amalfitana/festival-limone-minori/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Festival del Limone Minori 2026",
  "startDate": "2026-08-01",
  "endDate": "2026-08-31",
  "location": {
    "@type": "Place",
    "name": "Centro storico, Minori",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Minori",
      "addressRegion": "SA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/it-it/eventi/costiera-amalfitana/festival-limone-minori/"
};

const facts = [
  { dt: 'Periodo', dd: 'Agosto 2026' },
  { dt: 'Sede', dd: 'Centro storico, Minori' },
  { dt: 'Prodotto', dd: 'Limone IGP Costa d\'Amalfi' },
  { dt: 'Specialità', dd: 'Delizia al limone DOC' },
  { dt: 'Accesso', dd: 'Bus SITA o ferry' },
];
---

<BaseLayout
  title="Festival del Limone Minori 2026 – Il Limone IGP della Costa d'Amalfi"
  description="Il Festival del Limone a Minori ad agosto 2026. Degustazioni, laboratori e mercati dedicati al limone IGP della Costa d'Amalfi nel borgo medievale di Minori."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/costiera-hero.jpg"
      alt="Festival del Limone, Minori"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">Agosto 2026</span>
        <span class="text-white/70 text-sm">Minori, SA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Festival del Limone</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Il limone IGP della Costa d'Amalfi protagonista nel borgo medievale di Minori.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Informazioni sull'Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Il Festival del Limone di Minori celebra il prodotto che più di ogni altro identifica la Costiera Amalfitana: il limone sfusato IGP, coltivato nei terrazzamenti a picco sul mare con una tecnica tramandatasi per secoli. Minori, borgo medievale con la spiaggia più raccolta della costa, è la sede ideale per questa festa del gusto.</p>
            <p>Il festival propone degustazioni guidate di prodotti al limone — dalla delizia al limone (il dolce simbolo di Minori), al limoncello artigianale, alla pasta fresca con salsa di limone — laboratori con i produttori locali e un mercato dei limoneti terrazzati dove acquistare direttamente dagli agricoltori.</p>
          </div>
        </div>

        <!-- Specialità -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Le Specialità del Festival</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Dolcezze al limone</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">La Delizia al Limone</h4>
              <p class="text-slate-600 text-sm leading-relaxed">La delizia al limone è il dolce che ha reso famosa Minori in tutta Italia: una cupola di pan di Spagna farcita e ricoperta di crema al limone, nata nelle pasticcerie del borgo negli anni '70.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Il Limone Sfusato</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">L'oro della Costiera</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Il limone sfusato amalfitano IGP si distingue per la buccia spessa e profumatissima, ideale per il limoncello artigianale. I limoneti terrazzati sono un paesaggio culturale UNESCO in via di candidatura.</p>
            </div>
          </div>
        </div>

        <!-- Come arrivare -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Come arrivare</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Mezzo</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servizio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Note</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Ferry</td>
                  <td class="px-6 py-4 text-slate-600">Da Napoli o Amalfi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Servizio stagionale, molo di Minori</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus SITA</td>
                  <td class="px-6 py-4 text-slate-600">SS163 da Amalfi o Salerno</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Fermata Minori centro, 10 min da Amalfi</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Dettagli Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Si consiglia di arrivare con largo anticipo. Verificare il programma aggiornato sui canali ufficiali.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <LocalitySlider
    heading="Borghi Vicini a Minori"
    items={[
      { name: 'Minori',   href: '/it-it/costiera-amalfitana/minori/',   image: '/images/costiera-hero.jpg',  tag: 'Sede evento' },
      { name: 'Maiori',   href: '/it-it/costiera-amalfitana/maiori/',   image: '/images/costiera-hero.jpg',  tag: 'Costiera' },
      { name: 'Amalfi',   href: '/it-it/costiera-amalfitana/amalfi/',   image: '/images/amalfi-hero.jpg',    tag: 'Storica' },
      { name: 'Ravello',  href: '/it-it/costiera-amalfitana/ravello/',  image: '/images/ravello-hero.jpg',   tag: 'Cultura' },
    ]}
  />

</BaseLayout>
