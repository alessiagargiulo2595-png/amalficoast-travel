---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { events } from '../../../data/events-it';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Eventi', url: '/it-it/eventi/' },
];

const costieraEvents = events.filter(e => e.area === 'costiera-amalfitana');
const isoleEvents = events.filter(e => e.area === 'isole');
const penisolaEvents = events.filter(e => e.area === 'penisola-sorrentina');

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Eventi 2026 – Costiera Amalfitana e Penisola Sorrentina",
  "description": "I migliori festival ed eventi del 2026 sulla Costiera Amalfitana e sulla Penisola Sorrentina: Ravello Festival, fuochi di Ferragosto, sagre del pesce e celebrazioni gastronomiche.",
  "url": "https://amalficoast-travel.com/it-it/eventi/",
  "numberOfItems": events.length,
  "itemListElement": events.map((ev, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": ev.title,
    "url": `https://amalficoast-travel.com${ev.path}`,
  })),
};
---

<BaseLayout
  title="Eventi 2026 Costiera Amalfitana | Ravello Festival, Fuochi & Sagre Locali"
  description="I migliori eventi del 2026 sulla Costiera Amalfitana e sulla Penisola Sorrentina: Ravello Festival, fuochi di Ferragosto, la Sagra del Pesce a Positano e celebrazioni locali autentiche."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaItemList]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] flex items-end bg-charcoal overflow-hidden">
    <img
      src="/images/ravello-hero.jpg"
      alt="Eventi sulla Costiera Amalfitana 2026"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/40 to-black/80"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 pt-32">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Eventi 2026</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Calendario 2026</p>
        <h1 class="font-serif text-display text-white mb-4">Eventi</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Dal Ravello Festival ai fuochi di Ferragosto sul mare. Il calendario 2026 della Costiera Amalfitana e della Penisola Sorrentina.
        </p>
      </div>
    </div>
  </section>

  <!-- Costiera Amalfitana -->
  <section class="bg-med-cream py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Costiera Amalfitana</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Eventi sulla Costiera Amalfitana</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {costieraEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Isole -->
  <section class="bg-white py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Isole del Golfo</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Eventi sulle Isole</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {isoleEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Penisola Sorrentina -->
  <section class="bg-med-cream py-20 px-6 border-t border-slate-100">
    <div class="max-w-7xl mx-auto">
      <div class="mb-12">
        <p class="text-med-gold text-xs font-bold uppercase tracking-[0.3em] mb-2">Penisola Sorrentina</p>
        <h2 class="font-serif text-3xl font-bold text-slate-900">Eventi sulla Penisola Sorrentina</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {penisolaEvents.map((ev) => (
          <a href={ev.path} class="group block">
            <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden mb-4 shadow-xl">
              <img
                src={ev.image}
                alt={ev.title}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                referrerpolicy="no-referrer"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
              <div class="absolute inset-0 p-6 flex flex-col justify-end">
                <span class="text-med-gold text-[10px] font-bold uppercase tracking-[0.3em] mb-1">{ev.category}</span>
                <h3 class="font-serif text-xl font-bold text-white mb-1 leading-tight">{ev.title}</h3>
                <p class="text-white/70 text-xs">{ev.date} · {ev.location}</p>
              </div>
            </div>
            <p class="text-slate-500 text-sm leading-relaxed px-1">{ev.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
