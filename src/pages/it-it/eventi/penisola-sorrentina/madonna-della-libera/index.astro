---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Penisola Sorrentina', url: '/it-it/penisola-sorrentina/' },
  { name: 'Madonna della Libera Sant\'Agnello', url: '/it-it/eventi/penisola-sorrentina/madonna-della-libera/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Festa della Madonna della Libera Sant'Agnello 2026",
  "startDate": "2026-09-13",
  "endDate": "2026-09-13",
  "location": {
    "@type": "Place",
    "name": "Sant'Agnello, Penisola Sorrentina",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sant'Agnello",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/it-it/eventi/penisola-sorrentina/madonna-della-libera/"
};

const facts = [
  { dt: 'Data', dd: '13 Settembre 2026' },
  { dt: 'Localita', dd: 'Sant\'Agnello' },
  { dt: 'Tipologia', dd: 'Festa rionale' },
  { dt: 'Atmosfera', dd: 'Tradizionale e autentica' },
  { dt: 'Da Sorrento', dd: '5 min in bus' },
];
---

<BaseLayout
  title="Madonna della Libera Sant'Agnello 2026: Festa Rionale"
  description="La Festa della Madonna della Libera a Sant'Agnello il 13 settembre 2026. Luminarie tradizionali e celebrazione rionale con prodotti della terra."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Festa della Madonna della Libera, Sant'Agnello"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">13 Settembre 2026</span>
        <span class="text-white/70 text-sm">Sant'Agnello, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Madonna della Libera</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        La tradizione autentica di una festa rionale nel cuore della Penisola Sorrentina.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Informazioni sull'Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Festa rionale che conserva il sapore delle celebrazioni di una volta, con luminarie tradizionali e prodotti della terra. Un'occasione per vivere la Penisola Sorrentina lontano dai flussi turistici estivi.</p>
            <p>Sant'Agnello, a pochi minuti da Sorrento, mantiene una propria identita comunitaria ben distinta. La festa della Madonna della Libera e uno di quegli appuntamenti che i residenti difendono con orgoglio come patrimonio del proprio rione.</p>
          </div>
        </div>

        <!-- La Tradizione -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">La Celebrazione Tradizionale</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Luminarie</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">L'illuminazione tradizionale</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Le luminarie colorate allestite dai comitati locali illuminano le strade del rione secondo la tradizione secolare delle feste patronali campane, con arcate di lampadine colorate.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Prodotti locali</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">I sapori del territorio</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Stand gastronomici con prodotti tipici della Penisola Sorrentina: limoni, noci, olio d'oliva e dolci tradizionali preparati dalle famiglie del rione per l'occasione.</p>
            </div>
          </div>
        </div>

        <!-- Logistica -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Come arrivare</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Mezzo</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servizio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Note</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus locale</td>
                  <td class="px-6 py-4 text-slate-600">Da Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minuti, fermata Sant'Agnello centro</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">A piedi</td>
                  <td class="px-6 py-4 text-slate-600">Da Sorrento centro</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">20 minuti lungo la via principale</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Da Napoli</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Fermata Sorrento, poi bus locale</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Dettagli Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Si consiglia di arrivare con largo anticipo. Verificare il programma aggiornato sui canali ufficiali.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
