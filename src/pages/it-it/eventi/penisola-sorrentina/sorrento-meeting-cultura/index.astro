---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Penisola Sorrentina', url: '/it-it/penisola-sorrentina/' },
  { name: 'Sorrento Meeting', url: '/it-it/eventi/penisola-sorrentina/sorrento-meeting-cultura/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Sorrento Meeting 2026",
  "startDate": "2026-06-01",
  "endDate": "2026-07-31",
  "location": {
    "@type": "Place",
    "name": "Chiostro di San Francesco, Sorrento",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sorrento",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/it-it/eventi/penisola-sorrentina/sorrento-meeting-cultura/"
};

const facts = [
  { dt: 'Periodo', dd: 'Giugno–Luglio 2026' },
  { dt: 'Location', dd: 'Chiostro di San Francesco' },
  { dt: 'Tipologia', dd: 'Rassegna letteraria' },
  { dt: 'Accesso', dd: 'Prenotazione consigliata' },
  { dt: 'Da Napoli', dd: 'Circumvesuviana 70 min' },
];
---

<BaseLayout
  title="Sorrento Meeting 2026: Rassegna Letteraria al Chiostro di San Francesco"
  description="Il Sorrento Meeting da giugno a luglio 2026. Appuntamenti serali con autori internazionali nel Chiostro di San Francesco."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Sorrento Meeting, Chiostro di San Francesco"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">Giugno–Luglio 2026</span>
        <span class="text-white/70 text-sm">Sorrento, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Sorrento Meeting</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Letteratura e giornalismo internazionale nel chiostro gotico-arabo del XIV secolo.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Informazioni sull'Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Rassegna letteraria e giornalistica nel Chiostro di San Francesco. Appuntamenti serali con autori di rilievo internazionale. Il chiostro gotico-arabo del XIV secolo offre una cornice unica agli incontri culturali di questa rassegna estiva.</p>
            <p>Gli incontri si svolgono tipicamente al tramonto, sfruttando la magia della luce serale nel chiostro. I partecipanti possono poi proseguire la serata nei ristoranti e nelle terrazze panoramiche del centro di Sorrento.</p>
          </div>
        </div>

        <!-- Gli Incontri -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">La Rassegna Culturale</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Incontri con gli autori</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Letteratura internazionale</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Scrittori, giornalisti e intellettuali di fama internazionale si alternano nel chiostro per presentare le proprie opere e dialogare con il pubblico in un formato aperto e informale.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Il Chiostro</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Una cornice unica</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Il Chiostro di San Francesco, con le sue arcate gotiche e arabeggianti del XIV secolo, e uno dei luoghi piu suggestivi di Sorrento e attivo centro culturale durante tutta l'estate.</p>
            </div>
          </div>
        </div>

        <!-- Logistica -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Come arrivare</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Mezzo</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servizio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Note</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Da Napoli Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">70 minuti, fermata Sorrento</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Traghetto</td>
                  <td class="px-6 py-4 text-slate-600">Dalla costiera o da Napoli</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Porto di Sorrento, collegamento con le isole</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">A piedi</td>
                  <td class="px-6 py-4 text-slate-600">Dal centro di Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 minuti da Piazza Tasso</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Dettagli Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Si consiglia di arrivare con largo anticipo. Verificare il programma aggiornato sui canali ufficiali.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
