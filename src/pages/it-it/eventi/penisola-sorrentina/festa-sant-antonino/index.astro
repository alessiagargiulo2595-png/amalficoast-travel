---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import LocalitySlider from '../../../../../components/LocalitySlider.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Eventi', url: '/it-it/eventi/' },
  { name: "Festa di Sant'Antonino – Sorrento", url: '/it-it/eventi/penisola-sorrentina/festa-sant-antonino/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Festa di Sant'Antonino Sorrento 2026",
  "startDate": "2026-02-14",
  "endDate": "2026-02-14",
  "location": {
    "@type": "Place",
    "name": "Basilica di Sant'Antonino, Sorrento",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Sorrento",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/it-it/eventi/penisola-sorrentina/festa-sant-antonino/"
};

const facts = [
  { dt: 'Data', dd: '14 febbraio 2026' },
  { dt: 'Sede', dd: "Basilica di Sant'Antonino" },
  { dt: 'Tipo', dd: 'Festa patronale' },
  { dt: 'Processione', dd: 'Con il simulacro del santo' },
  { dt: 'Da Napoli', dd: 'Circumvesuviana 70 min' },
];
---

<BaseLayout
  title="Festa di Sant'Antonino Sorrento 2026 – Il Patrono della Città"
  description="La festa patronale di Sant'Antonino a Sorrento il 14 febbraio 2026. Processione del simulacro del santo per le vie del centro storico e tradizionali fuochi d'artificio."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/sorrento-hero.jpg"
      alt="Festa di Sant'Antonino, Sorrento"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">14 feb 2026</span>
        <span class="text-white/70 text-sm">Sorrento, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Festa di Sant'Antonino</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Il patrono di Sorrento festeggiato con processione solenne e fuochi d'artificio.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Informazioni sull'Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Sant'Antonino Abate è il patrono di Sorrento dal VI secolo d.C., quando secondo la tradizione il monaco eremita scacciò un drago marino che terrorizzava la città. La sua festa, il 14 febbraio, è la celebrazione religiosa più sentita dell'anno per i sorrentini — ben più intima e autentica delle grandi manifestazioni estive.</p>
            <p>La processione del simulacro del santo percorre le vie del centro storico in tarda mattinata, con la banda municipale, le autorità civili e religiose e i fedeli che portano ceri votivi. La sera, i fuochi d'artificio illuminano il porto di Sorrento in uno scenario invernale di rara bellezza.</p>
          </div>
        </div>

        <!-- La Festa -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">La Festa Patronale</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">La Processione</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Il simulacro per le vie</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Il prezioso simulacro argenteo di Sant'Antonino viene portato in processione per le vie del centro storico di Sorrento. Una tradizione secolare che unisce tutta la comunità cittadina.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">La Basilica</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Il cuore di Sorrento</h4>
              <p class="text-slate-600 text-sm leading-relaxed">La Basilica di Sant'Antonino, nel cuore del centro storico di Sorrento, custodisce le reliquie del santo. Le sue cripte romaniche ospitano ex voto di marinai salvati dal naufragio.</p>
            </div>
          </div>
        </div>

        <!-- Come arrivare -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Come arrivare</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Mezzo</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servizio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Note</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Circumvesuviana</td>
                  <td class="px-6 py-4 text-slate-600">Da Napoli Garibaldi</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">70 min, fermata Sorrento</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">A piedi</td>
                  <td class="px-6 py-4 text-slate-600">Dal centro di Sorrento</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">5 min dalla Piazza Tasso</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Dettagli Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Si consiglia di arrivare con largo anticipo. Verificare il programma aggiornato sui canali ufficiali.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <LocalitySlider
    heading="Scopri la Penisola Sorrentina"
    items={[
      { name: 'Sorrento',       href: '/it-it/penisola-sorrentina/sorrento/',       image: '/images/sorrento-hero.jpg',         tag: 'Sede evento' },
      { name: "Sant'Agnello",   href: '/it-it/penisola-sorrentina/sant-agnello/',   image: '/images/sorrento-hero.jpg',         tag: 'Vicina' },
      { name: 'Massa Lubrense', href: '/it-it/penisola-sorrentina/massa-lubrense/', image: '/images/massa-lubrense-hero.jpg',   tag: 'Natura' },
      { name: 'Vico Equense',   href: '/it-it/penisola-sorrentina/vico-equense/',   image: '/images/vico-equense-hero.jpg',     tag: 'Gastronomia' },
    ]}
  />

</BaseLayout>
