---
import BaseLayout from '../../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Penisola Sorrentina', url: '/it-it/penisola-sorrentina/' },
  { name: 'Sagra del Limone Massa Lubrense', url: '/it-it/eventi/penisola-sorrentina/sagra-limone-massa-lubrense/' },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  "name": "Sagra del Limone Massa Lubrense 2026",
  "startDate": "2026-07-11",
  "endDate": "2026-07-12",
  "location": {
    "@type": "Place",
    "name": "Centro storico di Massa Lubrense",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Massa Lubrense",
      "addressRegion": "NA",
      "addressCountry": "IT"
    }
  },
  "url": "https://amalficoast-travel.com/it-it/eventi/penisola-sorrentina/sagra-limone-massa-lubrense/"
};

const facts = [
  { dt: 'Date', dd: '11–12 Luglio 2026' },
  { dt: 'Prodotto', dd: 'Limone Femminello IGP' },
  { dt: 'Localita', dd: 'Centro storico Massa Lubrense' },
  { dt: 'Accesso', dd: 'Bus EAV da Sorrento ogni 20 min' },
  { dt: 'Ingresso', dd: 'Libero' },
];
---

<BaseLayout
  title="Sagra del Limone Massa Lubrense 2026: Degustazioni e Mercatini"
  description="La Sagra del Limone a Massa Lubrense l'11 e 12 luglio 2026. Percorsi di degustazione del Limone Femminello tra i portoni storici del borgo."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[eventSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/massa-lubrense-hero.jpg"
      alt="Sagra del Limone, Massa Lubrense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/50 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-5xl text-white">
      <div class="flex flex-wrap justify-center items-center gap-4 mb-6">
        <span class="bg-med-gold text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Evento 2026</span>
        <span class="text-white/70 text-sm">11–12 Luglio 2026</span>
        <span class="text-white/70 text-sm">Massa Lubrense, NA</span>
      </div>
      <h1 class="font-serif text-5xl md:text-7xl font-bold text-white leading-tight mb-6">Sagra del Limone</h1>
      <p class="text-white/85 text-lg md:text-xl font-light max-w-2xl mx-auto leading-relaxed">
        Il Limone Femminello IGP protagonista tra i portoni storici di Massa Lubrense.
      </p>
    </div>
  </section>

  <!-- Content 70/30 -->
  <section class="py-24 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-10 gap-16">

      <!-- Main Content (70%) -->
      <div class="lg:col-span-7 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-8">Informazioni sull'Evento</h2>
          <div class="space-y-4 text-slate-600 text-lg leading-relaxed">
            <p>Evento enogastronomico dedicato alla valorizzazione del limone locale. Prevede percorsi di degustazione tra i portoni storici del borgo e mercatini di artigianato. Collegamento tramite bus EAV da Sorrento Piazza Tasso ogni 20 minuti.</p>
            <p>Il Limone Femminello della Penisola Sorrentina e uno dei simboli dell'agricoltura locale, tutelato da indicazione geografica protetta. La sagra e un'opportunita per conoscere i produttori locali e assaggiare limoncelllo, granite e specialita a base di limone.</p>
          </div>
        </div>

        <!-- Degustazioni -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Percorsi di Degustazione</h3>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Limoncello artigianale</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Dal limoneto alla bottiglia</h4>
              <p class="text-slate-600 text-sm leading-relaxed">I produttori locali aprono le porte dei loro laboratori per mostrare il processo di produzione del limoncello tradizionale con scorze di Femminello biologico.</p>
            </div>
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm">
              <span class="text-med-gold text-[10px] font-bold uppercase tracking-widest mb-2 block">Cucina al limone</span>
              <h4 class="text-xl font-serif font-bold text-slate-900 mb-3">Gastronomia locale</h4>
              <p class="text-slate-600 text-sm leading-relaxed">Delizie al limone, granite, pasta al limone e dolci tradizionali animano i banchetti gastronomici lungo il percorso tra i portoni storici del borgo.</p>
            </div>
          </div>
        </div>

        <!-- Logistica -->
        <div>
          <h3 class="font-serif text-2xl font-bold text-slate-900 mb-6">Come arrivare</h3>
          <div class="bg-white rounded-[2rem] border border-slate-100 overflow-hidden shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-slate-50 border-b border-slate-100">
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Mezzo</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Servizio</th>
                  <th class="text-left px-6 py-4 font-semibold text-slate-900">Note</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Bus EAV</td>
                  <td class="px-6 py-4 text-slate-600">Da Sorrento Piazza Tasso</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Frequenza ogni 20 minuti</td>
                </tr>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-900">Auto</td>
                  <td class="px-6 py-4 text-slate-600">SS145 Sorrentina</td>
                  <td class="px-6 py-4 text-slate-500 text-xs">Parcheggi lungo la strada principale</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar (30%) -->
      <aside class="lg:col-span-3">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32 shadow-2xl">
          <p class="text-[10px] uppercase tracking-[0.3em] text-med-gold font-medium mb-6">Dettagli Evento</p>
          <dl class="space-y-4">
            {facts.map(({ dt, dd }, i) => (
              <>
                <div>
                  <dt class="text-white/40 text-[10px] uppercase tracking-widest font-bold mb-1">{dt}</dt>
                  <dd class="text-white font-medium">{dd}</dd>
                </div>
                {i < facts.length - 1 && <div class="border-t border-white/5"></div>}
              </>
            ))}
          </dl>
          <div class="mt-10 pt-8 border-t border-white/5">
            <p class="text-white/50 text-xs leading-relaxed">Si consiglia di arrivare con largo anticipo. Verificare il programma aggiornato sui canali ufficiali.</p>
          </div>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>
