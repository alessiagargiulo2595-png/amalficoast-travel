---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getLocalePath } from '../../i18n/translations';
import { homeContent } from '../../i18n/content';

const lang = 'it-it';
const t = getTranslations(lang);
const content = homeContent[lang];
---

<BaseLayout
  title={t.meta.destinations_title}
  description={t.meta.destinations_description}
  lang={lang}
  pageKey="destinations"
>
  <!-- Hero -->
  <section class="relative bg-charcoal text-white py-20 overflow-hidden">
    <img src="/images/costiera-hero.jpg" alt="Costiera Amalfitana" class="absolute inset-0 w-full h-full object-cover opacity-20" loading="eager" referrerpolicy="no-referrer"/>
    <div class="absolute inset-0 bg-charcoal/80"></div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-white/80 text-sm uppercase tracking-[0.3em] mb-3">Costiera Amalfitana</p>
      <h1 class="text-4xl md:text-5xl font-bold font-serif mb-4">Borghi e Destinazioni</h1>
      <p class="text-white/80 text-lg max-w-2xl mx-auto">Dalla mondana Positano alla tranquilla Cetara: ogni paese della Costiera Amalfitana ha un carattere unico.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <p class="text-lg text-slate-600 leading-relaxed">
      La Costiera Amalfitana non è un'unica destinazione ma una collana di borghi straordinariamente diversi tra loro, infilati su 50 chilometri di scogliere a picco sul mare. Ognuno ha la sua storia, la sua architettura, il suo carattere. Positano attira i fashionisti e i fotografi; Amalfi conserva i monumenti di una Repubblica marinara che fu potenza mondiale; Ravello vive di musica e giardini; i piccoli borghi come Praiano, Cetara e Vietri offrono un'Italia autentica, lontana dai circuiti di massa.
    </p>
  </section>

  <!-- Towns -->
  <section class="pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-16">
        {content.towns.map((town, i) => (
          <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-8 items-center`}>
            <div class="lg:w-1/2">
              <div class="bg-gradient-to-br from-charcoal to-charcoal rounded-[2rem] h-64 flex items-center justify-center">
                <div class="text-center">
                  <div class="text-6xl mb-2">🏘️</div>
                  <p class="text-charcoal font-semibold">{town.name}</p>
                </div>
              </div>
            </div>
            <div class="lg:w-1/2">
              <h2 class="text-3xl font-bold font-serif text-slate-900 mb-2">{town.name}</h2>
              <p class="text-med-blue font-medium mb-4">{town.tagline}</p>
              <p class="text-slate-600 leading-relaxed mb-6">{town.description}</p>
              <div>
                <h3 class="font-semibold text-slate-900 mb-3">Da non perdere:</h3>
                <ul class="space-y-2">
                  {town.highlights.map(h => (
                    <li class="flex items-center gap-2 text-slate-600 text-sm">
                      <svg class="w-4 h-4 text-med-blue flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      {h}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Come spostarsi -->
  <section class="bg-med-blue py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-serif text-slate-900 mb-6">Come spostarsi tra i borghi</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-3xl mb-3">⛴️</div>
          <h3 class="font-bold text-slate-900 mb-2">Traghetto</h3>
          <p class="text-slate-600 text-sm">Il modo più bello (e spesso il più veloce) per spostarsi. I traghetti collegano Positano, Amalfi, Ravello e Salerno da aprile a ottobre.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-3xl mb-3">🚌</div>
          <h3 class="font-bold text-slate-900 mb-2">Bus SITA</h3>
          <p class="text-slate-600 text-sm">Il bus pubblico percorre tutta la SS163 tutto l'anno. Economico ma lento in alta stagione per il traffico. Biglietti a bordo o nelle tabaccherie.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <div class="text-3xl mb-3">🚗</div>
          <h3 class="font-bold text-slate-900 mb-2">Auto privata</h3>
          <p class="text-slate-600 text-sm">Sconsigliata in luglio e agosto per il traffico intenso. In primavera e autunno è comoda, ma i parcheggi sono limitati e costosi.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center">
    <div class="max-w-2xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Pronto a pianificare il viaggio?</h2>
      <p class="text-slate-600 mb-8">Scopri i nostri itinerari consigliati per visitare al meglio la Costiera Amalfitana.</p>
      <a href={getLocalePath(lang, 'itineraries')}
        class="inline-block bg-med-blue text-white font-semibold px-8 py-3 rounded-full hover:bg-med-blue transition-colors">
        Vedi gli itinerari
      </a>
    </div>
  </section>
</BaseLayout>
