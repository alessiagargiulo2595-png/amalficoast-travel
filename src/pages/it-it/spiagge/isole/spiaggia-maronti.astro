---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Isole del Golfo', url: '/it-it/spiagge#isole' },
  { name: 'Spiaggia dei Maronti', url: '/it-it/spiagge/isole/spiaggia-maronti' },
];

const facts = [
  { label: 'Composizione', value: 'Sabbia vulcanica' },
  { label: 'Lunghezza', value: '3 km (la più grande dell\'isola)' },
  { label: 'Speciale', value: 'Fumarole calde naturali' },
  { label: 'Ombra', value: 'Dalle 19:00' },
  { label: 'Ideale per', value: 'Terme naturali, famiglie, relax' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia dei Maronti",
  "description": "Spiaggia vulcanica di Ischia, la più lunga dell'isola (3 km), famosa per le fumarole calde naturali e le sorgenti termali sotterranee.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Barano d'Ischia",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia dei Maronti Ischia 2026: Fumarole e Sabbia Calda"
  description="I Maronti sono la spiaggia più lunga di Ischia (3 km) con fumarole termali naturali. Guida 2026: come arrivare, cosa aspettarsi, consigli pratici."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-maronti-ischia.jpg"
      alt="Spiaggia dei Maronti, Ischia"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Ischia · Isole del Golfo</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia dei Maronti</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Tre chilometri di sabbia calda riscaldata dal vulcano.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Benessere Termale Naturale</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            I Maronti offrono un'esperienza unica in Italia. La spiaggia è enorme — tre chilometri di sabbia vulcanica scura — e la sabbia è riscaldata dal calore vulcanico del sottosuolo attraverso le <strong>fumarole</strong>: getti di vapore caldo che emergono dalla sabbia stessa, in alcuni punti a temperature che superano i 60°C.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Perfetta per chi ama camminare e vuole sfuggire alla calca dei porti. La vasta lunghezza garantisce che anche in agosto si trovi sempre un angolo tranquillo. Le acque sono calme, ideali per famiglie con bambini piccoli.
          </p>
        </div>

        <!-- Fumarole -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 3z"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Le Fumarole</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Le fumarole si trovano nella parte centrale della spiaggia (area Fumarole Beach). Puoi seppellire i piedi nella sabbia calda per un effetto termale naturale gratuito. <strong>Non avvicinarti troppo ai vapori</strong>: le temperature possono essere molto alte. I bambini devono essere sorvegliati in quest'area.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Linea 5</p>
              <p class="text-slate-700 font-medium mb-1">Da Ischia Porto</p>
              <p class="text-slate-500 text-sm">Scendere a Barano. Poi sentiero in discesa verso la spiaggia (15 min).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Da Sant'Angelo</p>
              <p class="text-slate-500 text-sm">5 minuti di barca. Scenografico e comodo. Approdo diretto sulla spiaggia.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Scopri tutto su Ischia</h2>
      <a
        href="/it-it/isole/ischia/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida completa a Ischia
      </a>
    </div>
  </section>

</BaseLayout>
