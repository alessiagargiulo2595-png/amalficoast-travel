---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Isole del Golfo', url: '/it-it/spiagge#isole' },
  { name: 'Cala del Pozzo Vecchio', url: '/it-it/spiagge/isole/cala-del-pozzo-vecchio' },
];

const facts = [
  { label: 'Composizione', value: 'Sabbia nera vulcanica' },
  { label: 'Vibe', value: 'Poetica e silenziosa' },
  { label: 'Accesso', value: '10 min a piedi dal bus' },
  { label: 'Ombra', value: 'Dalle 17:30' },
  { label: 'Ideale per', value: 'Cinema, poesia, relax autentico' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala del Pozzo Vecchio",
  "description": "La spiaggia di Procida resa immortale dal film Il Postino di Massimo Troisi. Sabbia nera vulcanica e acque smeraldo.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Procida",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia del Postino Procida 2026: Cala del Pozzo Vecchio"
  description="La spiaggia resa immortale dal film Il Postino. Sabbia nera vulcanica, acque smeraldo e il lato più autentico di Procida. Guida 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-pozzo-vecchio-procida.jpg"
      alt="Cala del Pozzo Vecchio, Procida - la spiaggia del Postino"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Procida · Isole del Golfo</p>
      <h1 class="font-serif text-display text-white mb-6">Cala del Pozzo Vecchio</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La spiaggia resa immortale da Massimo Troisi.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Il Cinema Fatto Spiaggia</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La spiaggia resa immortale da Massimo Troisi ne <em>Il Postino</em> (1994). Una mezzaluna di sabbia nera vulcanica e acque color smeraldo che sembra uscita direttamente dal film. Quando ci entri, capisci immediatamente perché Troisi e Michael Radford la scelsero come set principale.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            È il lato più autentico e meno turistico delle isole campane. Procida non ha mai avuto il turismo di massa di Capri o Ischia, e questa spiaggia ne conserva l'anima: pochi turisti, tanta poesia, acque pulitissime. Ideale per il relax totale e per chi ama le atmosfere cinematografiche.
          </p>
        </div>

        <!-- Il Postino -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-2xl">🎬</span>
            <h3 class="text-xl font-bold text-slate-900">Il Postino (1994)</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Il film di Michael Radford con Massimo Troisi e Philippe Noiret vinse l'Oscar come miglior film straniero. Questa spiaggia è il cuore del film. Molti visitatori vengono qui per rivivere le scene iconiche — il postino che cammina sulla riva, la poesia del mare.
          </p>
          <p class="text-slate-600 leading-relaxed italic">
            "Il mondo è bello e tu sei un po' curioso" — Il Postino, 1994
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Linea C1 ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Dal Porto di Procida</p>
              <p class="text-slate-500 text-sm">Fermata Pozzo Vecchio. 10 minuti a piedi in discesa verso la spiaggia.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">A piedi</p>
              <p class="text-slate-700 font-medium mb-1">Dal centro di Procida</p>
              <p class="text-slate-500 text-sm">20–25 minuti. Panoramico e piacevole attraverso le viuzze dell'isola.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <span class="text-med-gold">🌊</span> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Scopri tutto su Procida</h2>
      <a
        href="/it-it/isole/procida/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida completa a Procida
      </a>
    </div>
  </section>

</BaseLayout>
