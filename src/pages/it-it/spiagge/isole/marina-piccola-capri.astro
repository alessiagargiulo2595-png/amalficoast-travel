---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Isole del Golfo', url: '/it-it/spiagge#isole' },
  { name: 'Marina Piccola Capri', url: '/it-it/spiagge/isole/marina-piccola-capri' },
];

const facts = [
  { label: 'Composizione', value: 'Ciottoli e scoglio' },
  { label: 'Accesso', value: 'Bus o scale (Via Mulo)' },
  { label: 'Ombra', value: 'Dalle 16:00 ⚠️' },
  { label: 'Vista', value: 'Faraglioni (la migliore dell\'isola)' },
  { label: 'Ideale per', value: 'Lidi esclusivi, fotografia, snorkeling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina Piccola Capri",
  "description": "La spiaggia più famosa di Capri con la migliore vista ravvicinata sui Faraglioni. Lidi esclusivi e acque protette.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.5456",
    "longitude": "14.2344"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Capri",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina Piccola Capri 2026: Guida alla Spiaggia dei Faraglioni"
  description="Marina Piccola è la baia più famosa di Capri. Guida 2026 con prezzi dei lidi, come arrivare e la migliore vista sui Faraglioni."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-piccola-capri.jpg"
      alt="Marina Piccola, Capri, con i Faraglioni sullo sfondo"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Capri · Isole del Golfo</p>
      <h1 class="font-serif text-display text-white mb-6">Marina Piccola</h1>
      <p class="text-lg md:text-xl font-light text-white/80">I Faraglioni sembrano toccabili con mano.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Il Mito di Capri</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina Piccola è la baia riparata dal vento dove si trovano i lidi più famosi di Capri. Da qui i Faraglioni — le tre rocce iconiche emergenti dal mare — sembrano toccabili con mano: è la vista più drammatica e più fotografata dell'isola.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Nel 2026 la spiaggia libera è ridotta al minimo, quindi la prenotazione nei club come <strong>La Canzone del Mare</strong> (il più storico, fondato nel 1932 da Gracie Fields) è caldamente suggerita. Le acque sono protette e ideali per lo snorkeling.
          </p>
        </div>

        <!-- Shade Alert -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-2xl">⚠️</span>
            <h3 class="text-xl font-bold text-slate-900">Shade Alert</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Marina Piccola è in ombra <strong>dalle 16:00</strong> circa, per via dei monti che la circondano. Se vuoi sole pomeridiano, considera la spiaggia di Marina Grande o i lidi dell'altro lato dell'isola. La mattina e le prime ore del pomeriggio sono le migliori.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus Arancioni ⭐</p>
              <p class="text-slate-700 font-medium mb-1">Dal centro di Capri</p>
              <p class="text-slate-500 text-sm">Linea diretta Marina Piccola. Economico e frequente.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">A piedi da Via Mulo</p>
              <p class="text-slate-700 font-medium mb-1">15 minuti di discesa</p>
              <p class="text-slate-500 text-sm">Panoramico. Si gode il paesaggio dell'isola lungo il percorso.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Scopri tutto su Capri</h2>
      <a
        href="/it-it/isole/capri/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida completa a Capri
      </a>
    </div>
  </section>

</BaseLayout>
