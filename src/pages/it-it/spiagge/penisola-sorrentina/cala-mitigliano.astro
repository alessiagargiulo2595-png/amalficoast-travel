---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Penisola Sorrentina', url: '/it-it/spiagge#penisola-sorrentina' },
  { name: 'Cala di Mitigliano', url: '/it-it/spiagge/penisola-sorrentina/cala-mitigliano' },
];

const facts = [
  { label: 'Composizione', value: 'Ciottoli e pietre' },
  { label: 'Accesso', value: 'Sentiero ripido (30 min) o Barca' },
  { label: 'Ombra', value: 'Dalle 17:00' },
  { label: 'Vista', value: 'Faraglioni di Capri (frontale)' },
  { label: 'Ideale per', value: 'Trekking, snorkeling, fotografia' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Cala di Mitigliano",
  "description": "Spiaggia selvaggia con vista frontale mozzafiato sui Faraglioni di Capri. Raggiungibile via sentiero da Massa Lubrense o in barca.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Massa Lubrense",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Cala di Mitigliano: La Spiaggia Segreta vista Capri"
  description="Cala di Mitigliano a Massa Lubrense: la spiaggia nascosta con la migliore vista frontale sui Faraglioni di Capri. Come arrivare via sentiero o in barca."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/cala-mitigliano.jpg"
      alt="Cala di Mitigliano, Massa Lubrense, con vista su Capri"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Massa Lubrense · Vista Capri</p>
      <h1 class="font-serif text-display text-white mb-6">Cala di Mitigliano</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La spiaggia segreta con i Faraglioni di Capri davanti agli occhi.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Una Perla Nascosta</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Cala di Mitigliano è una perla nascosta della Penisola Sorrentina. Poco frequentata a causa del sentiero d'accesso impegnativo, offre una vista frontale mozzafiato su Capri e i suoi Faraglioni — probabilmente la più bella vista di Capri dal continente. L'acqua è limpidissima, con fondali rocciosi ideali per lo snorkeling.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            La grotta naturale sulla spiaggia offre riparo dal sole nelle ore più calde. Un vero paradiso per gli amanti del trekking e dell'esplorazione. Al tramonto, la luce radente trasforma i Faraglioni in oro: porta la macchina fotografica.
          </p>
        </div>

        <!-- Vista Capri -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-2xl">📸</span>
            <h3 class="text-xl font-bold text-slate-900">La Vista più Bella su Capri</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Dalla spiaggia hai una vista <strong>frontale e ravvicinata</strong> sui tre Faraglioni. Al tramonto (dalle 17:30 circa) la luce è perfetta. È la foto di Capri che non fanno i turisti — perché ci vuole un po' di gambe per arrivare qui.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Sentiero a piedi</p>
              <p class="text-slate-700 font-medium mb-1">Da Termini, Massa Lubrense</p>
              <p class="text-slate-500 text-sm">30 min di discesa ripida. Scarpe da trekking obbligatorie. Nessuna struttura in loco.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat</p>
              <p class="text-slate-700 font-medium mb-1">Da Sorrento o Marina del Cantone</p>
              <p class="text-slate-500 text-sm">L'opzione più comoda. Prenota un giro in barca con sosta alla cala.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <span class="text-med-gold">🌊</span> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Esplora la Penisola Sorrentina</h2>
      <a
        href="/it-it/penisola-sorrentina/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida alla Penisola Sorrentina
      </a>
    </div>
  </section>

</BaseLayout>
