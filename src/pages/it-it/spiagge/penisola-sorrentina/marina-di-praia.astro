---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Penisola Sorrentina', url: '/it-it/spiagge#penisola-sorrentina' },
  { name: 'Marina di Praia', url: '/it-it/spiagge/penisola-sorrentina/marina-di-praia' },
];

const facts = [
  { label: 'Composizione', value: 'Sabbia e ciottoli' },
  { label: 'Accesso', value: 'Scale nella roccia (50 scalini)' },
  { label: 'Ombra', value: 'Dalle 15:00' },
  { label: 'Servizi', value: 'Spiaggia libera' },
  { label: 'Ideale per', value: 'Tramonto, snorkeling, tranquillità' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina di Praia",
  "description": "Una spiaggia selvaggia e intima di Praiano, nascosta dietro scale creusate nella roccia. Sabbia dorata e acque trasparenti lontano dalla folla.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Praiano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina di Praia: La Spiaggia Selvaggia di Praiano"
  description="Marina di Praia a Praiano: la spiaggia nascosta raggiungibile da scale nella roccia. Tramonto perfetto, acque cristalline, lontano dalla folla della Costiera."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/praia-hero.jpg"
      alt="Marina di Praia, Praiano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Praiano · Selvaggia e Autentica</p>
      <h1 class="font-serif text-display text-white mb-6">Marina di Praia</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Una spiaggia segreta raggiungibile da scale creuse nella roccia, con il tramonto più bello della Costiera.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Oltre la Folla</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Marina di Praia è il segreto meglio custodito di Praiano. Non la troverai sulla cartina turistica principale, perché è raggiungibile solo da una corta serie di scale creuse direttamente nella roccia. Quello che scopri dall'altra parte? Una spiaggia di sabbia dorata e ciottoli, con acque turchesi e quasi nessuno.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            È il luogo perfetto per sfuggire alla folla della Costiera senza rinunciare alle acque cristalline di Praiano. Al tramonto il sole illumina le pareti di roccia sopra la spiaggia: l'ora migliore è verso le 19:00 da aprile a settembre, quando la luce è quasi orizzontale e l'acqua riflette sfumature di rosa e oro.
          </p>
        </div>

        <!-- Tramonto Note -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M21 12.79A6 6 0 0 0 17.21 3 7 7 0 0 0 12 19a7 7 0 0 0 5.21-2.79"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Il Tramonto Perfetto</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Marina di Praia ha uno dei tramontiperfetti della Costiera. Arriva intorno alle <strong>18:30 (estate)</strong> e avrai luce fino alle 19:30. La spiaggia è esposta a ovest, quindi il sole scende direttamente sopra l'orizzonte marino. Porta la macchina fotografica.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">A piedi</p>
              <p class="text-slate-700 font-medium mb-1">Dal centro di Praiano</p>
              <p class="text-slate-500 text-sm">5 minuti a piedi lungo via Mare, poi 50 scalini nella roccia. Scarpe comode consigliate.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat</p>
              <p class="text-slate-700 font-medium mb-1">Da Praiano o Marina Grande</p>
              <p class="text-slate-500 text-sm">Non è un sbarco regolare, ma i taxi boat locali la conoscono. Costo: €15-20 a persona.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Scopri altre spiagge della Costiera</h2>
      <a
        href="/it-it/spiagge"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida completa alle spiagge
      </a>
    </div>
  </section>

</BaseLayout>
