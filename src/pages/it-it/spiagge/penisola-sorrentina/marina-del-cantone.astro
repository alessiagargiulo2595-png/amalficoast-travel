---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Penisola Sorrentina', url: '/it-it/spiagge#penisola-sorrentina' },
  { name: 'Marina del Cantone', url: '/it-it/spiagge/penisola-sorrentina/marina-del-cantone' },
];

const facts = [
  { label: 'Composizione', value: 'Ciottoli grandi' },
  { label: 'Accesso', value: 'Facilissimo (piano)' },
  { label: 'Ombra', value: 'Dalle 18:30' },
  { label: 'Servizi', value: 'Lidi attrezzati, Ristoranti stellati' },
  { label: 'Ideale per', value: 'Famiglie, gastronomia, snorkeling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Marina del Cantone",
  "description": "Ampia spiaggia di ciottoli a Nerano, celebre per la gastronomia con lo Spaghetto alla Nerano e le acque cristalline dell'Area Marina Protetta.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Nerano",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Marina del Cantone Nerano: Spiaggia e Ristoranti 2026"
  description="La spiaggia più buona d'Italia: Marina del Cantone a Nerano unisce acque cristalline protette e lo Spaghetto alla Nerano originale. Guida 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/marina-del-cantone.jpg"
      alt="Marina del Cantone, Nerano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Nerano · Penisola Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Marina del Cantone</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La capitale del gusto affacciata sul mare più pulito della Campania.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Mare e Cucina d'Autore</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Nerano è la capitale del gusto della Penisola Sorrentina. La spiaggia di Marina del Cantone è ampia, pulita e baciata dal sole fino a tarda sera. Le acque sono tra le più cristalline della Campania, protette dall'Area Marina Protetta di Punta Campanella: lo snorkeling è eccellente, con praterie di posidonia e ricca fauna marina.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Ma la fama mondiale di Nerano è gastronomica. Qui è nato lo <strong>Spaghetto alla Nerano</strong> - zucchine fritte, provolone del Monaco, basilico - e tutti i ristoranti sul lungomare servono la versione originale. Perfetta per le famiglie e per chi vuole unire mare e alta cucina in una giornata sola.
          </p>
        </div>

        <!-- Consiglio Foodie -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Consiglio Foodie</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            La trattoria <strong>Lo Cantone</strong> e <strong>Maria Grazia</strong> sono i templi dello Spaghetto alla Nerano. Prenota il tavolo il mattino presto perché in estate i posti si esauriscono. Il pranzo al mare qui è un'esperienza gastronomica completa.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus EAV</p>
              <p class="text-slate-700 font-medium mb-1">Da Sorrento via Massa Lubrense</p>
              <p class="text-slate-500 text-sm">Scendere a Nerano. Poi 10 min a piedi verso la spiaggia.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Via Mare</p>
              <p class="text-slate-700 font-medium mb-1">Taxi boat da Sorrento</p>
              <p class="text-slate-500 text-sm">Approdo diretto sulla spiaggia. Scenografico e comodo.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Esplora la Penisola Sorrentina</h2>
      <a
        href="/it-it/penisola-sorrentina/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida alla Penisola Sorrentina
      </a>
    </div>
  </section>

</BaseLayout>
