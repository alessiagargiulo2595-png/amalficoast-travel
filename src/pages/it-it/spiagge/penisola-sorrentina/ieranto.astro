---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Penisola Sorrentina', url: '/it-it/spiagge#penisola-sorrentina' },
  { name: 'Ieranto', url: '/it-it/spiagge/penisola-sorrentina/ieranto' },
];

const facts = [
  { label: 'Composizione', value: 'Sabbia e ciottoli' },
  { label: 'Accesso', value: 'Via trekking (45-60 min) o barca' },
  { label: 'Ombra', value: 'Dalle 14:00' },
  { label: 'Servizi', value: 'Nessuno (spiaggia selvaggia)' },
  { label: 'Ideale per', value: 'Trekking, snorkeling, solitudine' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Ieranto",
  "description": "La spiaggia più difficile da raggiungere della Penisola Sorrentina, accessibile solo via trekking o barca. Un'oasi di selvaggia bellezza circondata da falesie e boschi di pini.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Massa Lubrense",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Ieranto: La Spiaggia Più Selvaggia della Penisola Sorrentina"
  description="Ieranto a Massa Lubrense: la spiaggia più difficile da raggiungere della Penisola Sorrentina, accessibile solo via trekking. Solitudine, natura selvaggia, acque cristalline lontano dalla civiltà."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/ieranto-hero.jpg"
      alt="Ieranto, Massa Lubrense"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Massa Lubrense · Autentica e Selvaggia</p>
      <h1 class="font-serif text-display text-white mb-6">Ieranto</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La spiaggia più difficile da raggiungere della Penisola Sorrentina. Raggiungibile solo via trekking o barca, un'oasi di solitudine e bellezza selvaggia.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Solo per i Coraggiosi</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Ieranto non è una spiaggia per tutti. Non c'è strada, non ci sono servizi, non ci sono ombrelloni. C'è solo un sentiero escursionistico di circa 45-60 minuti che cala attraverso un bosco di pini marittimi fino a una cala nascosta di sabbia dorata e ciottoli, circondata da falesie bianche di quasi 100 metri.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Se sei disposto a fare il trekking, troverai quello che pochi turisti vedranno mai: una spiaggia praticamente deserta, acque cristalline per lo snorkeling, e il suono dei cicali nelle pigne che scendono fino all'orizzonte marino. È il luogo dove la Costiera ritorna selvaggia.
          </p>
        </div>

        <!-- Trekking Note -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Il Trekking a Ieranto</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Il sentiero parte da Massa Lubrense (frazione Termini) e scende per circa 45-60 minuti lungo i pini marittimi con vista costante del mare. È ben segnalato ma ripido in alcuni punti. La salita al ritorno è più faticosa. Scarpe da trekking consigliate, almeno 1 litro d'acqua per persona, protezione solare alta.
          </p>
          <p class="text-slate-600 font-medium">
            Periodo migliore: <strong>maggio-ottobre</strong>. Evitare i mesi più caldi (luglio-agosto) per il caldo intenso durante la salita.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Via Trekking</p>
              <p class="text-slate-700 font-medium mb-1">Da Massa Lubrense (Termini)</p>
              <p class="text-slate-500 text-sm">45-60 minuti di discesa. Sentiero segnalato attraverso il bosco. Difficoltà media-alta. Consigliato con guida per la prima volta.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Via Mare</p>
              <p class="text-slate-700 font-medium mb-1">Da Sorrento o Marina Grande</p>
              <p class="text-slate-500 text-sm">Taxi boat privato. Consigliato contattare in anticipo. Costo: €50-80 per barca. Possibile anche con i charter privati durante l'estate.</p>
            </div>
          </div>
        </div>

        <!-- Snorkeling -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Snorkeling a Ieranto</h2>
          <p class="text-slate-600 text-lg leading-relaxed">
            Le acque intorno a Ieranto sono tra le più cristalline della Penisola Sorrentina. Non avrai folla che nuota sopra di te, e potrai avvistare dentici, ricciole, e occasionalmente gli altri pesci che abitano la fossa marina davanti alla spiaggia. La vicinanza alle falesie crea piccoli ecosistemi di corallo e posidonia.
          </p>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Scopri altre spiagge della Costiera</h2>
      <a
        href="/it-it/spiagge"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida completa alle spiagge
      </a>
    </div>
  </section>

</BaseLayout>
