---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Penisola Sorrentina', url: '/it-it/spiagge#penisola-sorrentina' },
  { name: 'Regina Giovanna', url: '/it-it/spiagge/penisola-sorrentina/regina-giovanna' },
];

const facts = [
  { label: 'Composizione', value: 'Scogliera' },
  { label: 'Accesso', value: 'Sentiero 20 min (Medio)' },
  { label: 'Ombra', value: 'Dalle 18:00' },
  { label: 'Servizi', value: 'Nessuno – spiaggia selvaggia' },
  { label: 'Ideale per', value: 'Archeologia, trekking, snorkeling' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Bagni della Regina Giovanna",
  "description": "Piscina naturale e sito archeologico romano a Sorrento. Un gioiello nascosto tra gli ulivi a 20 minuti a piedi dal centro.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6450",
    "longitude": "14.3540"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Sorrento",
    "addressRegion": "NA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Regina Giovanna Sorrento: La Piscina Naturale (2026)"
  description="Come raggiungere i Bagni della Regina Giovanna a Sorrento. Piscina naturale tra rovine romane, sentiero tra gli ulivi e acque smeraldo. Guida 2026."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/regina-giovanna-sorrento.jpg"
      alt="Bagni della Regina Giovanna, Sorrento"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Sorrento · Penisola Sorrentina</p>
      <h1 class="font-serif text-display text-white mb-6">Regina Giovanna</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La piscina naturale nascosta tra le rovine romane.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Archeologia e Nuoto</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            I Bagni della Regina Giovanna sono un sito archeologico a cielo aperto dove tuffarsi nel blu smeraldo. Una piscina naturale racchiusa tra i resti di una villa romana del I sec. d.C. — probabilmente di Publio Vedio Pollione — collega il mare aperto attraverso un arco di roccia. Nel 2026 resta una meta selvaggia: non ci sono stabilimenti.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            Il sentiero che porta ai bagni attraversa uliveti millenari con viste spettacolari sul Golfo di Napoli e sull'isola di Capri. Porta scarpe da trekking leggere e acqua a sufficienza, perché non ci sono bar o negozi nei pressi.
          </p>
        </div>

        <!-- Nota selvaggia -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <svg class="w-6 h-6 text-med-gold flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            <h3 class="text-xl font-bold text-slate-900">Spiaggia Selvaggia</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Non ci sono strutture, bar, né stabilimenti. Porta <strong>acqua, cibo, scarpe da scoglio</strong> e tutto il necessario. La spiaggia è frequentata principalmente da sorrentini e da chi conosce il posto: un vero angolo autentico.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus EAV ⭐ Consigliato</p>
              <p class="text-slate-700 font-medium mb-1">Linea "Capo di Sorrento"</p>
              <p class="text-slate-500 text-sm">Da Piazza Tasso. Poi 15–20 min a piedi tra gli uliveti.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">A Piedi dal Centro</p>
              <p class="text-slate-700 font-medium mb-1">Circa 40 minuti</p>
              <p class="text-slate-500 text-sm">Panoramica ma impegnativa. Seguire Via del Capo verso Punta del Capo.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <svg class="w-6 h-6 text-med-gold" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M2 12c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M2 18c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/></svg> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Esplora la Penisola Sorrentina</h2>
      <a
        href="/it-it/penisola-sorrentina/"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida alla Penisola Sorrentina
      </a>
    </div>
  </section>

</BaseLayout>
