---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Costiera Amalfitana', url: '/it-it/spiagge#costiera-amalfitana' },
  { name: 'Fiordo di Furore', url: '/it-it/spiagge/costiera-amalfitana/fiordo-di-furore' },
];

const facts = [
  { label: 'Composizione', value: 'Ciottoli' },
  { label: 'Accesso', value: 'Scale (circa 200 scalini)' },
  { label: 'Ombra', value: 'Dalle 14:30 ⚠️' },
  { label: 'Servizi', value: 'Spiaggia libera' },
  { label: 'Ideale per', value: 'Fotografia, Coppie' },
];

const logistica = [
  { mezzo: 'Bus SITA', fermata: 'Furore Fiordo', note: 'Linea Amalfi–Positano' },
  { mezzo: 'Scooter', fermata: 'Ponte Furore', note: 'Pochi posti bordo strada' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Fiordo di Furore",
  "description": "Un'iconica spiaggia incastonata in un fiordo naturale con acque cristalline e un ponte monumentale alto 30 metri.",
  "image": "https://amalficoast-travel.com/images/fiordo-furore.jpg",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6122",
    "longitude": "14.5534"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Furore",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "publicAccess": "true",
  "amenityFeature": {
    "@type": "LocationFeatureSpecification",
    "name": "Orario Ombra",
    "value": "Dalle 14:30"
  }
};
---

<BaseLayout
  title="Fiordo di Furore 2026: Guida, Accesso e Orari Ombra"
  description="Come visitare il Fiordo di Furore nel 2026. Orari della luce, come arrivare in bus e consigli per lo scatto perfetto."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/fiordo-furore-hero.jpg"
      alt="Fiordo di Furore, Costiera Amalfitana"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Costiera Amalfitana</p>
      <h1 class="font-serif text-display text-white mb-6">Fiordo di Furore</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Un capolavoro della natura incastonato nella roccia.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Un'icona della Costiera</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Il Fiordo di Furore è una delle immagini più iconiche d'Italia. Non è una spiaggia tradizionale, ma una profonda spaccatura naturale dove il mare s'insinua sotto un ponte monumentale alto 30 metri. Nel 2026, l'accesso è regolamentato per preservare il sito: la spiaggia è piccola e l'acqua è solitamente più fresca rispetto alla costa aperta.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            È il paradiso dei fotografi, ma attenzione alla luce: il sole illumina il fondo del fiordo solo nelle ore centrali della giornata. Arriva tra le 11 e le 13 per gli scatti migliori. Il tuffo dal ponte è una tradizione locale, ma è vietato ai turisti: goditi il panorama dall'alto prima di scendere i 200 scalini verso la spiaggia.
          </p>
        </div>

        <!-- Nota Importante -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-2xl">⚠️</span>
            <h3 class="text-xl font-bold text-slate-900">Shade Alert</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Il sole arriva solo tra le <strong>11:00 e le 14:30</strong>. Prima e dopo questa finestra la spiaggia è in ombra totale. Se vuoi sole per nuotare, organizza la visita di conseguenza. Se vuoi foto perfette dell'acqua turchese illuminata, punta alle 11:30.
          </p>
        </div>

        <!-- Logistica -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="overflow-hidden rounded-[2rem] border border-slate-100 shadow-sm">
            <table class="w-full text-sm">
              <thead>
                <tr class="bg-charcoal text-white">
                  <th class="text-left p-4 font-medium">Mezzo</th>
                  <th class="text-left p-4 font-medium">Fermata</th>
                  <th class="text-left p-4 font-medium">Note</th>
                </tr>
              </thead>
              <tbody>
                {logistica.map((row, i) => (
                  <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
                    <td class="p-4 font-medium text-slate-900">{row.mezzo}</td>
                    <td class="p-4 text-slate-600">{row.fermata}</td>
                    <td class="p-4 text-slate-500">{row.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <span class="text-med-gold">🌊</span> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Scopri altre spiagge della Costiera</h2>
      <a
        href="/it-it/spiagge"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida completa alle spiagge
      </a>
    </div>
  </section>

</BaseLayout>
