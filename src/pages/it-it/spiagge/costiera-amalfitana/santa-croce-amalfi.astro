---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Costiera Amalfitana', url: '/it-it/spiagge#costiera-amalfitana' },
  { name: 'Santa Croce', url: '/it-it/spiagge/costiera-amalfitana/santa-croce-amalfi' },
];

const facts = [
  { label: 'Composizione', value: 'Ciottoli bianchi' },
  { label: 'Accesso', value: 'Solo via mare (Taxi Boat)' },
  { label: 'Ombra', value: 'Dalle 16:00' },
  { label: 'Servizi', value: '2 Ristoranti con lido' },
  { label: 'Ideale per', value: 'Fuga romantica, pesce fresco' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia di Santa Croce",
  "description": "Spiaggia esclusiva raggiungibile solo via mare da Amalfi, famosa per le acque trasparenti e i ristoranti storici.",
  "isAccessibleForFree": "false",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Amalfi",
    "addressRegion": "SA",
    "addressCountry": "IT"
  }
};
---

<BaseLayout
  title="Spiaggia di Santa Croce Amalfi: Come arrivare via Mare"
  description="Santa Croce è la fuga perfetta da Amalfi. Raggiungibile solo in barca, con acque cristalline e ristoranti storici con navetta gratuita."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/santa-croce-amalfi.jpg"
      alt="Spiaggia di Santa Croce, Amalfi"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Amalfi · Solo via Mare</p>
      <h1 class="font-serif text-display text-white mb-6">Santa Croce</h1>
      <p class="text-lg md:text-xl font-light text-white/80">La fuga segreta a pochi minuti dal caos di Amalfi.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">La Fuga Perfetta da Amalfi</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            Santa Croce è la risposta al caos di luglio e agosto ad Amalfi. Raggiungibile solo con pochi minuti di barca dal molo principale, offre acque di una trasparenza incredibile su fondali rocciosi. La spiaggia di ciottoli bianchi è raccolta tra alte scogliere che la proteggono dal vento.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            I due ristoranti storici — Da Gemma e La Caravella — hanno lidi privati sulla spiaggia e offrono navette gratuite dal molo di Amalfi per i propri clienti. È l'ideale per chi vuole una giornata di mare "selvaggia" ma con il comfort di un ottimo pranzo a base di pesce freschissimo.
          </p>
        </div>

        <!-- Consiglio locale -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-2xl">🤫</span>
            <h3 class="text-xl font-bold text-slate-900">Consiglio Local</h3>
          </div>
          <p class="text-slate-600 leading-relaxed">
            Prenota il pranzo al ristorante con anticipo: ti offrono la navetta dal molo <strong>gratuitamente</strong> per i clienti. È il modo più economico (e più scenografico) per arrivare a Santa Croce.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Taxi Boat ⭐ Unico accesso</p>
              <p class="text-slate-700 font-medium mb-1">Dal Molo di Amalfi</p>
              <p class="text-slate-500 text-sm">Circa 5 minuti di traversata. Costo: €5–€8 a persona (andata e ritorno).</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Navetta Ristorante</p>
              <p class="text-slate-700 font-medium mb-1">Gratuita per clienti</p>
              <p class="text-slate-500 text-sm">Prenota il pranzo e la barca è inclusa nel servizio.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <span class="text-med-gold">🌊</span> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Scopri altre spiagge della Costiera</h2>
      <a
        href="/it-it/spiagge"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida completa alle spiagge
      </a>
    </div>
  </section>

</BaseLayout>
