---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
  { name: 'Costiera Amalfitana', url: '/it-it/spiagge#costiera-amalfitana' },
  { name: 'Spiaggia Grande Positano', url: '/it-it/spiagge/costiera-amalfitana/spiaggia-grande-positano' },
];

const facts = [
  { label: 'Composizione', value: 'Sabbia e ciottoli' },
  { label: 'Accesso', value: 'Facile (piano)' },
  { label: 'Ombra', value: 'Dalle 17:30' },
  { label: 'Servizi', value: 'Beach Club di lusso, Ristoranti, Porto' },
  { label: 'Ideale per', value: 'Atmosfera, mondanità, VIP-watching' },
];

const beachSchema = {
  "@context": "https://schema.org",
  "@type": "Beach",
  "name": "Spiaggia Grande di Positano",
  "description": "La spiaggia principale di Positano, cuore della vita mondana e dei beach club di lusso della Costiera Amalfitana.",
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "40.6273",
    "longitude": "14.4849"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Positano",
    "addressRegion": "SA",
    "addressCountry": "IT"
  },
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Ristoranti", "value": "Sì" },
    { "@type": "LocationFeatureSpecification", "name": "Beach Club", "value": "Sì" }
  ]
};
---

<BaseLayout
  title="Spiaggia Grande Positano 2026: Beach Club e Prezzi"
  description="Vivi il cuore di Positano. Prezzi lettini 2026, ristoranti e come raggiungere la Spiaggia Grande via mare."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[beachSchema]}
>

  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden flex items-center justify-center">
    <img
      src="/images/spiaggia-grande-positano.jpg"
      alt="Spiaggia Grande di Positano"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/20 via-black/35 to-black/70"></div>
    <div class="relative z-10 text-center px-6 max-w-4xl text-white">
      <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Positano · Costiera Amalfitana</p>
      <h1 class="font-serif text-display text-white mb-6">Spiaggia Grande</h1>
      <p class="text-lg md:text-xl font-light text-white/80">Il cuore mondano della Costiera Amalfitana.</p>
    </div>
  </section>

  <!-- Contenuto + Sidebar -->
  <section class="bg-med-cream py-24 px-6">
    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-16">

      <!-- Testo principale -->
      <div class="lg:col-span-2 space-y-12">
        <div>
          <h2 class="font-serif text-4xl font-bold text-slate-900 mb-6">Il Glamour della Costiera</h2>
          <p class="text-slate-600 text-lg leading-relaxed mb-6">
            La Spiaggia Grande di Positano è il centro della vita mondana della costiera. Con la città verticale alle spalle — case color pastello che si arrampicano fino alla chiesa di Santa Maria Assunta — offre uno scenario unico al mondo. Nel 2026, i Beach Club richiedono prenotazioni con settimane di anticipo in alta stagione.
          </p>
          <p class="text-slate-600 text-lg leading-relaxed">
            È il punto di partenza per tutti i taxi-boat diretti alle calette isolate della costiera. Se cerchi il mix perfetto tra comodità, cocktail d'autore e atmosfera esclusiva, questo è il tuo posto. La parte libera della spiaggia, più a est, è gratuita ma si occupa rapidamente dopo le 9.
          </p>
        </div>

        <!-- Nota prezzi -->
        <div class="bg-white p-8 rounded-[2rem] shadow-xl border border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <span class="text-2xl">💶</span>
            <h3 class="text-xl font-bold text-slate-900">Prezzi 2026</h3>
          </div>
          <p class="text-slate-600 leading-relaxed mb-4">
            Un lettino + ombrellone nei beach club di Spiaggia Grande costa mediamente <strong>€35–€60 a persona</strong>. I ristoranti sul lungomare (La Buca di Bacco, La Scalinatella) offrono servizio ombrellone incluso con il pranzo.
          </p>
          <p class="text-slate-600 leading-relaxed">
            Il <strong>parcheggio</strong> nel centro di Positano è sconsigliato: arrivi via traghetto da Amalfi o Sorrento, oppure con il Bus SITA e scendete alla fermata Sponda.
          </p>
        </div>

        <!-- Come arrivare -->
        <div>
          <h2 class="font-serif text-3xl font-bold text-slate-900 mb-6">Come Arrivare</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Via Mare ⭐ Consigliato</p>
              <p class="text-slate-700 font-medium mb-1">Traghetto da Amalfi o Sorrento</p>
              <p class="text-slate-500 text-sm">Approdo diretto sulla Spiaggia Grande. Godi il panorama dall'acqua.</p>
            </div>
            <div class="bg-white p-6 rounded-[2rem] border border-slate-100 shadow-sm">
              <p class="text-med-gold text-xs font-bold uppercase tracking-wider mb-2">Bus SITA</p>
              <p class="text-slate-700 font-medium mb-1">Fermata Sponda</p>
              <p class="text-slate-500 text-sm">Scalinata ripida fino alla spiaggia (circa 10 min a piedi).</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar Fast-Facts -->
      <aside class="lg:col-span-1">
        <div class="bg-slate-900 text-white p-10 rounded-[3rem] sticky top-32">
          <h3 class="font-serif text-2xl font-bold mb-8 flex items-center gap-3">
            <span class="text-med-gold">🌊</span> Fast-Facts
          </h3>
          <div class="space-y-6">
            {facts.map((item) => (
              <div class="border-b border-white/5 pb-4 last:border-0">
                <span class="text-white/40 text-sm font-light block mb-1">{item.label}</span>
                <span class="text-white font-medium text-sm">{item.value}</span>
              </div>
            ))}
          </div>
          <div class="mt-10 pt-8 border-t border-white/10">
            <a
              href="/it-it/spiagge"
              class="inline-flex items-center gap-2 text-med-gold text-sm font-medium hover:text-white transition-colors"
            >
              ← Tutte le spiagge
            </a>
          </div>
        </div>
      </aside>

    </div>
  </section>

  <!-- CTA -->
  <section class="bg-med-blue py-16 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-4">Scopri altre spiagge della Costiera</h2>
      <a
        href="/it-it/spiagge"
        class="inline-block bg-white text-med-blue font-semibold px-8 py-3 rounded-full hover:bg-med-cream transition-colors"
      >
        Guida completa alle spiagge
      </a>
    </div>
  </section>

</BaseLayout>
