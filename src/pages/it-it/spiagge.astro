---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'it-it';

const breadcrumbs = [
  { name: 'Home', url: '/it-it/' },
  { name: 'Spiagge', url: '/it-it/spiagge' },
];

const categories = [
  {
    id: 'costiera-amalfitana',
    title: 'Costiera Amalfitana',
    description: 'Calette di ciottoli incastonate tra scogliere a picco, da Positano a Vietri sul Mare.',
    icon: '🏖️',
    beaches: [
      { name: 'Fiordo di Furore', path: '/it-it/spiagge/costiera-amalfitana/fiordo-di-furore', tag: 'Fotografico' },
      { name: 'Spiaggia Grande', path: '/it-it/spiagge/costiera-amalfitana/spiaggia-grande-positano', tag: 'Glamour' },
      { name: 'Santa Croce', path: '/it-it/spiagge/costiera-amalfitana/santa-croce-amalfi', tag: 'Solo via mare' },
    ],
  },
  {
    id: 'penisola-sorrentina',
    title: 'Penisola Sorrentina',
    description: 'Spiagge vulcaniche e borghi marinari affacciati sul Golfo di Napoli.',
    icon: '🌊',
    beaches: [
      { name: 'Regina Giovanna', path: '/it-it/spiagge/penisola-sorrentina/regina-giovanna', tag: 'Archeo-beach' },
      { name: 'Marina del Cantone', path: '/it-it/spiagge/penisola-sorrentina/marina-del-cantone', tag: 'Foodie' },
      { name: 'Cala di Mitigliano', path: '/it-it/spiagge/penisola-sorrentina/cala-mitigliano', tag: 'Vista Capri' },
    ],
  },
  {
    id: 'isole',
    title: 'Isole del Golfo',
    description: 'Le perle del Mediterraneo: Capri, Ischia e la colorata Procida.',
    icon: '⚓',
    beaches: [
      { name: 'Marina Piccola', path: '/it-it/spiagge/isole/marina-piccola-capri', tag: 'Capri' },
      { name: 'Spiaggia dei Maronti', path: '/it-it/spiagge/isole/spiaggia-maronti', tag: 'Ischia' },
      { name: 'Cala del Pozzo Vecchio', path: '/it-it/spiagge/isole/cala-del-pozzo-vecchio', tag: 'Procida' },
    ],
  },
];

const collections = [
  { title: 'Raggiungibili solo via mare', path: '/it-it/spiagge#solo-via-mare', icon: '⚓' },
  { title: 'Per famiglie con bambini', path: '/it-it/spiagge#famiglie', icon: '👨‍👩‍👧' },
  { title: 'Dove vedere il tramonto', path: '/it-it/spiagge#tramonto', icon: '🌅' },
];

const schemaBeaches = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Le migliori spiagge della Costiera Amalfitana",
  "description": "Guida completa alle spiagge della Costiera Amalfitana, Penisola Sorrentina e Isole del Golfo.",
  "url": "https://amalficoast-travel.com/it-it/spiagge",
  "numberOfItems": 9,
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Fiordo di Furore", "url": "https://amalficoast-travel.com/it-it/spiagge/costiera-amalfitana/fiordo-di-furore" },
    { "@type": "ListItem", "position": 2, "name": "Spiaggia Grande Positano", "url": "https://amalficoast-travel.com/it-it/spiagge/costiera-amalfitana/spiaggia-grande-positano" },
    { "@type": "ListItem", "position": 3, "name": "Santa Croce Amalfi", "url": "https://amalficoast-travel.com/it-it/spiagge/costiera-amalfitana/santa-croce-amalfi" },
    { "@type": "ListItem", "position": 4, "name": "Bagni della Regina Giovanna", "url": "https://amalficoast-travel.com/it-it/spiagge/penisola-sorrentina/regina-giovanna" },
    { "@type": "ListItem", "position": 5, "name": "Marina del Cantone", "url": "https://amalficoast-travel.com/it-it/spiagge/penisola-sorrentina/marina-del-cantone" },
    { "@type": "ListItem", "position": 6, "name": "Cala di Mitigliano", "url": "https://amalficoast-travel.com/it-it/spiagge/penisola-sorrentina/cala-mitigliano" },
    { "@type": "ListItem", "position": 7, "name": "Marina Piccola Capri", "url": "https://amalficoast-travel.com/it-it/spiagge/isole/marina-piccola-capri" },
    { "@type": "ListItem", "position": 8, "name": "Spiaggia dei Maronti", "url": "https://amalficoast-travel.com/it-it/spiagge/isole/spiaggia-maronti" },
    { "@type": "ListItem", "position": 9, "name": "Cala del Pozzo Vecchio", "url": "https://amalficoast-travel.com/it-it/spiagge/isole/cala-del-pozzo-vecchio" },
  ],
};
---

<BaseLayout
  title="Spiagge Costiera Amalfitana 2026: Guida Completa"
  description="Dalle calette segrete raggiungibili solo via mare ai lidi attrezzati. Guida alle 9 spiagge imperdibili della Costiera Amalfitana, Penisola Sorrentina e Isole del Golfo."
  lang={lang}
  breadcrumbs={breadcrumbs}
  schema={[schemaBeaches]}
>

  <!-- Hero -->
  <section class="relative h-[80vh] flex items-center bg-charcoal overflow-hidden">
    <img
      src="/images/spiagge-hero.jpg"
      alt="Spiagge della Costiera Amalfitana"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/25 via-black/40 to-black/75"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 py-24">
      <nav class="flex items-center gap-2 text-white/60 text-xs mb-6">
        <a href="/it-it/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Spiagge</span>
      </nav>
      <div class="max-w-3xl">
        <p class="text-med-gold text-sm font-medium uppercase tracking-[0.3em] mb-3">Guida 2026</p>
        <h1 class="font-serif text-display text-white mb-4">Le Spiagge</h1>
        <p class="text-xl text-white/80 leading-relaxed">
          Dalle calette segrete raggiungibili solo via mare ai lidi attrezzati per famiglie. Scopri il blu perfetto della Campania.
        </p>
      </div>
    </div>
  </section>

  <!-- Categoria cards -->
  <section class="bg-med-cream py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {categories.map((cat) => (
          <div class="bg-white p-10 rounded-[3rem] shadow-xl border border-slate-100 flex flex-col h-full">
            <div class="w-14 h-14 rounded-2xl bg-med-blue/10 text-med-blue flex items-center justify-center mb-8 text-2xl">
              {cat.icon}
            </div>
            <h2 class="font-serif text-3xl font-bold text-slate-900 mb-4">{cat.title}</h2>
            <p class="text-slate-500 text-sm leading-relaxed mb-8 flex-grow">{cat.description}</p>
            <div class="space-y-3">
              {cat.beaches.map((beach) => (
                <a
                  href={beach.path}
                  class="flex items-center justify-between p-4 rounded-2xl bg-slate-50 hover:bg-med-gold/10 transition-colors group"
                >
                  <span class="font-medium text-slate-700 group-hover:text-med-gold transition-colors">{beach.name}</span>
                  <span class="text-[10px] font-bold uppercase tracking-wider text-slate-400 group-hover:text-med-gold transition-colors">{beach.tag}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Guide tematiche -->
  <section class="bg-charcoal py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="font-serif text-4xl font-bold text-white mb-4">Guide Tematiche</h2>
        <p class="text-white/40">Selezioni curate per ogni esigenza</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {collections.map((col) => (
          <a
            href={col.path}
            class="group bg-white/5 p-8 rounded-3xl border border-white/10 hover:bg-white/10 transition-all text-center"
          >
            <div class="text-4xl mb-6">{col.icon}</div>
            <h3 class="font-serif text-xl font-bold text-white mb-4">{col.title}</h3>
            <span class="text-med-gold text-xs font-bold uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">
              Scopri di più →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Consigli pratici -->
  <section class="bg-med-blue py-16" id="consigli">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="font-serif text-2xl font-bold text-white mb-8">Consigli pratici per le spiagge</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <h3 class="font-bold text-slate-900 mb-3">🕘 Quando andare</h3>
          <p class="text-slate-600 text-sm">In luglio e agosto arrivi prima delle 9 per trovare posto. La sera è il momento migliore per godersi le spiagge meno affollate.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <h3 class="font-bold text-slate-900 mb-3">👟 Cosa portare</h3>
          <p class="text-slate-600 text-sm">Le spiagge sono quasi tutte di ciottoli: porta scarpe da scoglio. Utile uno zaino impermeabile per le spiagge via barca o sentiero.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <h3 class="font-bold text-slate-900 mb-3">💶 Costi</h3>
          <p class="text-slate-600 text-sm">Uno stabilimento balneare costa tra €15 e €35 a persona (lettino + ombrellone). Tutte le spiagge hanno anche una parte libera gratuita.</p>
        </div>
        <div class="bg-white rounded-[2rem] p-6 shadow-sm">
          <h3 class="font-bold text-slate-900 mb-3">🌊 Qualità dell'acqua</h3>
          <p class="text-slate-600 text-sm">L'acqua della costiera è tra le più pulite d'Italia, con Bandiera Blu in molti tratti. La visibilità sottomarina è eccellente: porta la maschera.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
